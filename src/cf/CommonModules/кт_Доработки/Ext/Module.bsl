#Если Сервер Или ТолстыйКлиентОбычноеПриложение Или ВнешнееСоединение Тогда

// Закрывает заказы клиентов, по которым в течение 5 дней не было оплаты
// и отгрузки (полной или частичной).
//
Процедура кт_ЗакрытиеНеОплаченныхЗаказов() Экспорт
	
	КоличествоДнейБезДвижения = 5;
	ДатаОтсечения = ДобавитьКДате(НачалоДня(ТекущаяДатаСеанса()), "День", -КоличествоДнейБезДвижения);
	
	ИспользуетсяСтатусЗакрыт = ПолучитьФункциональнуюОпцию("НеЗакрыватьЗаказыКлиентовБезПолнойОплаты")
		ИЛИ ПолучитьФункциональнуюОпцию("НеЗакрыватьЗаказыКлиентовБезПолнойОтгрузки");
	
	Запрос = Новый Запрос;
	Запрос.Текст =
	"ВЫБРАТЬ
	|	ЗаказКлиента.Ссылка КАК Заказ
	|ИЗ
	|	Документ.ЗаказКлиента КАК ЗаказКлиента
	|		ЛЕВОЕ СОЕДИНЕНИЕ РегистрНакопления.РасчетыСКлиентами.Обороты(, , , ) КАК ОборотыОплаты
	|		ПО ЗаказКлиента.ОбъектРасчетов = ОборотыОплаты.ОбъектРасчетов
	|		ЛЕВОЕ СОЕДИНЕНИЕ РегистрНакопления.РаспоряженияНаОтгрузку.Обороты(, , , ) КАК ОборотыОтгрузки
	|		ПО ЗаказКлиента.Ссылка = ОборотыОтгрузки.Распоряжение
	|ГДЕ
	|	ЗаказКлиента.Проведен
	|	И НЕ ЗаказКлиента.ПометкаУдаления
	|	И ЗаказКлиента.Статус <> ЗНАЧЕНИЕ(Перечисление.СтатусыЗаказовКлиентов.Закрыт)
	|	И ЗаказКлиента.Статус <> ЗНАЧЕНИЕ(Перечисление.СтатусыЗаказовКлиентов.НеСогласован)
	|	И ЗаказКлиента.Дата <= &ДатаОтсечения
	|	И ЕСТЬNULL(ОборотыОплаты.СуммаРасход, 0) = 0
	|	И ЕСТЬNULL(ОборотыОтгрузки.СуммаРасход, 0) = 0";
	
	Запрос.УстановитьПараметр("ДатаОтсечения", ДатаОтсечения);
	
	Выборка = Запрос.Выполнить().Выбрать();
	
	СтруктураПараметровЗакрытия = Новый Структура;
	СтруктураПараметровЗакрытия.Вставить("ИмяТабличнойЧасти",            "Товары");
	СтруктураПараметровЗакрытия.Вставить("ПричинаОтмены",                Неопределено);
	СтруктураПараметровЗакрытия.Вставить("ПроверятьОстатки",             Ложь);
	СтруктураПараметровЗакрытия.Вставить("ОтменитьНеотработанныеСтроки", Истина);
	
	КодОсновногоЯзыка = ОбщегоНазначения.КодОсновногоЯзыка();
	ИмяСобытия = НСтр("ru = 'Автоматическое закрытие неоплаченных заказов клиентов'", КодОсновногоЯзыка);
	
	Пока Выборка.Следующий() Цикл
		
		НачатьТранзакцию();
		
		Попытка
			
			ЗаблокироватьДанныеДляРедактирования(Выборка.Заказ);
			
			ЗаказОбъект = Выборка.Заказ.ПолучитьОбъект();
			ЗаказИзменен = кт_ЗакрытьЗаказКлиента(ЗаказОбъект, СтруктураПараметровЗакрытия, ИспользуетсяСтатусЗакрыт);
			
			Если ЗаказИзменен Тогда
				ЗаказОбъект.Записать(РежимЗаписиДокумента.Проведение);
			КонецЕсли;
			
			ЗафиксироватьТранзакцию();
			
		Исключение
			
			ОтменитьТранзакцию();
			
			ЗаписьЖурналаРегистрации(
				ИмяСобытия,
				УровеньЖурналаРегистрации.Ошибка,
				Метаданные.Документы.ЗаказКлиента,
				Выборка.Заказ,
				СтрШаблон(
					НСтр("ru = 'Не удалось закрыть заказ %1: %2'", КодОсновногоЯзыка),
					Выборка.Заказ,
					КраткоеПредставлениеОшибки(ИнформацияОбОшибке())));
			
		КонецПопытки;
		
	КонецЦикла;
	
КонецПроцедуры

Функция кт_ЗакрытьЗаказКлиента(ЗаказОбъект, СтруктураПараметровЗакрытия, ИспользуетсяСтатусЗакрыт)
	
	Если ИспользуетсяСтатусЗакрыт
		И ЗаказОбъект.УстановитьСтатус("Закрыт", СтруктураПараметровЗакрытия) Тогда
		Возврат Истина;
	КонецЕсли;
	
	Возврат ЗаказыСервер.СкорректироватьСтрокиЗаказа(ЗаказОбъект, СтруктураПараметровЗакрытия);
	
КонецФункции

#КонецЕсли
