#Область ОбработкаЗаполнение

&НаСервере
Процедура ЗаполнитьПартнера()
	
	ПартнерыИКонтрагенты.ЗаполнитьКонтрагентаПартнераПоУмолчанию(ЭтотОбъект.Партнер, ЭтотОбъект.Контрагент,  Истина);
	Если ЗначениеЗаполнено(Контрагент) Тогда
		_ОбработкаДоставкиТоваровСервер.ЗаполнитьПодчиненныеСвойстваПартнера( ЭтотОбъект);
	КонецЕсли; 
	ПартнерыИКонтрагенты.ЗаполнитьКонтактноеЛицоПартнераПоУмолчанию(ЭтотОбъект.Партнер, ЭтотОбъект.КонтактноеЛицо);
КонецПроцедуры	//ЗаполнитьПартнера()

&НаСервере
Функция ПроверитьДату(ДатаПроверки, ГодПроверки )
	Запрос = Новый Запрос;
	Запрос.Текст = "ВЫБРАТЬ
	               |	ДанныеПроизводственногоКалендаря.Дата КАК Дата,
	               |	ДанныеПроизводственногоКалендаря.ВидДня КАК ВидДня
	               |ИЗ
	               |	РегистрСведений.ДанныеПроизводственногоКалендаря КАК ДанныеПроизводственногоКалендаря
	               |ГДЕ
	               |	ДанныеПроизводственногоКалендаря.Дата = &ДатаПроверки
	               |	И ДанныеПроизводственногоКалендаря.Год = &ГодПроверки
				   |";
	
	Запрос.УстановитьПараметр("ДатаПроверки",НачалоДня(ДатаПроверки));
	Запрос.УстановитьПараметр("ГодПроверки" ,ГодПроверки);
	
	Результат = Запрос.Выполнить();
	Выборка = Результат.Выбрать();
	Выборка.Следующий();
	Если Выборка.ВидДня = Перечисления.ВидыДнейПроизводственногоКалендаря.Рабочий Тогда
		Возврат Истина;
	Иначе
		Возврат Ложь;
	КонецЕсли;
		 	
КонецФункции // ПроверитьДату()

#КонецОбласти

#Область ЗаполнениеНаОснованииЗаказаКлиента

&НаСервере
Процедура ЗаполнитьДокументНаОснованииЗаказа(Знач ЗаказКлиента)
	
	НужныДокументы	= Истина;
	
	//Если ПроверкаЗаполненостиТЧТовары Тогда
	НоваяСтрока					= Заказы.Добавить();
	НоваяСтрока.НомерЗаказа		= ЗаказКлиента.Номер;
	НоваяСтрока.ДатаЗаказа		= ЗаказКлиента.Дата;
	НоваяСтрока.ЗаказКлиента	= ЗаказКлиента.Ссылка;
	НоваяСтрока.НужныДокументы	= Истина;
	//КонецЕсли;		//ПроаеркаЗаполненостиТЧТовары 	
	
	
	Запрос = Новый Запрос;
	Запрос.Текст = ТекстЗапросаВыбораЗаказа();
	Запрос.УстановитьПараметр("ЗаказКлиента", ЗаказКлиента);
	Выборка = Запрос.Выполнить().Выбрать();
	
	Выборка.Следующий();
	
	МассивДопустимыхСтатусов = Новый Массив();
	МассивДопустимыхСтатусов.Добавить(Перечисления.СтатусыЗаказовКлиентов.КОбеспечению);
	МассивДопустимыхСтатусов.Добавить(Перечисления.СтатусыЗаказовКлиентов.КОтгрузке);
	
	//++ Обновление
	//ОбщегоНазначенияУТ.ПроверитьВозможностьВводаНаОсновании(
	//	Выборка.ДокументОснование,
	//	Выборка.СтатусДокумента,
	//	Выборка.ЕстьОшибкиПроведен,
	//	Выборка.ЕстьОшибкиСтатус,
	//	МассивДопустимыхСтатусов);
	ПараметрыПроверки = ОбщегоНазначенияУТ.ПараметрыПроверкиВозможностиВводаНаОсновании();
	ПараметрыПроверки.Вставить("Статус", Выборка.СтатусДокумента);
	ПараметрыПроверки.Вставить("ЕстьОшибкиПроведен", Выборка.ЕстьОшибкиПроведен);
	ПараметрыПроверки.Вставить("ЕстьОшибкиСтатус", Выборка.ЕстьОшибкиСтатус);
	ПараметрыПроверки.Вставить("МассивДопустимыхСтатусов", МассивДопустимыхСтатусов);
	ПараметрыПроверки.Вставить("СоглашениеДоступноВнешнемуПользователю", Неопределено);
	ПараметрыПроверки.Вставить("ПрерыватьВыполнение", Истина);
	ОбщегоНазначенияУТ.ПроверитьВозможностьВводаНаОснованииСПараметрами(ЗаказКлиента, ПараметрыПроверки);
	//--
	//Заполнение шапки
	ЗаполнитьШапкуЗаказа(Выборка.Ссылка);
	
	//Заполнение табличных частей
	ЗаполнитьТЧТовары(Выборка.Ссылка);
	
КонецПроцедуры	//ЗаполнитьДокументНаОснованииЗаказа(ДанныеЗаполнения)

&НаСервере
Процедура ЗаполнитьДокументНаОснованииВнутреннегоЗаказа(Знач ЗаказКлиента)
	
	НужныДокументы	= Истина;

	//Если ПроверкаЗаполненостиТЧТовары Тогда
	НоваяСтрока					= Заказы.Добавить();
	НоваяСтрока.НомерЗаказа		= ЗаказКлиента.Номер;
	НоваяСтрока.ДатаЗаказа		= ЗаказКлиента.Дата;
	НоваяСтрока.ЗаказКлиента	= ЗаказКлиента.Ссылка;
	НоваяСтрока.НужныДокументы	= Истина;
	//КонецЕсли;		//ПроаеркаЗаполненостиТЧТовары 	
	
	
	Запрос = Новый Запрос;
	Запрос.Текст = ТекстЗапросаВыбораВнутреннегоЗаказа();
	Запрос.УстановитьПараметр("ЗаказКлиента", ЗаказКлиента);
	Выборка = Запрос.Выполнить().Выбрать();
	
	Выборка.Следующий();
	
	МассивДопустимыхСтатусов = Новый Массив();
	МассивДопустимыхСтатусов.Добавить(Перечисления.СтатусыВнутреннихЗаказов.КВыполнению);
	
	//++ Обновление
	//ОбщегоНазначенияУТ.ПроверитьВозможностьВводаНаОсновании(
	//	Выборка.ДокументОснование,
	//	Выборка.СтатусДокумента,
	//	Выборка.ЕстьОшибкиПроведен,
	//	Выборка.ЕстьОшибкиСтатус,
	//	МассивДопустимыхСтатусов);
	ПараметрыПроверки = ОбщегоНазначенияУТ.ПараметрыПроверкиВозможностиВводаНаОсновании();
	ПараметрыПроверки.Вставить("Статус", Выборка.СтатусДокумента);
	ПараметрыПроверки.Вставить("ЕстьОшибкиПроведен", Выборка.ЕстьОшибкиПроведен);
	ПараметрыПроверки.Вставить("ЕстьОшибкиСтатус", Выборка.ЕстьОшибкиСтатус);
	ПараметрыПроверки.Вставить("МассивДопустимыхСтатусов", МассивДопустимыхСтатусов);
	ПараметрыПроверки.Вставить("СоглашениеДоступноВнешнемуПользователю", Неопределено);
	ПараметрыПроверки.Вставить("ПрерыватьВыполнение", Истина);
	ОбщегоНазначенияУТ.ПроверитьВозможностьВводаНаОснованииСПараметрами(ЗаказКлиента, ПараметрыПроверки);
	//--
	//Заполнение шапки
	Статус					= Перечисления._СтатусыЗаявокНаДоставку.КВыполнению;
	Организация     		= ЗаказКлиента.Организация;
	Склад					= ЗаказКлиента.Склад;
	НаправлениеДеятельности	= ЗаказКлиента.НаправлениеДеятельности;
	ДокументОснование		= ЗаказКлиента.Ссылка;
	
	ЖелаемаяДатаОтгрузки	= _ДоработкиСлужебный.ПолучитьСледующийДень(Дата); 

	Для каждого СтрТоварыЗаказ Из ЗаказКлиента.Товары Цикл
	    Если ЗначениеЗаполнено(СтрТоварыЗаказ.АналитикаРасходов) и ТипЗнч(СтрТоварыЗаказ.АналитикаРасходов) = Тип("ДокументСсылка.ЗаказКлиента") Тогда
		     Партнер    = СтрТоварыЗаказ.АналитикаРасходов.Партнер;
		     Контрагент = СтрТоварыЗаказ.АналитикаРасходов.Контрагент;
		     Прервать;
		КонецЕсли;
	КонецЦикла;
	//Заполнение табличных частей
	ЗаполнитьТЧТоварыВнутреннегоЗаказа(Выборка.Ссылка);
	
КонецПроцедуры	//ЗаполнитьДокументНаОснованииЗаказа(ДанныеЗаполнения)


&НаСервере
Процедура ЗаполнитьШапкуЗаказа(ТекЗаказ, ЗаполнитьОснование = Истина)
	Статус					= Перечисления._СтатусыЗаявокНаДоставку.КВыполнению;
	Организация     		= ТекЗаказ.Организация;
	Склад					= ТекЗаказ.Склад;
	Партнер					= ТекЗаказ.Ссылка.Партнер;
	НаправлениеДеятельности	= ТекЗаказ.НаправлениеДеятельности;
	
	Если ЗаполнитьОснование Тогда
		ДокументОснование		= ТекЗаказ.Ссылка;
	КонецЕсли;
	
	//	ЖелаемаяДатаОтгрузки	= ?(ЗначениеЗаполнено(ТекЗаказ.ЖелаемаяДатаОтгрузки), ТекЗаказ.ЖелаемаяДатаОтгрузки, ?(ЗначениеЗаполнено(ТекЗаказ.ДатаОтгрузки),  ТекЗаказ.ДатаОтгрузки, Дата(1,1,1)));
	//ЖелаемаяДатаОтгрузки	= _ДоработкиСлужебный.ПолучитьСледующийДень(ДокументОснование.Дата); 
	ЖелаемаяДатаОтгрузки	= _ДоработкиСлужебный.ПолучитьСледующийДень(Дата); 
	
	ЗаполнитьПартнера();
КонецПроцедуры	// ЗаполнитьШапкуЗаказа()

&НаСервере
Функция ТекстЗапросаВыбораЗаказа(ПоискПоССылке = Истина)
	ТекстЗапроса = "ВЫБРАТЬ РАЗРЕШЕННЫЕ
					|	ЗаказКлиента.Ссылка,
					|	ЗаказКлиента.Номер,
					|	ЗаказКлиента.Дата,
					|	ЗаказКлиента.Организация КАК Организация,
					|	ЗаказКлиента.Партнер КАК  Партнер,
					|	ЗаказКлиента.Статус КАК СтатусДокумента,
					|	ЗаказКлиента.Приоритет КАК Приоритет,
					|	ЗаказКлиента.Проведен КАК Проведен,
					|	ЗаказКлиента.Склад КАК СкладДокумента,
					|	ЗаказКлиента.Склад.ЭтоГруппа КАК ЭтоГруппа,
					|	ЗаказКлиента.НаправлениеДеятельности КАК НаправлениеДеятельности,
					|	ЗаказКлиента.ДокументОснование,
					|	ЗаказКлиента.ДатаОтгрузки,
					|	ЗаказКлиента.АдресДоставки,
					|	НЕ ЗаказКлиента.Проведен КАК ЕстьОшибкиПроведен,
					|	ЗаказКлиента.ПометкаУдаления КАК ЕстьОшибкиУдален,
					|";
	
		Если ПоискПоССылке Тогда
			ТекстЗапроса = ТекстЗапроса + "
					|	ВЫБОР
					|		КОГДА ( ЗаказКлиента.Статус = ЗНАЧЕНИЕ(Перечисление.СтатусыЗаказовКлиентов.КОбеспечению) )
					|			ТОГДА ЛОЖЬ
					|		ИНАЧЕ ИСТИНА
					|	КОНЕЦ КАК ЕстьОшибкиСтатус
					|";
		Иначе
			ТекстЗапроса = ТекстЗапроса + "
					|	ВЫБОР
					|		КОГДА ( ЗаказКлиента.Статус = ЗНАЧЕНИЕ(Перечисление.СтатусыЗаказовКлиентов.КОбеспечению) ) ИЛИ
					|			  ( ЗаказКлиента.Статус = ЗНАЧЕНИЕ(Перечисление.СтатусыЗаказовКлиентов.КОтгрузке) )	
					|			ТОГДА ЛОЖЬ
					|		ИНАЧЕ ИСТИНА
					|	КОНЕЦ КАК ЕстьОшибкиСтатус
					|";
		КонецЕсли;
		
		ТекстЗапроса = ТекстЗапроса + "
					|ИЗ
					|	Документ.ЗаказКлиента КАК ЗаказКлиента
					|";
		Если ПоискПоССылке Тогда
			ТекстЗапроса = ТекстЗапроса + "
					|ГДЕ
					|	ЗаказКлиента.Ссылка = &ЗаказКлиента
					|"
		Иначе
			ТекстЗапроса = ТекстЗапроса + "
					|ГДЕ
					|	ЗаказКлиента.Номер = &Номер
					|	И ЗаказКлиента.Дата = &Дата
					|	И ЗаказКлиента.Организация = &Организация
					|	И ЗаказКлиента.Партнер = &Партнер
					|"
		КонецЕсли;
				
		ТекстЗапроса = ТекстЗапроса + "
					|";
	
	Возврат ТекстЗапроса;
КонецФункции	// ТекстЗапросаЗаказа()

