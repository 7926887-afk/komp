	Запрос.УстановитьПараметр("Серия", 				Серия);
	Запрос.УстановитьПараметр("Склад", 				ПараметрыОтбора.Склад);
	
	Результат = Запрос.Выполнить();
	
	Если Результат.Пустой() Тогда
		Возврат 0;
	КонецЕсли;
	
	Остатки = Результат.Выгрузить();
	Остатки.Свернуть("Назначение, Номенклатура, Характеристика, Серия, Склад, ДокументОтгрузки","КОтгрузкеОстаток");
	
	Возврат Остатки[0].КОтгрузкеОстаток;
	
КонецФункции // ПоступилоПоЗаказу()

&НаСервере
Функция ТекстЗапросаВыбораЗаказаИзРегистра()
	
	ТекстЗапроса = 
	"ВЫБРАТЬ
	|	РаспоряженияНаОтгрузку.Распоряжение КАК ЗаказКлиента,
	|	РаспоряженияНаОтгрузку.КодСтроки КАК КодСтроки,
	|	РаспоряженияНаОтгрузку.Склад КАК Склад,
	|	РаспоряженияНаОтгрузку.Номенклатура КАК Номенклатура,
	|	РаспоряженияНаОтгрузку.Характеристика КАК Характеристика,
	|	РаспоряженияНаОтгрузку.Серия КАК Серия,
	|	СУММА(РаспоряженияНаОтгрузку.ЗаказаноОборот) КАК ЗаказаноОстаток,
	|	СУММА(РаспоряженияНаОтгрузку.КОформлениюОборот) КАК КОформлениюОстаток,
	|	СУММА(РаспоряженияНаОтгрузку.ЗаказаноОборот - РаспоряженияНаОтгрузку.КОформлениюОборот) КАК ОстатокПоЗаказу
	|ИЗ
	|	РегистрНакопления.РаспоряженияНаОтгрузку.Обороты(
	|			,
	|			&ДатаКон,
	|			,
	|			Распоряжение = &ЗаказКлиента
	|				И Склад = &Склад) КАК РаспоряженияНаОтгрузку
	|
	|СГРУППИРОВАТЬ ПО
	|	РаспоряженияНаОтгрузку.Характеристика,
	|	РаспоряженияНаОтгрузку.Распоряжение,
	|	РаспоряженияНаОтгрузку.Серия,
	|	РаспоряженияНаОтгрузку.Склад,
	|	РаспоряженияНаОтгрузку.Номенклатура,
	|	РаспоряженияНаОтгрузку.КодСтроки
	|
	|ИМЕЮЩИЕ
	|	СУММА(РаспоряженияНаОтгрузку.ЗаказаноОборот - РаспоряженияНаОтгрузку.КОформлениюОборот) > 0";
	//ТекстЗапроса = 
	//"ВЫБРАТЬ
	//|	ЗапасыИПотребностиОстатки.Номенклатура КАК Номенклатура,
	//|	ЗапасыИПотребностиОстатки.Характеристика КАК Характеристика,
	//|	ЗапасыИПотребностиОстатки.Склад КАК Склад,
	//|	ЗапасыИПотребностиОстатки.Назначение КАК Назначение,
	//|	ЗапасыИПотребностиОстатки.Заказ КАК ЗаказКлиента,
	//|	ЗапасыИПотребностиОстатки.КОбеспечениюОстаток КАК ОстатокПоЗаказу
	//|ИЗ
	//|	РегистрНакопления.ЗапасыИПотребности.Остатки(
	//|			&ДатаКон,
	//|			Назначение.Заказ = &ЗаказКлиента
	//|				И Склад = &Склад) КАК ЗапасыИПотребностиОстатки";
	Возврат ТекстЗапроса;
КонецФункции // ТекстЗапросаВыбораЗаказаИзРегистра()

&НаСервере
Функция ЗаказаноПоЗаказу(ВыбранныйЗаказ, Номенклатура, Характеристика, Серия )
	
	Запрос = Новый Запрос;
	Запрос.Текст = "ВЫБРАТЬ
	               |	_ЗаявкаНаДоставкуЗаказы.Ссылка,
	               |	_ЗаявкаНаДоставкуТовары.Номенклатура,
	               |	_ЗаявкаНаДоставкуТовары.Характеристика,
	               |	_ЗаявкаНаДоставкуТовары.Серия,
	               |	_ЗаявкаНаДоставкуТовары.КоличествоУпаковок
	               |ИЗ
	               |	Документ._ЗаявкаНаДоставку.Заказы КАК _ЗаявкаНаДоставкуЗаказы
	               |		ВНУТРЕННЕЕ СОЕДИНЕНИЕ Документ._ЗаявкаНаДоставку.Товары КАК _ЗаявкаНаДоставкуТовары
	               |		ПО _ЗаявкаНаДоставкуЗаказы.Ссылка = _ЗаявкаНаДоставкуТовары.Ссылка
	               |ГДЕ
	               |	_ЗаявкаНаДоставкуЗаказы.ЗаказКлиента = &ЗаказКлиента
	               |	И _ЗаявкаНаДоставкуТовары.Номенклатура = &Номенклатура
	               |	И _ЗаявкаНаДоставкуТовары.Характеристика = &Характеристика
	               |	И _ЗаявкаНаДоставкуТовары.Серия = &Серия
	               |	И _ЗаявкаНаДоставкуЗаказы.Ссылка.ПометкаУдаления = ЛОЖЬ
	               |	И _ЗаявкаНаДоставкуЗаказы.Ссылка.Проведен = ИСТИНА";
	
	Запрос.УстановитьПараметр("ЗаказКлиента",   ВыбранныйЗаказ);
	Запрос.УстановитьПараметр("Номенклатура",   Номенклатура);
	Запрос.УстановитьПараметр("Характеристика", Характеристика);
	Запрос.УстановитьПараметр("Серия",			Серия);
	
	Результат = Запрос.Выполнить().Выгрузить();
	
	Количество = Результат.Итог("КоличествоУпаковок");
	
	Возврат Количество;
	
КонецФункции // ЗаказаноПоЗаказу()

&НаСервере
Функция ПолучитьЗаказ(ЗаказКлиента, ДатаПроверки) Экспорт
	
	Запрос = Новый Запрос;
	Запрос.Текст = ТекстЗапросаВыбораЗаказаИзРегистра();
	
	Запрос.УстановитьПараметр("ДатаКон",		КонецДня(ДатаПроверки));
	Запрос.УстановитьПараметр("ЗаказКлиента",	ЗаказКлиента);
	Запрос.УстановитьПараметр("Склад",			ЗаказКлиента.Склад);
	Результат = Запрос.Выполнить().Выгрузить();
	
	Возврат Результат;
	
КонецФункции // ПолучитьЗаказ()

