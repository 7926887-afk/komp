#Область РасходныеОрдераНаТовары

&НаСервере
Процедура СоздатьОрдераСервер(Отказ)
	
	МассивЗаказов = Заказы.ВыгрузитьКолонку("ЗаказКлиента");
	
	МассивСсылок = Новый Массив;
	
	Для Каждого Элемент Из МассивЗаказов Цикл
		//**Добавлено Максимов В.А.
		Если ТипЗнч(Элемент) = Тип("ДокументСсылка.ЗаказПоставщику") Тогда
			Если НЕ Элемент.Статус = Перечисления.СтатусыЗаказовПоставщикам.Закрыт Тогда
				МассивСсылок.Добавить(Элемент); 
			КонецЕсли;	
		Иначе
			Если НЕ Элемент.Закрыт Тогда
				МассивСсылок.Добавить(Элемент); 
			КонецЕсли;
		КонецЕсли;
		//*************************
	КонецЦикла; 
	
	Запрос = Новый Запрос;
	Запрос.Текст = "ВЫБРАТЬ
	               |	РасходныйОрдерНаТовары.Ссылка КАК РасходныйОрдерНаТовары,
	               |	РасходныйОрдерНаТовары._ЗаявкаНаДоставку КАК ЗаявкаНаДоставку,
	               |	РасходныйОрдерНаТовары.ПометкаУдаления КАК ПометкаУдаления,
	               |	РасходныйОрдерНаТовары.Проведен КАК Проведен
	               |ИЗ
	               |	Документ.РасходныйОрдерНаТовары КАК РасходныйОрдерНаТовары
	               |ГДЕ
	               |	РасходныйОрдерНаТовары._ЗаявкаНаДоставку = &_ЗаявкаНаДоставку
	               |	И РасходныйОрдерНаТовары.ПометкаУдаления = ЛОЖЬ";
	
	Запрос.УстановитьПараметр("_ЗаявкаНаДоставку", Ссылка);
	
	Результат = Запрос.Выполнить();
	Если НЕ Результат.Пустой() Тогда
		Выборка  = Результат.Выгрузить()[0];
		ТекОрдер = Выборка.РасходныйОрдерНаТовары;
		Если ТекОрдер.Проведен Тогда
			Отказ = Истина;
			ТекстСообщения = НСтр("ru='По данной заявке уже создан расходный ордер №'") + ТекОрдер.Номер +  НСтр("ru=' от '") + ТекОрдер.Дата;
			ОбщегоНазначенияКлиентСервер.СообщитьПользователю(ТекстСообщения);
			Возврат;
		КонецЕсли;
		ТекОрдерОбьект = ТекОрдер.ПолучитьОбъект();
		Если ТекОрдер.ПометкаУдаления Тогда
			ТекОрдерОбьект.ПометкаУдаления = Ложь;
		КонецЕсли;
		ТекОрдерОбьект.ТоварыПоРаспоряжениям.Очистить();
		ТекОрдерОбьект.ОтгружаемыеТовары.Очистить();
		ТекОрдерОбьект.ДополнительныеРеквизиты.Очистить();
		ТекОрдерОбьект.Записать(РежимЗаписиДокумента.Запись);
		
		_ОбработкаДоставкиТоваровСервер.ОформитьРасходныеОрдераПоДоставкеНаСервере(МассивСсылок, Ссылка);	//, Ложь
	Иначе 
		_ОбработкаДоставкиТоваровСервер.ОформитьРасходныеОрдераПоДоставкеНаСервере(МассивСсылок, Ссылка);
	КонецЕсли;

КонецПроцедуры	// СоздатьОрдераСервер()

&НаСервере
Функция НовыйОрдер()
	
	НовыйРасходныйОрдерНаТовары						= Документы.РасходныйОрдерНаТовары.СоздатьДокумент(); 
	НовыйРасходныйОрдерНаТовары.Дата				= ТекущаяДата();
	НовыйРасходныйОрдерНаТовары.ДатаОтгрузки		= ДатаОтгрузки;
	НовыйРасходныйОрдерНаТовары.Склад				= Склад;
	НовыйРасходныйОрдерНаТовары._СпособДоставки		= СпособДоставки;
	НовыйРасходныйОрдерНаТовары._ЗаявкаНаДоставку	= Ссылка;
	
	Возврат НовыйРасходныйОрдерНаТовары;
	
КонецФункции // НовыйОрдер()

&НаСервере
Процедура УдалитьОрдераСервер()
	
	Запрос = Новый Запрос;
	Запрос.Текст = "ВЫБРАТЬ
	|	РасходныйОрдерНаТовары.Ссылка КАК РасходныйОрдерНаТоварыСсылка,
	|	РасходныйОрдерНаТовары._ЗаявкаНаДоставку КАК _ЗаявкаНаДоставку
	|ИЗ
	|	Документ.РасходныйОрдерНаТовары КАК РасходныйОрдерНаТовары
	|ГДЕ
	|	НЕ РасходныйОрдерНаТовары.ПометкаУдаления
	|	И РасходныйОрдерНаТовары.Проведен
	|	И РасходныйОрдерНаТовары._ЗаявкаНаДоставку = &_ЗаявкаНаДоставку";
	
	Запрос.УстановитьПараметр("_ЗаявкаНаДоставку", Ссылка);
	
	Результат = Запрос.Выполнить();
	Если НЕ Результат.Пустой() Тогда
		Выборка = Результат.Выбрать();
		Пока Выборка.Следующий() Цикл
			РасходныйОрдерНаТоварыДокумент = Выборка.РасходныйОрдерНаТоварыСсылка.ПолучитьОбъект();
			Если НЕ РасходныйОрдерНаТоварыДокумент = Неопределено Тогда
				РасходныйОрдерНаТоварыДокумент.Записать(РежимЗаписиДокумента.ОтменаПроведения);
				РасходныйОрдерНаТоварыДокумент.Удалить();
			КонецЕсли; 
		КонецЦикла;		// Результат.Следующий() 
	КонецЕсли;
КонецПроцедуры	// УдалитьОрдераСервер()

#КонецОбласти

