&НаСервере
Функция ЗаполнитьТЧТовары(ВыбранныйЗаказ) Экспорт
	
	ПроверкаЗаполненостиТЧТовары = Ложь;
	
	Выборка = ПолучитьЗаказ(ВыбранныйЗаказ,ТекущаяДата());
	
	Для Каждого ТекСтрока Из ВыбранныйЗаказ.Товары Цикл
		
		Если ТекСтрока.ВариантОбеспечения = Перечисления.ВариантыОбеспечения.НеТребуется
			ИЛИ ТекСтрока._Отгрузка Тогда
			
			Продолжить;
		КонецЕсли;
		
		Отбор				  = Новый Структура("Номенклатура, Характеристика, Склад", ТекСтрока.Номенклатура, ТекСтрока.Характеристика, ТекСтрока.Склад);
		ОтборЗак			  = Новый Структура("Номенклатура, Характеристика, Серия, Склад, ВариантОбеспечения", ТекСтрока.Номенклатура, ТекСтрока.Характеристика, ТекСтрока.Серия, ТекСтрока.Склад, Перечисления.ВариантыОбеспечения.НеТребуется);
		ОтборТек			  = Новый Структура("Номенклатура, Характеристика, Серия, Склад, ВариантОбеспечения, _Отгрузка", ТекСтрока.Номенклатура, ТекСтрока.Характеристика, ТекСтрока.Серия, ВыбранныйЗаказ.Склад, Перечисления.ВариантыОбеспечения.КОбеспечению, Ложь);
		ОтборЗаказано		  = Новый Структура("Номенклатура, Характеристика, Серия, Склад, ВариантОбеспечения, _Отгрузка", ТекСтрока.Номенклатура, ТекСтрока.Характеристика, ТекСтрока.Серия, ВыбранныйЗаказ.Склад, Перечисления.ВариантыОбеспечения.Отгрузить, Истина);
		
		ПараметрыОтбора		  = Новый Структура();
		Назначение			  = Справочники.Назначения.НайтиПоРеквизиту("Заказ", ВыбранныйЗаказ); 
		ПараметрыОтбора.Вставить("Заказ",			ВыбранныйЗаказ);
		ПараметрыОтбора.Вставить("Назначение",		Назначение);
		ПараметрыОтбора.Вставить("Номенклатура",	ТекСтрока.Номенклатура);
		ПараметрыОтбора.Вставить("Характеристика",	ТекСтрока.Характеристика);
		ПараметрыОтбора.Вставить("Серия",			ТекСтрока.Серия);
		ПараметрыОтбора.Вставить("Склад",			ВыбранныйЗаказ.Склад);
		
		ОстатокНаСкладе		 = ОстатокНаСкладе(ПараметрыОтбора);
		ОстатокПоОтгузке	 = ОстатокПоОтгузке(ПараметрыОтбора);
		Если ОстатокНаСкладе - ОстатокПоОтгузке <= 0 Тогда
			ОстатокНаСкладе = 0;
		Иначе
			ОстатокНаСкладе = ОстатокНаСкладе - ОстатокПоОтгузке;
		КонецЕсли;
		
		МассивНайденныхСтрок = Выборка.НайтиСтроки(Отбор);
		Если МассивНайденныхСтрок.Количество() > 0 Тогда
			МассивЗаказано	 = ЭтотОбъект.Товары.НайтиСтроки(Отбор);
			КолЗаказано		 = 0;
			ЗаказаноПоЗаказу = ЗаказаноПоЗаказу(ВыбранныйЗаказ, ТекСтрока.Номенклатура, ТекСтрока.Характеристика, ТекСтрока.Серия);
			КоличествоОст	 = 0;
			//МассивЗаказа	 = ВыбранныйЗаказ.Товары.НайтиСтроки(ОтборЗак);
			МассивЗаказа	 = ВыбранныйЗаказ.Товары.НайтиСтроки(ОтборТек);
			Для Каждого тСтр Из МассивЗаказа Цикл
				КоличествоОст = КоличествоОст + тСтр.КоличествоУпаковок;
			КонецЦикла;		// тСтр Из 
			
			Если МассивЗаказано.Количество() > 0 Тогда
				Для Каждого ТекСтрЗаказано Из МассивЗаказано Цикл
 					КолЗаказано = КолЗаказано + ТекСтрЗаказано.Количество - ЗаказаноПоЗаказу;		//- КоличествоОст 
				КонецЦикла;
			КонецЕсли;
			//**** 2025-04-18
			ОстатокНаСкладе = ОстатокНаСкладе - КолЗаказано;
			//****
			
			мОстатокПоЗаказу = 0;
			Для Каждого тСтр Из МассивНайденныхСтрок Цикл
				мОстатокПоЗаказу = мОстатокПоЗаказу + тСтр.ОстатокПоЗаказу;
			КонецЦикла;		// тСтр Из МассивНайденныхСтрок
//			НайденнаяСтрока = МассивНайденныхСтрок[0];
			ОстатокПоЗаказу = ОстаткиПоЗаказу(ВыбранныйЗаказ, ТекСтрока, ТекущаяДата());			//** 
//			ОстатокПоЗаказу = НайденнаяСтрока.ОстатокПоЗаказу - ЗаказаноПоЗаказу;					
//			ОстатокПоЗаказу = мОстатокПоЗаказу - ЗаказаноПоЗаказу;									//** 
			Если ОстатокПоЗаказу < 0 Тогда
				Продолжить;
			КонецЕсли;
			
//**  			ОстатокНаСкладе = ПроверкаКоличестваНаСкладе(ТекСтрока,  ТекущаяДата()) - КолЗаказано;
			
			Если ОстатокНаСкладе > 0 Тогда
				Если ОстатокПоЗаказу > ОстатокНаСкладе Тогда
					КолВОтгрузку = ОстатокНаСкладе;
					Если КолВОтгрузку > ТекСтрока.КоличествоУпаковок Тогда
						КолВОтгрузку = ТекСтрока.КоличествоУпаковок;
					КонецЕсли; 
				Иначе
					КолВОтгрузку = ОстатокПоЗаказу;
					Если КолВОтгрузку > ТекСтрока.КоличествоУпаковок Тогда
						КолВОтгрузку = ТекСтрока.КоличествоУпаковок;
					КонецЕсли; 
				КонецЕсли;
				
				НоваяСтрока	= Товары.Добавить();
				ЗаполнитьЗначенияСвойств(НоваяСтрока, ТекСтрока);
				НоваяСтрока.Количество = КолВОтгрузку;
				Если ТекСтрока.Упаковка.Числитель = 0 Тогда
					Числитель = 1;
				Иначе
					Числитель = ТекСтрока.Упаковка.Числитель;
				КонецЕсли;
				НоваяСтрока.КоличествоУпаковок = КолВОтгрузку / Числитель;
				НоваяСтрока._УИДОтгрузка = ТекСтрока._УИДОтгрузка;
			КонецЕсли;		//ОстатокНаСкладе > 0
		КонецЕсли; 	//МассивНайденныхСтрок > 0
	КонецЦикла;
	
	Если (НЕ Товары.Количество() = 0) ИЛИ
		 (НЕ Товары.Итог("Количество") = 0) Тогда
		ПроверкаЗаполненостиТЧТовары = Истина;
	КонецЕсли;		// 		
	Возврат ПроверкаЗаполненостиТЧТовары;
	
КонецФункции	//ЗаполнитьТЧТовары()

