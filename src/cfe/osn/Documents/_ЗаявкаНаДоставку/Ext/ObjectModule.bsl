				ТекстСообщения = НСтр("ru='По данной заявке уже было создано распоряжение экспедитору №'") + ЭтотОбъект.ПоручениеЭкспидитору.Номер +  НСтр("ru=' от '") + 
								 ЭтотОбъект.ПоручениеЭкспидитору.Дата + Символы.ПС + НСтр("ru='Если хотите внести изменения отмените удаление распоряжения экспедитора'");
				ОбщегоНазначенияКлиентСервер.СообщитьПользователю(ТекстСообщения);
