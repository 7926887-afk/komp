&НаСервере
Процедура ЗаполнитьТЧПоЗаказуПоставщика(ТекЗаказ) Экспорт 
	ПроверкаЗаполненостиТЧТовары = Ложь;
	
	//Выборка = ПолучитьЗаказ(ВыбранныйЗаказ,ТекущаяДата());
	
	Для Каждого ТекСтрока Из ТекЗаказ.Товары Цикл
		НоваяСтрока	= Товары.Добавить();
		ЗаполнитьЗначенияСвойств(НоваяСтрока, ТекСтрока);
		НоваяСтрока.ВариантОбеспечения = Перечисления.ВариантыОбеспечения.Отгрузить;
	КонецЦикла;
	
	Если (НЕ Товары.Количество() = 0) ИЛИ
		 (НЕ Товары.Итог("Количество") = 0) Тогда
		ПроверкаЗаполненостиТЧТовары = Истина;
	КонецЕсли;		// 		
	
	Если ПроверкаЗаполненостиТЧТовары Тогда  

		НужныДокументы	= Истина;

		НоваяСтрока					= Заказы.Добавить();
		НоваяСтрока.НомерЗаказа		= ТекЗаказ.Номер;
		НоваяСтрока.ДатаЗаказа		= ТекЗаказ.Дата;
		НоваяСтрока.ЗаказКлиента	= ТекЗаказ.Ссылка;
		НоваяСтрока.НужныДокументы	= Истина;
	КонецЕсли;		//ПроаеркаЗаполненостиТЧТовары 		
КонецПроцедуры	// ЗаполнитьТЧ()



