#Область ОбработчикиСобытий

Процедура ПередУдалением(Отказ)
	РегистрыСведений.Кт_ОбработкаЗаявкиНаДоставку.УдалитьКлючОбработкиЗаказа( ЭтотОбъект.Ссылка );
КонецПроцедуры

Процедура ПередЗаписью(Отказ, РежимЗаписи, РежимПроведения)
	
	ОбновлениеИнформационнойБазы.ПроверитьОбъектОбработан(ЭтотОбъект);
	
	ДополнительныеСвойства.Вставить("ЭтоНовый",    ЭтоНовый());
	ДополнительныеСвойства.Вставить("РежимЗаписи", РежимЗаписи);
	
	
	Если ЭтоНовый() И НЕ ЗначениеЗаполнено(Номер) Тогда
		УстановитьНовыйНомер();
	КонецЕсли;
	
КонецПроцедуры	//ПередЗаписью(Отказ, РежимЗаписи, РежимПроведения)()


Процедура ОбработкаЗаполнения(ДанныеЗаполнения, СтандартнаяОбработка)
	
	
	//Если ТипЗнч(ДанныеЗаполнения.Основание) = Тип("ДокументСсылка.ЗаказПоставщику") Тогда
	//	
	//ИначеЕсли ТипЗнч(ДанныеЗаполнения.Основание) = Тип("ДокументСсылка.ЗаказКлиента") Тогда	

	//	Если НЕ ДанныеЗаполнения.Основание = Неопределено И ДанныеЗаполнения.Основание.Закрыт Тогда
	//		Возврат;
	//	КонецЕсли; 
	//Иначе
	//    Возврат;
	//КонецЕсли;	
	
	Если ТипЗнч(ДанныеЗаполнения) = Тип("Структура") Тогда 
		ДокументОснование = ДанныеЗаполнения.Основание;
		ТипДанныхЗаполнения = ТипЗнч(ДокументОснование); 
	Иначе 
		ДокументОснование = ДанныеЗаполнения;
		ТипДанныхЗаполнения = ТипЗнч(ДанныеЗаполнения);
	КонецЕсли;	
	
	Если ТипДанныхЗаполнения = Тип("ДокументСсылка.ЗаказКлиента") Тогда
		_ВидЗаявки = Перечисления._ВидыЗаявки.ДоКлиента;
		ЗаполнитьДокументНаОснованииЗаказа(ДокументОснование); 
		СпособДоставки = Перечисления.СпособыДоставки.ДоКлиента;
	ИначеЕсли ТипДанныхЗаполнения = Тип("ДокументСсылка.ЗаказПоставщику") Тогда	
		_ВидЗаявки = Перечисления._ВидыЗаявки.ОтПоставщика;	
		ЗаполнитьДокументНаОснованииЗаказаПоставщику(ДокументОснование);
		СпособДоставки = Перечисления.СпособыДоставки.НашимиСиламиСАдресаОтправителя;
	ИначеЕсли ТипДанныхЗаполнения = Тип("ДокументСсылка.ЗаказНаВнутреннееПотребление") Тогда	
		_ВидЗаявки = Перечисления._ВидыЗаявки.ОтПоставщика;	
		ЗаполнитьДокументНаОснованииВнутреннегоЗаказа(ДокументОснование);
		СпособДоставки = Перечисления.СпособыДоставки.НашимиСиламиСАдресаОтправителя;
	//ИначеЕсли ТипДанныхЗаполнения = Тип("Массив") Тогда	
	//	ЗаполнитьДокументНаОснованииЗаказов(ДанныеЗаполнения);
	Иначе
		ВызватьИсключение НСтр("ru='Документ может быть создан только на основании заказа клиента, внутреннего заказа или заказа поставщику.'");
        Возврат;
	КонецЕсли;  	
	
	КлючУникальности = Новый УникальныйИдентификатор;
КонецПроцедуры	//ОбработкаЗаполнения(ДанныеЗаполнения, СтандартнаяОбработка)

&НаСервере
Процедура ОбработкаПроведения(Отказ, РежимПроведения)
	
	Если ( РегистрыСведений.Кт_ОбработкаЗаявкиНаДоставку.ПолучитьКлючОбработкиЗаказа( ЭтотОбъект.Ссылка ) ) Тогда
		Возврат
	КонецЕсли;
	
	//**ДОБАВЛЕНО Максимов В.А.
	
	Если ЭтотОбъект.СпособДоставки <> Перечисления.СпособыДоставки.Самовывоз Тогда
		Если НЕ ЗначениеЗаполнено(ЭтотОбъект.ЗонаДоставки) Тогда
	 		Сообщить("Не заполнено поле Зона доставки");
		   	Отказ = Истина;
			Возврат;
		КонецЕсли;
	КонецЕсли;	                              
	
	//*************************
	
	Если НЕ ЭтотОбъект.ВеземДокументы Тогда
		_ОбработкаДоставкиТоваровСервер.СформироватьЗаписиРегистра_ЗаказЗаявка(ЭтотОбъект, ЭтотОбъект.КлючУникальности,,Истина);
		
		_ОбработкаДоставкиТоваровСервер.ОбработкаЗаказов(ЭтотОбъект, ЭтотОбъект.КлючУникальности);  
		РегистрыСведений.Кт_ОбработкаЗаявкиНаДоставку.УстановитьКлючОбработкиЗаказа( ЭтотОбъект.Ссылка );
		ЗаписатьЗаказы();
		СоздатьОрдераСервер(Отказ);
	Иначе
		//СоздатьПоручениеЭкспедитору(Отказ);
	КонецЕсли;
	
	
КонецПроцедуры

&НаСервере
Процедура ОбработкаУдаленияПроведения(Отказ)
	
	Если НЕ РегистрыСведений.Кт_ОбработкаЗаявкиНаДоставку.ПолучитьКлючОбработкиЗаказа( ЭтотОбъект.Ссылка ) Тогда
		Возврат
	КонецЕсли; 
	
	КлючУникальности = ЭтотОбъект.КлючУникальности;
	_ОбработкаДоставкиТоваровСервер.ОбработкаЗаказов(ЭтотОбъект, КлючУникальности, Истина);
	_ОбработкаДоставкиТоваровСервер.СформироватьЗаписиРегистра_ЗаказЗаявка(ЭтотОбъект, КлючУникальности, Истина);
	
	//Просто удалим запись об обработке
	РегистрыСведений.Кт_ОбработкаЗаявкиНаДоставку.УдалитьКлючОбработкиЗаказа( ЭтотОбъект.Ссылка );

	
  	УдалитьОрдераСервер();
	
КонецПроцедуры

&НаСервере
Процедура ЗаписатьЗаказы()
	Для каждого ТекЗаказ Из ЭтотОбъект.Заказы Цикл
		ТекЗаказ = ТекЗаказ.ЗаказКлиента.ПолучитьОбъект();
		_ДоработкиСлужебный.ЗаписатьДокументКлиента(ТекЗаказ, Истина);
	КонецЦикла;
КонецПроцедуры

Функция ОснованиеЗаказНаВнутреннееПотребление() Экспорт
	
	ТипВнутреннегоЗаказа = Тип("ДокументСсылка.ЗаказНаВнутреннееПотребление");
	
	Если ЗначениеЗаполнено(ДокументОснование)
		И ТипЗнч(ДокументОснование) = ТипВнутреннегоЗаказа Тогда
		Возврат Истина;
	КонецЕсли;
	
	Для Каждого СтрокаЗаказа Из Заказы Цикл
		Если ЗначениеЗаполнено(СтрокаЗаказа.ЗаказКлиента)
			И ТипЗнч(СтрокаЗаказа.ЗаказКлиента) = ТипВнутреннегоЗаказа Тогда
			Возврат Истина;
		КонецЕсли;
	КонецЦикла;
	
	Возврат Ложь;
	
КонецФункции

&НаСервере
Процедура ОбработкаПроверкиЗаполнения(Отказ, ПроверяемыеРеквизиты)
	
	Если ОснованиеЗаказНаВнутреннееПотребление() Тогда
		МассивНепроверяемыхРеквизитов = Новый Массив;
		МассивНепроверяемыхРеквизитов.Добавить("Партнер");
		МассивНепроверяемыхРеквизитов.Добавить("Контрагент");
		ОбщегоНазначения.УдалитьНепроверяемыеРеквизитыИзМассива(ПроверяемыеРеквизиты, МассивНепроверяемыхРеквизитов);
	КонецЕсли;
	
	Если НЕ ЭтотОбъект.ВеземДокументы Тогда
		
		Если ЭтотОбъект.Товары.Количество() = 0 Тогда
		 	Отказ = Истина;
			
			ТекстСообщения = НСтр("ru='Не заполнена табличная часть ""Товары""'");
			ОбщегоНазначенияКлиентСервер.СообщитьПользователю(
				ТекстСообщения,
				ЭтотОбъект.Ссылка,
				,
				"Объект",
				Истина);
			КонецЕсли;
		
	 КонецЕсли;	
	 
КонецПроцедуры	// ОбработкаПроверкиЗаполнения()

#КонецОбласти

