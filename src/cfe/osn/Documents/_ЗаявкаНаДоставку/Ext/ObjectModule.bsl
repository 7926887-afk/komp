&НаСервере
Процедура ОбработкаВеземДокументыМодуль() Экспорт
	
	Если ЭтотОбъект.ВеземДокументы Тогда
		ЭтотОбъект.Товары.Очистить();
	Иначе
		ЭтотОбъект.Товары.Очистить();
		ЭтотОбъект.Заказы.Очистить();
		ТекЗаказ  = ЭтотОбъект.ДокументОснование;	
		ЗаполнитьТЧПоЗаказуПоставщика(ТекЗаказ);
	КонецЕсли;
	
