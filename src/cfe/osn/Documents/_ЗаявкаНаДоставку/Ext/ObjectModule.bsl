&НаСервере
Функция ПроверкаКоличестваНаСкладе(СтрокаЗаказа, ДатаПроверки) Экспорт
	
	ОстатокНаСкладе = 0;
	Запрос = Новый Запрос;
	Запрос.Текст = "ВЫБРАТЬ
	|	ТоварыНаСкладахОстаткиИОбороты.Номенклатура КАК Номенклатура,
	|	ТоварыНаСкладахОстаткиИОбороты.Характеристика КАК Характеристика,
	|	ТоварыНаСкладахОстаткиИОбороты.Серия КАК Серия,
	|	ТоварыНаСкладахОстаткиИОбороты.Склад КАК Склад,
	|	ТоварыНаСкладахОстаткиИОбороты.ВНаличииКонечныйОстаток КАК ВНаличииОстаток,
	|	ТоварыНаСкладахОстаткиИОбороты.КОтгрузкеКонечныйОстаток КАК КОтгрузкеКонечныйОстаток,
	|	ТоварыНаСкладахОстаткиИОбороты.ВНаличииКонечныйОстаток - ТоварыНаСкладахОстаткиИОбороты.КОтгрузкеКонечныйОстаток КАК ОстатокТовара
	|ИЗ
	|	РегистрНакопления.ТоварыНаСкладах.ОстаткиИОбороты(
	|			,
	|			&ДатаКон,
	|			Секунда,
	|			ДвиженияИГраницыПериода,
	|			Склад = &ВыбСклад
	|				И Номенклатура = &ВыбНоменклатура
	|				И Характеристика = &Характеристика
	|				И Серия = &Серия) КАК ТоварыНаСкладахОстаткиИОбороты
	|
	|СГРУППИРОВАТЬ ПО
	|	ТоварыНаСкладахОстаткиИОбороты.Номенклатура,
	|	ТоварыНаСкладахОстаткиИОбороты.Характеристика,
	|	ТоварыНаСкладахОстаткиИОбороты.Серия,
	|	ТоварыНаСкладахОстаткиИОбороты.Склад,
	|	ТоварыНаСкладахОстаткиИОбороты.ВНаличииКонечныйОстаток,
	|	ТоварыНаСкладахОстаткиИОбороты.КОтгрузкеКонечныйОстаток";
	
	Запрос.УстановитьПараметр("ДатаКон", 		 КонецДня(ДатаПроверки));
	Запрос.УстановитьПараметр("ВыбНоменклатура", СтрокаЗаказа.Номенклатура);
	Запрос.УстановитьПараметр("Характеристика",  СтрокаЗаказа.Характеристика);
	Запрос.УстановитьПараметр("Серия", 			 СтрокаЗаказа.Серия);
	Запрос.УстановитьПараметр("ВыбСклад", 		 СтрокаЗаказа.Склад);
	
	Результат = Запрос.Выполнить();
	Выборка = Результат.Выбрать();
	Пока Выборка.Следующий() Цикл
		ОстатокНаСкладе = ОстатокНаСкладе + Выборка.ОстатокТовара;
	КонецЦикла;
	
	Возврат ОстатокНаСкладе;
	
КонецФункции	//ПроверкаКоличестваНаСкладе()

&НаСервере
Функция ОстаткиПоЗаказу(ВыбранныйЗаказ, СтрокаЗаказа, ДатаПроверки) Экспорт
	
	ОстатокПоЗаказу = 0;
	Запрос = Новый Запрос;
	Запрос.Текст = 
	"ВЫБРАТЬ
	|	РаспоряженияНаОтгрузкуОбороты.Распоряжение КАК ЗаказКлиента,
	|	РаспоряженияНаОтгрузкуОбороты.Склад КАК Склад,
	|	РаспоряженияНаОтгрузкуОбороты.Номенклатура КАК Номенклатура,
	|	РаспоряженияНаОтгрузкуОбороты.Характеристика КАК Характеристика,
	|	РаспоряженияНаОтгрузкуОбороты.Серия КАК Серия,
	|	СУММА(РаспоряженияНаОтгрузкуОбороты.ЗаказаноОборот) КАК ЗаказаноОборот,
	|	СУММА(РаспоряженияНаОтгрузкуОбороты.КОформлениюОборот) КАК КОформлениюОборот,
	|	СУММА(РаспоряженияНаОтгрузкуОбороты.ЗаказаноОборот - РаспоряженияНаОтгрузкуОбороты.КОформлениюОборот) КАК ОстатокПоЗаказу
	|ИЗ
	|	РегистрНакопления.РаспоряженияНаОтгрузку.Обороты(
	|			,
	|			&ДатаКон,
	|			,
	|			Распоряжение = &ЗаказКлиента
	|				И Склад = &Склад
	|				И Номенклатура = &Номенклатура
	|				И Характеристика = &Характеристика
	|				И Серия = &Серия) КАК РаспоряженияНаОтгрузкуОбороты
	|
	|СГРУППИРОВАТЬ ПО
	|	РаспоряженияНаОтгрузкуОбороты.Номенклатура,
	|	РаспоряженияНаОтгрузкуОбороты.Распоряжение,
	|	РаспоряженияНаОтгрузкуОбороты.Склад,
	|	РаспоряженияНаОтгрузкуОбороты.Характеристика,
	|	РаспоряженияНаОтгрузкуОбороты.Серия";
	Запрос.УстановитьПараметр("ДатаКон",		КонецДня(ДатаПроверки));
	Запрос.УстановитьПараметр("ЗаказКлиента",	ВыбранныйЗаказ);
	Запрос.УстановитьПараметр("Склад",			СтрокаЗаказа.Склад);
	Запрос.УстановитьПараметр("Номенклатура",	СтрокаЗаказа.Номенклатура);
	Запрос.УстановитьПараметр("Характеристика",	СтрокаЗаказа.Характеристика);
	Запрос.УстановитьПараметр("Серия",			СтрокаЗаказа.Серия);
	
	Результат = Запрос.Выполнить();
	Выборка = Результат.Выбрать();
	Пока Выборка.Следующий() Цикл
		ОстатокПоЗаказу = ОстатокПоЗаказу + Выборка.ОстатокПоЗаказу;
	КонецЦикла;
	
	Возврат ОстатокПоЗаказу;
	
КонецФункции // ОстаткиПоЗаказу()

&НаСервере
Функция ОстатокНаСкладе(ПараметрыОтбора)
	
	ВыбранныйЗаказ	= ПараметрыОтбора.Заказ;
	Назначение		= ПараметрыОтбора.Назначение;
	Номенклатура	= ПараметрыОтбора.Номенклатура;
	Характеристика	= ПараметрыОтбора.Характеристика;
	
	Если ( ПараметрыОтбора.Свойство("Серия") ) Тогда
		Серия		= ПараметрыОтбора.Серия;
	Иначе	
		Серия 		= Справочники.СерииНоменклатуры.ПустаяСсылка();
	КонецЕсли;		
	//Склад			= ПараметрыОтбора.Склад;
	ДатаПроверки	= ТекущаяДата();
	
	Запрос = Новый Запрос;
	Запрос.Текст = "ВЫБРАТЬ
	               |	0 КАК Индекс,
	               |	ТоварыНаСкладахОстатки.Назначение КАК Назначение,
	               |	ТоварыНаСкладахОстатки.Номенклатура КАК Номенклатура,
	               |	ТоварыНаСкладахОстатки.Характеристика КАК Характеристика,
	               |	ТоварыНаСкладахОстатки.Серия КАК Серия,
	               |	ТоварыНаСкладахОстатки.Склад КАК Склад,
	               |	ЕСТЬNULL(ТоварыНаСкладахОстатки.ВНаличииОстаток,0) КАК ВНаличииОстаток
	               |ПОМЕСТИТЬ ВТ_Остатки
	               |ИЗ
	               |	РегистрНакопления.ТоварыНаСкладах.Остатки(
	               |			&ДатаОтбора,
	               |			Назначение = &Назначение
	               |				И Номенклатура = &Номенклатура
	               |				И Характеристика = &Характеристика
	               |				И Серия = &Серия
	               |				И Склад = &Склад) КАК ТоварыНаСкладахОстатки
	               |
				   //|ОБЪЕДИНИТЬ ВСЕ
				   //|
				   //|ВЫБРАТЬ
				   //|	1,
				   //|	ЗНАЧЕНИЕ(Справочник.Назначения.ПустаяСсылка),
				   //|	ТоварыНаСкладахОстатки.Номенклатура,
				   //|	ТоварыНаСкладахОстатки.Характеристика,
				   //|	ТоварыНаСкладахОстатки.Серия,
				   //|	ТоварыНаСкладахОстатки.Склад,
				   //|	ЕСТЬNULL(ТоварыНаСкладахОстатки.ВНаличииОстаток,0)
				   //|ИЗ
				   //|	РегистрНакопления.ТоварыНаСкладах.Остатки(
				   //|			&ДатаОтбора,
				   //|			Номенклатура = &Номенклатура
				   //|				И Характеристика = &Характеристика
				   //|				И Серия = &Серия
				   //|				И Склад = &Склад) КАК ТоварыНаСкладахОстатки
	               |;
	               |
	               |////////////////////////////////////////////////////////////////////////////////
	               |ВЫБРАТЬ
	               |	ВТ_Остатки.Индекс КАК Индекс,
	               |	ВТ_Остатки.Назначение КАК Назначение,
	               |	ВТ_Остатки.Номенклатура КАК Номенклатура,
	               |	ВТ_Остатки.Характеристика КАК Характеристика,
	               |	ВТ_Остатки.Серия КАК Серия,
	               |	ВТ_Остатки.Склад КАК Склад,
	               |	СУММА(ВТ_Остатки.ВНаличииОстаток) КАК ВНаличииОстаток
	               |ИЗ
	               |	ВТ_Остатки КАК ВТ_Остатки
	               |
	               |СГРУППИРОВАТЬ ПО
	               |	ВТ_Остатки.Индекс,
	               |	ВТ_Остатки.Назначение,
	               |	ВТ_Остатки.Номенклатура,
	               |	ВТ_Остатки.Характеристика,
	               |	ВТ_Остатки.Серия,
	               |	ВТ_Остатки.Склад
	               |
	               |УПОРЯДОЧИТЬ ПО
	               |	Индекс";
	
	Запрос.УстановитьПараметр("ДатаОтбора", 	КонецДня(ДатаПроверки));
	Запрос.УстановитьПараметр("Назначение", 	Назначение);
	Запрос.УстановитьПараметр("Номенклатура", 	Номенклатура);
	Запрос.УстановитьПараметр("Характеристика", Характеристика);
	Запрос.УстановитьПараметр("Серия", 			Серия);
	Запрос.УстановитьПараметр("Склад", 			ПараметрыОтбора.Склад);
	
	Результат = Запрос.Выполнить();
	
	Если Результат.Пустой() Тогда
		Возврат 0;
	КонецЕсли;
	
	Рез = 0;
	Выборка = Результат.Выбрать();
	Пока ( Выборка.Следующий() ) Цикл
		Если ( Выборка.ВНаличииОстаток <> 0 ) Тогда
			Рез = Выборка.ВНаличииОстаток;
			Прервать;
		КонецЕсли;
	КонецЦикла;	
	
	
	Возврат Рез;
	
КонецФункции // ПоступилоПоЗаказу()

