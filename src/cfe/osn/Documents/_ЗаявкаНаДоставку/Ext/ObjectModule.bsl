			ДокументОснование = Выборка.Ссылка;
			ПервыйЗаказ = Ложь;
		КонецЕсли;		// ПервыйЗаказ 		 
		
		//Заполнение табличных частей
		//ЗаполнитьТЧПоЗаказу_Клиента_Поставщика(Выборка);
		
	КонецЦикла;		// ТекСтрока
	
	
