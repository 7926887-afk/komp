&НаСервере
Процедура ДобавитьВыбранныйЗаказНаСервере( СсылкаЗаказа , ДобавлятьТовары ) 
		
	Объект.НужныДокументы	= Истина;

	НоваяСтрока = Объект.Заказы.Добавить();
	НоваяСтрока.НомерЗаказа		= СсылкаЗаказа.Номер;
	НоваяСтрока.ДатаЗаказа      = СсылкаЗаказа.Дата;
	НоваяСтрока.ЗаказКлиента    = СсылкаЗаказа;
	НоваяСтрока.НужныДокументы  = Истина;
	
	ЭтаФорма.Модифицированность = Истина;
	
	Если НЕ ( ДобавлятьТовары ) Тогда
		Возврат;
	КонецЕсли;	
	
	Об = РеквизитФормыВЗначение("Объект");
	Если ( ТипЗнч( СсылкаЗаказа ) = Тип("ДокументСсылка.ЗаказКлиента") ) Тогда
		Об.ЗаполнитьТЧТовары(СсылкаЗаказа);
	Иначе
		Об.ЗаполнитьТЧПоЗаказуПоставщика(СсылкаЗаказа);
	КонецЕсли;	
	
	ЗначениеВРеквизитФормы(Об,"Объект");
	
КонецПроцедуры	

