&НаКлиенте
Процедура ЗаказыВыбор(Элемент, ВыбраннаяСтрока, Поле, СтандартнаяОбработка)
	
	СтандартнаяОбработка = Ложь;
	ТекДанн = Элемент.ТекущиеДанные; 
	
	Если  (Поле.Имя = "ЗаказыЗаказКлиента" ) ИЛИ
		  (Поле.Имя = "ЗаказыНомерЗаказа"  ) ИЛИ
		  (Поле.Имя = "ЗаказыДатаЗаказа"   ) Тогда
		  
		Если ТекДанн <> Неопределено Тогда
			ОбъектСсылка = ТекДанн.ЗаказКлиента;
			ПоказатьЗначение(,ОбъектСсылка); 
		КонецЕсли;
		
	ИначеЕсли  (Поле.Имя = "ЗаказыНужныДокументы" )Тогда
		
		Если ТекДанн <> Неопределено Тогда
			ТекДанн.НужныДокументы = ?(ТекДанн.НужныДокументы, Ложь, Истина);
		КонецЕсли;
	
	КонецЕсли;
	
КонецПроцедуры

