&НаСервере
Функция ДобавитьТовары(ВыбранныйЗаказ)
	
	ПроверкаЗаполненостиТЧТовары = Ложь;
	СтароеКолСтрок 	 = Объект.Товары.Количество();
	СтароеКоличество = Объект.Товары.Итог("Количество");
	ДокументОбъект	 = РеквизитФормыВЗначение("Объект"); 
	Выборка			 = ДокументОбъект.ПолучитьЗаказ(ВыбранныйЗаказ,Объект.Дата);
	
	Для Каждого ТекСтрока Из ВыбранныйЗаказ.Товары Цикл
		Отбор = Новый Структура("КодСтроки, Номенклатура", ТекСтрока.НомерСтроки, ТекСтрока.Номенклатура);
		МассивНайденныхСтрок = Выборка.НайтиСтроки(Отбор);
		Если МассивНайденныхСтрок.Количество() > 0 Тогда
			НайденнаяСтрока = МассивНайденныхСтрок[0];
			//ОстатокПоЗаказу = ДокументОбъект.ОстаткиПоЗаказу(ВыбранныйЗаказ, ТекСтрока, Объект.Дата);
			ОстатокПоЗаказу = НайденнаяСтрока.ОстатокПоЗаказу;
			ОстатокНаСкладе = ДокументОбъект.ПроверкаКоличестваНаСкладе(ТекСтрока, Объект.Дата);
			Если ОстатокНаСкладе > 0 Тогда
				Если ОстатокПоЗаказу > ОстатокНаСкладе Тогда
					КолВОтгрузку = ОстатокНаСкладе;
				Иначе
					КолВОтгрузку = ОстатокПоЗаказу;
				КонецЕсли;
			Иначе
				КолВОтгрузку = 0
			КонецЕсли;		//ОстатокНаСкладе > 0 
			
			Если Не КолВОтгрузку = 0 Тогда
				
				Если Объект.Товары.НайтиСтроки( Новый Структура("Номенклатура, Характеристика, Серия",ТекСтрока.Номенклатура, ТекСтрока.Характеристика, ТекСтрока.Серия ) ).Количество() = 0 Тогда
					НоваяСтрока	= Объект.Товары.Добавить();
					ЗаполнитьЗначенияСвойств(НоваяСтрока, ТекСтрока);
					НоваяСтрока.Артикул = ТекСтрока.Номенклатура.Артикул;
					Если НоваяСтрока.Количество > КолВОтгрузку Тогда
						НоваяСтрока.Количество = КолВОтгрузку;
						Если ТекСтрока.Упаковка.Числитель = 0 Тогда
							Числитель = 1;
						Иначе
							Числитель = ТекСтрока.Упаковка.Числитель;
						КонецЕсли;
						НоваяСтрока.КоличествоУпаковок = КолВОтгрузку / Числитель;
					КонецЕсли;		//НоваяСтрока.Количество > КолВОтгрузку
				Иначе			// Объект.Товары.НайтиСтроки
					НоваяСтрока	= Объект.Товары.НайтиСтроки( Новый Структура("Номенклатура, Характеристика, Серия",ТекСтрока.Номенклатура, ТекСтрока.Характеристика, ТекСтрока.Серия )  )[0];
					Если НоваяСтрока.Количество + ТекСтрока.Количество > КолВОтгрузку Тогда
						ТекущийОстаток = НоваяСтрока.Количество + ( КолВОтгрузку - ТекСтрока.Количество);
						НоваяСтрока.Количество = ТекущийОстаток;
						Если ТекСтрока.Упаковка.Числитель = 0 Тогда
							Числитель = 1;
						Иначе
							Числитель = ТекСтрока.Упаковка.Числитель;
						КонецЕсли;
						НоваяСтрока.КоличествоУпаковок = ТекущийОстаток / Числитель;	//**  НоваяСтрока.КоличествоУпаковок + ТекущийОстаток / Числитель;
					Иначе			//НоваяСтрока.Количество + ТекСтрока.Количество
						НоваяСтрока.Количество = НоваяСтрока.Количество + ТекСтрока.Количество;
  						НоваяСтрока.КоличествоУпаковок = НоваяСтрока.КоличествоУпаковок + ТекСтрока.КоличествоУпаковок;
					КонецЕсли;		//НоваяСтрока.Количество + ТекСтрока.Количество
				КонецЕсли;		//Объект.Товары.НайтиСтроки
			КонецЕсли;		//Не КолВОтгрузку = 0 		 
		КонецЕсли;		//МассивНайденныхСтрок.Количество() > 0
	КонецЦикла;
	
	Если (НЕ Объект.Товары.Количество() = СтароеКолСтрок) ИЛИ
		 (НЕ Объект.Товары.Итог("Количество") = СтароеКоличество) Тогда
		ПроверкаЗаполненостиТЧТовары = Истина;
	КонецЕсли;
	Возврат ПроверкаЗаполненостиТЧТовары;
	
КонецФункции //ДобавитьТовары(ВыбранноеЗначение)()

&НаСервере
Процедура ЗаказыОбработкаВыбораНаСервере(ВыбранноеЗначение )
	
	Если ( НЕ  ЗначениеЗаполнено(Объект.Партнер) ) И ( Объект.Заказы.Количество() = 0 ) Тогда
		Объект.Партнер = ВыбранноеЗначение.Партнер;
		ПриИзмененииПартнераСервер();
	КонецЕсли;
	
	Если Объект.Заказы.НайтиСтроки(Новый Структура("ЗаказКлиента", ВыбранноеЗначение.Ссылка)).Количество() = 0 Тогда
		ПроверкаЗаполненостиТЧТовары = ДобавитьТовары(ВыбранноеЗначение);;
		Если ПроверкаЗаполненостиТЧТовары Тогда
			
			Объект.НужныДокументы	= Истина;

			НоваяСтрока					= Объект.Заказы.Добавить();
			НоваяСтрока.НомерЗаказа		= ВыбранноеЗначение.Номер;
			НоваяСтрока.ДатаЗаказа		= ВыбранноеЗначение.Дата;
			НоваяСтрока.ЗаказКлиента	= ВыбранноеЗначение.Ссылка;
			НоваяСтрока.НужныДокументы	= Истина;
			ДобавитьТовары(ВыбранноеЗначение);	
		КонецЕсли;		//ПроверкаЗаполненостиТЧТовары 		
	КонецЕсли; 
	
КонецПроцедуры

&НаСервере
Процедура ПриОбработкеУдаленияЕаСервере(ТекущийЗаказКлиента, Отказ);
	
	Если НЕ Отказ Тогда
		Для Каждого ТекСтрока Из ТекущийЗаказКлиента.Товары Цикл
			Если НЕ Объект.Товары.НайтиСтроки( Новый Структура("Номенклатура, Характеристика, Серия",ТекСтрока.Номенклатура, ТекСтрока.Характеристика, ТекСтрока.Серия )  ).Количество() = 0 Тогда
				УдаляемыеСтроки	= Объект.Товары.НайтиСтроки( Новый Структура("Номенклатура, Характеристика, Серия",ТекСтрока.Номенклатура, ТекСтрока.Характеристика, ТекСтрока.Серия )  );
				Для Каждого УдаляемаяСтрока Из УдаляемыеСтроки Цикл
					Если ( УдаляемаяСтрока.Количество  = ТекСтрока.Количество ) И (УдаляемаяСтрока.КоличествоУпаковок  = ТекСтрока.КоличествоУпаковок ) Тогда
						Объект.Товары.Удалить(УдаляемаяСтрока);
					Иначе
						УдаляемаяСтрока.Количество = УдаляемаяСтрока.Количество - ТекСтрока.Количество;
						УдаляемаяСтрока.КоличествоУпаковок = УдаляемаяСтрока.Количество;
					КонецЕсли; 
				КонецЦикла;
			КонецЕсли;
		КонецЦикла; 
	КонецЕсли; 
	
КонецПроцедуры	//ПриобработкеУдаленияЕаСервере(Элемент.ТекущиеДанные.ЗаказКлиента);()

&НаСервере
