&НаКлиенте
Процедура КомандаДобавитьЗаказ(Команда)
	
	Если Объект.Проведен Тогда
		Сообщить("Для внесения изменений отмените проведение документа");
		Возврат;
	КонецЕсли;
	
	ВыполнятьОтбор = ЗначениеЗаполнено(Объект.Партнер);
	Если ВыполнятьОтбор Тогда
		ПараметрыОтбора = Новый Структура("Партнер, Закрыт", Объект.Партнер, Ложь);		
		ПараметрыПодбора = Новый Структура("ЗакрыватьПриВыборе, МножественныйВыбор, Отбор", Истина, Ложь, ПараметрыОтбора);
	Иначе
		ПараметрыПодбора = Новый Структура("ЗакрыватьПриВыборе, МножественныйВыбор, Отбор", Истина, Ложь);
	КонецЕсли;     
	
	ОповещениеОВыборе = Новый ОписаниеОповещения("ВыборДополнительногоЗаказа",ЭтотОбъект);
	
	Если ( Объект._ВидЗаявки = ПредопределенноеЗначение("Перечисление._ВидыЗаявки.ДоКлиента" )) Тогда
		ОткрытьФорму("Документ.ЗаказКлиента.ФормаВыбора", ПараметрыПодбора,  ЭтаФорма,,,,ОповещениеОВыборе); 
	Иначе
		ОткрытьФорму("Документ.ЗаказПоставщику.ФормаВыбора", ПараметрыПодбора,  ЭтаФорма,,,,ОповещениеОВыборе); 
	КонецЕсли;	
КонецПроцедуры

&НаКлиенте
Процедура ВыборДополнительногоЗаказа( Результат, ДопПараметры ) Экспорт
	Если ( Результат = Неопределено ) Тогда
		Возврат;
	КонецЕсли;	
	
	Если ( Объект.ДокументОснование = Результат ) Тогда
		ОбщегоНазначенияКлиентСервер.СообщитьПользователю("Выбранный заказ является документом-основанием заявки");
		Возврат;
	КонецЕсли;
	
	Оповещение = Новый ОписаниеОповещения("ПослеЗакрытияВопросаДобавленияТоваров", ЭтотОбъект, Новый Структура("Заказ",Результат));	
 
    ПоказатьВопрос(Оповещение,"Добавить товары из выбранного заказа?",
        РежимДиалогаВопрос.ДаНетОтмена,0,КодВозвратаДиалога.Да);   
	
КонецПроцедуры	

&НаКлиенте
Процедура ПослеЗакрытияВопросаДобавленияТоваров(Результат, ДопПараметры) Экспорт
	Если Результат = КодВозвратаДиалога.Отмена Тогда
		Возврат;
	КонецЕсли;	
	
    Если Результат = КодВозвратаДиалога.Да Тогда
       ДобавитьВыбранныйЗаказНаСервере( ДопПараметры.Заказ, Истина ); 
   	Иначе
	   ДобавитьВыбранныйЗаказНаСервере( ДопПараметры.Заказ, Ложь );
    КонецЕсли;	
 
КонецПроцедуры


