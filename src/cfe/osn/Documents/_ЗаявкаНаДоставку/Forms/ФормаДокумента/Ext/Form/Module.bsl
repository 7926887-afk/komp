#Область ПрограммныйИнтерфейс

&НаСервере
Процедура ОформлениеФормы()

	Если Объект.СпособДоставки = Перечисления.СпособыДоставки.Самовывоз Тогда
		ЭтаФорма.Элементы.ЗонаДоставки.Видимость = Ложь;
	Иначе
		ЭтаФорма.Элементы.ЗонаДоставки.Видимость = Истина;				
	КонецЕсли;	
	
	Если Объект.ВеземДокументы Тогда
		ЭтаФорма.Элементы.ОткрытьПоручениеЭкспедитору.Видимость		= Истина;

		Если ( ЗначениеЗаполнено( Объект.ПоручениеЭкспидитору ) )  Тогда
			ЭтаФорма.Элементы.ОткрытьПоручениеЭкспедитору.Доступность	= Истина;
			ЭтаФорма.Элементы.ВеземДокументы.Доступность = Ложь;
		КонецЕсли;
		
	Иначе	
		ЭтаФорма.Элементы.ОткрытьПоручениеЭкспедитору.Видимость		= Ложь;
		ЭтаФорма.Элементы.ОткрытьПоручениеЭкспедитору.Доступность	= Ложь;
		//ЭтаФорма.Элементы.ВеземДокументы.Доступность = Истина;
	КонецЕсли;
	
	Если ( Объект._ВидЗаявки = Перечисления._ВидыЗаявки.ОтПоставщика )	Тогда
		Элементы.ГруппаДоверенность.Видимость = Истина;
	Иначе
		Элементы.ГруппаДоверенность.Видимость = Ложь;
	КонецЕсли;	
	
	//Если ( Объект.Заказы.Количество() > 0 ) Тогда
	//	Элементы.СтраницаЗаказы.Видимость = Истина;
	//	Элементы.ДокументОснование.Видимость = Ложь;
	//Иначе	
	//	Элементы.СтраницаЗаказы.Видимость = Ложь;
	//	Элементы.ДокументОснование.Видимость = Истина;
	//КонецЕсли;
	
	УстановитьВидимостьКонтрагента();
	
КонецПроцедуры	

&НаСервере
Процедура УстановитьВидимостьКонтрагента()
	
	Об = РеквизитФормыВЗначение("Объект");
	
	ВидимостьКонтрагента = НЕ Об.ОснованиеЗаказНаВнутреннееПотребление();
	
	Если Элементы.Найти("ГруппаКлиент") <> Неопределено Тогда
		Элементы.ГруппаКлиент.Видимость = ВидимостьКонтрагента;
	КонецЕсли;
	
КонецПроцедуры

#КонецОбласти

#Область ОбработчикиСобытийФормы

&НаСервере
Процедура ПриЧтенииСозданииНаСервере()
	_ОбработкаДоставкиТоваровСервер.УстановитьСтраницуДоставки(Элементы, Объект);
	
	Если Объект.Ссылка.Пустая() Тогда
		Объект.Статус = Перечисления._СтатусыЗаявокНаДоставку.КВыполнению;
	Иначе	
		Если ( Объект.ВеземДокументы ) И ( Объект.ПоручениеЭкспидитору = ПредопределенноеЗначение("Документ.ПоручениеЭкспедитору.ПустаяСсылка" )) Тогда
			Запрос = Новый Запрос;
			Запрос.Текст = "ВЫБРАТЬ
			               |	ПоручениеЭкспедитору.Ссылка КАК Ссылка
			               |ИЗ
			               |	Документ.ПоручениеЭкспедитору КАК ПоручениеЭкспедитору
			               |ГДЕ
			               |	ПоручениеЭкспедитору._ЗаявкаНаДоставку = &_ЗаявкаНаДоставку";
			Запрос.УстановитьПараметр("_ЗаявкаНаДоставку", Объект.Ссылка );
			Результат = Запрос.Выполнить();
			Если НЕ ( Результат.Пустой() ) Тогда
				Выборка = Результат.Выбрать();
				Выборка.Следующий();
				Объект.ПоручениеЭкспидитору = Выборка.Ссылка;
			КонецЕсли;	
			
		КонецЕсли;	
	КонецЕсли; 
	
	ДоставкаТоваровКлиентСервер.ЗаполнитьСписокВыбораПоляВремени(Элементы.ВремяДоставкиС);
	ДоставкаТоваровКлиентСервер.ЗаполнитьСписокВыбораПоляВремени(Элементы.ВремяДоставкиПо);

	ЗаполнитьСлужебныеРеквизитыПоНоменклатуре();
КонецПроцедуры	//ПриЧтенииСозданииНаСервере()

&НаСервере
Процедура ПриСозданииНаСервере(Отказ, СтандартнаяОбработка)
	
	Если ( Объект.Ссылка.Пустая() ) И НЕ ( ЗначениеЗаполнено( Объект.ДокументОснование ) ) И ( Объект.Заказы.Количество() = 0 ) Тогда
		ВызватьИсключение НСтр("ru='Документ может быть создан только на основании заказа клиента или заказа поставщику.'");
		Отказ = Истина;
		Возврат;
	КонецЕсли;	
	
	ИспользоватьНаправленияДеятельности = ПолучитьФункциональнуюОпцию("ИспользоватьУчетДоходовПоНаправлениямДеятельности");
	
	ПриЧтенииСозданииНаСервере();
	ОбновитьИнформациюОДоверенности();
	ОформлениеФормы();
КонецПроцедуры

&НаСервере
Процедура ПередЗаписьюСервер()
	Если НЕ ЗначениеЗаполнено(Объект.ДатаОтгрузки) Тогда
		Объект.ДатаОтгрузки = Объект.ЖелаемаяДатаОтгрузки;
	КонецЕсли;
	
КонецПроцедуры // ПередЗаписьюСервер()

&НаКлиенте
Процедура ПередЗаписью(Отказ, ПараметрыЗаписи, ПараметрыПроведения)
	
	Если ( Объект.СпособДоставки <> ПредопределенноеЗначение("Перечисление.СпособыДоставки.Самовывоз" )  ) Тогда
		Если ПустаяСтрока(Объект.АдресДоставки)  Тогда
			Отказ = Истина;
			ТекстСообщения = НСтр("ru='Не заполнен адрес доставки'");
			ОбщегоНазначенияКлиентСервер.СообщитьПользователю(ТекстСообщения);
			Возврат;
		КонецЕсли;  
	КонецЕсли;	

	
	//++ Сухарев Б.В. 31.01.2019
	Если ПараметрыЗаписи.РежимЗаписи = РежимЗаписиДокумента.Проведение Тогда 
		Если ( Объект._ВидЗаявки = ПредопределенноеЗначение("Перечисление._ВидыЗаявки.ДоКлиента" )) Тогда
			Для Каждого ТекЗаказ Из Объект.Заказы Цикл
				тЗаказ = ТекЗаказ.ЗаказКлиента;
				Если НЕ тЗаказ = _ДоработкиСлужебный.ПолучитьПустуюСсылку(ТипЗнч(Объект.ДокументОснование)) Тогда
					Парам  = Новый Структура("Ключ",тЗаказ);
					мФорма = ПолучитьФорму("Документ.ЗаказКлиента.ФормаОбъекта", Парам); 
					Попытка
						мФорма.Закрыть(0);
					Исключение
	//** 					ОбщегоНазначенияКлиентСервер.СообщитьПользователю(НСтр("ru='Заказ '") + ТекЗаказ + НСтр("ru=' открыт другим пользователем или фоновым заданием'"));
					КонецПопытки;
				КонецЕсли; 
			КонецЦикла;		// ТекЗаказ Из Заказы  
		КонецЕсли;	
	КонецЕсли;
	//== Сухарев Б.В
	
	Если НеВыполнятьПроверкуПередЗаписью Тогда
		НеВыполнятьПроверкуПередЗаписью = Ложь;
		Возврат;
	КонецЕсли;
	ПередЗаписьюСервер();
		

КонецПроцедуры

&НаСервере
Процедура ПередЗаписьюНаСервере(Отказ, ТекущийОбъект, ПараметрыЗаписи)
	МодификацияКонфигурацииПереопределяемый.ПередЗаписьюНаСервере(ЭтаФорма, Отказ, ТекущийОбъект, ПараметрыЗаписи);
КонецПроцедуры

&НаСервере
Процедура ПриЗаписиНаСервере(Отказ, ТекущийОбъект, ПараметрыЗаписи)
	Если ( Объект.ВеземДокументы ) И ( Объект.ПоручениеЭкспидитору = ПредопределенноеЗначение("Документ.ПоручениеЭкспедитору.ПустаяСсылка" )) Тогда
		НовыйПоручениеЭкспедитору = ОбновитьПоручение();
		НовыйПоручениеЭкспедитору._ЗаявкаНаДоставку = ТекущийОбъект.Ссылка;
		НовыйПоручениеЭкспедитору.Записать(РежимЗаписиДокумента.Проведение);
		
		ТекущийОбъект.ПоручениеЭкспидитору = НовыйПоручениеЭкспедитору.Ссылка;	
	КонецЕсли;	
КонецПроцедуры


&НаКлиенте
Процедура ПослеЗаписи(ПараметрыЗаписи)
	ОформлениеФормы();
	
	ВыбранныеЗаказы = Новый Структура();
	Для Каждого ТекЗаказ Из Объект.Заказы Цикл
		//**Изменено 20.09.19 Максимов
		//ВыбранныеЗаказы.Вставить(ТекЗаказ.НомерЗаказа, ТекЗаказ.ЗаказКлиента);
		
		Если ТипЗнч(ТекЗаказ.ЗаказКлиента) = Тип("ДокументСсылка.ЗаказПоставщику") Тогда 
			//ВыбранныеЗаказы.Вставить(ТекЗаказ.НомерЗаказа, ТекЗаказ.ЗаказКлиента);  
			ЗаписатьИнфоВЗаказПоставщику();
		Иначе	
			Если Лев(ТекЗаказ.НомерЗаказа, 1) = "К" ИЛИ Лев(ТекЗаказ.НомерЗаказа, 1) = "И" Тогда
				ВыбранныеЗаказы.Вставить(ТекЗаказ.НомерЗаказа, ТекЗаказ.ЗаказКлиента);
			Иначе	
				ВыбранныеЗаказы.Вставить("С" + ТекЗаказ.НомерЗаказа, ТекЗаказ.ЗаказКлиента);		
			КонецЕсли;		
		КонецЕсли;		
		//****************************
	КонецЦикла;
	ПараметрыЗаписи.Вставить("ВыбранныеЗаказы", ВыбранныеЗаказы);
	ПараметрыЗаписи.Вставить("Объект", Объект);
	Оповестить("Запись_ЗаказаНаОтгрузку", ПараметрыЗаписи, Объект.Ссылка);

КонецПроцедуры  

&НаСервере
Процедура ЗаписатьИнфоВЗаказПоставщику() 
	
	ТаблЗаказов = Объект.Заказы.Выгрузить();
	ТаблЗаказов.Свернуть("ЗаказКлиента");
	
	Для Каждого ТекЗаказ Из ТаблЗаказов Цикл
		ЗаказПостОбъект = ТекЗаказ.ЗаказКлиента.ПолучитьОбъект();
		ЗаказПостОбъект.СпособДоставки = Объект.Ссылка.СпособДоставки;
		ЗаказПостОбъект.АдресДоставки  = Объект.Ссылка.АдресДоставки;
		ЗаказПостОбъект.АдресДоставкиЗначенияПолей = Объект.Ссылка.АдресДоставкиЗначенияПолей;
		ЗаказПостОбъект.ДополнительнаяИнформацияПоДоставке = Объект.Ссылка.ДополнительнаяИнформацияПоДоставке;
		Если НачалоДня(ЗаказПостОбъект.ЖелаемаяДатаПоступления) <> НачалоДня(Объект.Ссылка.ЖелаемаяДатаОтгрузки) Тогда
			ЗаказПостОбъект.ЖелаемаяДатаПоступления = Объект.Ссылка.ЖелаемаяДатаОтгрузки;
		КонецЕсли; 
		
		Если НачалоДня(ЗаказПостОбъект.ДатаПоступления) <> НачалоДня(Объект.Ссылка.ЖелаемаяДатаОтгрузки) И ЗаказПостОбъект.ПоступлениеОднойДатой Тогда
			ЗаказПостОбъект.ДатаПоступления = Объект.Ссылка.ЖелаемаяДатаОтгрузки;
		КонецЕсли; 
		Для Каждого Стр ИЗ ЗаказПостОбъект.Товары Цикл
			Стр.ДатаПоступления = Объект.Ссылка.ЖелаемаяДатаОтгрузки;
		КонецЦикла;

		ЗаказПостОбъект.Записать(РежимЗаписиДокумента.Проведение); 
	КонецЦикла;
КонецПроцедуры


