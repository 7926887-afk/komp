&НаСервере
Процедура ЗаполнитьАдресДаставкиНаСервере() 
	
	Об = РеквизитФормыВЗначение("Объект");
	
	Если Об.ОснованиеЗаказНаВнутреннееПотребление() Тогда
		ВладелецАдреса = Объект.Организация;
		ВидФактическийАдрес = Справочники.ВидыКонтактнойИнформации.ФактАдресОрганизации;
		ВидЮридическийАдрес = Справочники.ВидыКонтактнойИнформации.ЮрАдресОрганизации;
	Иначе
		Если ЗначениеЗаполнено(Объект.Контрагент) Тогда
			ВладелецАдреса = Объект.Контрагент;
			ВидФактическийАдрес = Справочники.ВидыКонтактнойИнформации.ФактАдресКонтрагента;
			ВидЮридическийАдрес = Справочники.ВидыКонтактнойИнформации.ЮрАдресКонтрагента;
		Иначе
			ВладелецАдреса = Объект.Партнер;
			ВидФактическийАдрес = Справочники.ВидыКонтактнойИнформации.АдресПартнера;
			ВидЮридическийАдрес = Справочники.ВидыКонтактнойИнформации.АдресПартнера;
		КонецЕсли;
	КонецЕсли;
	
	ФактическийАдрес = УправлениеКонтактнойИнформацией.КонтактнаяИнформацияОбъекта(
			ВладелецАдреса,
			ВидФактическийАдрес,
			ТекущаяДатаСеанса());
			
	ЮридическийАдрес = УправлениеКонтактнойИнформацией.КонтактнаяИнформацияОбъекта(
			ВладелецАдреса,
			ВидЮридическийАдрес,
			ТекущаяДатаСеанса());
			
			
	Если ЗначениеЗаполнено(ФактическийАдрес) Тогда
		Элементы.АдресДоставки.СписокВыбора.Добавить(ФактическийАдрес);
		Объект.АдресДоставки = ФактическийАдрес;
	КонецЕсли;
	
	Если ЗначениеЗаполнено(ЮридическийАдрес) Тогда
		Элементы.АдресДоставки.СписокВыбора.Добавить(ЮридическийАдрес);
		 Если НЕ  ЗначениеЗаполнено(ФактическийАдрес) Тогда
			Объект.АдресДоставки = ЮридическийАдрес;
		 КонецЕсли; 
	КонецЕсли;
	
КонецПроцедуры

