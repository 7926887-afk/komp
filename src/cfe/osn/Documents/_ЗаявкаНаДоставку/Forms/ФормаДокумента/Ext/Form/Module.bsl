&НаСервере
Процедура ПриИзмененииПартнераСервер()
	
	_ОбработкаДоставкиТоваровСервер.ЗаявкаОчиститьРеквизитыДоставки(Элементы, Объект);
	ПартнерыИКонтрагенты.ЗаполнитьКонтрагентаПартнераПоУмолчанию(Объект.Партнер, Объект.Контрагент,  Истина);
	Если ЗначениеЗаполнено(Объект.Контрагент) Тогда
		_ОбработкаДоставкиТоваровСервер.ЗаполнитьПодчиненныеСвойстваПартнера( Объект);
	КонецЕсли; 
	
	НаправленияДеятельностиКэшированныеЗначения = Новый Структура("ИспользоватьНаправленияДеятельности, 
																																							| ИспользоватьОбособленноеОбеспечениеЗаказов,
																																							| НазначениеПоУмолчанию", ИспользоватьНаправленияДеятельности, Истина, Неопределено);
	Если ИспользоватьНаправленияДеятельности Тогда
		НаправленияДеятельностиСервер.ЗаполнитьНаправлениеПоУмолчанию(Объект.НаправлениеДеятельности, Объект.Соглашение, Объект.Договор);
	КонецЕсли;
	ИзмененныеСтроки = НаправленияДеятельностиСервер.ПриИзмененииНаправленияДеятельности(ЭтотОбъект);
	ЗакупкиСервер.ОчиститьРеквизитыСписанияНаРасходыПриУстановкеНазначенияВТабличнойЧасти(ИзмененныеСтроки);
	
	ЗаполнитьАдресДаставкиНаСервере();
	ПартнерыИКонтрагенты.ЗаполнитьКонтактноеЛицоПартнераПоУмолчанию(Объект.Партнер, Объект.КонтактноеЛицо);
	
