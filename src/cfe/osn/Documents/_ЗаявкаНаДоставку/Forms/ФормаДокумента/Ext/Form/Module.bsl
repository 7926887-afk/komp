&НаСервере
Функция ОбновитьПоручение()
	
	Если НЕ ( ЗначениеЗаполнено( Объект.ПоручениеЭкспидитору ) ) Тогда
		НовыйПоручениеЭкспедитору				= Документы.ПоручениеЭкспедитору.СоздатьДокумент(); 
	Иначе
		НовыйПоручениеЭкспедитору				= Объект.ПоручениеЭкспидитору;
		НовыйПоручениеЭкспедитору				= НовыйПоручениеЭкспедитору.ПолучитьОбъект();
		НовыйПоручениеЭкспедитору.Записать(РежимЗаписиДокумента.ОтменаПроведения);
	КонецЕсли; 	
						
	НовыйПоручениеЭкспедитору.Дата				= Объект.ЖелаемаяДатаОтгрузки;	//ТекущаяДата();
	НовыйПоручениеЭкспедитору.ДатаВыполнения	= Объект.ЖелаемаяДатаОтгрузки;
	
	
	НовыйПоручениеЭкспедитору.Склад				= Объект.Склад;
	НовыйПоручениеЭкспедитору.Пункт				= Объект.Партнер;
	НовыйПоручениеЭкспедитору.ЗонаДоставки		= Объект.ЗонаДоставки;
	НовыйПоручениеЭкспедитору.АдресДоставки		= Объект.АдресДоставки;
	НовыйПоручениеЭкспедитору.ВремяДоставкиС	= Объект.ВремяДоставкиС;
	НовыйПоручениеЭкспедитору.ВремяДоставкиПо	= Объект.ВремяДоставкиПо;
	НовыйПоручениеЭкспедитору.КонтактноеЛицо	= Объект.КонтактноеЛицо;
	НовыйПоручениеЭкспедитору.Ответственный		= Объект.Автор;
	НовыйПоручениеЭкспедитору.СпособДоставки	= Объект.СпособДоставки;						// Перечисления.СпособыДоставки.ПоручениеЭкспедиторуСоСклада;
	СтрокаЗаказа								= "Заказ клиента №" + Объект.ДокументОснование.Номер + " от " +  Объект.ДокументОснование.Дата + "  " + СокрЛП(Объект.ДокументОснование.Партнер.НаименованиеПолное);
	НовыйПоручениеЭкспедитору.ДополнительнаяИнформацияПоДоставке = СокрЛП(Объект.ДополнительнаяИнформацияПоДоставке);
	НовыйПоручениеЭкспедитору.ОсобыеУсловияПеревозкиОписание	 = "Доставка документов. " + 
																	СтрокаЗаказа + 
//																	СокрЛП(ЭтотОбъект.ДокументОснование.ДополнительнаяИнформацияПоДоставке) + 
																	?(Объект.ОсобыеУсловияПеревозки, Символы.ПС + СокрЛП(Объект.ОсобыеУсловияПеревозкиОписание), "");
	
	Возврат НовыйПоручениеЭкспедитору;
	
КонецФункции // НовоеПоручение()

&НаСервере
Процедура ОбновитьИнформациюОДоверенности()
	Если ( Объект.Ссылка.Пустая() ) Тогда 
		ЭтаФорма.ТекстДоверенность = "Для создания доверенности запишите документ";
		Возврат;
	КонецЕсли;	
	
	Если НЕ ( Объект._ВидЗаявки = Перечисления._ВидыЗаявки.ОтПоставщика )	Тогда
		ЭтаФорма.ТекстДоверенность = "Доверенность создается если вид заявки - от поставщика ";
		Возврат;
	КонецЕсли;
	
	Запрос = Новый Запрос;
	Запрос.Текст = "ВЫБРАТЬ
	               |	ДоверенностьВыданная.Ссылка КАК Ссылка
	               |ИЗ
	               |	Документ.ДоверенностьВыданная КАК ДоверенностьВыданная
	               |ГДЕ
	               |	ДоверенностьВыданная._ЗаявкаНаДоставку = &_ЗаявкаНаДоставку"; 
	Запрос.УстановитьПараметр("_ЗаявкаНаДоставку", Объект.Ссылка );
	Результат = Запрос.Выполнить();
	Если НЕ ( Результат.Пустой() ) Тогда
		Выборка = Результат.Выбрать();
		Выборка.Следующий();
		ЭтаФорма.ТекстДоверенность = Строка( Выборка.Ссылка );
		ЭтаФорма.ДоверенностьВыданная = Выборка.Ссылка;  
	Иначе
		ЭтаФорма.ТекстДоверенность = "Ввести доверенность";
	КонецЕсли;
	
КонецПроцедуры

&НаСервере
Функция СоздатьДоверенностьНаСервере()
	НовДок = Документы.ДоверенностьВыданная.СоздатьДокумент();
	НовДок.ЗаполнитьПоЗаявкеНаДоставку( Объект.Ссылка ); 
	НовДок.Дата = ТекущаяДатаСеанса();
	НовДок._ЗаявкаНаДоставку = Объект.Ссылка;
	НовДок.Статус = Перечисления.СтатусыДоверенностей.НеВыдана;//Перечисления.СтатусыДоверенностей.Выдана; //РИВ  
	ОтветственныеЛицаСервер.ПриИзмененииСвязанныхРеквизитовДокумента(НовДок);    
	НовДок.Товары.Очистить();
	Для Каждого Стр ИЗ Объект.Ссылка.Товары Цикл
		НовСтр = НовДок.Товары.Добавить();
		ЗаполнитьЗначенияСвойств(НовСтр, Стр);
	КонецЦикла;
	
	
	НовДок.Записать(РежимЗаписиДокумента.Запись);
	Возврат НовДок.Ссылка;
КонецФункции	

