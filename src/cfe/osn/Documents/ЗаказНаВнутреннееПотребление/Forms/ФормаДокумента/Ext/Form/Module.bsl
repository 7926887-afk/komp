&НаСервере
Процедура Кт_ПриСозданииНаСервереПосле(Отказ, СтандартнаяОбработка)
	
	Если УправлениеДоступом.ЕстьРоль("ПолныеПрава") Тогда
		
		НовыйЭлемент = ЭтаФорма.Элементы.Добавить("Закрыт", Тип("ПолеФормы"),Элементы.Шапка);
		НовыйЭлемент.Вид = ВидПоляФормы.ПолеФлажка;
		НовыйЭлемент.ПутьКДанным = "Объект.Закрыт";
		
	КонецЕсли;

	
	НовыйЭлемент  = Элементы.Добавить("_ЗаявкаНаЗакупку",Тип("ПолеФормы"),Элементы.Товары);
	НовыйЭлемент.Вид = ВидПоляФормы.ПолеВвода;      
	НовыйЭлемент.ПутьКДанным = "Объект.Товары._ЗаявкаНаЗакупку";
	
КонецПроцедуры
