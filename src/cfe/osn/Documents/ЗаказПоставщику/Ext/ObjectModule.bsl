//++ Сухарев Б.В. 12.10.2018 Заполнение шапки на основании заявки на закупку
Процедура ЗаполнитьШапкуДокументаПоЗаявкеНаЗакупку(Знач ЗаявкаНаЗакупку, ПоДокументуОснование = Истина)
	Запрос = Новый Запрос("
	|ВЫБРАТЬ
	|	ЗаявкаНаЗакупку.Ссылка                 КАК Ссылка,
	|	ЗаявкаНаЗакупку.Статус                 КАК СтатусДокумента,
	|	ЗаявкаНаЗакупку.Приоритет              КАК Приоритет,
	|	ЗаявкаНаЗакупку.Проведен               КАК Проведен,
	|	ЗаявкаНаЗакупку.Организация            КАК Организация,
	|	ЗаявкаНаЗакупку.Сделка                 КАК Сделка,
	|	ЗаявкаНаЗакупку.Склад                  КАК СкладДокумента,
	|	ЗаявкаНаЗакупку.Склад.ЭтоГруппа        КАК ЭтоГруппа,
	|	ЗаявкаНаЗакупку.ДокументОснование      КАК ДокументОснование,
	|	ЗаявкаНаЗакупку.НалогообложениеНДС     КАК НалогообложениеНДС,
	|	ЗаявкаНаЗакупку.ЗакупкаПодДеятельность КАК ЗакупкаПодДеятельность,
	|	ЗаявкаНаЗакупку.Подразделение          КАК Подразделение,
	|	ЗаявкаНаЗакупку.ХозяйственнаяОперация  КАК ХозяйственнаяОперация
	|ИЗ
	|	Документ.ЗаявкаНаЗакупку КАК ЗаявкаНаЗакупку
	|ГДЕ
	|	ЗаявкаНаЗакупку.Ссылка = &ЗаявкаНаЗакупку
	|");
	Запрос.УстановитьПараметр("ЗаявкаНаЗакупку", ЗаявкаНаЗакупку);
	Реквизиты = Запрос.Выполнить().Выбрать();
	Реквизиты.Следующий();
	
	МассивДопустимыхСтатусов = Новый Массив;
	МассивДопустимыхСтатусов.Добавить(Перечисления.СтатусыЗаказовПоставщикам.Согласован);
	МассивДопустимыхСтатусов.Добавить(Перечисления.СтатусыЗаказовПоставщикам.Подтвержден);
//	МассивДопустимыхСтатусов.Добавить(Перечисления.СтатусыЗаказовПоставщикам.Закрыт);
	
	Если ПоДокументуОснование Тогда
		
		ОбщегоНазначенияУТ.ПроверитьВозможностьВводаНаОсновании(
			  ЗаявкаНаЗакупку
			, Реквизиты.СтатусДокумента
			, НЕ Реквизиты.Проведен
			, (МассивДопустимыхСтатусов.Найти(ЗаявкаНаЗакупку.Статус) = Неопределено)
			
			, МассивДопустимыхСтатусов);
			
		ДокументОснование   = Реквизиты.ДокументОснование;
		
	КонецЕсли;		// ПоДокументуОснование 		
	
	Организация             = Реквизиты.Организация;
	Сделка                  = Реквизиты.Сделка;
	Приоритет               = Реквизиты.Приоритет;
	НалогообложениеНДС      = Реквизиты.НалогообложениеНДС;
	ЗакупкаПодДеятельность  = Реквизиты.ЗакупкаПодДеятельность;
	Склад                   = Реквизиты.СкладДокумента;
	Подразделение           = Реквизиты.Подразделение;
	ХозяйственнаяОперация   = Реквизиты.ХозяйственнаяОперация;
	Дата					= ТекущаяДата();
	
КонецПроцедуры	// ЗаполнитьШапкуДокументаНаОснованииЗаявкиНаЗакупку(Знач ЗаявкаНаЗакупку)()

//++ Сухарев Б.В. 14.10.2018 Заполнение ТЧ Товары на основании заявки на закупку
Процедура ЗаполнитьТЧТоварыПоЗаявкеНаЗакупку(Знач ЗаявкаНаЗакупку)
	
	ЗапросЗаказыВНазначениях = Новый Запрос("ВЫБРАТЬ
	                                        |	ЗаявкаНаЗакупкуТовары.Назначение КАК Назначение,
	                                        |	ВЫРАЗИТЬ(ВЫБОР
	                                        |			КОГДА ЗаявкаНаЗакупкуТовары.Назначение = ЗНАЧЕНИЕ(Справочник.Назначения.ПустаяСсылка)
	                                        |				ТОГДА ЗаявкаНаЗакупкуТовары.Ссылка.ДокументОснование
	                                        |			КОГДА НЕ ЗаявкаНаЗакупкуТовары.Назначение.Заказ ССЫЛКА Документ.ЗаказКлиента
	                                        |				ТОГДА ЗаявкаНаЗакупкуТовары.Ссылка.ДокументОснование
	                                        |			ИНАЧЕ ЗаявкаНаЗакупкуТовары.Назначение.Заказ
	                                        |		КОНЕЦ КАК Документ.ЗаказКлиента) КАК ЗаказКлиента
	                                        |ИЗ
	                                        |	Документ.ЗаявкаНаЗакупку.Товары КАК ЗаявкаНаЗакупкуТовары
	                                        |ГДЕ
	                                        |	ЗаявкаНаЗакупкуТовары.Ссылка = &ЗаявкаНаЗакупку
	                                        |
	                                        |СГРУППИРОВАТЬ ПО
	                                        |	ЗаявкаНаЗакупкуТовары.Назначение,
	                                        |	ВЫРАЗИТЬ(ВЫБОР
	                                        |			КОГДА ЗаявкаНаЗакупкуТовары.Назначение = ЗНАЧЕНИЕ(Справочник.Назначения.ПустаяСсылка)
	                                        |				ТОГДА ЗаявкаНаЗакупкуТовары.Ссылка.ДокументОснование
	                                        |			КОГДА НЕ ЗаявкаНаЗакупкуТовары.Назначение.Заказ ССЫЛКА Документ.ЗаказКлиента
	                                        |				ТОГДА ЗаявкаНаЗакупкуТовары.Ссылка.ДокументОснование
	                                        |			ИНАЧЕ ЗаявкаНаЗакупкуТовары.Назначение.Заказ
	                                        |		КОНЕЦ КАК Документ.ЗаказКлиента)");
	ЗапросЗаказыВНазначениях.УстановитьПараметр("ЗаявкаНаЗакупку", ЗаявкаНаЗакупку);
	
	ТаблицаСЗаказами = ЗапросЗаказыВНазначениях.Выполнить().Выгрузить();
	
	// Таблица товаров в заявке на закупку
	ТаблицаТоваровПоЗаявке = ЗаявкаНаЗакупку.Товары.Выгрузить();
	ТаблицаТовары          = ТаблицаТоваровПоЗаявке.СкопироватьКолонки();
	ТаблицаТовары.Колонки.Добавить("ЗаказКлиента");
	ТаблицаТовары.Колонки.Добавить("_ЗаявкаНаЗакупку");
	
	Для Каждого СтрокаДанных Из ТаблицаСЗаказами Цикл
		
		// Остатки товаров по заказу
		ПараметрыТаблицыТовары  = Новый Структура("ПолучатьТовары, ПолучатьУслуги, ПолучатьРаботы, Отбор", Истина, Истина, Истина, Неопределено);
		ТаблицаТоваровПоЗаказуКлиента = ОбеспечениеСервер.ТаблицаОстатковКЗаказу(СтрокаДанных.ЗаказКлиента, ПараметрыТаблицыТовары);
		Для Каждого СтрокаТоваровПоЗаявке Из ТаблицаТоваровПоЗаявке.НайтиСтроки(Новый Структура("Назначение", СтрокаДанных.Назначение)) Цикл
			
			ОтборПоТаблице = Новый Структура("Номенклатура, Характеристика");
			ЗаполнитьЗначенияСвойств(ОтборПоТаблице, СтрокаТоваровПоЗаявке);
			
			СтрокиТоваровПоЗаказуКлиента = ТаблицаТоваровПоЗаказуКлиента.НайтиСтроки(ОтборПоТаблице);
			Если СтрокиТоваровПоЗаказуКлиента.Количество() = 0 Тогда
				Продолжить;
			КонецЕсли;
			
			СтрокаДанныхПоОстатку	= СтрокиТоваровПоЗаказуКлиента[0];
			КоличествоКЗаказу		= Мин(СтрокаТоваровПоЗаявке.Количество, СтрокаДанныхПоОстатку.Количество);
			Если КоличествоКЗаказу	= 0 Тогда // Если ноль, заказывать не нужно
				Продолжить;
			КонецЕсли;
			
			СтрокаТаблицыТоваров	= ТаблицаТовары.Добавить();
			ЗаполнитьЗначенияСвойств(СтрокаТаблицыТоваров, СтрокаТоваровПоЗаявке);
			
			СтрокаТаблицыТоваров.ЗаказКлиента	   = СтрокаДанных.ЗаказКлиента;
			
			// Нужно пересчитать суммы, затем перепишем количество
			КоэффициентПересчета 				   = Окр(КоличествоКЗаказу/СтрокаТоваровПоЗаявке.Количество, 5);
			СтрокаТаблицыТоваров.Сумма             = Окр(СтрокаТоваровПоЗаявке.Сумма * КоэффициентПересчета, 2);
			СтрокаТаблицыТоваров.СуммаРучнойСкидки = Окр(СтрокаТоваровПоЗаявке.СуммаРучнойСкидки * КоэффициентПересчета, 2);
			СтрокаТаблицыТоваров.СуммаНДС          = Окр(СтрокаТоваровПоЗаявке.СуммаНДС * КоэффициентПересчета, 2);
			СтрокаТаблицыТоваров.СуммаСНДС         = Окр(СтрокаТоваровПоЗаявке.СуммаСНДС * КоэффициентПересчета, 2);
			
			СтрокаТаблицыТоваров.Количество        = КоличествоКЗаказу; // меньшее из планового, либо остаток по заказу, либо желаемое из заявки
			
		КонецЦикла;
		
	КонецЦикла;
	
	//Заполнение табличной части.
	Если ТаблицаТовары.Количество() > 0 Тогда
		Для Каждого ТекСтрока Из ТаблицаТовары Цикл
			ТекСтрока.КодСтроки     = ТекСтрока.НомерСтроки;
			ТекСтрока._ЗаявкаНаЗакупку = ЗаявкаНаЗакупку;
		КонецЦикла;		// ТекСтрока Из ТаблицаТовары
		Товары.Загрузить(ТаблицаТовары);
	КонецЕсли;
	
КонецПроцедуры	// ЗаполнитьТЧТоварыПоЗаявкеНаЗакупку()

//++ Сухарев Б.В. 19.10.2018 Заполнение ТЧ Товары на основании СпмскаНоменклатуры
Процедура ЗаполнитьТЧТоварыПоСпискуНоменклатуры(Знач ДанныеЗаполнения)
	
	ТаблицаТовары = Товары.Выгрузить();	
	
	СписокНоменклатуры = ДанныеЗаполнения.СписокНоменклатуры;
	Для Каждого ТекСтрока Из СписокНоменклатуры Цикл
		НоваяСтрокаТоваров						= ТаблицаТовары.Добавить();
		НоваяСтрокаТоваров.Номенклатура			= ТекСтрока.Номенклатура;
		НоваяСтрокаТоваров.КоличествоУпаковок	= ТекСтрока.Количество;
		НоваяСтрокаТоваров.Упаковка				= ТекСтрока.Упаковка;
		НоваяСтрокаТоваров.Количество			= ТекСтрока.Количество;
		НоваяСтрокаТоваров.Назначение			= ТекСтрока.Назначение;
		НоваяСтрокаТоваров.Склад				= ТекСтрока.Заявка.Склад;
		НоваяСтрокаТоваров.ЗаказКлиента			= ТекСтрока.Заявка.ДокументОснование;
		НоваяСтрокаТоваров._ЗаявкаНаЗакупку		= ТекСтрока.Заявка;
		НоваяСтрокаТоваров.СтавкаНДС			= ТекСтрока.Номенклатура.СтавкаНДС;
		НоваяСтрокаТоваров._УИДЗакупка			= ТекСтрока._УИДЗакупка;
		Если ТекСтрока.Свойство("Характеристика") Тогда
			НоваяСтрокаТоваров.Характеристика		= ТекСтрока.Характеристика;
		КонецЕсли;
		
	КонецЦикла;		// ТекСтрока 
	
	//Заполнение табличной части.
	Если ТаблицаТовары.Количество() > 0 Тогда
		Товары.Загрузить(ТаблицаТовары);
	КонецЕсли;
КонецПроцедуры	// ЗаполнитьТЧТоварыПоСпискуНоменклатуры()
 

Процедура ЗаполнитьДокументНаОснованииЗаявкиНаЗакупку(Знач ЗаявкаНаЗакупку)
	
	//++ Сухарев Б.В. 23.01.2019
	_ДокЗаявкаНаЗакупку		= ЗаявкаНаЗакупку;
	//== Сухарев Б.В
	
	//Заполнение шапки
	ЗаполнитьШапкуДокументаПоЗаявкеНаЗакупку(ЗаявкаНаЗакупку);
	
	//Заполнение ТЧ Товары
	ЗаполнитьТЧТоварыПоЗаявкеНаЗакупку(ЗаявкаНаЗакупку);
	
	
КонецПроцедуры

//++ Сухарев Б.В. 12.10.2018 заполнение на основании заявок на закупку
Процедура ЗаполнитьДокументНаОснованииЗаявокНаЗакупку(Знач ДанныеЗаполнения)
	
	Если ( НЕ ДанныеЗаполнения.Свойство("СписокНоменклатуры") ) ИЛИ ( ДанныеЗаполнения.СписокНоменклатуры.Количество() = 0 ) Тогда
		Возврат;
	КонецЕсли;
	
	СписокНоменклатуры = ДанныеЗаполнения.СписокНоменклатуры;
	ЗаявкаНаЗакупку    = ДанныеЗаполнения.СписокНоменклатуры[0].Заявка;
	ЭтотОбъект._ЗаявкаНаЗакупку = Истина;
	
	//Заполнение шапки
	ЗаполнитьШапкуДокументаПоЗаявкеНаЗакупку( ЗаявкаНаЗакупку, Ложь);
	
	//Заполнение ТЧ Товары
	ЗаполнитьТЧТоварыПоСпискуНоменклатуры(ДанныеЗаполнения);
	//ЗаполнитьТЧТоварыПоЗаявкеНаЗакупку(ЗаявкаНаЗакупку);
	
КонецПроцедуры	// ЗаполнитьДокументНаОснованииЗаявокНаЗакупку(ДанныеЗаполнения)()
