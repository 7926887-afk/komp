&НаСервере
Функция ЕстьЗаявкиНазакупку()
	
	ЕстьЗаявка = Ложь;
	
	Запрос = Новый Запрос;
	Запрос.Текст = "ВЫБРАТЬ
					|	ЗаказПоставщикуТовары.Ссылка КАК Ссылка,
					|	ЗаказПоставщикуТовары.ЗаказКлиента КАК ЗаказКлиента,
					|	ЗаказПоставщикуТовары._ЗаявкаНаЗакупку КАК _ЗаявкаНаЗакупку
					|ИЗ
					|	Документ.ЗаказПоставщику.Товары КАК ЗаказПоставщикуТовары
					|ГДЕ
					|	НЕ ЗаказПоставщикуТовары._ЗаявкаНаЗакупку = &_ЗаявкаНаЗакупку
					|	И ЗаказПоставщикуТовары.Ссылка = &Ссылка";	
					
	Запрос.УстановитьПараметр("_ЗаявкаНаЗакупку", Документы.ЗаявкаНаЗакупку.ПустаяСсылка());
	Запрос.УстановитьПараметр("Ссылка", ЭтотОбъект.Ссылка);
	
	Результат = Запрос.Выполнить();
	Выборка = Результат.Выбрать();
	Пока Выборка.Следующий() Цикл
		 ЕстьЗаявка = Истина;
		 Прервать;
	КонецЦикла;
	
	Возврат ЕстьЗаявка;
	
КонецФункции // ЕстьЗаявкиНазакупку()

&НаСервере
Процедура ЗаполнитьОснование()
	
	Если НЕ ЭтотОбъект.ДокументОснование = Документы.ЗаказКлиента.ПустаяСсылка() Тогда
		Возврат;
	КонецЕсли;
	
	ДокОснование = Документы.ЗаказКлиента.ПустаяСсылка();
	КозЗаказов    = 0;
	
	Для Каждого ТекСтрока Из ЭтотОбъект.Товары Цикл
		Если ( НЕ ДокОснование = ТекСтрока.ЗаказКлиента ) И ( НЕ ТекСтрока.ЗаказКлиента = Документы.ЗаказКлиента.ПустаяСсылка() ) Тогда
			ДокОснование = ТекСтрока.ЗаказКлиента;
			КозЗаказов = КозЗаказов + 1;
		КонецЕсли;
	КонецЦикла;		// ТекСтрока Из ЭтотОбъект.Товары
	
	Если КозЗаказов = 1 Тогда
		 ЭтотОбъект.ДокументОснование = ДокОснование;
	 КонецЕсли;
	 
КонецПроцедуры // ЗаполнитьОснование()

&НаСервере
Функция ПолучитьЗаявкиНаЗакупку() Экспорт
	Результат = Новый Массив;
	
	Запрос = Новый Запрос;
	Запрос.Текст = "ВЫБРАТЬ
	               |	ЕСТЬNULL(ЗаказПоставщику._ДокЗаявкаНаЗакупку, ЗНАЧЕНИЕ(Документ.ЗаявкаНаЗакупку.ПустаяСсылка)) КАК ЗаявкаНаЗакупку
	               |ПОМЕСТИТЬ ВТ_Заявки
	               |ИЗ
	               |	Документ.ЗаказПоставщику КАК ЗаказПоставщику
	               |ГДЕ
	               |	ЗаказПоставщику.Ссылка = &Ссылка
	               |
	               |ОБЪЕДИНИТЬ ВСЕ
	               |
	               |ВЫБРАТЬ
	               |	ЕСТЬNULL(ЗаказПоставщикуТовары._ЗаявкаНаЗакупку, ЗНАЧЕНИЕ(Документ.ЗаявкаНаЗакупку.ПустаяСсылка))
	               |ИЗ
	               |	Документ.ЗаказПоставщику.Товары КАК ЗаказПоставщикуТовары
	               |ГДЕ
	               |	ЗаказПоставщикуТовары.Ссылка = &Ссылка
	               |;
	               |
	               |////////////////////////////////////////////////////////////////////////////////
	               |ВЫБРАТЬ РАЗЛИЧНЫЕ
	               |	ВТ_Заявки.ЗаявкаНаЗакупку КАК ЗаявкаНаЗакупку,
				   |    ЛОЖЬ КАК БитаяСсылка
	               |ИЗ
	               |	ВТ_Заявки КАК ВТ_Заявки
	               |ГДЕ
	               |	ВТ_Заявки.ЗаявкаНаЗакупку <> ЗНАЧЕНИЕ(Документ.ЗаявкаНаЗакупку.ПустаяСсылка)";
	
	//Запрос.УстановитьПараметр("_ЗаявкаНаЗакупку", Документы.ЗаявкаНаЗакупку.ПустаяСсылка());
	Запрос.УстановитьПараметр("Ссылка", ЭтотОбъект.Ссылка);
	
	Т = Запрос.Выполнить().Выгрузить();
	ЕстьБитые = Ложь;
	Для Каждого СтрокаТаб Из Т Цикл
		ЭтоБитая = Ложь;
		Попытка
			//***************************************************************
			//ИЗМЕНЕНО Стефутин В.П. 02.07.2023
			//Номер = СтрокаТаб.ЗаявкаНаЗакупку.Номер;
			//***************************************************************
		Исключение
			ЭтоБитая = Истина;
			ЕстьБитые = Истина;
		КонецПопытки;
		
		Если НЕ ЭтоБитая Тогда
			Результат.Добавить(СтрокаТаб.ЗаявкаНаЗакупку);
		КонецЕсли;	
		
	КонецЦикла;	
	
	Если ( ЕстьБитые ) Тогда
		ОбщегоНазначенияКлиентСервер.СообщитьПользователю("Внимание!! Документ имеет ссылки на удаленные заявки на закупку");
	КонецЕсли;	
	
	Возврат Результат;
		
КонецФункции // ПолучитьЗаявкиНаЗакупку()

&Перед("ЗаполнитьДокументПоОтбору")
Процедура Расш1_ЗаполнитьДокументПоОтбору(Знач ДанныеЗаполнения)
	
	//++ Сухарев Б.В. 19.10.2018
	Если ДанныеЗаполнения.Свойство("ДокументОснование") И ДанныеЗаполнения.Свойство("РабочийСтолЗакупок") Тогда
		ЗаполнитьДокументНаОснованииЗаявокНаЗакупку(ДанныеЗаполнения);
		Возврат;
	КонецЕсли;
	//-- Сухарев Б.В
	
КонецПроцедуры
 
