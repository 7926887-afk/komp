&НаСервере
Процедура ОбработатьЗаявкуНаЗакупкуСервер(Отметка = Истина)
	
	СписокЗаявокНаЗакупку = ПолучитьЗаявкиНаЗакупку();
	Для Каждого ТекЗаявка Из СписокЗаявокНаЗакупку Цикл
		ОбработатьТоварыЗакуки(ТекЗаявка, Отметка);
	КонецЦикла;		// ТекЗаявка Из Список 
	
	Если НЕ _ДокЗаявкаНаЗакупку = Документы.ЗаявкаНаЗакупку.ПустаяСсылка() Тогда
		ОбработатьТоварыЗакуки(_ДокЗаявкаНаЗакупку, Отметка);
	КонецЕсли;	
	
КонецПроцедуры	// ОбработатьЗаявкуНаЗакупкуСервер()

&НаСервере
Процедура ОбработатьТоварыЗакуки(ДокЗаявкаНаЗакупку, Отметка)
	ЗаявкаОбъект = ДокЗаявкаНаЗакупку.ПолучитьОбъект();
	Для Каждого ТекСтрока Из ЗаявкаОбъект.Товары Цикл
		Если НЕ Отметка Тогда
			Если ТекСтрока.ЗаказПоставщику = Ссылка Тогда
				ТекСтрока.ЗаказПоставщику = Документы.ЗаказПоставщику.ПустаяСсылка();
			ТекСтрока.Заказано = Отметка;
			КонецЕсли;
		Иначе
			ТекСтрока.Заказано = Отметка;
		КонецЕсли; 	
	КонецЦикла;		// ТекСтрока Из ДокЗаявка.Товары 
	_ДоработкиСлужебный.ЗаписатьДокументКлиента(ЗаявкаОбъект);
КонецПроцедуры	// ОбработатьТоварыЗакпки()

&После("ЗаполнитьДокументНаОснованииЗаказаКлиента")
Процедура КТ_ЗаполнитьДокументНаОснованииЗаказаКлиента(Знач ДанныеЗаполнения)
	
	ЗаказКлиента = ДанныеЗаполнения.Основание;
	//КАВ начало
	Для Каждого Стр Из Товары Цикл
		Стр.ЗаказКлиента = ЗаказКлиента;
	КонецЦикла;
	//КАВ конец
	
КонецПроцедуры

