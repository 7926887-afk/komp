&НаСервере
Функция ЗаявкиНаЗакупку()
	
	ДокументОбъект = РеквизитФормыВЗначение("Объект");
	Возврат  ДокументОбъект.ПолучитьЗаявкиНаЗакупку();
	
КонецФункции // ЗаявкиНаЗакупку()
 
&НаКлиенте
Процедура ПолучитьДоступКПолям()
	
	Если _ДоработкиСлужебный.ПолучитьДоступКполямДокумента() Тогда 
		//РИВ 01.07.24
		ЭтаФорма.Элементы.Товары_Отгрузка.ТолькоПросмотр		= Ложь;
		//==
		ЭтаФорма.Элементы.ТоварыЗаказКлиента.ТолькоПросмотр		= Ложь;
		ЭтаФорма.Элементы.Товары_ЗаявкаНаЗакупку.ТолькоПросмотр	= Ложь;
		ЭтаФорма.Элементы.Товары_УИДЗакупка.ТолькоПросмотр		= Ложь;
	Иначе
		//РИВ 01.07.24
		ЭтаФорма.Элементы.Товары_Отгрузка.ТолькоПросмотр		= Истина;
		//==
		ЭтаФорма.Элементы.ТоварыЗаказКлиента.ТолькоПросмотр		= Истина;
		ЭтаФорма.Элементы.Товары_ЗаявкаНаЗакупку.ТолькоПросмотр	= Истина;
		ЭтаФорма.Элементы.Товары_УИДЗакупка.ТолькоПросмотр		= Истина;
	КонецЕсли;
	
КонецПроцедуры	// ПолучитьДоступКПолям()

