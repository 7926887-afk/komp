
#Область ОбработчикиСобытийФормы

&НаСервере
Процедура Кт_ПриСозданииНаСервереПосле(Отказ, СтандартнаяОбработка)
	
	//**ИЗМЕНЕНО Максимов
	Если НЕ РольДоступна("АдминистраторСистемы") Тогда
		Элементы.Статус.Видимость 						= Ложь;
		Элементы.Приоритет.Видимость 					= Ложь;
		Элементы.Договор.Видимость						= Ложь;
		Элементы.ХозяйственнаяОперация.Видимость 		= Ложь;
		Элементы.ГруппаСостояниеЭДО.Видимость 			= Ложь;
		Элементы.ЗакрытьЗаказ.Видимость					= Ложь;
		Элементы.Состояние.Видимость					= Ложь;
		Элементы.ПодменюОтчетыВажное.Видимость			= Ложь;
		Элементы.ПодменюОтчетыОбычное.Видимость			= Ложь;
		Элементы.ТоварыПоискПоШтрихкоду.Видимость		= Ложь;
		Элементы.ПодменюЭДО.Видимость 					= Ложь;
		Элементы.ЗачетОплатыФорма.Видимость				= Ложь;
		Элементы.ТоварыЗагрузитьДанныеИзТСД.Видимость 	= Ложь;
		
		КоманднаяПанель.ПодчиненныеЭлементы.ФормаСправка.Видимость				= Ложь;
		//КоманднаяПанель.ПодчиненныеЭлементы.ЗачетОплаты.Видимость 				= Ложь;
		КоманднаяПанель.ПодчиненныеЭлементы.ФормаГруппаКомандыФормы.Видимость	= Ложь;
		КоманднаяПанель.ПодчиненныеЭлементы.ПодменюСоздатьНаОсновании.Видимость = Ложь;
		
		Элементы.Товары.КоманднаяПанель.ПодчиненныеЭлементы.ГруппаЦеныСкидки.Видимость 			= Ложь;
		Элементы.Товары.КоманднаяПанель.ПодчиненныеЭлементы.ГруппаТоварыЗаполнить.Видимость 	= Ложь;
		Элементы.Товары.КоманднаяПанель.ПодчиненныеЭлементы.ТоварыРазбитьСтроку.Видимость 		= Ложь;
		Элементы.Товары.КоманднаяПанель.ПодчиненныеЭлементы.ГруппаДобавитьСтроки.Видимость 		= Истина;
		Элементы.Товары.КоманднаяПанель.ПодчиненныеЭлементы.ГруппаДобавитьСтроки.Доступность 	= Истина;
		Элементы.ГруппаСтраницы.ПодчиненныеЭлементы.СтраницаДоставка.Видимость 					= Ложь;
		
		//Элементы.ПодменюПечать.ПодчиненныеЭлементы.ПодменюПечатьОбычное.ПодчиненныеЭлементы.ПодменюПечатьОбычное_1.Видимость = Ложь;
		
	КонецЕсли;
	
	Запрос = Новый Запрос;
	Запрос.Текст = 
	"ВЫБРАТЬ
	|	ГруппыДоступа.Ссылка КАК Ссылка
	|ИЗ
	|	Справочник.ГруппыДоступа КАК ГруппыДоступа
	|ГДЕ
	|	ГруппыДоступа.Пользователи.Пользователь = &Пользователь";
	Запрос.УстановитьПараметр("Пользователь", Пользователи.ТекущийПользователь());
	ГруппыДоступа = Запрос.Выполнить().Выгрузить();
	
	Для Каждого Группа Из ГруппыДоступа Цикл
		Если Группа.Ссылка.Наименование = "Менеджер по закупкам" Тогда
			КоманднаяПанель.ПодчиненныеЭлементы.ПодменюСоздатьНаОсновании.Видимость = Истина;
		КонецЕсли;
	КонецЦикла;
	//*****************
	
	_РаботаСИнтерфейсомСервер.НастроитьФормуЗаказаПоставщикуДляМенеджераПоЗакупкам( ЭтаФорма );
	
КонецПроцедуры

