Процедура Кт_ПриОткрытииПосле(Отказ)
	
	//++ Сухарев Б.В. 08.02.2019
	ПолучитьДоступКПолям();
	//== Сухарев Б.В
	
КонецПроцедуры

#КонецОбласти

&НаКлиенте
&ИзменениеИКонтроль("ПередЗаписью")
Процедура Кт_ПередЗаписью(Отказ, ПараметрыЗаписи)

	Если НеВыполнятьПроверкуПередЗаписью Тогда
		НеВыполнятьПроверкуПередЗаписью = Ложь;
		Возврат;
	КонецЕсли;

	// Если документ проводится, предложим дозаполнить данные, если они некорректны
	Если ПараметрыЗаписи.РежимЗаписи = РежимЗаписиДокумента.Проведение Тогда

		Отказ = Истина;
		ДополнительныеПараметры = Новый Структура;
		ДополнительныеПараметры.Вставить("ПараметрыЗаписи", ПараметрыЗаписи);
		МногооборотнаяТараКлиент.ПредложитьПодобратьМногооборотнуюТару(
		ЭтаФорма,
		"Товары",
		"Номенклатура,Характеристика,Количество,Склад,ДатаПоступления",
		Новый ОписаниеОповещения("ПередЗаписьюПредложитьПодобратьМногооборотнуюТаруЗавершение", ЭтотОбъект, ДополнительныеПараметры));
#Вставка
		//++ Сухарев Б.В. 31.01.2019
		СписокЗаявокНаЗакупку = ЗаявкиНаЗакупку();
		Если СписокЗаявокНаЗакупку.Количество() > 0 Тогда
			Для Каждого ТекЗаявка Из СписокЗаявокНаЗакупку Цикл
				Парам  = Новый Структура("Ключ", ТекЗаявка);
				мФорма = ПолучитьФорму("Документ.ЗаявкаНаЗакупку.ФормаОбъекта", Парам);
				Если мФорма.Открыта() Тогда
					Попытка
						мФорма.Закрыть(0);
					Исключение
						ОбщегоНазначенияКлиентСервер.СообщитьПользователю(НСтр("ru='Заявка на закупку '") + ТекЗаявка + НСтр("ru=' открыта другим пользователем или фоновым заданием'"));
					КонецПопытки;
				КонецЕсли;
			КонецЦикла;
		КонецЕсли;
		//== Сухарев Б.В.
#КонецВставки
		Возврат;

	КонецЕсли;

	ОбщегоНазначенияУТКлиент.ЗаписатьОбъектПриНеобходимости(ЭтотОбъект, ПараметрыЗаписи, Отказ);

КонецПроцедуры


&НаСервере
Процедура ДополнительныеОтчетыИОбработкиВыполнитьНазначаемуюКомандуНаСервере(ИмяЭлемента, РезультатВыполнения)
	
	ДополнительныеОтчетыИОбработки.ВыполнитьНазначаемуюКомандуНаСервере(ЭтаФорма, ИмяЭлемента, РезультатВыполнения);
	
КонецПроцедуры

