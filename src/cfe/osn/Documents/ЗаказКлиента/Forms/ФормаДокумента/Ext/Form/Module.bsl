&НаСервере
Процедура ОбработатьКодСтроки()
	
	ТаблицаТоваровДокумента = Объект.Товары.Выгрузить();
	ТаблицаТоваровДокумента.Свернуть("КодСтроки");
	ТаблицаТоваровДокумента.Сортировать("КодСтроки Убыв"); 
	мКодСтроки = ТаблицаТоваровДокумента[0].КодСтроки;
	
	Для Каждого ТекСтрока Из Объект.Товары Цикл
		СтруктураПоиска = Новый Структура("КодСтроки", ТекСтрока.КодСтроки);
		МассивСтрок    = Объект.Товары.НайтиСтроки(СтруктураПоиска);
		Если МассивСтрок.Количество() > 1 Тогда
			Для Ном = 1 По МассивСтрок.Количество() - 1 Цикл
				мКодСтроки = мКодСтроки + 1;
				Объект.Товары[МассивСтрок[1].НомерСтроки-1].КодСтроки = мКодСтроки;
			КонецЦикла;// Ном 
		КонецЕсли;
	КонецЦикла;// ТекСтрока Из Товары 
	
КонецПроцедуры// ОбработатьКодСтроки()

