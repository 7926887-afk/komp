&НаКлиенте
&После("ОбработкаОповещенияФрагмент")
Процедура Расш1_ОбработкаОповещенияФрагмент(Знач ИмяСобытия, Знач Параметр)

	//***********************************************************************
	//ИЗМЕНЕНО Сухарев Б.В. 09.08.2018
	Если (ИмяСобытия = "Запись_ЗаказаНаОтгрузку") Тогда
		ВыбранныеЗаказы = НЕОПРЕДЕЛЕНО;
		НомерЗаказа		= НЕОПРЕДЕЛЕНО;
		Если Параметр.Свойство("ВыбранныеЗаказы", ВыбранныеЗаказы) Тогда
			Если НЕ ВыбранныеЗаказы = НЕОПРЕДЕЛЕНО Тогда
				Если ВыбранныеЗаказы.Свойство(Объект.Номер) Тогда
					ЭтаФорма.Прочитать();
					ЭтаФорма.ОбновитьОтображениеДанных(ЭтаФорма.Элементы.Товары);
					ЭтаФорма.Элементы.Товары.Обновить();
				КонецЕсли;
			КонецЕсли;
		КонецЕсли;
	КонецЕсли;
	//***********************************************************************
	
КонецПроцедуры

