Функция ПолучитьЗаявкуНаДоставку(Заказ)
	
	Запрос = Новый Запрос;
	Запрос.Текст = "ВЫБРАТЬ
	|	_ЗаявкаНаДоставкуТовары.Ссылка КАК Заявка,
	|	Довер.Ссылка КАК Довер
	|ИЗ
	|	Документ._ЗаявкаНаДоставку.Товары КАК _ЗаявкаНаДоставкуТовары
	|		ЛЕВОЕ СОЕДИНЕНИЕ (ВЫБРАТЬ
	|			ДоверенностьВыданная.Ссылка КАК Ссылка,
	|			ДоверенностьВыданная._ЗаявкаНаДоставку КАК _ЗаявкаНаДоставку
	|		ИЗ
	|			Документ.ДоверенностьВыданная КАК ДоверенностьВыданная
	|		ГДЕ
	|			ДоверенностьВыданная.Проведен) КАК Довер
	|		ПО _ЗаявкаНаДоставкуТовары.Ссылка = Довер._ЗаявкаНаДоставку
	|ГДЕ
	|	_ЗаявкаНаДоставкуТовары.Ссылка.Проведен
	|	И _ЗаявкаНаДоставкуТовары.Ссылка.ДокументОснование = &Заказ";
	
	Запрос.УстановитьПараметр("Заказ", Заказ);
	
	Результат = Запрос.Выполнить();
	Если  НЕ Результат.Пустой() Тогда
		Выборка	  = Результат.Выгрузить()[0];
		Если НЕ ЗначениеЗаполнено(Выборка.Довер) Тогда
			Возврат Выборка.Заявка;
		Иначе
			Возврат Документы._ЗаявкаНаДоставку.ПустаяСсылка();
		КонецЕсли;
	Иначе
		Возврат Ложь;
	КонецЕсли;
	
КонецФункции 

Функция ПолучитьДоверенность(Заказ)
	
	Запрос = Новый Запрос;
	Запрос.Текст = "ВЫБРАТЬ
	|	_ЗаявкаНаДоставкуТовары.Ссылка КАК Заявка,
	|	Довер.Ссылка КАК Довер
	|ИЗ
	|	Документ._ЗаявкаНаДоставку.Товары КАК _ЗаявкаНаДоставкуТовары
	|		ЛЕВОЕ СОЕДИНЕНИЕ (ВЫБРАТЬ
	|			ДоверенностьВыданная.Ссылка КАК Ссылка,
	|			ДоверенностьВыданная._ЗаявкаНаДоставку КАК _ЗаявкаНаДоставку
	|		ИЗ
	|			Документ.ДоверенностьВыданная КАК ДоверенностьВыданная
	|		ГДЕ
	|			ДоверенностьВыданная.Проведен) КАК Довер
	|		ПО _ЗаявкаНаДоставкуТовары.Ссылка = Довер._ЗаявкаНаДоставку
	|ГДЕ
	|	_ЗаявкаНаДоставкуТовары.Ссылка.Проведен
	|	И _ЗаявкаНаДоставкуТовары.Ссылка.ДокументОснование = &Заказ";
	
	Запрос.УстановитьПараметр("Заказ", Заказ);
	
	Результат = Запрос.Выполнить();
	Если  НЕ Результат.Пустой() Тогда
		Выборка	  = Результат.Выгрузить()[0];
		Если ЗначениеЗаполнено(Выборка.Довер) Тогда
			Возврат Выборка.Довер;
		Иначе
			Возврат Документы.ДоверенностьВыданная.ПустаяСсылка();
		КонецЕсли;
	Иначе
		Возврат Ложь;
	КонецЕсли;
	
КонецФункции



