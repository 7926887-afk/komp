&НаКлиенте
Процедура Компит_ВыборДокументов(МассивДокументов) 
	
	СписокДокументов = Новый СписокЗначений;
//	СписокДокументов.ЗагрузитьЗначения(МассивДокументов);
	
	ПараметрыОткрытия = Новый Структура();
	
	ПараметрыОткрытия.Вставить("ЗначенияДляВыбора", МассивДокументов);
	Если МассивДокументов.Количество() > 1 Тогда
		ПараметрыОткрытия.Вставить("НесколькоДокументов", Истина);
	ИначеЕсли МассивДокументов.Количество() = 0 Тогда
        ТекстСообщения = НСтр("ru='Для задания на перевозку по ордерам не созданы реализация и счет-фактура'");
        ОбщегоНазначенияКлиентСервер.СообщитьПользователю(ТекстСообщения);
		Возврат;
	Иначе
		ПараметрыОткрытия.Вставить("НесколькоДокументов", Ложь);
	КонецЕсли;  
	ПараметрыОткрытия.Вставить("Заголовок", НСтр("ru = 'Выбор документа'"));
	
	Компит_ОткрытьВыборДокументовНаКлиенте(ПараметрыОткрытия);
	
КонецПроцедуры // ВыборДокументов()

&НаКлиенте
Процедура Компит_ОткрытьВыборДокументовНаКлиенте(ПараметрыОткрытия)
	
	Если ПараметрыОткрытия.НесколькоДокументов Тогда
		ОписаниеОповещенияОВыбореДокумента = Новый ОписаниеОповещения(
				"СоздатьДокументыПечатиУПД",
				_ОбработкаДоставкиТоваровКлиент);
		
		ОткрытьФорму("ОбщаяФорма._ВыборЗначенияИзСпискаОтгрузки",
					 ПараметрыОткрытия,
					 ,
					 Новый УникальныйИдентификатор(),
					 ,
					 ,
					 ОписаниеОповещенияОВыбореДокумента,
					 РежимОткрытияОкнаФормы.БлокироватьОкноВладельца);
	Иначе
		ЗначенияДляВыбора = Новый Массив;
		Для Каждого ТекЗначение Из ПараметрыОткрытия.ЗначенияДляВыбора Цикл
			ЗначенияДляВыбора.Добавить(ТекЗначение.Документ);
		КонецЦикла;		// ТекЗначение
		_ОбработкаДоставкиТоваровКлиент.СоздатьДокументыПечатиУПД(ЗначенияДляВыбора, ПараметрыОткрытия);
	КонецЕсли; 
	
				
КонецПроцедуры // ОткрыытьВыборДокументов()

