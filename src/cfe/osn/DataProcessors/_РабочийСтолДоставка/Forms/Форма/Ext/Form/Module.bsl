Процедура ПослеЗакрытияЗаявки(Параметры, Параметр2) Экспорт
	//Сообщить("1");
	//Параметр2.Доверенность = ПолучитьДоверенность(Параметр2.Распоряжение);
    ОбновитьСпискиДляТекущейСтраницы();
