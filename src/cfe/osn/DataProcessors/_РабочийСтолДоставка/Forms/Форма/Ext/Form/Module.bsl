&НаСервере
Функция ВыборДокументовДляПечатиУПД(Объект)
	
	ТаблицаДокументов = Новый ТаблицаЗначений;
	ТаблицаДокументов.Колонки.Добавить("Документ");
	
	ТаблицаВыборки		= ТаблицаДокументов;
	ТаблицаВыборки.Очистить();
	ВыбранныеДокументы	= _ОбработкаДоставкиТоваровСервер.ВывестиСтруктуруПодчиненности(Объект, ТаблицаВыборки);
	
	Возврат _ДоработкиСлужебный.ПреобразоватьТаблицуЗначенийВМассив(ТаблицаДокументов);
	
КонецФункции	// ВыборДокументовДляПечатиУПД()

&НаСервере
Функция Компит_ПечатьУПДНаСервере(ДокСсылка, Заказ = Ложь)
	Если ( ДокСсылка.Проведен ) И
		( (ДокСсылка.Ссылка.Статус = Перечисления.СтатусыЗаданийНаПеревозку.КПогрузке ) ИЛИ
		(ДокСсылка.Ссылка.Статус = Перечисления.СтатусыЗаданийНаПеревозку.Отправлено) 	ИЛИ 
		(ДокСсылка.Ссылка.Статус = Перечисления.СтатусыЗаданийНаПеревозку.Закрыто)	) 	Тогда
		
		ТаблицаДокументов		= ДокСсылка.Распоряжения.Выгрузить();
		ТаблицаДокументов.Свернуть("Распоряжение");
		ТаблицаРаспоряжений		= ТаблицаДокументов.Скопировать();
		ИзменяемаяКолонка		= ТаблицаРаспоряжений.Колонки.Найти("Распоряжение");
		ИзменяемаяКолонка.Имя	= "Документ";
		
		Если НЕ Заказ Тогда
			
			МассивДокументов		= Новый Массив;
			МассивРаспоряжение		= _ДоработкиСлужебный.ПреобразоватьТаблицуЗначенийВМассив(ТаблицаРаспоряжений);
			
			Для Каждого ТекСтрока Из ТаблицаДокументов Цикл
				
				ТекМассивДокументов	= ВыборДокументовДляПечатиУПД(ТекСтрока.Распоряжение);
				ТаблицаРеализаций	= _ДоработкиСлужебный.ПреобразоватьМассивВТаблицуЗначений(МассивДокументов);
				
				Если ТаблицаРеализаций.Количество() = 0 Тогда
					ТаблицаРеализаций.Колонки.Добавить("Документ");
				КонецЕсли;
				
				Если ТипЗнч(ТекСтрока.Распоряжение) = Тип("ДокументСсылка.ЗаказКлиента") И ТаблицаРеализаций.Найти(ТекСтрока.Распоряжение, "Документ") = Неопределено   Тогда
					Для Каждого мРаспоряжение Из МассивРаспоряжение Цикл
						Если мРаспоряжение.Документ = ТекСтрока.Распоряжение Тогда
							Прервать
						КонецЕсли;
					КонецЦикла;		// мРаспоряжение Из 
					МассивДокументов.Добавить(мРаспоряжение);
				КонецЕсли;
				
				Для Каждого ТекДокумент Из ТекМассивДокументов Цикл
					МассивДокументов.Добавить(ТекДокумент);
				КонецЦикла;		// ТекЭлемент Из ТекМассивДокументов
			КонецЦикла;		// ТекСтрока Из ТаблицаДокументов
			
		Иначе
			
			МассивДокументов		= _ДоработкиСлужебный.ПреобразоватьТаблицуЗначенийВМассив(ТаблицаРаспоряжений);
			
		КонецЕсли;   
		
		Возврат МассивДокументов;
		
	КонецЕсли; 
КонецФункции

