#Область ОбработчикиСобытийЭлементовТаблицыФормыРаспоряженияНаДоставку

&НаКлиенте
Процедура РаспоряженияНаДоставкуВыбор(Элемент, ВыбраннаяСтрока, Поле, СтандартнаяОбработка)
	
	СтандартнаяОбработка = Ложь;
	
	ВыбраннаяСтрокаЭлементДерева = РаспоряженияНаДоставку.НайтиПоИдентификатору(ВыбраннаяСтрока);
	
	//**ИЗМЕНЕНО Максимов В.А.
	
	Если Поле.Имя = "РаспоряженияНаДоставкуНомер" Тогда
		Если ЗначениеЗаполнено(ВыбраннаяСтрокаЭлементДерева.Распоряжение) Тогда
			ПоказатьЗначение(Неопределено, ВыбраннаяСтрокаЭлементДерева.Распоряжение);
		КонецЕсли; 
	//РИВ
	ИначеЕсли Поле.Имя = "РаспоряженияНаДоставкуДоверенность" Тогда
		Если ЗначениеЗаполнено(ВыбраннаяСтрокаЭлементДерева.Доверенность) Тогда 
			П = Новый Структура("Ключ", ВыбраннаяСтрокаЭлементДерева.Доверенность);
			ОповещениеОЗакрытии = Новый ОписаниеОповещения("ПослеЗакрытияЗаявки",ЭтотОбъект,ВыбраннаяСтрокаЭлементДерева);  
			
			ОткрытьФорму("Документ.ДоверенностьВыданная.ФормаОбъекта", П, ЭтотОбъект,,,, ОповещениеОЗакрытии,РежимОткрытияОкнаФормы.БлокироватьОкноВладельца);

			//ПоказатьЗначение(Неопределено, ВыбраннаяСтрокаЭлементДерева.Доверенность);  
		Иначе 
			ЗаявкаДост = ПолучитьЗаявкуНаДоставку(ВыбраннаяСтрокаЭлементДерева.Распоряжение);
			П = Новый Структура("Ключ", ЗаявкаДост);
			ОповещениеОЗакрытии = Новый ОписаниеОповещения("ПослеЗакрытияЗаявки",ЭтотОбъект,ВыбраннаяСтрокаЭлементДерева);  
			
			ОткрытьФорму("Документ._ЗаявкаНаДоставку.ФормаОбъекта", П, ЭтотОбъект,,,, ОповещениеОЗакрытии,РежимОткрытияОкнаФормы.БлокироватьОкноВладельца);
			//ПоказатьЗначение(Оповещение, ЗаявкаДост);	
			
		КонецЕсли;
	//РИВ	
	Иначе	
		Если ВыбраннаяСтрокаЭлементДерева.ПолучитьЭлементы().Количество() = 0 Тогда
			Если ЗначениеЗаполнено(ВыбраннаяСтрокаЭлементДерева.ЗаявкаНаДоставку) Тогда
				ПоказатьЗначение(Неопределено, ВыбраннаяСтрокаЭлементДерева.ЗаявкаНаДоставку);
			Иначе
				ПоказатьЗначение(Неопределено, ВыбраннаяСтрокаЭлементДерева.Распоряжение);				
			КонецЕсли;
		КонецЕсли;
	КонецЕсли;	
	
	//************************
	
КонецПроцедуры    

