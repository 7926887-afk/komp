        ОбщегоНазначенияКлиентСервер.СообщитьПользователю(ТекстСообщения);
		Возврат
	КонецЕсли;

	ОбъектыПечати	 = Новый Массив;
	Для Каждого текДокумент Из МассивДокументов Цикл
		Если ТипЗнч(текДокумент.Документ) = Тип("ДокументСсылка.ЗаказКлиента") Тогда
			ОбъектыПечати.Добавить(текДокумент.Документ);
		КонецЕсли;
	КонецЦикла;		// текДокумент Из 
	
   	_ОбработкаЗакупкиКлиент.ПечатьКомплектаДокументов(ОбъектыПечати);
