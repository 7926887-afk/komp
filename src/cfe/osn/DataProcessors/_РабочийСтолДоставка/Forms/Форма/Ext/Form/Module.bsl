&НаСервере
Процедура Компит_СоздатьРеализациюНаСервере(ДокСсылка)
	
	Если ( ДокСсылка.Проведен ) И
		 ( (ДокСсылка.Ссылка.Статус = Перечисления.СтатусыЗаданийНаПеревозку.КПогрузке )   ИЛИ
		   (ДокСсылка.Ссылка.Статус = Перечисления.СтатусыЗаданийНаПеревозку.Отправлено) ) Тогда
		_ОбработкаДоставкиТоваровСервер.СоздатьРеализациюПоЗаданиюНаПеревозку(ДокСсылка.Ссылка);
	КонецЕсли; 
	
КонецПроцедуры

&НаКлиенте
Процедура Компит_СоздатьРеализацию(Команда)
	Если НЕ ЭтотОбъект.ТекущийЭлемент.Имя = "ЗаданияНаПеревозкуВРаботе" Тогда
        ТекстСообщения = НСтр("ru='Выбарите задание на перевозку'");
        ОбщегоНазначенияКлиентСервер.СообщитьПользователю(ТекстСообщения);
		Возврат
	КонецЕсли; 
	
	ДокСсылка = ДокументПолучитьСсылку(ЭтотОбъект.ТекущийЭлемент.ТекущиеДанные.Ссылка);
	Если ДокСсылка.ПометкаУдаления Тогда
        ТекстСообщения = НСтр("ru='Задание помечено на удаление'");
        ОбщегоНазначенияКлиентСервер.СообщитьПользователю(ТекстСообщения);
		Возврат
	КонецЕсли;
	Если НЕ ДокСсылка.Проведен Тогда
        ТекстСообщения = НСтр("ru='Нельзя создовать документы по непроведенному заданию'");
        ОбщегоНазначенияКлиентСервер.СообщитьПользователю(ТекстСообщения);
		Возврат
	КонецЕсли;
	
	//**ДОБАВЛЕНО Максимов В.А.
	
	Статус = Неопределено;
	Разрешено = Ложь;
	
	ДоступностьРоли(Разрешено);
	
	Если НЕ Разрешено Тогда
		НайтиСвязанныеОрдера(ДокСсылка.Ссылка, Статус); 
		
		Если Статус Тогда
			Компит_СоздатьРеализациюНаСервере(ДокСсылка);
		Иначе
	        ТекстСообщения = НСтр("ru='Имеются не подготовленные к отгрузке товары'");
	        ОбщегоНазначенияКлиентСервер.СообщитьПользователю(ТекстСообщения);
			Возврат		
		КонецЕсли;
	Иначе
		Компит_СоздатьРеализациюНаСервере(ДокСсылка);  		
	КонецЕсли;	
	
	//***********************
	
КонецПроцедуры

//**ДОБАВЛЕНО Максимов В.А.
	
&НаСервере
Процедура ДоступностьРоли(Разрешено)

	Если РольДоступна("АдминистраторСистемы") Тогда
		Разрешено = Истина;
	Иначе
		Разрешено = Ложь;
	КонецЕсли;	
	
КонецПроцедуры	

