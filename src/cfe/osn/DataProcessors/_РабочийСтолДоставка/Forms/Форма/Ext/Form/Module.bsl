//********************************ДОВ 
  
&НаКлиенте
Процедура _ПечатьКомплектаЗаказа(Команда)
	Если НЕ ЭтотОбъект.ТекущийЭлемент.Имя = "ЗаданияНаПеревозкуВРаботе" Тогда
        ТекстСообщения = НСтр("ru='Выбарите задание на перевозку'");
        ОбщегоНазначенияКлиентСервер.СообщитьПользователю(ТекстСообщения);
		Возврат
	КонецЕсли; 
	
	ДокСсылка = ДокументПолучитьСсылку(ЭтотОбъект.ТекущийЭлемент.ТекущиеДанные.Ссылка);
	Если ДокСсылка.ПометкаУдаления Тогда
        ТекстСообщения = НСтр("ru='Задание помечено на удаление'");
