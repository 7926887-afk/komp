&НаКлиенте
Процедура СоздатьДокументСборкиРазборки(Команда)

	ФормаДокументаСборкаТоваров = ПолучитьФорму("Документ.ЗаказНаСборку.ФормаОбъекта");
	
	ДанныеФормы       = ФормаДокументаСборкаТоваров.Объект; 	// Получаем объект формы в переменную
	ДокументОснование = ПолучитьСсылкуНаДокументЗаказКлиента(); // Заказ клиента
	
	Если НЕ ПроверитьДокументПроведен(ДокументОснование) Тогда
		Возврат;
	КонецЕсли;
	
	// Заполняем документ на сервере
	ПараметрыЗаполнения = Новый Структура("ДанныеФормы, ДокументОснование, ТипДокумента", ДанныеФормы, ДокументОснование, "Сборка");
//	СоздатьЗаказНаСборкуНаСервере(ПараметрыЗаполнения);
	ЗаполнитьДокументНаСервере(ПараметрыЗаполнения);
	
	КопироватьДанныеФормы(ПараметрыЗаполнения.ДанныеФормы, ФормаДокументаСборкаТоваров.Объект); // копируем наш объект в объект формы и далее открываем ее
	
	ФормаДокументаСборкаТоваров.Элементы.ДокументОснование.Видимость = Истина;
	ФормаДокументаСборкаТоваров.Открыть();

