// Создаем заявку на закупку  или документ сборки/разборкина основе заказа
&НаСервереБезКонтекста
Процедура ЗаполнитьДокументНаСервере(ПараметрыЗаполнения)

	Если ПараметрыЗаполнения.ТипДокумента = "Закупка" Тогда
		
		НовыйДокументЗаявкиНаЗакупку = Документы.ЗаявкаНаЗакупку.СоздатьДокумент();
		Если НЕ ТипЗнч(ПараметрыЗаполнения) = Тип("Структура")
			ИЛИ НЕ ПараметрыЗаполнения.Свойство("ДокументОснование")
		Тогда
			ЗначениеВДанныеФормы(НовыйДокументЗаявкиНаЗакупку, ПараметрыЗаполнения.ДанныеФормы);
			Возврат;
		КонецЕсли;
		
		ПараметрыЗаполнения.ДанныеФормы.ПоступлениеОднойДатой = Ложь;
		ПараметрыЗаполнения.ДанныеФормы.Дата				  = ТекущаяДата();
		ПараметрыЗаполнения.ДанныеФормы.ДатаСогласования	  = ТекущаяДата();
		ПараметрыЗаполнения.ДанныеФормы.Статус		 	 	  = Перечисления.СтатусыЗаказовПоставщикам.Согласован;
		ПараметрыЗаполнения.ДанныеФормы.ЦенаВключаетНДС 	  = Истина;
		
		НовыйДокументЗаявкиНаЗакупку.Дата				 	  = ТекущаяДата();
		НовыйДокументЗаявкиНаЗакупку.ДатаСогласования	      = ТекущаяДата();
		НовыйДокументЗаявкиНаЗакупку.ПоступлениеОднойДатой	  = Ложь;
		НовыйДокументЗаявкиНаЗакупку.Заполнить(ПараметрыЗаполнения.ДокументОснование);
		ЗначениеВДанныеФормы(НовыйДокументЗаявкиНаЗакупку, ПараметрыЗаполнения.ДанныеФормы);
		
	ИначеЕсли  ПараметрыЗаполнения.ТипДокумента = "Сборка" Тогда
		
		НовыйДокументСборкаТоваров = Документы.ЗаказНаСборку.СоздатьДокумент();
		Если НЕ ТипЗнч(ПараметрыЗаполнения) = Тип("Структура")
			ИЛИ НЕ ПараметрыЗаполнения.Свойство("ДокументОснование")
		Тогда
			ЗначениеВДанныеФормы(НовыйДокументСборкаТоваров, ПараметрыЗаполнения.ДанныеФормы);
			Возврат;
		КонецЕсли;
		
		ЗаполнитьПоЗаказуКлиента(НовыйДокументСборкаТоваров, ПараметрыЗаполнения);
		
		ЗначениеВДанныеФормы(НовыйДокументСборкаТоваров, ПараметрыЗаполнения.ДанныеФормы);
	КонецЕсли 

КонецПроцедуры

// Создаем заявку на доставку на основе заказов
&НаСервере
Функция ВыбранныеЗаказы(ПроверкаКлиента = Ложь)
	
	СтрОшибок = НСтр("ru = ''");
	
	СписокЗаказов = Новый ТаблицаЗначений;
	СписокЗаказов.Колонки.Добавить("Дата",    		 Новый ОписаниеТипов("Дата")); 
	СписокЗаказов.Колонки.Добавить("Номер",   		 Новый ОписаниеТипов("Строка")); 
	СписокЗаказов.Колонки.Добавить("Организация"); 
	СписокЗаказов.Колонки.Добавить("Партнер"); 
	СписокЗаказов.Колонки.Добавить("Склад"); 
	СписокЗаказов.Колонки.Добавить("СуммаДокумента", ОбщегоНазначения.ОписаниеТипаЧисло(15, 2)); 
	СписокЗаказов.Колонки.Добавить("СпособДоставки"); 
	
	ВыделенныеСтроки = Элементы.ЗаказыКлиентов.ВыделенныеСтроки;
	
	Схема       = Элементы.ЗаказыКлиентов.ПолучитьИсполняемуюСхемуКомпоновкиДанных();
	Настройки   = Элементы.ЗаказыКлиентов.ПолучитьИсполняемыеНастройкиКомпоновкиДанных();
 
	КМ			= Новый КомпоновщикМакетаКомпоновкиДанных;
	Макет	    = КМ.Выполнить(Схема, Настройки, , , Тип("ГенераторМакетаКомпоновкиДанныхДляКоллекцииЗначений"));
 
	ПК			= Новый ПроцессорКомпоновкиДанных;
	ПК.Инициализировать(Макет);
 
	ТЗ			= Новый ТаблицаЗначений;
	
	ПВ			= Новый ПроцессорВыводаРезультатаКомпоновкиДанныхВКоллекциюЗначений;
	ПВ.УстановитьОбъект(ТЗ);
	ПВ.Вывести(ПК);	
	
	Контроль		 = Истина; 
	ОсновнойКлиент	 = Истина; 
	ОсновнойСклад	 = Истина;
	Для Каждого ТекСтрока Из ВыделенныеСтроки Цикл
		СтрДанных    = ТЗ.Получить(ТекСтрока - 1);
		ТекКлиент	 = СтрДанных.Партнер;
		ТекСклад	 = СтрДанных.Склад;
		
		Если Контроль Тогда
			Клиент   = ТекКлиент;
			Склад	 = ТекСклад;
			Контроль = Ложь;
		КонецЕсли;
		
		Если ( НЕ ТекКлиент = Клиент ) И ( НЕ ПроверкаКлиента )  Тогда
			Если ОсновнойКлиент Тогда
				СтрОшибок	   = СтрОшибок + ?( НЕ СтрОшибок = "", Символы.ПС, "" ) + "Основной клиент = " + Клиент.Наименование;
				ОсновнойКлиент = Ложь;
			КонецЕсли;		//  		 
			
			СтрОшибок = СтрОшибок + ?( НЕ СтрОшибок = "", Символы.ПС, "" ) + " Заказ клиента  № " + СтрДанных.Номер + " - по другому клиенту : " + СтрДанных.Партнер.Наименование;
			Продолжить;
		КонецЕсли;
		
		Если ( НЕ ТекСклад = Склад ) Тогда
			Если ОсновнойСклад Тогда
				СтрОшибок	  = СтрОшибок + ?( НЕ СтрОшибок = "", Символы.ПС, "" ) + "Основной склад = " + Склад.Наименование;
				ОсновнойСклад = Ложь;
			КонецЕсли;		//  		 
			СтрОшибок = СтрОшибок + ?( НЕ СтрОшибок = "", Символы.ПС, "" ) + " Заказ клиента  № " + СтрДанных.Номер + " - отгузка с другого склада: " + СтрДанных.Склад.Наименование;
			Продолжить;
		КонецЕсли;
		
		Если СтрДанных.СпособДоставки = Перечисления.СпособыДоставки.Самовывоз Тогда
			СтрОшибок = " Заказ клиента  № " + СтрДанных.Номер + " - способ доставки : " + Перечисления.СпособыДоставки.Самовывоз;
			Продолжить;
		КонецЕсли;
		
		
		НоваяСтрока  = СписокЗаказов.Добавить();
		ЗаполнитьЗначенияСвойств(НоваяСтрока, СтрДанных);
	КонецЦикла;		// ТекСтрока  
	
	Если НЕ СтрОшибок = "" Тогда
		ОбщегоНазначенияКлиентСервер.СообщитьПользователю(СтрОшибок);
	КонецЕсли;
	
	Если СписокЗаказов.Количество() > 0 Тогда
		мСписокЗаказов = _ДоработкиСлужебный.ПреобразоватьТаблицуЗначенийВМассив(СписокЗаказов);
		Возврат Новый Структура("СписокЗаказов", мСписокЗаказов);
	Иначе
		Возврат Неопределено;
	КонецЕсли;
	
КонецФункции // ВыбранныеЗаказы()

&НаСервереБезКонтекста
Процедура ЗаполнитьЗаявкуНаСервере(ПараметрыЗаполнения)

	НовыйДокументЗаявкиНаДоставку	    = Документы._ЗаявкаНаДоставку.СоздатьДокумент();
	НовыйДокументЗаявкиНаДоставку.Дата  = ТекущаяДата();
	//НовыйДокументЗаявкиНаДоставку.Дата  = _ДоработкиСлужебный.ПолучитьСледующийДень(ТекущаяДата());
	
	Если НЕ ТипЗнч(ПараметрыЗаполнения) = Тип("Структура") ИЛИ НЕ ПараметрыЗаполнения.Свойство("ДокументОснование") Тогда
		ЗначениеВДанныеФормы(НовыйДокументЗаявкиНаДоставку, ПараметрыЗаполнения.ДанныеФормы);
		Возврат;
	КонецЕсли;
	
	Если ( ПараметрыЗаполнения.СписокЗаказов = Неопределено ) И ( НЕ ПараметрыЗаполнения.ДокументОснование = ПустойЗаказ() ) Тогда
		НовыйДокументЗаявкиНаДоставку.Заполнить(ПараметрыЗаполнения.ДокументОснование);
	Иначе			// ПараметрыЗаполнения.СписокЗаказов = Неопределено
		НовыйДокументЗаявкиНаДоставку.Заполнить(ПараметрыЗаполнения.СписокЗаказов);
	КонецЕсли;		// ПараметрыЗаполнения.СписокЗаказов = Неопределено 
	
	ЗначениеВДанныеФормы(НовыйДокументЗаявкиНаДоставку, ПараметрыЗаполнения.ДанныеФормы);

КонецПроцедуры

