// Создаем новый заказ клиента
&НаСервере
Процедура ЗаполнитьЗаказКлиентаНаСервере(ПараметрыЗаполнения)
	НовыйДокументЗаказКлиента					 = Документы.ЗаказКлиента.СоздатьДокумент();
//    НовыйДокументЗаказКлиента.Статус			 = Перечисления.СтатусыЗаказовКлиентов.КОбеспечению;		// Согласован
    НовыйДокументЗаказКлиента.Статус			 = Перечисления.СтатусыЗаказовКлиентов.НеСогласован;		// НЕ Согласован
    НовыйДокументЗаказКлиента.Приоритет			 = Справочники.Приоритеты.НайтиПоНаименованию("Средний");
    НовыйДокументЗаказКлиента.Дата				 = ТекущаяДата();
	НовыйДокументЗаказКлиента._РабочийСтолПродаж = Истина;
	//**Изменено Максимов В.А. 19.10.20
	НовыйДокументЗаказКлиента.Менеджер			 = Пользователи.ТекущийПользователь();	
	НовыйДокументЗаказКлиента.ХозяйственнаяОперация = Перечисления.ХозяйственныеОперации.РеализацияКлиенту;
	//*********************************	
	ЗначениеВДанныеФормы(НовыйДокументЗаказКлиента, ПараметрыЗаполнения.ДанныеФормы);
КонецПроцедуры

