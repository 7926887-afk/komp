
#Область ОбработчикиОсновныхСобытийЭлементовФормы

&НаСервере
Процедура ПриСозданииНаСервере(Отказ, СтандартнаяОбработка)
	
	УстановитьУсловноеОформление();
	УстановитьУсловноеОформлениеЗадач();
	УстановитьУсловноеОформлениеРеализация();
	УстановитьУсловноеОформлениеЗаказНаСборку();
	ЗаказыКлиентовСписок.Параметры.УстановитьЗначениеПараметра("ДатаАктуальности", НачалоДня(ТекущаяДатаСеанса()));
	
	ОбработкаЗадачПользователя();
	
	НомерЗаказа = "";
	ДатаЗаказа  = '00010101';
	Если Параметры.Свойство("НомерЗаказа", НомерЗаказа) И Параметры.Свойство("ДатаЗаказа", ДатаЗаказа) Тогда
		ПараметрыЗаказа = Новый Структура("НомерЗаказа, ДатаЗаказа", НомерЗаказа, ДатаЗаказа);
		Объект.ПараметрыЗаказа = ПараметрыЗаказа;
	КонецЕсли;
	
	//++ **ДОБАВЛЕНО Максимов В.А.
	Элементы.ФормаГруппа1.ПодчиненныеЭлементы.ФормаРеализация.Доступность   = Ложь;
	Элементы.ФормаГруппа1.ПодчиненныеЭлементы.ФормаПечатьТОРГ12.Доступность = Ложь;
	Элементы.ЗаказыКлиентов.ПодчиненныеЭлементы.ГруппаКолонокСПредопределеннымиЗначениями.ПодчиненныеЭлементы.ЗаказыКлиентовСогласован.Видимость = Истина;
	//-- *************************
	
	ОбновитьОтборыДинамическихСписков();
	
	_РаботаСИнтерфейсомСервер.СистемаНапоминанийПриСозданииНаСервере("ГруппаРазделыРабочегоСтола", ЭтаФорма);

	//РИВ +++ 14.10.25
	//Если Элементы.ПредставлениеСостояния.Родитель = Элементы.СписокДокументыПродажи Тогда
		//Расположение = Элементы.ПредставлениеСостояния;
	//Иначе
	//	Расположение = Элементы.ПредставлениеСостояния.Родитель;
	//КонецЕсли;
	
	
	// СтандартныеПодсистемы.УчетОригиналовПервичныхДокументов
	//УчетОригиналовПервичныхДокументов.ПриСозданииНаСервере_ФормаСписка(ЭтотОбъект,Элементы.РеализацияТоваровУслугСписок );//, Расположение);
	// Конец СтандартныеПодсистемы.УчетОригиналовПервичныхДокументов
	                                                   //ЗаказКлиента
	РеквизитЗаказКлиента = ЭтотОбъект.Элементы.Вставить("РеализацияТоваровУслугСписокЗаказКлиента", Тип("ПолеФормы"), Элементы.РеализацияТоваровУслугСписок, ЭтотОбъект.Элементы.РеализацияТоваровУслугСписокСуммаДокумента);//, Расположение);
	РеквизитЗаказКлиента.Вид = ВидПоляФормы.ПолеНадписи;
	//РеквизитЗаказКлиента.ГиперссылкаЯчейки = Истина; 
	РеквизитЗаказКлиента.Заголовок = НСтр("ru='Заказ клиента'");
	РеквизитЗаказКлиента.ПутьКДанным = Элементы.РеализацияТоваровУслугСписок.Имя + ".ЗаказКлиента";	
	
	
	// Создание колонок в динамическом списке
	РеквизитСписокСостояниеПолучен = Элементы.Вставить("РеализацияТоваровУслугСписокСостояниеОригиналПолучен",Тип("ПолеФормы"),Элементы.РеализацияТоваровУслугСписок);//,Расположение);
	РеквизитСписокСостояниеПолучен.Вид = ВидПоляФормы.ПолеКартинки;
	РеквизитСписокСостояниеПолучен.ПоложениеЗаголовка = ПоложениеЗаголовкаЭлементаФормы.Нет; 
	РеквизитСписокСостояниеПолучен.КартинкаЗначений = БиблиотекаКартинок.КоллекцияПиктограммНаличиеОригиналаПервичногоДокумента;
	РеквизитСписокСостояниеПолучен.КартинкаШапки = БиблиотекаКартинок.СостояниеОригиналаПервичногоДокументаОригиналПолучен;
	РеквизитСписокСостояниеПолучен.Заголовок = НСтр("ru='Состояние оригинал получен'");
	РеквизитСписокСостояниеПолучен.ПутьКДанным = Элементы.РеализацияТоваровУслугСписок.Имя + ".СостояниеОригиналПолучен";
	
	РеквизитСписокСостояние = Элементы.Вставить("РеализацияТоваровУслугСписокСостояниеОригиналаПервичногоДокумента",Тип("ПолеФормы"),Элементы.РеализацияТоваровУслугСписок);//,Расположение);
	РеквизитСписокСостояние.Вид = ВидПоляФормы.ПолеНадписи;
	РеквизитСписокСостояние.ГиперссылкаЯчейки = Истина; 
	РеквизитСписокСостояние.Заголовок = НСтр("ru='Состояние оригинала'");
	РеквизитСписокСостояние.ПутьКДанным = Элементы.РеализацияТоваровУслугСписок.Имя + ".СостояниеОригиналаПервичногоДокумента";
	//РИВ --- 14.10.25    
	
	//##+                  
	Если УправлениеДоступом.ЕстьРоль("ДобавлениеИзменениеЗаказовНаВнутреннееПотребление") ИЛИ УправлениеДоступом.ЕстьРоль("ДопПрава") Тогда
	     Элементы.ГруппаВнутренниеЗаказы.Видимость = Истина;
	ИНаче	
	     Элементы.ГруппаВнутренниеЗаказы.Видимость = Ложь;
	КонецЕсли;
	//##-
	
КонецПроцедуры
	   
