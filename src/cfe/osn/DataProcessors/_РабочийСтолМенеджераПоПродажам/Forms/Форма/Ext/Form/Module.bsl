Функция ОбработатьКомплектыН(ТаблицаОбработки)
	
	Для Каждого ТекСтрока Из ТаблицаОбработки Цикл
		Если ТекСтрока.Комплект Тогда
			ТЗКомплекта = _ОбработкаЗакупкиСервер.ПолучитьНоборКомплекта(ТекСтрока.Номенклатура, ТекСтрока.Характеристика);
			Если ТЗКомплекта.Количество() > 0 Тогда
				ДоляСтоимости = ТЗКомплекта.Итог("ДоляСтоимости");
				Если ДоляСтоимости = 0 Тогда
					ДоляСтоимости = 1;
				КонецЕсли;
				Для Каждого СтрКомплекта Из ТЗКомплекта Цикл
					НоваяСтрока = ТаблицаОбработки.Добавить();
					ЗаполнитьЗначенияСвойств(НоваяСтрока, ТекСтрока, "ЗаказКлиента, ЗаявкаНаЗакупку, НомерСтроки");
					НоваяСтрока.Номенклатура					= СтрКомплекта.Номенклатура;
					НоваяСтрока.Характеристика					= СтрКомплекта.Характеристика;
					НоваяСтрока.Количество						= СтрКомплекта.Количество * ТекСтрока.Количество;
					//НоваяСтрока.КоличествоУпаковок				= СтрКомплекта.КоличествоУпаковок * ТекСтрока.КоличествоУпаковок;
					//НоваяСтрока.Упаковка						= СтрКомплекта.Упаковка;
					НоваяСтрока.Комплектующая					= Истина;
					НоваяСтрока.Цена                            = 0;
					НоваяСтрока.Комплект = (НоваяСтрока.Номенклатура.ВидНоменклатуры.Наименование = "Комплекты");
				КонецЦикла;
			КонецЕсли;
		КонецЕсли;
	КонецЦикла;
	Возврат ТаблицаОбработки;
	
КонецФункции // ОбработатьКомплекты()

&НаСервереБезКонтекста
Функция ПолучитьТекстЗапросаРаспределения(ВидДокумента)
	ТекстЗапроса = 
	"ВЫБРАТЬ
	|	ЗаказКлиентаТовары.Ссылка КАК ЗаказКлиента,
	|	ЗаказКлиентаТовары.НомерСтроки КАК НомерСтроки,
	|	ЗаказКлиентаТовары.КодСтроки КАК КодСтроки,
	|	ЗаказКлиентаТовары.Номенклатура КАК Номенклатура,
	|	ЗаказКлиентаТовары.Номенклатура.Артикул КАК Артикул,
	|	ЗаказКлиентаТовары.Характеристика КАК Характеристика,
	|	ЗаказКлиентаТовары.Количество КАК Количество,
	|	"+?(ВидДокумента = "ЗаказКлиента","ЗаказКлиентаТовары.Цена","0")+" КАК Цена,
	|	ЗаказКлиентаТовары._ЗаявкаНаЗакупку КАК ЗаявкаНаЗакупку,
	|	ЛОЖЬ КАК Комплектующая,
	|	ВЫБОР
	|		КОГДА ЗаказКлиентаТовары.Номенклатура.ВидНоменклатуры.Наименование = ""Комплекты""
	|			ТОГДА ИСТИНА
	|		ИНАЧЕ ЛОЖЬ
	|	КОНЕЦ КАК Комплект
	|ИЗ
	|	Документ."+ВидДокумента+".Товары КАК ЗаказКлиентаТовары
	|ГДЕ
	|	ЗаказКлиентаТовары.Ссылка = &ЗаказКлиента
	|	И ЗаказКлиентаТовары.Номенклатура.ТипНоменклатуры <> ЗНАЧЕНИЕ(Перечисление.ТипыНоменклатуры.Услуга)
	|	И ЗаказКлиентаТовары.Номенклатура.ТипНоменклатуры <> ЗНАЧЕНИЕ(Перечисление.ТипыНоменклатуры.Работа)
	|
	|УПОРЯДОЧИТЬ ПО
	|	Номенклатура,
	|	НомерСтроки
	|АВТОУПОРЯДОЧИВАНИЕ
	|;
	|
	|////////////////////////////////////////////////////////////////////////////////
	|ВЫБРАТЬ
	|	ЗаказПоставщикуТовары.Ссылка КАК ЗаказПоставщику,
	|	ЗаказПоставщикуТовары.Номенклатура КАК Номенклатура,
	|	ЗаказПоставщикуТовары.Характеристика КАК Характеристика,
	|	ЗаказПоставщикуТовары.ДатаОтгрузки КАК ДатаОтгрузки,
	|	ЗаказПоставщикуТовары._ЗаявкаНаЗакупку КАК ЗаявкаНаЗакупку,
	|	ЗаказПоставщикуТовары.Ссылка.Партнер КАК Поставщик,
	|	ЗаказПоставщикуТовары.Ссылка.Номер КАК НомерЗаказаПоставщику,
	|	ЗаказПоставщикуТовары.Количество КАК КоличествоЗаказано
	|ИЗ
	|	Документ.ЗаказПоставщику.Товары КАК ЗаказПоставщикуТовары
	|ГДЕ
	|	ЗаказПоставщикуТовары.Ссылка.Проведен
	|	И ЗаказПоставщикуТовары.Назначение.Заказ = &ЗаказКлиента
	|	И ЗаказПоставщикуТовары.Номенклатура.ТипНоменклатуры <> ЗНАЧЕНИЕ(Перечисление.ТипыНоменклатуры.Услуга)
	|	И ЗаказПоставщикуТовары.Номенклатура.ТипНоменклатуры <> ЗНАЧЕНИЕ(Перечисление.ТипыНоменклатуры.Работа)
	|
	|УПОРЯДОЧИТЬ ПО
	|	Номенклатура,
	|	ЗаказПоставщику
	|АВТОУПОРЯДОЧИВАНИЕ
	|;
	|
	|////////////////////////////////////////////////////////////////////////////////
	|ВЫБРАТЬ
	|	ПриобретениеТоваровУслуг_ТоварыТ.ЗаказПоставщику КАК ЗаказПоставщику,
	|	ПриобретениеТоваровУслуг_ТоварыТ.Назначение КАК Назначение,
	|	ПриобретениеТоваровУслуг_ТоварыТ.Номенклатура КАК Номенклатура,
	|	ПриобретениеТоваровУслуг_ТоварыТ.Характеристика КАК Характеристика,
	|	СУММА(ПриобретениеТоваровУслуг_ТоварыТ.Количество) КАК Количество
	|ИЗ
	|	Документ.ПриобретениеТоваровУслуг.Товары КАК ПриобретениеТоваровУслуг_ТоварыТ
	|ГДЕ
	|	ПриобретениеТоваровУслуг_ТоварыТ.Ссылка.Проведен = ИСТИНА
	|	И ПриобретениеТоваровУслуг_ТоварыТ.Номенклатура.ТипНоменклатуры <> ЗНАЧЕНИЕ(Перечисление.ТипыНоменклатуры.Услуга)
	|	И ПриобретениеТоваровУслуг_ТоварыТ.Номенклатура.ТипНоменклатуры <> ЗНАЧЕНИЕ(Перечисление.ТипыНоменклатуры.Работа)
	|	И ПриобретениеТоваровУслуг_ТоварыТ.Назначение.Заказ = &ЗаказКлиента
	|
	|СГРУППИРОВАТЬ ПО
	|	ПриобретениеТоваровУслуг_ТоварыТ.ЗаказПоставщику,
	|	ПриобретениеТоваровУслуг_ТоварыТ.Назначение,
	|	ПриобретениеТоваровУслуг_ТоварыТ.Номенклатура,
	|	ПриобретениеТоваровУслуг_ТоварыТ.Характеристика
	|
	|УПОРЯДОЧИТЬ ПО
	|	ЗаказПоставщику
	|АВТОУПОРЯДОЧИВАНИЕ
	|;
	|
	|"; 
	
	Если ВидДокумента = "ЗаказНаВнутреннееПотребление" Тогда
		
		ТекстЗапроса = ТекстЗапроса + "
		|////////////////////////////////////////////////////////////////////////////////
		|ВЫБРАТЬ
		|	ВнутреннееПотреблениеТовары.Номенклатура КАК Номенклатура,
		|	ВнутреннееПотреблениеТовары.Характеристика КАК Характеристика,
		|	ВнутреннееПотреблениеТовары.АналитикаРасходов КАК Статус,
		|	СУММА(ВнутреннееПотреблениеТовары.Количество) КАК Количество
		|ИЗ
		|	Документ.ВнутреннееПотребление.Товары КАК ВнутреннееПотреблениеТовары
		|ГДЕ
		|	ВнутреннееПотреблениеТовары.Ссылка.Проведен = ИСТИНА
		|	И ВнутреннееПотреблениеТовары.Назначение.Заказ = &ЗаказКлиента
		|
		|СГРУППИРОВАТЬ ПО
		|	ВнутреннееПотреблениеТовары.Номенклатура,
		|	ВнутреннееПотреблениеТовары.Характеристика,
		|	ВнутреннееПотреблениеТовары.АналитикаРасходов
		|;";  
		
	ИНачеЕсли ВидДокумента = "ЗаказКлиента" Тогда	
		
		ТекстЗапроса = ТекстЗапроса + "
		|////////////////////////////////////////////////////////////////////////////////
		|ВЫБРАТЬ
		|	РасходныйОрдерНаТоварыТоварыПоРаспоряжениям.Номенклатура КАК Номенклатура,
		|	РасходныйОрдерНаТоварыТоварыПоРаспоряжениям.Характеристика КАК Характеристика,
		|	ВЫБОР
		|		КОГДА РасходныйОрдерНаТоварыТоварыПоРаспоряжениям.Ссылка.ОтгрузкаПоЗаданиюНаПеревозку = ИСТИНА
		|			ТОГДА РасходныйОрдерНаТоварыТоварыПоРаспоряжениям.Ссылка.ЗаданиеНаПеревозку.Статус
		|		ИНАЧЕ ""Самовывоз""
		|	КОНЕЦ КАК Статус,
		|	СУММА(РасходныйОрдерНаТоварыТоварыПоРаспоряжениям.Количество) КАК Количество
		|ИЗ
		|	Документ.РасходныйОрдерНаТовары.ТоварыПоРаспоряжениям КАК РасходныйОрдерНаТоварыТоварыПоРаспоряжениям
		|ГДЕ
		|	РасходныйОрдерНаТоварыТоварыПоРаспоряжениям.Ссылка.Проведен = ИСТИНА
		|	И РасходныйОрдерНаТоварыТоварыПоРаспоряжениям.Ссылка.Статус = ЗНАЧЕНИЕ(Перечисление.СтатусыРасходныхОрдеров.Отгружен)
		|	И РасходныйОрдерНаТоварыТоварыПоРаспоряжениям.Назначение.Заказ = &ЗаказКлиента
		|
		|СГРУППИРОВАТЬ ПО
		|	РасходныйОрдерНаТоварыТоварыПоРаспоряжениям.Номенклатура,
		|	РасходныйОрдерНаТоварыТоварыПоРаспоряжениям.Характеристика,
		|	ВЫБОР
		|		КОГДА РасходныйОрдерНаТоварыТоварыПоРаспоряжениям.Ссылка.ОтгрузкаПоЗаданиюНаПеревозку = ИСТИНА
		|			ТОГДА РасходныйОрдерНаТоварыТоварыПоРаспоряжениям.Ссылка.ЗаданиеНаПеревозку.Статус
		|		ИНАЧЕ ""Самовывоз""
		|	КОНЕЦ
		|;";
		
	КонецЕсли;    
	
	ТекстЗапроса = ТекстЗапроса + "
	|////////////////////////////////////////////////////////////////////////////////
	|ВЫБРАТЬ
	|	СборкаТоваров.Номенклатура КАК Номенклатура,
	|	СборкаТоваров.Количество КАК Количество,
	|	СборкаТоваров.Характеристика КАК Характеристика
	|ИЗ
	|	Документ.СборкаТоваров КАК СборкаТоваров
	|ГДЕ
	|	СборкаТоваров.Проведен = ИСТИНА
	|	И СборкаТоваров.Статус = ЗНАЧЕНИЕ(Перечисление.СтатусыСборокТоваров.СобраноРазобрано)
	|	И СборкаТоваров.Назначение.Заказ = &ЗаказКлиента";
	
	Возврат ТекстЗапроса;
	
КонецФункции


&НаСервереБезКонтекста 
Функция РаспределитьНаСервере(ЗаказКлиента)
	
	Запрос = Новый Запрос;
	Запрос.Текст =  ПолучитьТекстЗапросаРаспределения(ЗаказКлиента.Метаданные().Имя);
	Запрос.УстановитьПараметр("ЗаказКлиента", ЗаказКлиента);
	РезультатЗапроса  = Запрос.ВыполнитьПакет();
	тзЗаказКлиента    = РезультатЗапроса[0].Выгрузить();
	тзЗаказПоставщику = РезультатЗапроса[1].Выгрузить();
	тзПТиУ            = РезультатЗапроса[2].Выгрузить();
	тзРО              = РезультатЗапроса[3].Выгрузить();
	тзСборка          = РезультатЗапроса[4].Выгрузить();
	
	Если ЛОЖЬ Тогда 
		тзЗаказКлиента    = Новый ТаблицаЗначений;
		тзЗаказПоставщику = Новый ТаблицаЗначений;
		тзПТиУ            = Новый ТаблицаЗначений;
		тзРО              = Новый ТаблицаЗначений;
		тзСборка          = Новый ТаблицаЗначений;
	КонецЕсли;
	
	ОбработатьКомплектыН(тзЗаказКлиента);
	
	//***************************************************************************************************
	// распределим Заказ клиента по Заказам поставщикам
	тзРаспределено = тзЗаказКлиента.СкопироватьКолонки();
	тзРаспределено.Колонки.Добавить("КоличествоЗаказано", Новый ОписаниеТипов("Число"));
	тзРаспределено.Колонки.Добавить("ЗаказПоставщику");
	тзРаспределено.Колонки.Добавить("Поставщик");
	тзРаспределено.Колонки.Добавить("НомерЗаказаПоставщику");
	тзРаспределено.Колонки.Добавить("ДатаОтгрузки");
	
	Для каждого СтрЗаказКлиента Из тзЗаказКлиента Цикл
		
		Отбор = Новый Структура("Номенклатура, ЗаявкаНаЗакупку", СтрЗаказКлиента.Номенклатура, СтрЗаказКлиента.ЗаявкаНаЗакупку);
		СтрокиЗаказыПоставщику = тзЗаказПоставщику.НайтиСтроки(Отбор);
		Для каждого СтрЗаказПокупателя Из СтрокиЗаказыПоставщику Цикл
			
			Если СтрЗаказПокупателя.КоличествоЗаказано = 0 Тогда
				Продолжить;
			КонецЕсли;
			
			КРаспределению = СтрЗаказПокупателя.КоличествоЗаказано;
			Если КРаспределению >= СтрЗаказКлиента.Количество Тогда
				Распределено = СтрЗаказКлиента.Количество;
			Иначе
				Распределено = КРаспределению;
			КонецЕсли;
			
			Если Распределено > 0 Тогда
				//***********************************
				НовСтрока = тзРаспределено.Добавить();
				ЗаполнитьЗначенияСвойств(НовСтрока, СтрЗаказКлиента);
				ЗаполнитьЗначенияСвойств(НовСтрока, СтрЗаказПокупателя);
				НовСтрока.КоличествоЗаказано = Распределено;
				НовСтрока.Количество  = Распределено;
				
				СтрЗаказКлиента.Количество     = СтрЗаказКлиента.Количество - Распределено;
				СтрЗаказПокупателя.КоличествоЗаказано = СтрЗаказПокупателя.КоличествоЗаказано - Распределено;
				КРаспределению                        = КРаспределению - Распределено;
			КонецЕсли;
			
			Если КРаспределению = 0 Тогда
				Продолжить;
			КонецЕсли;
			
			Если СтрЗаказКлиента.Количество = 0 Тогда
				Прервать;
			КонецЕсли;
			
		КонецЦикла;
		
		Если СтрЗаказКлиента.Количество > 0 Тогда
			// остались незаказанные позиции
			//***********************************
			НовСтрока = тзРаспределено.Добавить();
			ЗаполнитьЗначенияСвойств(НовСтрока, СтрЗаказКлиента);
		КонецЕсли;
		
	КонецЦикла;
	
	//***************************************************************************************************
	// распределелим поступления товаров
	
	тзРаспределено.Колонки.Добавить("КоличествоВНаличииПодЗаказ", Новый ОписаниеТипов("Число"));
	Для Каждого Стр Из тзРаспределено Цикл
		
		Если Стр.Комплект = Истина Тогда
			Отбор = Новый Структура("Номенклатура,Характеристика", Стр.Номенклатура, Стр.Характеристика);
			СтрокиПоступления = тзСборка.НайтиСтроки(Отбор);
			Для каждого Поступление Из СтрокиПоступления Цикл
				Если Поступление.Количество = 0 Тогда
					Продолжить;
				КонецЕсли;
				
				Поступило = Мин(Стр.Количество - Стр.КоличествоВНаличииПодЗаказ, Поступление.Количество);
				Стр.КоличествоВНаличииПодЗаказ = Стр.КоличествоВНаличииПодЗаказ + Поступило;
				Поступление.Количество = Поступление.Количество - Поступило;
				
				Если Стр.Количество <= Стр.КоличествоВНаличииПодЗаказ Тогда
					Прервать;
				КонецЕсли;
			КонецЦикла;
		Иначе
			Если Стр.КоличествоЗаказано = 0 Тогда
				Продолжить;
			КонецЕсли;
		
			Отбор = Новый Структура("Номенклатура,Характеристика,ЗаказПоставщику", Стр.Номенклатура, Стр.Характеристика, Стр.ЗаказПоставщику);
			СтрокиПоступления = тзПТиУ.НайтиСтроки(Отбор);
			Для каждого Поступление Из СтрокиПоступления Цикл
				Если Поступление.Количество = 0 Тогда
					Продолжить;
				КонецЕсли;
				
				Поступило = Мин(Стр.КоличествоЗаказано - Стр.КоличествоВНаличииПодЗаказ, Поступление.Количество);
				Стр.КоличествоВНаличииПодЗаказ = Стр.КоличествоВНаличииПодЗаказ + Поступило;
				Поступление.Количество = Поступление.Количество - Поступило;
				
				Если Стр.КоличествоЗаказано <= Стр.КоличествоВНаличииПодЗаказ Тогда
					Прервать;
				КонецЕсли;
			КонецЦикла;
		КонецЕсли;
		
	КонецЦикла;
	
	//***************************************************************************************************
	// распределим отгрузку
	
	тзРаспределено.Колонки.Добавить("КоличествоОтгружено", Новый ОписаниеТипов("Число"));
	тзРаспределено.Колонки.Добавить("Статус", Новый ОписаниеТипов("Строка"));
	Для Каждого Стр Из тзРаспределено Цикл
		
		Если Стр.КоличествоВНаличииПодЗаказ = 0 Тогда
			Продолжить;
		КонецЕсли;
		
		Отбор = Новый Структура("Номенклатура,Характеристика", Стр.Номенклатура, Стр.Характеристика);
		СтрокиРО = тзРО.НайтиСтроки(Отбор);
		Для каждого РО Из СтрокиРО Цикл
			Если РО.Количество = 0 Тогда
				Продолжить;
			КонецЕсли;
			
			Расход = Мин(РО.Количество, Стр.КоличествоВНаличииПодЗаказ - Стр.КоличествоОтгружено);
			Стр.КоличествоОтгружено = Стр.КоличествоОтгружено + Расход;
			Стр.Статус              = Строка(РО.Статус);
			РО.Количество = РО.Количество - Расход;
			
			Если Стр.КоличествоВНаличииПодЗаказ <= Стр.КоличествоОтгружено Тогда
				Прервать;
			КонецЕсли;
			
		КонецЦикла;
	
	КонецЦикла;
	
	тзРаспределено.Свернуть("ЗаказКлиента, КодСтроки, НомерСтроки, Номенклатура, Цена, Артикул, ЗаявкаНаЗакупку, ЗаказПоставщику, Поставщик, НомерЗаказаПоставщику, ДатаОтгрузки, Комплектующая, Комплект, Статус", "Количество, КоличествоЗаказано, КоличествоВНаличииПодЗаказ, КоличествоОтгружено");
	тзРаспределено.Сортировать("НомерСтроки, Комплектующая");
	
	тзРаспределено.Колонки.Добавить("Сумма", Новый ОписаниеТипов("Число"));
	Для каждого Стр Из тзРаспределено Цикл
		Стр.Сумма = Стр.Количество * Стр.Цена;
	КонецЦикла;
	
	Возврат тзРаспределено;
	
КонецФункции

&НаСервере
Процедура ОбновитьДанныеТаблицыТоваровЗаказаНаСервереН(СсылкаНаДокумент)
	
	ЭтотОбъект.ЗаказыКлиентовТовары.Очистить();
	
	Если ЗначениеЗаполнено(СсылкаНаДокумент) Тогда
		
		ДанныеЗаполнения = РаспределитьНаСервере(СсылкаНаДокумент);
		Если ТипЗнч(ДанныеЗаполнения) = Тип("ТаблицаЗначений") Тогда
			ЭтотОбъект.ЗаказыКлиентовТовары.Загрузить(ДанныеЗаполнения);
		КонецЕсли;
		
	КонецЕсли;  
	
	
КонецПроцедуры

