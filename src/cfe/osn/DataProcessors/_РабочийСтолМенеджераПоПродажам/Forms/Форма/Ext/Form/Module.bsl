// добавим реквизиты и элементы формы
&НаСервере
Процедура ДополнитьФормуПриСозданииНаСервере(ФормаОбъекта)

	// YuS, добавляем поле быстрого отбора
	ГруппаБыстрыхОтборовФормы = ФормаОбъекта.Элементы.Найти("ГруппаЗаказыКлиентовБыстрыеОтборы");
	
	// Поле "Документы возвращены"
	Если ФормаОбъекта.Элементы.Найти("ЗаказыКлиентовМенеджерКонтрагента") = Неопределено Тогда
		
		// найдем реквизит
		РеквизитДобавляемыйНаФорму = Неопределено;
		РеквизитыФормыМассив = ФормаОбъекта.ПолучитьРеквизиты();
		Для Каждого ЭлементМассиваРеквизитФормы Из РеквизитыФормыМассив Цикл
			
			Если ЭлементМассиваРеквизитФормы.Имя = "ЗаказыКлиентовМенеджерКонтрагента" Тогда
				
				РеквизитДобавляемыйНаФорму = ЭлементМассиваРеквизитФормы;
				
				Прервать;
				
			КонецЕсли;
			
		КонецЦикла;
		
		// добавим реквизит
		Если РеквизитДобавляемыйНаФорму = Неопределено Тогда
			РеквизитыФормыМассив = Новый Массив;
			РеквизитыФормыМассив.Добавить(Новый РеквизитФормы("ЗаказыКлиентовМенеджерКонтрагента", Новый ОписаниеТипов("СправочникСсылка.Пользователи", , , , , , ), , "Менеджер клиента", Ложь));
			ФормаОбъекта.ИзменитьРеквизиты(РеквизитыФормыМассив);
		КонецЕсли;
		
		// элемент формы
		ЭлементФормыМенеджерКонтрагента = ФормаОбъекта.Элементы.Добавить("ЗаказыКлиентовМенеджерКонтрагента", Тип("ПолеФормы"), ГруппаБыстрыхОтборовФормы);
		ЭлементФормыМенеджерКонтрагента.Заголовок          = НСтр("ru = 'Менеджер клиента'");
		ЭлементФормыМенеджерКонтрагента.ПоложениеЗаголовка = ПоложениеЗаголовкаЭлементаФормы.Верх;
		ЭлементФормыМенеджерКонтрагента.Вид                = ВидПоляФормы.ПолеВвода;
		ЭлементФормыМенеджерКонтрагента.ПутьКДанным        = "ЗаказыКлиентовСписок.МенеджерКонтрагента";
		
		// расширение элемента
		ЭлементФормыМенеджерКонтрагента.КнопкаОткрытия          = Ложь;
		ЭлементФормыМенеджерКонтрагента.КнопкаВыпадающегоСписка = Истина;
		ЭлементФормыМенеджерКонтрагента.КнопкаОчистки           = Истина;
		ЭлементФормыМенеджерКонтрагента.РежимВыбораИзСписка     = Ложь;
		
		ЭлементФормыМенеджерКонтрагента.УстановитьДействие("ПриИзменении", "ЗаказыКлиентовМенеджерКонтрагентаПриИзменении");
		
	КонецЕсли;
	
	// Поле "Документы возвращены"
	Если ФормаОбъекта.Элементы.Найти("ЗаказыКлиентовДокументыВозвращены") = Неопределено Тогда
		
		// найдем реквизит
		РеквизитДобавляемыйНаФорму = Неопределено;
		РеквизитыФормыМассив = ФормаОбъекта.ПолучитьРеквизиты();
		Для Каждого ЭлементМассиваРеквизитФормы Из РеквизитыФормыМассив Цикл
			
			Если ЭлементМассиваРеквизитФормы.Имя = "ЗаказыКлиентовДокументыВозвращены" Тогда
				
				РеквизитДобавляемыйНаФорму = ЭлементМассиваРеквизитФормы;
				
				Прервать;
				
			КонецЕсли;
			
		КонецЦикла;
		
		// добавим реквизит
		Если РеквизитДобавляемыйНаФорму = Неопределено Тогда
			РеквизитыФормыМассив = Новый Массив;
			РеквизитыФормыМассив.Добавить(Новый РеквизитФормы("ЗаказыКлиентовДокументыВозвращены", Новый ОписаниеТипов("Строка", , , , Новый КвалификаторыСтроки(100, ДопустимаяДлина.Переменная), , ), , "Документы возвращены", Ложь));
			ФормаОбъекта.ИзменитьРеквизиты(РеквизитыФормыМассив);
		КонецЕсли;
		
		// элемент формы
		ЭлементФормыДокументыВозвращены = ФормаОбъекта.Элементы.Добавить("ЗаказыКлиентовДокументыВозвращены", Тип("ПолеФормы"), ГруппаБыстрыхОтборовФормы);
		ЭлементФормыДокументыВозвращены.Заголовок          = НСтр("ru = 'Документы возвращены'");
		ЭлементФормыДокументыВозвращены.ПоложениеЗаголовка = ПоложениеЗаголовкаЭлементаФормы.Верх;
		ЭлементФормыДокументыВозвращены.Вид                = ВидПоляФормы.ПолеВвода;
		ЭлементФормыДокументыВозвращены.ПутьКДанным        = "ЗаказыКлиентовСписок.ДокументыВозвращены";
		
		// расширение элемента
		ЭлементФормыДокументыВозвращены.КнопкаВыпадающегоСписка = Истина;
		ЭлементФормыДокументыВозвращены.КнопкаОчистки           = Истина;
		ЭлементФормыДокументыВозвращены.РежимВыбораИзСписка     = Истина;
		
		// список значений элемента
		СписокВыбораЗначений = ЭлементФормыДокументыВозвращены.СписокВыбора;
		СписокВыбораЗначений.Добавить("Да",  "Да", , );
		СписокВыбораЗначений.Добавить("Нет", "Нет", , );
		
		ЭлементФормыДокументыВозвращены.УстановитьДействие("ПриИзменении", "ЗаказыКлиентовДокументыВозвращеныПриИзменении");
		
	КонецЕсли;

КонецПроцедуры

// действие "При изменении" добавленного поля формы
&НаКлиенте
Процедура ЗаказыКлиентовМенеджерКонтрагентаПриИзменении(Элемент)

	ДанныеРеквизитаФормы = ЭтаФорма[Элемент.Имя];
	Если ДанныеРеквизитаФормы = Неопределено Тогда
		Возврат;
	КонецЕсли;
	
	//УстановитьЭлементОтбораДинамическогоСписка(	ДинамическийСписок,
	//												ИмяПоля,
	//												ПравоеЗначение = Неопределено,
	//												ВидСравнения = Неопределено,
	//												Представление = Неопределено,
	//												Использование = Неопределено,
	//												РежимОтображения = Неопределено,
	//												ИдентификаторПользовательскойНастройки = Неопределено)
	
	Если ЗначениеЗаполнено(ДанныеРеквизитаФормы) Тогда
		ОбщегоНазначенияКлиентСервер.УстановитьЭлементОтбораДинамическогоСписка(ЗаказыКлиентовСписок, "ЗаказыКлиентовСписок.МенеджерКонтрагента", ДанныеРеквизитаФормы, ВидСравненияКомпоновкиДанных.Равно, , Истина);
	Иначе
		ОбщегоНазначенияКлиентСервер.УстановитьЭлементОтбораДинамическогоСписка(ЗаказыКлиентовСписок, "ЗаказыКлиентовСписок.МенеджерКонтрагента", ДанныеРеквизитаФормы, ВидСравненияКомпоновкиДанных.Равно, , Ложь);
	КонецЕсли;

КонецПроцедуры

// действие "При изменении" добавленного поля формы
&НаКлиенте
Процедура ЗаказыКлиентовДокументыВозвращеныПриИзменении(Элемент)

	ДанныеРеквизитаФормы = ЭтаФорма[Элемент.Имя];
	Если ДанныеРеквизитаФормы = Неопределено Тогда
		Возврат;
	КонецЕсли;
	
	Если ДанныеРеквизитаФормы = "Да" Тогда
		ОбщегоНазначенияКлиентСервер.УстановитьЭлементОтбораДинамическогоСписка(ЗаказыКлиентовСписок, "ЗаказыКлиентовСписок.ДокументыВозвращены", Истина, ВидСравненияКомпоновкиДанных.Равно, , Истина);
	ИначеЕсли ДанныеРеквизитаФормы = "Нет" Тогда
		ОбщегоНазначенияКлиентСервер.УстановитьЭлементОтбораДинамическогоСписка(ЗаказыКлиентовСписок, "ЗаказыКлиентовСписок.ДокументыВозвращены", Истина, ВидСравненияКомпоновкиДанных.НеЗаполнено, , Истина);
	Иначе
		ОбщегоНазначенияКлиентСервер.УстановитьЭлементОтбораДинамическогоСписка(ЗаказыКлиентовСписок, "ЗаказыКлиентовСписок.ДокументыВозвращены", Истина, ВидСравненияКомпоновкиДанных.Равно, , Ложь);
	КонецЕсли;

КонецПроцедуры

