#КонецОбласти



#Область НастройкиИнтерфейса

&НаКлиенте
Процедура НастройкаИнтерфейсаНачало()
	НастройкаИнтерфейсаСервер(Истина);
	ОбщегоНазначенияКлиент.ОбновитьИнтерфейсПрограммы();
КонецПроцедуры	// НастройкаИнтерфейсаНачало()
 
&НаКлиенте 
Процедура НастройкаИнтерфейсаКонец()
  	НастройкаИнтерфейсаСервер(Ложь);
	ОбщегоНазначенияКлиент.ОбновитьИнтерфейсПрограммы();
КонецПроцедуры	// НастройкаИнтерфейсаКонец()

&НаСервере
Процедура НастройкаИнтерфейсаСервер(Минимальный)
	
	Настройки = ХранилищеСистемныхНастроек.Загрузить("Общее/НастройкиИнтерфейсаКлиентскогоПриложения");
	
	Если Минимальный Тогда
		Настройки = МинимальныйИнтерфейс(Настройки);
	Иначе
		Настройки = РабочийИнтерфейс();
	КонецЕсли;
	
	ХранилищеСистемныхНастроек.Сохранить("Общее/НастройкиИнтерфейсаКлиентскогоПриложения", , Настройки);
	
КонецПроцедуры	// НастройкаМинимальногоИнтерфейса()

&НаСервере
Функция МинимальныйИнтерфейс(Настройки)
	Настройки				 = Новый НастройкиИнтерфейсаКлиентскогоПриложения;
	ГруппаНастроек			 = Новый ГруппаНастройкиСоставаИнтерфейсаКлиентскогоПриложения;
	НастройкиСостава		 = Новый НастройкиСоставаИнтерфейсаКлиентскогоПриложения;
	ГруппаВерх				 = Новый ГруппаНастройкиСоставаИнтерфейсаКлиентскогоПриложения;
	ГруппаВерх.Добавить(Новый ЭлементНастройкиСоставаИнтерфейсаКлиентскогоПриложения("ПанельИнструментов"));
	ГруппаВерх.Добавить(Новый ЭлементНастройкиСоставаИнтерфейсаКлиентскогоПриложения("ПанельОткрытых"));
	НастройкиСостава.Верх.Добавить(ГруппаВерх);
	Настройки.УстановитьСостав(НастройкиСостава);
    Возврат Настройки;	
КонецФункции	// МинимальныйИнтерфейс()()
 
&НаСервере
Функция РабочийИнтерфейс()
	Настройки				 = Новый НастройкиИнтерфейсаКлиентскогоПриложения;
	НастройкиСостава		 = Новый НастройкиСоставаИнтерфейсаКлиентскогоПриложения;
	ГруппаВерх				 = Новый ГруппаНастройкиСоставаИнтерфейсаКлиентскогоПриложения;
	ГруппаВерх.Добавить(Новый ЭлементНастройкиСоставаИнтерфейсаКлиентскогоПриложения("ПанельИнструментов"));
	ГруппаВерх.Добавить(Новый ЭлементНастройкиСоставаИнтерфейсаКлиентскогоПриложения("ПанельОткрытых"));
	НастройкиСостава.Верх.Добавить(ГруппаВерх);
	НастройкиСостава.Лево.Добавить(Новый ЭлементНастройкиСоставаИнтерфейсаКлиентскогоПриложения("ПанельРазделов"));
	Настройки.УстановитьСостав(НастройкиСостава);
    Возврат Настройки;	
КонецФункции	// РабочийИнтерфейс()

#КонецОбласти



#Область Раскраска

&НаСервере
Процедура УстановитьУсловноеОформление()
	
	// Условное оформление динамического списка "Список"
	СписокУсловноеОформление = ЗаказыКлиентовСписок.КомпоновщикНастроек.Настройки.УсловноеОформление;
	СписокУсловноеОформление.Элементы.Очистить();
	
	//**ИЗМЕНЕНО Максимов В.А.
	
	Если НЕ РольДоступна("АдминистраторСистемы") Тогда
		Если НЕ РольДоступна("Администрирование") Тогда
			Запрос = Новый Запрос;
			Запрос.Текст = 
			"ВЫБРАТЬ
			|	ГруппыДоступа.Ссылка КАК Ссылка,
			|	ГруппыДоступа.Пользователи.(
			|		Пользователь КАК Пользователь
			|	) КАК Пользователи,
			|	ГруппыДоступа.ЗначенияДоступа.(
			|		ЗначениеДоступа КАК ЗначениеДоступа
			|	) КАК ЗначенияДоступа
			|ИЗ
			|	Справочник.ГруппыДоступа КАК ГруппыДоступа
			|ГДЕ
			|	ГруппыДоступа.Пользователи.Пользователь = &Пользователь";
			
			Запрос.УстановитьПараметр("Пользователь", Пользователи.ТекущийПользователь());
			
			ГруппыДоступа = Запрос.Выполнить().Выгрузить();

			МассивОрганизаций = Новый Массив;
			СписокГруппДоступа = Новый Массив;
			Для Каждого Группа Из ГруппыДоступа Цикл
				Для Каждого Стр Из Группа.ЗначенияДоступа Цикл			
			 		СписокГруппДоступа.Добавить(Стр.ЗначениеДоступа);					
					Если ТипЗнч(Стр.ЗначениеДоступа) = Тип("СправочникСсылка.Организации") Тогда
						МассивОрганизаций.Добавить(Стр.ЗначениеДоступа);
					КонецЕсли;	
				КонецЦикла;
			КонецЦикла;	
				
			НовыйЗапрос = Новый Запрос;
			НовыйЗапрос.Текст = 
			"ВЫБРАТЬ
			|	ДокументЗаказКлиента.Ссылка КАК Ссылка,
			|	ДокументЗаказКлиента.ПометкаУдаления КАК ПометкаУдаления,
			|	ДокументЗаказКлиента.Номер КАК Номер,
			|	ДокументЗаказКлиента.Дата КАК Дата,
			|	ДокументЗаказКлиента.Проведен КАК Проведен,
			|	ДокументЗаказКлиента.Приоритет КАК Приоритет,
			|	ВЫБОР
			|		КОГДА ДокументЗаказКлиента.Проведен = ИСТИНА
			|			ТОГДА 0
			|		КОГДА ДокументЗаказКлиента.ПометкаУдаления = ИСТИНА
			|			ТОГДА 1
			|		ИНАЧЕ 2
			|	КОНЕЦ КАК СостояниеДокумента,
			|	ДокументЗаказКлиента.Партнер КАК Партнер,
			|	ДокументЗаказКлиента.Партнер.ОсновнойМенеджер КАК МенеджерКонтрагента,
			|	ДокументЗаказКлиента.Контрагент КАК Контрагент,
			|	ДокументЗаказКлиента.Организация КАК Организация,
			|	ДокументЗаказКлиента.Валюта КАК Валюта,
			|	ДокументЗаказКлиента.СуммаДокумента КАК СуммаДокумента,
			|	ДокументЗаказКлиента.Склад КАК Склад,
			|	ДокументЗаказКлиента.ЦенаВключаетНДС КАК ЦенаВключаетНДС,
			|	ДокументЗаказКлиента.Менеджер КАК Менеджер,
			|	ДокументЗаказКлиента.ДополнительнаяИнформация КАК ДополнительнаяИнформация,
			|	ВЫБОР
			|		КОГДА ДокументЗаказКлиента.ПометкаУдаления = ИСТИНА
			|			ТОГДА 6
			|		КОГДА ДокументЗаказКлиента.Проведен = ЛОЖЬ
			|				И ДокументЗаказКлиента.ПометкаУдаления = ЛОЖЬ
			|			ТОГДА 4
			|		КОГДА ДокументЗаказКлиента.Статус = ЗНАЧЕНИЕ(Перечисление.СтатусыЗаказовКлиентов.НеСогласован)
			|			ТОГДА 2
			|		КОГДА ДокументЗаказКлиента.Статус = ЗНАЧЕНИЕ(Перечисление.СтатусыЗаказовКлиентов.КОбеспечению)
			|			ТОГДА 0
			|		КОГДА ДокументЗаказКлиента.Статус = ЗНАЧЕНИЕ(Перечисление.СтатусыЗаказовКлиентов.КОтгрузке)
			|			ТОГДА 3
			|		КОГДА ДокументЗаказКлиента.Статус = ЗНАЧЕНИЕ(Перечисление.СтатусыЗаказовКлиентов.Закрыт)
			|			ТОГДА 5
			|		ИНАЧЕ 1
			|	КОНЕЦ КАК Статус,
			|	ДокументЗаказКлиента.Статус КАК СтатусСсылка,
			|	ДокументЗаказКлиента.Согласован КАК Согласован,
			|	ДокументЗаказКлиента.Комментарий КАК Комментарий,
			|	ДокументЗаказКлиента.Автор КАК Автор,
			|	ДокументЗаказКлиента.Закрыт КАК Закрыт,
			|	ЕСТЬNULL(ДополнительныеРеквизитыДокумента.Значение, ЛОЖЬ) КАК ДокументыВозвращены,
			|	ЕСТЬNULL(РасчетыСКлиентамиОстаткиИОбороты.КОплатеПриход, 0) КАК КОплатеПриход,
			|	ЕСТЬNULL(РасчетыСКлиентамиОстаткиИОбороты.КОплатеРасход, 0) КАК КОплатеРасход,
			|	ЕСТЬNULL(РасчетыСКлиентамиОстаткиИОбороты.КОплатеКонечныйОстаток, 0) КАК КОплатеКонечныйОстаток,
			|	ЕСТЬNULL(ТоварыКОтгрузкеОстаткиИОбороты.КОтгрузкеПриход, 0) КАК КОтгрузкеПриход,
			|	ЕСТЬNULL(ТоварыКОтгрузкеОстаткиИОбороты.КОтгрузкеРасход, 0) КАК КОтгрузкеРасход,
			|	ЕСТЬNULL(ТоварыКОтгрузкеОстаткиИОбороты.КОтгрузкеКонечныйОстаток, 0) КАК КОтгрузкеКонечныйОстаток,
			|	ДокументЗаказКлиента.КонтактноеЛицо КАК КонтактноеЛицо,
			|	СостоянияЗаказовКлиентов.Состояние КАК Состояние,
			|	ВЫБОР
			|		КОГДА СостоянияЗаказовКлиентов.Состояние = ЗНАЧЕНИЕ(Перечисление.СтатусыЗаказовКлиентов.Закрыт)
			|			ТОГДА 0
			|		ИНАЧЕ 1
			|	КОНЕЦ КАК СостояниеЗаказа,
			|	ДокументЗаказКлиента.СпособДоставки КАК СпособДоставки,
			|	ВЫБОР
			|		КОГДА ТоварыКОтгрузкеОстаткиИОбороты.КОтгрузкеПриход ЕСТЬ НЕ NULL 
			|				И НЕ ТоварыКОтгрузкеОстаткиИОбороты.КОтгрузкеПриход = 0
			|			ТОГДА ВЫРАЗИТЬ(ТоварыКОтгрузкеОстаткиИОбороты.КОтгрузкеРасход * 100 / ТоварыКОтгрузкеОстаткиИОбороты.КОтгрузкеПриход КАК ЧИСЛО(3, 0))
			|		ИНАЧЕ 0
			|	КОНЕЦ КАК ПроцентОтгрузки2,
			|	ЕСТЬNULL(СостоянияЗаказовКлиентов.СуммаОплаты, 0) КАК СуммаОплаты,
			|	ЕСТЬNULL(СостоянияЗаказовКлиентов.ПроцентОплаты, 0) КАК ПроцентОплаты,
			|	ЕСТЬNULL(СостоянияЗаказовКлиентов.СуммаОтгрузки, 0) КАК СуммаОтгрузки,
			|	ЕСТЬNULL(СостоянияЗаказовКлиентов.ПроцентОтгрузки, 0) КАК ПроцентОтгрузки,
			|	ВЫБОР
			|		КОГДА ЕСТЬNULL(СостоянияЗаказовКлиентов.СуммаДолга, 0) < 0
			|			ТОГДА ЕСТЬNULL(СостоянияЗаказовКлиентов.СуммаДолга, 0)
			|		ИНАЧЕ 0
			|	КОНЕЦ КАК НашДолг,
			|	ВЫБОР
			|		КОГДА ЕСТЬNULL(СостоянияЗаказовКлиентов.СуммаДолга, 0) > 0
			|			ТОГДА ЕСТЬNULL(СостоянияЗаказовКлиентов.СуммаДолга, 0)
			|		ИНАЧЕ 0
			|	КОНЕЦ КАК ДолгКлиента,
			|	ЕСТЬNULL(СостоянияЗаказовКлиентов.ПроцентДолга, 0) КАК ПроцентДолга,
			|	ЕСТЬNULL(СостоянияЗаказовКлиентов.ДатаСобытия, ДАТАВРЕМЯ(1, 1, 1)) КАК ДатаСобытия,
			|	ЕСТЬNULL(СостоянияЗаказовКлиентов.ЕстьРасхожденияОрдерНакладная, ЛОЖЬ) КАК ЕстьРасхожденияОрдерНакладная,
			|	ВЫБОР
			|		КОГДА НЕ ДокументЗаказКлиента.Проведен
			|			ТОГДА ЛОЖЬ
			|		КОГДА СостоянияЗаказовКлиентов.ДатаСобытия <> ДАТАВРЕМЯ(1, 1, 1)
			|				И &ДатаАктуальности > СостоянияЗаказовКлиентов.ДатаСобытия
			|			ТОГДА ИСТИНА
			|		ИНАЧЕ ЛОЖЬ
			|	КОНЕЦ КАК Просрочен
			|ИЗ
			|	РегистрСведений.СостоянияЗаказовКлиентов КАК СостоянияЗаказовКлиентов
			|		ЛЕВОЕ СОЕДИНЕНИЕ Документ.ЗаказКлиента КАК ДокументЗаказКлиента
			|			ЛЕВОЕ СОЕДИНЕНИЕ (ВЫБРАТЬ
			|				ДополнительныеРеквизиты.Ссылка КАК ДокументСсылка,
			|				ДополнительныеРеквизиты.Свойство КАК Свойство,
			|				ДополнительныеРеквизиты.Значение КАК Значение
			|			ИЗ
			|				Документ.ЗаказКлиента.ДополнительныеРеквизиты КАК ДополнительныеРеквизиты
			|			ГДЕ
			|				ДополнительныеРеквизиты.Свойство.Заголовок ПОДОБНО ""Документы возвращены"") КАК ДополнительныеРеквизитыДокумента
			|			ПО (ДополнительныеРеквизитыДокумента.ДокументСсылка = ДокументЗаказКлиента.Ссылка)
			|			ЛЕВОЕ СОЕДИНЕНИЕ РегистрНакопления.РасчетыСКлиентами.ОстаткиИОбороты(, , Период, Движения, ) КАК РасчетыСКлиентамиОстаткиИОбороты
			|			ПО ДокументЗаказКлиента.Ссылка = РасчетыСКлиентамиОстаткиИОбороты.ОбъектРасчетов.Объект
			|			ЛЕВОЕ СОЕДИНЕНИЕ РегистрНакопления.ТоварыКОтгрузке.ОстаткиИОбороты(, , Период, Движения, ) КАК ТоварыКОтгрузкеОстаткиИОбороты
			|			ПО ДокументЗаказКлиента.Ссылка = ТоварыКОтгрузкеОстаткиИОбороты.Назначение.Заказ
			|		ПО СостоянияЗаказовКлиентов.Заказ = ДокументЗаказКлиента.Ссылка
			|ГДЕ
			|	ДокументЗаказКлиента.Партнер.ГруппаДоступа В(&ГруппаДоступа)
			|	И ДокументЗаказКлиента.Партнер.ГруппаДоступа <> ЗНАЧЕНИЕ(Справочник.ГруппыДоступаПартнеров.ПустаяСсылка)";
			Если МассивОрганизаций.Количество() > 0 Тогда
				НовыйЗапрос.Текст = НовыйЗапрос.Текст + 
								"
								|   И ДокументЗаказКлиента.Организация В (&Организация)"; 
			КонецЕсли;
				
			ЗаказыКлиентовСписок.ТекстЗапроса = НовыйЗапрос.Текст;
			ЗаказыКлиентовСписок.Параметры.УстановитьЗначениеПараметра("ГруппаДоступа",СписокГруппДоступа);
			Если МассивОрганизаций.Количество() > 0 Тогда
				ЗаказыКлиентовСписок.Параметры.УстановитьЗначениеПараметра("Организация",МассивОрганизаций);
			КонецЕсли;	
			
		КонецЕсли;	
	КонецЕсли;
	
	//********************************
	
	// Документ имеет высокий приоритет
	Элемент = СписокУсловноеОформление.Элементы.Добавить();
	Элемент.Представление = НСтр("ru = 'Документ имеет высокий приоритет'");
	
