// Проверить варианты комплектации по товарной позиции
&НаСервереБезКонтекста
Функция ПроверитьОстаткиКОформлениюПоКомплектам(СсылкаНаДокумент)

	Если НЕ ТипЗнч(СсылкаНаДокумент) = Тип("ДокументСсылка.ЗаказКлиента") Тогда
		Возврат Неопределено;
	КонецЕсли;
	
	Запрос = Новый Запрос;
	Запрос.Текст =
	"ВЫБРАТЬ
	|	ВариантыКомплектацииНоменклатуры.Ссылка КАК Ссылка,
	|	ЗаказКлиентаТовары.Номенклатура КАК Номенклатура,
	|	ЗаказКлиентаТовары.Характеристика КАК Характеристика,
	|	ЗаказКлиентаТовары.КоличествоУпаковок КАК КоличествоУпаковок
	|ИЗ
	|	Справочник.ВариантыКомплектацииНоменклатуры КАК ВариантыКомплектацииНоменклатуры
	|		ВНУТРЕННЕЕ СОЕДИНЕНИЕ Документ.ЗаказКлиента.Товары КАК ЗаказКлиентаТовары
	|		ПО ВариантыКомплектацииНоменклатуры.Владелец = ЗаказКлиентаТовары.Номенклатура
	|			И ВариантыКомплектацииНоменклатуры.Характеристика = ЗаказКлиентаТовары.Характеристика
	|			И (ЗаказКлиентаТовары.Ссылка = &СсылкаНаДокумент)
	|ГДЕ
	|	ВариантыКомплектацииНоменклатуры.Основной";
	Запрос.УстановитьПараметр("СсылкаНаДокумент", СсылкаНаДокумент);
	КомплектыЗаказа		= Запрос.Выполнить().Выгрузить();
	МассивКомплектов	= КомплектыЗаказа.ВыгрузитьКолонку("Номенклатура");
	
	
	
	ТекстЗапросаПоТоварамНаСкладах 		= ТекстЗапросаТоварыНаСкладах();
	ЗапросПоТоварамПоТоварамНаСкладах 	= Новый Запрос(ТекстЗапросаПоТоварамНаСкладах);
	НазначениеТовара					= ПолучитьНазначение(СсылкаНаДокумент).Ссылка;
	ЗапросПоТоварамПоТоварамНаСкладах.УстановитьПараметр("Назначение", НазначениеТовара);
	
	ТаблицаОстатков = ЗапросПоТоварамПоТоварамНаСкладах.Выполнить().Выгрузить();
	ТаблицаКонтроля = ТаблицаОстатков.СкопироватьКолонки();
	
	Для Каждого ТекКомплкт Из КомплектыЗаказа Цикл
		Для Каждого ТекСтрока Из ТекКомплкт.Ссылка.Товары Цикл
			СтрутураПоиска  = Новый Структура("Номенклатура, Характеристика, Назначение", ТекСтрока.Номенклатура, ТекСтрока.Характеристика, НазначениеТовара);
			НайденныеСтроки = ТаблицаОстатков.НайтиСтроки(СтрутураПоиска);
			Если НЕ НайденныеСтроки.Количество() = 0 Тогда
				Для Каждого СтрОстатков Из НайденныеСтроки Цикл
					СтрОстатков.Остаток = СтрОстатков.Остаток - ТекСтрока.КоличествоУпаковок * ТекКомплкт.КоличествоУпаковок;
					НоваяСтрока = ТаблицаКонтроля.Добавить();
					ЗаполнитьЗначенияСвойств(НоваяСтрока, СтрОстатков);
				КонецЦикла;		// СтрОстатков Из НайденныеСтроки 
			КонецЕсли;
		КонецЦикла;		// ТекСтрока Из ТекКомплкт.Ссылка.Товары
	КонецЦикла;		// ТекКомплкт Из КомплектыЗаказа 
	
	//ОбщееКоличество = ТаблицаОстатков.Итог("Остаток");
	ОбщееКоличество = ТаблицаКонтроля.Итог("Остаток");
	
	Возврат (ОбщееКоличество >= 0);

КонецФункции

&НаСервереБезКонтекста
Функция ТекстЗапросаТоварыНаСкладах()
	ТекстЗапроса =
	"ВЫБРАТЬ
	|	ТоварыНаСкладахОстатки.Номенклатура КАК Номенклатура,
	|	ТоварыНаСкладахОстатки.Характеристика КАК Характеристика,
	|	ТоварыНаСкладахОстатки.Назначение КАК Назначение,
	|	ТоварыНаСкладахОстатки.Склад КАК Склад,
	|	ТоварыНаСкладахОстатки.ВНаличииОстаток КАК ВНаличииОстаток,
	|	ТоварыНаСкладахОстатки.КОтгрузкеОстаток КАК КОтгрузкеОстаток,
	|	ТоварыНаСкладахОстатки.ВНаличииОстаток КАК Остаток
	|ИЗ
	|	РегистрНакопления.ТоварыНаСкладах.Остатки КАК ТоварыНаСкладахОстатки
	|ГДЕ
	|	ТоварыНаСкладахОстатки.Назначение = &Назначение";
	
	Возврат ТекстЗапроса;
