&НаКлиенте
Процедура СоздатьЗаказ(Команда)
	Если Элементы.ГруппаРазделыРабочегоСтола.ТекущаяСтраница = Элементы.ГруппаВнутренниеЗаказы Тогда
	
    ФормаДокументаЗаказКлиента = ПолучитьФорму("Документ.ЗаказНаВнутреннееПотребление.ФормаОбъекта");
	ДанныеФормы			       = ФормаДокументаЗаказКлиента.Объект;
	ПараметрыЗаполнения		   = Новый Структура("ДанныеФормы", ДанныеФормы);
	ЗаполнитьВнутреннийЗаказНаСервере(ПараметрыЗаполнения);
	КопироватьДанныеФормы(ПараметрыЗаполнения.ДанныеФормы, ФормаДокументаЗаказКлиента.Объект); // копируем наш объект в объект формы и далее открываем ее
    ФормаДокументаЗаказКлиента.Открыть();

	ИНачеЕсли Элементы.ГруппаРазделыРабочегоСтола.ТекущаяСтраница = Элементы.ГруппаЗаказыКлиентов Тогда
		
    ФормаДокументаЗаказКлиента = ПолучитьФорму("Документ.ЗаказКлиента.ФормаОбъекта");
	ДанныеФормы			       = ФормаДокументаЗаказКлиента.Объект;
	ПараметрыЗаполнения		   = Новый Структура("ДанныеФормы", ДанныеФормы);
	ЗаполнитьЗаказКлиентаНаСервере(ПараметрыЗаполнения);
	КопироватьДанныеФормы(ПараметрыЗаполнения.ДанныеФормы, ФормаДокументаЗаказКлиента.Объект); // копируем наш объект в объект формы и далее открываем ее
    ФормаДокументаЗаказКлиента.Открыть();
		
	КонецЕсли;

//	ОткрытьФорму("Документ.ЗаказКлиента.ФормаОбъекта");

КонецПроцедуры

