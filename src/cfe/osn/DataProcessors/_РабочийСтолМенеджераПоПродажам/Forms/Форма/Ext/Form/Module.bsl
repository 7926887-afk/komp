&НаСервереБезКонтекста
Функция ПолучитьСостояниеЗаказаКлиента(СсылкаНаДокумент)

	СтруктураСостоянияРасчетов = Новый Структура;
	СтруктураСостоянияРасчетов.Вставить("Состояние",           Перечисления.СостоянияЗаказовКлиентов.ПустаяСсылка());
	СтруктураСостоянияРасчетов.Вставить("СостояниеПросрочено", Ложь);
	СтруктураСостоянияРасчетов.Вставить("СуммаОплаты",         0);
	СтруктураСостоянияРасчетов.Вставить("СуммаОтгрузки",       0);
	СтруктураСостоянияРасчетов.Вставить("ПроцентОплаты",       0);
	СтруктураСостоянияРасчетов.Вставить("ПроцентОтгрузки",     0);
	СтруктураСостоянияРасчетов.Вставить("СуммаДолга",          0);
	СтруктураСостоянияРасчетов.Вставить("ПроцентДолга",        0);
	СтруктураСостоянияРасчетов.Вставить("СуммаКОплате",        0);
	
	Документы.ЗаказКлиента.РассчитатьСостояние(СсылкаНаДокумент, СсылкаНаДокумент.Договор, СтруктураСостоянияРасчетов);
	
	Возврат СтруктураСостоянияРасчетов;

КонецФункции

// Получим данные о состоянии заказа поставщику
&НаСервереБезКонтекста
Функция ПолучитьСостояниеЗаказаПоставщику(СсылкаНаДокумент)

	СтруктураСостоянияРасчетов = Новый Структура;
	СтруктураСостоянияРасчетов.Вставить("Состояние",           Перечисления.СостоянияЗаказовПоставщикам.ПустаяСсылка());
	СтруктураСостоянияРасчетов.Вставить("СостояниеПросрочено", Ложь);
	СтруктураСостоянияРасчетов.Вставить("СуммаОплаты",         0);
	СтруктураСостоянияРасчетов.Вставить("СуммаОтгрузки",       0);
	СтруктураСостоянияРасчетов.Вставить("ПроцентОплаты",       0);
	СтруктураСостоянияРасчетов.Вставить("ПроцентОтгрузки",     0);
	СтруктураСостоянияРасчетов.Вставить("СуммаДолга",          0);
	СтруктураСостоянияРасчетов.Вставить("ПроцентДолга",        0);
	СтруктураСостоянияРасчетов.Вставить("СуммаКОплате",        0);
	
	Документы.ЗаказПоставщику.РассчитатьСостояние(СсылкаНаДокумент, СсылкаНаДокумент.Договор, СтруктураСостоянияРасчетов);
	
	Возврат СтруктураСостоянияРасчетов;

КонецФункции

// Заполнение таблицы формы по товарам клиента
&НаКлиенте
Процедура ОбновитьДанныеТаблицыТоваровЗаказаПокупателя(СсылкаНаДокумент)

	ДанныеЗаполнения = ПолучитьДанныеПоТоварамЗаказаКлиента(СсылкаНаДокумент);
	
	// Заполним данные по товарам заказа клиента
	Если ТипЗнч(ДанныеЗаполнения) = Тип("Массив")
		И НЕ ДанныеЗаполнения.Количество() = 0
	Тогда
		
		ЗаказыКлиентовТовары.Очистить(); // очистим таблицу перед заполнением
		Для Каждого СтрокаДанных Из ДанныеЗаполнения Цикл
			
			// Данные не соответствуют ожидаемым
			Если НЕ ТипЗнч(СтрокаДанных) = Тип("Структура") Тогда
				Продолжить;
			КонецЕсли;
			
			СтрокаДанныхПоТоварамЗаказаКлиента = ЗаказыКлиентовТовары.Добавить();
			ЗаполнитьЗначенияСвойств(СтрокаДанныхПоТоварамЗаказаКлиента, СтрокаДанных);
			
			//Если СтрокаДанных.Комплектующая И НЕ ЭтаФорма.Элементы.ЗаказыКлиентовТовары.ТекущийЭлемент = Неопределено Тогда
			//	ЭтаФорма.Элементы.ЗаказыКлиентовТовары.ЦветФона = Новый Цвет(205,255,200);
			//КонецЕсли;
			//
		КонецЦикла;
		
	КонецЕсли;

КонецПроцедуры

