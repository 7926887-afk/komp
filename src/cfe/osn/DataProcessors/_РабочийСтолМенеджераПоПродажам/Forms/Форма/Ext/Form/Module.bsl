&НаСервереБезКонтекста
Процедура ЗаполнитьПоЗаказуКлиента(НовыйДокументСборкаТоваров, ПараметрыЗаполнения)
	
	Реквизиты	 = ПолучитьДанныеПоЗаказуКлиента(ПараметрыЗаполнения.ДокументОснование);
	ЗаказКлиента = ПараметрыЗаполнения.ДокументОснование;
	
	Документы.ЗаказКлиента.ПроверитьВозможностьВводаНаОсновании(
		ЗаказКлиента,
		Реквизиты.СтатусДокумента,
		НЕ Реквизиты.Проведен);
	
	// Заполнение шапки
	НовыйДокументСборкаТоваров.Дата					   = ТекущаяДата();
	НовыйДокументСборкаТоваров.ДокументОснование       = ЗаказКлиента;
	НовыйДокументСборкаТоваров.Организация             = Реквизиты.Организация;
	НовыйДокументСборкаТоваров.Сделка                  = Реквизиты.Сделка;
	НовыйДокументСборкаТоваров.Подразделение           = Реквизиты.Подразделение;
	НовыйДокументСборкаТоваров.НаправлениеДеятельности = Реквизиты.НаправлениеДеятельности;
	НовыйДокументСборкаТоваров.Статус		 	 	   = Перечисления.СтатусыВнутреннихЗаказов.КВыполнению;
	НовыйДокументСборкаТоваров.ХозяйственнаяОперация   = Перечисления.ХозяйственныеОперации.СборкаТоваров;
	НовыйДокументСборкаТоваров.Ответственный		   = ПользователиКлиентСервер.ТекущийПользователь();
	НовыйДокументСборкаТоваров.ВариантПриемкиТоваров   = Перечисления.ВариантыПриемкиТоваров.РазделенаПоЗаказамИНакладным;
	НовыйДокументСборкаТоваров.НачалоСборкиРазборки	   = ТекущаяДата();
	НовыйДокументСборкаТоваров.ОкончаниеСборкиРазборки = ТекущаяДата();
	НовыйДокументСборкаТоваров.Приоритет               = ЗначениеНастроекПовтИсп.ПолучитьПриоритетПоУмолчанию();

//	НовыйДокументСборкаТоваров.СборкаПодДеятельность   = Перечисления.ТипыНалогообложенияНДС;
	
//	ПараметрыЗаполнения = Документы.ЗаказНаСборку.ПараметрыЗаполненияВидаДеятельностиНДС(НовыйДокументСборкаТоваров);
	
	// Заполнение табличной части.
	//ПараметрыТаблицыТовары							   = ПараметрыТаблицыОстатковПоЗаказу();
	//ПараметрыТаблицыТовары.ПолучатьУслуги			   = Ложь;
	//ПараметрыТаблицыТовары.ПолучатьРаботы			   = Ложь;
	//ТаблицаТовары									   = ТаблицаОстатковКЗаказу(ЗаказКлиента, ПараметрыТаблицыТовары);
	
	ПараметрыСоздания = Документы.ЗаказНаСборку.ПараметрыСозданияНаОснованииОбеспечивающегоЗаказа();
	
	МенеджерВременныхТаблиц = Новый МенеджерВременныхТаблиц;
	МенеджерДокумента = ОбщегоНазначения.МенеджерОбъектаПоСсылке(ЗаказКлиента);
	МенеджерДокумента.ТоварыДокументаДляСозданияОбеспечивающегоЗаказа(
		ЗаказКлиента,
		ПараметрыСоздания,
		МенеджерВременныхТаблиц);
		
	Запрос = Новый Запрос();
	Запрос.МенеджерВременныхТаблиц = МенеджерВременныхТаблиц;
	
	Запрос.УстановитьПараметр("Склады", ЗаказКлиента.Склад);
	Запрос.УстановитьПараметр("ВсеСклады", Не ЗначениеЗаполнено(ЗаказКлиента.Склад));

	ВариантыОбеспечения = Новый Массив;
	ВариантыОбеспечения.Добавить(Перечисления.ВариантыОбеспечения.КОбеспечению);
	
	Запрос.УстановитьПараметр("ВариантыОбеспечения", ВариантыОбеспечения);
	Запрос.УстановитьПараметр("ВсеДействия", ВариантыОбеспечения.Количество() = 0);
	Запрос.Текст = 
		"ВЫБРАТЬ
		|	МИНИМУМ(Товары.НомерСтроки) КАК НомерСтрокиВДокументе,
		|	Товары.Номенклатура КАК Номенклатура,
		|	МИНИМУМ(Товары.Номенклатура.ТипНоменклатуры) КАК ТипНоменклатуры,
		|	Товары.Характеристика КАК Характеристика,
		|	Товары.Упаковка КАК Упаковка,
		|	Товары.Склад КАК Склад,
		|	Товары.Подразделение КАК Подразделение,
		|	Товары.Назначение КАК Назначение,
		|	Товары.ВариантОбеспечения КАК ВариантОбеспечения,
		|	Товары.Обособленно КАК Обособленно,
		|	Товары.ДатаОтгрузки КАК ДатаОтгрузки,
		|	СУММА(Товары.КоличествоПоДокументу) КАК КоличествоУпаковок,
		|	ИСТИНА КАК Отметка,
		|	СУММА(Товары.КоличествоПоДокументу) КАК Количество
		|ИЗ
		|	ТоварыДокумента КАК Товары
		|ГДЕ
		|	(&ВсеСклады ИЛИ Товары.Склад = &Склады)
		|		И (&ВсеДействия ИЛИ Товары.ВариантОбеспечения В(&ВариантыОбеспечения))
		|СГРУППИРОВАТЬ ПО
		|	Товары.Номенклатура,
		|	Товары.Характеристика,
		|	Товары.Упаковка,
		|	Товары.Склад,
		|	Товары.Подразделение,
		|	Товары.Назначение,
		|	Товары.ВариантОбеспечения,
		|	Товары.Обособленно,
		|	Товары.ДатаОтгрузки
		|УПОРЯДОЧИТЬ ПО
		|	НомерСтрокиВДокументе";
	
	УстановитьПривилегированныйРежим(Истина);
	ПакетРезультатов = Запрос.ВыполнитьПакет();
	ТаблицаТовары = ПакетРезультатов[0].Выгрузить();
	
	//**ИЗМЕНЕНО Максимов В.А.
	
	Если ТаблицаТовары.Количество() > 0 Тогда
		
		Для Каждого Строка Из ТаблицаТовары Цикл
			
			Если Строка.Номенклатура.ВидНоменклатуры.Наименование = "Комплекты" Тогда
				НовыйДокументСборкаТоваров.Упаковка			   = ПолучитьУпаковку(ЗаказКлиента, Строка.Номенклатура, Строка.Характеристика);
				ЗаполнитьЗначенияСвойств(НовыйДокументСборкаТоваров, Строка);
				
				НовыйДокументСборкаТоваров.ВариантКомплектации = Справочники.ВариантыКомплектацииНоменклатуры.ПолучитьОсновнуюКомплектацию(
					НовыйДокументСборкаТоваров.Номенклатура, НовыйДокументСборкаТоваров.Характеристика);
				
				ЗаполнитьТоварыПоВариантуКомплектации(НовыйДокументСборкаТоваров);
				
				Прервать;

			КонецЕсли;		
							
		КонецЦикла;	
		
		//НовыйДокументСборкаТоваров.Упаковка			   = ПолучитьУпаковку(ЗаказКлиента, ТаблицаТовары[0].Номенклатура, ТаблицаТовары[0].Характеристика);
		//ЗаполнитьЗначенияСвойств(НовыйДокументСборкаТоваров, ТаблицаТовары[0]);
		//
		//НовыйДокументСборкаТоваров.ВариантКомплектации = Справочники.ВариантыКомплектацииНоменклатуры.ПолучитьОсновнуюКомплектацию(
		//	НовыйДокументСборкаТоваров.Номенклатура, НовыйДокументСборкаТоваров.Характеристика);
		//
		//ЗаполнитьТоварыПоВариантуКомплектации(НовыйДокументСборкаТоваров);
		
	КонецЕсли;
	
	//*********************
	
	ИнициализироватьДокумент(НовыйДокументСборкаТоваров, Реквизиты, ЗаказКлиента);

КонецПроцедуры

&НаСервереБезКонтекста
Процедура ЗаполнитьТоварыПоВариантуКомплектации(НовыйДокументСборкаТоваров)
	
	НовыйДокументСборкаТоваров.Товары.Загрузить(Справочники.ВариантыКомплектацииНоменклатуры.ПолучитьКомплектующиеНоменклатуры(НовыйДокументСборкаТоваров.ВариантКомплектации, , НовыйДокументСборкаТоваров.Количество));
	Для Каждого ТекСтрока Из НовыйДокументСборкаТоваров.Товары Цикл
//		ТекСтрока.ВариантОбеспечения = Перечисления.ВариантыОбеспечения.ОтгрузитьОбособленно; 
	КонецЦикла;		// ТекСтрока Из НовыйДокументСборкаТоваров.Товары.Загрузить

КонецПроцедуры

&НаСервереБезКонтекста
Функция ПолучитьДанныеПоЗаказуКлиента(ЗаказКлиента)
	
	Запрос = Новый Запрос("ВЫБРАТЬ
	                      |	ЗаказКлиента.Статус КАК СтатусДокумента,
	                      |	ЗаказКлиента.Проведен КАК Проведен,
	                      |	ЗаказКлиента.Организация КАК Организация,
	                      |	ЗаказКлиента.Сделка КАК Сделка,
	                      |	ЗаказКлиента.Подразделение КАК Подразделение,
	                      |	ВЫБОР
	                      |		КОГДА ЗаказКлиента.НаправлениеДеятельности.УчетЗатрат
	                      |			ТОГДА ЗаказКлиента.НаправлениеДеятельности
	                      |		ИНАЧЕ ЗНАЧЕНИЕ(Справочник.НаправленияДеятельности.ПустаяСсылка)
	                      |	КОНЕЦ КАК НаправлениеДеятельности
	                      |ИЗ
	                      |	Документ.ЗаказКлиента КАК ЗаказКлиента
	                      |ГДЕ
	                      |	ЗаказКлиента.Ссылка = &ЗаказКлиента");
	
	Запрос.УстановитьПараметр("ЗаказКлиента", ЗаказКлиента);
	Реквизиты = Запрос.Выполнить().Выбрать();
	Реквизиты.Следующий();
	Возврат Реквизиты;
	
КонецФункции // ПолучитьДанныеПоЗаказуКлиента()

&НаСервереБезКонтекста
Функция ПолучитьУпаковку(ЗаказКлиента, Номенклатура, Характеристика)
	
	СтруктураПоиска = Новый Структура("Номенклатура, Характеристика", Номенклатура, Характеристика);
	МассивСтрок = ЗаказКлиента.Товары.НайтиСтроки(СтруктураПоиска);
	Если НЕ МассивСтрок.Количество() = 0 Тогда
		Возврат МассивСтрок[0].Упаковка;
	Иначе
		Возврат Справочники.УпаковкиЕдиницыИзмерения.ПустаяСсылка();
	КонецЕсли;
	
КонецФункции // ПолучитУпаковку()

&НаСервереБезКонтекста
Процедура ИнициализироватьДокумент(НовыйДокументСборкаТоваров, Реквизиты, ДанныеЗаполнения = Неопределено)

	НовыйДокументСборкаТоваров.Ответственный = Пользователи.ТекущийПользователь();
	НовыйДокументСборкаТоваров.Организация = ЗначениеНастроекПовтИсп.ПолучитьОрганизациюПоУмолчанию(Реквизиты.Организация);
	НовыйДокументСборкаТоваров.Склад = ЗначениеНастроекПовтИсп.ПолучитьСкладПоУмолчанию(НовыйДокументСборкаТоваров.Склад);
	НовыйДокументСборкаТоваров.Подразделение = ЗначениеНастроекПовтИсп.ПодразделениеПользователя(Пользователи.ТекущийПользователь());
	НовыйДокументСборкаТоваров.ВариантОбеспечения = Перечисления.ВариантыОбеспечения.КОбеспечению;
	
	Статус = Перечисления.СтатусыВнутреннихЗаказов.Закрыт;
	
	ОбеспечениеВДокументахСервер.ЗаполнитьВариантОбеспеченияПоУмолчанию(НовыйДокументСборкаТоваров.Товары);
	
	ВариантОбеспечения = Неопределено;
	Если НовыйДокументСборкаТоваров.Товары.Количество() > 0 Тогда
		ВариантОбеспечения = НовыйДокументСборкаТоваров.Товары[0].ВариантОбеспечения;
	КонецЕсли;
	
	Если НЕ ВариантОбеспечения = Перечисления.ВариантыОбеспечения.Отгрузить Тогда
		 ВариантОбеспечения = Перечисления.ВариантыОбеспечения.Отгрузить;
	КонецЕсли;
	 
	Для Каждого ТекСтрока Из НовыйДокументСборкаТоваров.Товары Цикл
		ТекСтрока.ВариантОбеспечения = ВариантОбеспечения;
		ТекСтрока.Обособленно = Истина;
	КонецЦикла;		// ТекСтрока Из НовыйДокументСборкаТоваров.Товары 
	
	// Заполнение варианта обеспечения разбираемого комплекта.
	ТаблицаИзОбъекта = Новый ТаблицаЗначений();
	ТаблицаИзОбъекта.Колонки.Добавить("Номенклатура", Новый ОписаниеТипов("СправочникСсылка.Номенклатура"));
	ЗаполнитьЗначенияСвойств(ТаблицаИзОбъекта.Добавить(), НовыйДокументСборкаТоваров);
	
	ТаблицаИзОбъекта.Колонки.Добавить("ВариантОбеспечения");
	ТаблицаИзОбъекта.Колонки.Добавить("Обособленно");
	ОбеспечениеВДокументахСервер.ЗаполнитьВариантОбеспеченияПоУмолчанию(ТаблицаИзОбъекта);
	
	ВариантОбеспечения = ТаблицаИзОбъекта[0].ВариантОбеспечения;
	
	ОбосабливатьПоНазначениюЗаказа = Константы.ВариантОбособленияТоваровВСборке.Получить()
		<> Перечисления.ВариантыОбособленияТоваровВСборке.НазначениеСобираемогоКомплекта;
	
	ВариантПриемкиТоваров = ЗакупкиСервер.ПолучитьВариантПриемкиТоваров();
	
	ПараметрыЗаполнения = Документы.ЗаказНаСборку.ПараметрыЗаполненияВидаДеятельностиНДС(НовыйДокументСборкаТоваров);
	УчетНДСУП.ЗаполнитьВидДеятельностиНДС(НовыйДокументСборкаТоваров.СборкаПодДеятельность, ПараметрыЗаполнения);
	
КонецПроцедуры


#КонецОбласти

#Область ПечатьСчетНаОплату

&НаСервере
Функция Компит_ПечатьСчетНаОплатуСервер(ЗаказКлиента)
	
	ПараметрыПечати = Неопределено;
	
	МассивОбъектов = Новый Массив;
	МассивОбъектов.Добавить(ЗаказКлиента.Ссылка);	
	
	Если ПараметрыПечати <> Неопределено И ПараметрыПечати.Свойство("ОтображатьСкидки") Тогда
		ОтображатьСкидки = ПараметрыПечати.ОтображатьСкидки;
	Иначе
		ОтображатьСкидки = (Константы.ОтображениеСкидокВПечатныхФормахДокументовПродажи.Получить()
			<> Перечисления.ВариантыВыводаСкидокВПечатныхФормах.НеВыводитьСкидки);
	КонецЕсли; 
	
	МенеджерВременныхТаблиц = Новый МенеджерВременныхТаблиц;
	ОтветственныеЛицаСервер.СформироватьВременнуюТаблицуОтветственныхЛицДокументов(МассивОбъектов, МенеджерВременныхТаблиц);	
	
	Запрос = Новый Запрос;
	Запрос.МенеджерВременныхТаблиц = МенеджерВременныхТаблиц;
	Запрос.Текст =
	"ВЫБРАТЬ
	|	Документы.Ссылка КАК Ссылка,
	|	Документы.Номер КАК Номер,
	|	Документы.Дата КАК Дата,
	|	НЕОПРЕДЕЛЕНО КАК ДокументОснование,
	|	ЕСТЬNULL(Документы.БанковскийСчет.Владелец, Документы.Организация) КАК Организация,
	|	Документы.Организация КАК ОрганизацияПоставщик,
	|	ТаблицаОтветственныеЛица.РуководительНаименование КАК Руководитель,
	|	ТаблицаОтветственныеЛица.РуководительДолжность КАК ДолжностьРуководителя,
	|	ТаблицаОтветственныеЛица.ГлавныйБухгалтерНаименование КАК ГлавныйБухгалтер,
	|	ВЫБОР
	|		КОГДА Документы.НалогообложениеНДС = ЗНАЧЕНИЕ(Перечисление.ТипыНалогообложенияНДС.ПродажаНеОблагаетсяНДС)
	|				ИЛИ Документы.НалогообложениеНДС = ЗНАЧЕНИЕ(Перечисление.ТипыНалогообложенияНДС.ПродажаОблагаетсяЕНВД)
	|			ТОГДА ЛОЖЬ
	|		ИНАЧЕ ИСТИНА
	|	КОНЕЦ КАК УчитыватьНДС,
	|	Документы.Контрагент КАК Контрагент,
	|	Документы.Контрагент.ЮрФизЛицо КАК КонтрагентЮрФизЛицо,
	|	Документы.БанковскийСчет КАК БанковскийСчет,
	|	ВЫБОР
	|		КОГДА Документы.БанковскийСчет.ИностранныйБанк
	|				ИЛИ Документы.БанковскийСчет.ВалютаДенежныхСредств <> Константы.ВалютаРегламентированногоУчета
	|				ИЛИ Документы.БанковскийСчетКонтрагента.ИностранныйБанк
	|			ТОГДА ИСТИНА
	|		ИНАЧЕ ЛОЖЬ
	|	КОНЕЦ КАК ПлатежЗаРубеж,
	|	Документы.БанковскийСчет.ВалютаДенежныхСредств КАК ВалютаДенежныхСредств,
	|	Документы.БанковскийСчет.СВИФТБанка КАК СВИФТБанка,
	|	Документы.БанковскийСчет.СВИФТБанкаДляРасчетов КАК СВИФТБанкаДляРасчетов,
	|	Документы.БанковскийСчет.АдресБанка КАК АдресБанка,
	|	Документы.БанковскийСчет.АдресБанкаДляРасчетов КАК АдресБанкаДляРасчетов,
	|	Документы.БанковскийСчет.СчетВБанкеДляРасчетов КАК СчетВБанкеДляРасчетов,
	|	Документы.БанковскийСчет.НомерСчета КАК НомерБанковскогоСчета,
	|	ВЫБОР
	|		КОГДА Документы.БанковскийСчет.РучноеИзменениеРеквизитовБанка
	|			ТОГДА Документы.БанковскийСчет.БИКБанка
	|		ИНАЧЕ КлассификаторБанков.Код
	|	КОНЕЦ КАК БИКБанк,
	|	ВЫБОР
	|		КОГДА Документы.БанковскийСчет.РучноеИзменениеРеквизитовБанка
	|			ТОГДА Документы.БанковскийСчет.НаименованиеБанка
	|		ИНАЧЕ КлассификаторБанков.Наименование
	|	КОНЕЦ КАК НаименованиеБанка,
	|	ВЫБОР
	|		КОГДА Документы.БанковскийСчет.РучноеИзменениеРеквизитовБанка
	|			ТОГДА Документы.БанковскийСчет.КоррСчетБанка
	|		ИНАЧЕ КлассификаторБанков.КоррСчет
	|	КОНЕЦ КАК КоррСчетБанка,
