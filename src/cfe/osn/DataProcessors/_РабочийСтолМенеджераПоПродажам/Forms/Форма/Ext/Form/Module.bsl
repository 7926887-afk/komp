КонецПроцедуры

&НаСервереБезКонтекста
Функция СобратьДанныеПоЗаказуСервер(ЗаказСсылка)
	
	
	СтруктураСостоянияРасчетов = ПолучитьСостояниеЗаказаКлиента(ЗаказСсылка);
	
	ДанныеПоЗаказу = Новый Структура;
	ДанныеПоЗаказу.Вставить("Проведен",        ПроверитьДокументПроведен(ЗаказСсылка));  
	ДанныеПоЗаказу.Вставить("Закрыт",          ПроверитьДокументНаЗакрыт(ЗаказСсылка));
	ДанныеПоЗаказу.Вставить("ЕстьНабор",       ПроверитьЗаказКлиентаТоварыЕстьНабор(ЗаказСсылка));
	ДанныеПоЗаказу.Вставить("ЕстьКомплект",    ПроверитьЗаказКлиентаТоварыЕстьКомплект(ЗаказСсылка));
	ДанныеПоЗаказу.Вставить("СостояниеЗаказа", СтруктураСостоянияРасчетов.Состояние);
	ДанныеПоЗаказу.Вставить("ОстаткиКОформлениюПоКомплектам", ПроверитьОстаткиКОформлениюПоКомплектам(ЗаказСсылка));
	
	Возврат ДанныеПоЗаказу;
	
КонецФункции // СобратьДанныеПоЗаказуСервер()    

&НаСервереБезКонтекста
Функция СобратьДанныеПоВнутреннемуЗаказуСервер(ЗаказСсылка)
	
	ДанныеПоЗаказу = Новый Структура;
	ДанныеПоЗаказу.Вставить("Проведен",        ПроверитьДокументПроведен(ЗаказСсылка));  
	ДанныеПоЗаказу.Вставить("Закрыт",          ПроверитьДокументНаЗакрыт(ЗаказСсылка));
	
	Возврат ДанныеПоЗаказу;
	
КонецФункции // СобратьДанныеПоВнутреннемуЗаказуСервер()

&НаКлиенте
Процедура СобратьОбработатьДанныеЗаказа()
	
	Если ИдентификаторТекущейСтроки = Элементы.ЗаказыКлиентов.ТекущаяСтрока Тогда
	    Возврат;
	КонецЕсли;  
	
	ИдентификаторТекущейСтроки = Элементы.ЗаказыКлиентов.ТекущаяСтрока;
	
	ТекущиеДанные = Элементы.ЗаказыКлиентов.ТекущиеДанные;
	
	Если ТекущиеДанные = Неопределено Тогда
		Возврат;
	КонецЕсли;

	СсылкаНаДокумент = ТекущиеДанные.Ссылка;
	
	ДанныеЗаполнения = СобратьДанныеПоЗаказуСервер(СсылкаНаДокумент);
	
	ОбновитьДанныеТаблицыТоваровЗаказаНаСервереН(СсылкаНаДокумент);

	
	КнопкаДействияФормыСоздатьЗаявкуНаЗакупку = Элементы.Найти("ФормаСоздатьЗаявкуНаЗакупку");
	Если НЕ КнопкаДействияФормыСоздатьЗаявкуНаЗакупку = Неопределено Тогда
		// Установим доступность кнопки создания заявки на закупку
		КнопкаДействияФормыСоздатьЗаявкуНаЗакупку.Доступность = ДанныеЗаполнения.Проведен И ДанныеЗаполнения.Закрыт;
	КонецЕсли;
	
	КнопкаДействияФормыСоздатьЗаявкуНаДоставку = Элементы.Найти("ФормаСоздатьЗаявкуНаДоставку");
	Если НЕ КнопкаДействияФормыСоздатьЗаявкуНаДоставку = Неопределено Тогда
		// Установим доступность кнопки создания заявки на доставку
		КнопкаДействияФормыСоздатьЗаявкуНаДоставку.Доступность = ДанныеЗаполнения.Проведен И ДанныеЗаполнения.Закрыт;
	КонецЕсли;
	
	КнопкаДействияФормыСоздатьДокументСборкиРазборки = Элементы.Найти("ФормаСоздатьДокументСборкиРазборки");
	Если НЕ КнопкаДействияФормыСоздатьДокументСборкиРазборки = Неопределено Тогда
		
		// Проверим состояние заказа
		ДанныеОСостоянии = ДанныеЗаполнения.СостояниеЗаказа;
		
		АктивироватьКнопку = Ложь;
		Если  (ДанныеОСостоянии = ПредопределенноеЗначение("Перечисление.СостоянияЗаказовКлиентов.ГотовКОбеспечению")
			ИЛИ ДанныеОСостоянии = ПредопределенноеЗначение("Перечисление.СостоянияЗаказовКлиентов.ОжидаетсяОбеспечение")
			ИЛИ ДанныеОСостоянии = ПредопределенноеЗначение("Перечисление.СостоянияЗаказовКлиентов.ГотовКОтгрузке"))
			И (ДанныеЗаполнения.ЕстьКомплект ИЛИ ДанныеЗаполнения.ЕстьНабор) Тогда
			// нужно найти заказ поставщику и оценить его состояние, после чего будет решение о доступности кнопки
			АктивироватьКнопку = ДанныеЗаполнения.ОстаткиКОформлениюПоКомплектам;
		КонецЕсли;
		
		// Установим доступность кнопки создания заявки на закупку
		КнопкаДействияФормыСоздатьДокументСборкиРазборки.Доступность = АктивироватьКнопку И ДанныеЗаполнения.Проведен И ДанныеЗаполнения.Закрыт;
		
	КонецЕсли;
	
	КнопкаДействияФормыСоздатьЗаданиеНаПеревозку = Элементы.Найти("ФормаСоздатьЗаданиеНаПеревозку");
	Если НЕ КнопкаДействияФормыСоздатьЗаданиеНаПеревозку = Неопределено Тогда
		// Установим доступность кнопки создания заявки на доставку
		КнопкаДействияФормыСоздатьЗаданиеНаПеревозку.Доступность = ДанныеЗаполнения.Проведен И ДанныеЗаполнения.Закрыт; 
		
	КонецЕсли;
	
	Флаг = Ложь;
	
	УстановитьОтборПоЗаказу(СсылкаНаДокумент);

КонецПроцедуры

&НаКлиенте
Процедура СобратьОбработатьДанныеВнутреннегоЗаказа()
	                                                           
	//Если ИдентификаторТекущейСтроки = Элементы.ВнутренниеЗаказы.ТекущаяСтрока Тогда
	//    Возврат;
	//КонецЕсли;  
	//
	//ИдентификаторТекущейСтроки = Элементы.ВнутренниеЗаказы.ТекущаяСтрока;
	
	ТекущиеДанные = Элементы.ВнутренниеЗаказы.ТекущиеДанные;
	
	Если ТекущиеДанные = Неопределено Тогда
		Возврат;
	КонецЕсли;

	СсылкаНаДокумент = ТекущиеДанные.Ссылка;
	
	ДанныеЗаполнения = СобратьДанныеПоВнутреннемуЗаказуСервер(СсылкаНаДокумент);
	
	ОбновитьДанныеТаблицыТоваровЗаказаНаСервереН(СсылкаНаДокумент);

	
	КнопкаДействияФормыСоздатьЗаявкуНаЗакупку = Элементы.Найти("ФормаСоздатьЗаявкуНаЗакупку");
	Если НЕ КнопкаДействияФормыСоздатьЗаявкуНаЗакупку = Неопределено Тогда
		// Установим доступность кнопки создания заявки на закупку
		КнопкаДействияФормыСоздатьЗаявкуНаЗакупку.Доступность = ДанныеЗаполнения.Проведен И ДанныеЗаполнения.Закрыт;
	КонецЕсли;
	
	КнопкаДействияФормыСоздатьЗаявкуНаДоставку = Элементы.Найти("ФормаСоздатьЗаявкуНаДоставку");
	Если НЕ КнопкаДействияФормыСоздатьЗаявкуНаДоставку = Неопределено Тогда
		// Установим доступность кнопки создания заявки на доставку
		КнопкаДействияФормыСоздатьЗаявкуНаДоставку.Доступность = ДанныеЗаполнения.Проведен И ДанныеЗаполнения.Закрыт;
	КонецЕсли;
	
	КнопкаДействияФормыСоздатьЗаданиеНаПеревозку = Элементы.Найти("ФормаСоздатьЗаданиеНаПеревозку");
	Если НЕ КнопкаДействияФормыСоздатьЗаданиеНаПеревозку = Неопределено Тогда
		// Установим доступность кнопки создания заявки на доставку
		КнопкаДействияФормыСоздатьЗаданиеНаПеревозку.Доступность = ДанныеЗаполнения.Проведен И ДанныеЗаполнения.Закрыт; 
		
	КонецЕсли;
	
		
	
	Флаг = Ложь;
	
	УстановитьОтборПоЗаказу(СсылкаНаДокумент);

КонецПроцедуры



&НаКлиенте
Процедура ЗаказыКлиентовПередНачаломИзменения(Элемент, Отказ)
//	ОткрытьЗначение(Элемент.ТекущиеДанные.Ссылка);
//	ТекСтрока = Элементы.ЗаказыКлиентов.ТекущаяСтрока.Ссылка;
	ТекСтрока = Элемент.ТекущиеДанные.Ссылка;
	ФЛ = Новый Структура("Ключ", ТекСтрока);
	Форма = ПолучитьФорму("Документ.ЗаказКлиента.ФормаОбъекта", ФЛ);
	Форма.Открыть();
КонецПроцедуры

&НаКлиенте
Процедура ЗаявкиНаДоставкуСписокЗаказыВыбор(Элемент, ВыбраннаяСтрока, Поле, СтандартнаяОбработка)
	Если ( Поле.Имя = "ЗаявкиНаДоставкуСписокЗаказыЗаказКлиента" ) ИЛИ 
		 ( Поле.Имя = "ЗаявкиНаДоставкуСписокЗаказыНомерЗаказа"  ) ИЛИ
		 ( Поле.Имя = "ЗаявкиНаДоставкуСписокЗаказыДатаЗаказа"  ) Тогда
		 
 		СтандартнаяОбработка = Ложь;
		
		ТекДанн = Элементы.ЗаявкиНаДоставкуСписокЗаказы.ТекущиеДанные; 
		 Если ТекДанн <> Неопределено Тогда
		 	ОбъектСсылка = ТекДанн.ЗаказКлиента;
			ПоказатьЗначение(,ОбъектСсылка);
		 КонецЕсли;
		 
	 КонецЕсли;
	 
КонецПроцедуры

&НаКлиенте
Процедура ЗаданиеНаПеревозкуСписокРаспоряженияВыбор(Элемент, ВыбраннаяСтрока, Поле, СтандартнаяОбработка)
	
	Если ( Поле.Имя = "ЗаданиеНаПеревозкуСписокРаспоряженияРаспоряжение" ) ИЛИ 
		 ( Поле.Имя = "ЗаданиеНаПеревозкуСписокРаспоряженияСклад"  ) ИЛИ
		 ( Поле.Имя = "ЗаданиеНаПеревозкуСписокРаспоряженияПолучательОтправитель"  ) ИЛИ
		 ( Поле.Имя = "ЗаданиеНаПеревозкуСписокРаспоряженияПеревозчик"  ) Тогда
		 
 		СтандартнаяОбработка = Ложь;
		
		ТекДанн = Элементы.ЗаданиеНаПеревозкуСписокРаспоряжения.ТекущиеДанные; 
		 Если ТекДанн <> Неопределено Тогда
		 	ОбъектСсылка = ТекДанн.Распоряжение;
			ПоказатьЗначение(,ОбъектСсылка);
		 КонецЕсли;
		 
	 КонецЕсли;
	
КонецПроцедуры

&НаКлиенте
Процедура ЗадачиПользователяСписокВыбор(Элемент, ВыбраннаяСтрока, Поле, СтандартнаяОбработка)
	
	ТекущаяСтрокаСписка = ВыбраннаяСтрока;
	СтандартнаяОбработка	 = Ложь;
	
	Если Поле = Элементы.ЗадачиПользователяСписокПредмет Тогда
		ПоказатьЗначение(,Элементы.ЗадачиПользователяСписок.ТекущиеДанные.Предмет);
	Иначе
		ПоказатьЗначение(,Элементы.ЗадачиПользователяСписок.ТекущиеДанные.Ссылка);
	КонецЕсли;
	
КонецПроцедуры

&НаКлиенте
Процедура ГруппаРазделыРабочегоСтолаПриСменеСтраницы(Элемент, ТекущаяСтраница)
	
	//**ДОБАВЛЕНО Максимов В.А

	Если ТекущаяСтраница.Имя = "ГруппаЗадачиПльзователя" Тогда
		ОбновитьСписокЗадачНаСервере();
		Элементы.ФормаГруппа1.ПодчиненныеЭлементы.ФормаСчетНаОплату.Доступность = Ложь;
		Элементы.ФормаГруппа1.ПодчиненныеЭлементы.ФормаРеализация.Доступность 	= Ложь;		
		Элементы.ФормаГруппа1.ПодчиненныеЭлементы.ФормаПечатьТОРГ12.Доступность = Ложь;
		Элементы.ФормаГруппа1.ПодчиненныеЭлементы.ФормаСчетНаОплатуСФаксимиле.Доступность	= Ложь;
	КонецЕсли;
	
	Если ТекущаяСтраница.Имя = "ГруппаРеализацииТоваровУслуг" Тогда
		УстановитьОтменитьОтборРеализация(Неопределено);	
		Элементы.ФормаГруппа1.ПодчиненныеЭлементы.ФормаСчетНаОплату.Доступность = Ложь;
		Элементы.ФормаГруппа1.ПодчиненныеЭлементы.ФормаРеализация.Доступность 	= Истина;	
		Элементы.ФормаГруппа1.ПодчиненныеЭлементы.ФормаПечатьТОРГ12.Доступность = Истина;
		Элементы.ФормаГруппа1.ПодчиненныеЭлементы.ФормаСчетНаОплатуСФаксимиле.Доступность	= Ложь;
	КонецЕсли;	
	
	Если ТекущаяСтраница.Имя = "ГруппаЗаказыКлиентов" Тогда
		Элементы.ФормаГруппа1.ПодчиненныеЭлементы.ФормаРеализация.Доступность 	= Ложь;
		Элементы.ФормаГруппа1.ПодчиненныеЭлементы.ФормаСчетНаОплату.Доступность = Истина;
		Элементы.ФормаГруппа1.ПодчиненныеЭлементы.ФормаПечатьТОРГ12.Доступность = Ложь;
		Элементы.ФормаГруппа1.ПодчиненныеЭлементы.ФормаСчетНаОплатуСФаксимиле.Доступность	= Истина;
	КонецЕсли;
	
	Если ТекущаяСтраница.Имя = "ГруппаЗаказыНаСборку" Тогда
		УстановитьОтменитьОтборЗаказНаСборку(Неопределено);	
		Элементы.ФормаГруппа1.ПодчиненныеЭлементы.ФормаСчетНаОплату.Доступность = Ложь;
		Элементы.ФормаГруппа1.ПодчиненныеЭлементы.ФормаРеализация.Доступность 	= Ложь;
		Элементы.ФормаГруппа1.ПодчиненныеЭлементы.ФормаПечатьТОРГ12.Доступность = Ложь;
		Элементы.ФормаГруппа1.ПодчиненныеЭлементы.ФормаСчетНаОплатуСФаксимиле.Доступность	= Ложь;
	КонецЕсли;		
	
	Если ТекущаяСтраница.Имя = "ГруппаЗаявкиНаДоставку" Тогда	
		Элементы.ФормаГруппа1.ПодчиненныеЭлементы.ФормаСчетНаОплату.Доступность = Ложь;
		Элементы.ФормаГруппа1.ПодчиненныеЭлементы.ФормаРеализация.Доступность 	= Ложь;
		Элементы.ФормаГруппа1.ПодчиненныеЭлементы.ФормаПечатьТОРГ12.Доступность = Ложь;
		Элементы.ФормаГруппа1.ПодчиненныеЭлементы.ФормаСчетНаОплатуСФаксимиле.Доступность	= Ложь;		
	КонецЕсли;		
		
	//************************
	
КонецПроцедуры

