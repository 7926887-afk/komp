Процедура СчетОферта(Команда)

	ЗаявкаСсылка = Элементы.ЗаказыКлиентов.ТекущиеДанные.Ссылка;
	Если ( ЗаявкаСсылка = Неопределено ) Тогда
		Возврат;
	КонецЕсли;
		
	ПараметрКоманды = Новый Массив;
	ПараметрКоманды.Добавить(ЗаявкаСсылка);
	
	СписокДокументов = Новый СписокЗначений;
	СписокДокументов.Добавить(ЗаявкаСсылка);
	
	ПараметрыПечати  = Новый Структура;
	ПараметрыПечати.Вставить("СписокДокументов"		,  ПоместитьВоВременноеХранилище(СписокДокументов));
	ПараметрыПечати.Вставить("КоличествоЭкземпляров",  1);
	ПараметрыПечати.Вставить("СтруктураМакетаШаблона", Неопределено);
	           
	           
	УправлениеПечатьюКлиент.ВыполнитьКомандуПечати(
		"Обработка.ВПФ_Счет_оферта",
		"ПФ_MXL_СчетОферта",
		ПараметрКоманды,,
		ПараметрыПечати);
		
КонецПроцедуры
