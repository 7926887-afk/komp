&НаКлиенте
Процедура СоздатьЗаявкуНаДоставку(Команда)
	
	Если Элементы.ГруппаРазделыРабочегоСтола.ТекущаяСтраница = Элементы.ГруппаВнутренниеЗаказы Тогда
		
		СтруктураДанных = Новый Структура("Основание, ДокументОснование", ПолучитьСсылкуНаДокументВнутреннийЗаказ(), ПолучитьСсылкуНаДокументВнутреннийЗаказ());
		
		ПараметрыФормы 	= Новый Структура("ЗначенияЗаполнения", СтруктураДанных);
		
		ФормаДокументаЗаявкаНаДоставку = ПолучитьФорму("Документ._ЗаявкаНаДоставку.ФормаОбъекта", ПараметрыФормы);
		
		Если Элементы.ВнутренниеЗаказы.ВыделенныеСтроки.Количество() > 1 Тогда
			ДанныеФормы        = ФормаДокументаЗаявкаНаДоставку.Объект; 	// Получаем объект формы в переменную
			ДокументОснование  = ПустойВнутреннийЗаказ();
			
			ПолучитьЗаказы	   = ВыбранныеЗаказы();
			Если ПолучитьЗаказы = Неопределено Тогда
				Возврат;
			Иначе
				СписокЗаказов  = ПолучитьЗаказы.СписокЗаказов;
			КонецЕсли;
		Иначе			// Элементы.ЗаказыКлиентов.ВыделенныеСтроки.Количество() > 1
			ДанныеФормы        = ФормаДокументаЗаявкаНаДоставку.Объект; 	// Получаем объект формы в переменную
			ДокументОснование  = ПолучитьСсылкуНаДокументВнутреннийЗаказ(); 	// Заказ клиента
			СписокЗаказов 	   = Неопределено;
			
			Если НЕ ПроверитьДокументПроведен(ДокументОснование) Тогда
				Возврат;
			КонецЕсли;
			
			Если НЕ ПроверитьДокументНаЗакрыт(ДокументОснование) Тогда
				Возврат;
			КонецЕсли; 
			
		КонецЕсли;		// Элементы.ЗаказыКлиентов.ВыделенныеСтроки.Количество() > 1 	 
		
		// Заполняем документ на сервере
		ПараметрыЗаполнения    = Новый Структура("ДанныеФормы, ДокументОснование, СписокЗаказов", ДанныеФормы, ДокументОснование, СписокЗаказов);
		ЗаполнитьЗаявкуНаСервере(ПараметрыЗаполнения);
		
		КопироватьДанныеФормы(ПараметрыЗаполнения.ДанныеФормы, ФормаДокументаЗаявкаНаДоставку.Объект); // копируем наш объект в объект формы и далее открываем ее

	ИНачеЕсли Элементы.ГруппаРазделыРабочегоСтола.ТекущаяСтраница = Элементы.ГруппаЗаказыКлиентов Тогда
		
		СтруктураДанных = Новый Структура("Основание, ДокументОснование", ПолучитьСсылкуНаДокументЗаказКлиента(), ПолучитьСсылкуНаДокументЗаказКлиента());
		
		ПараметрыФормы 	= Новый Структура("ЗначенияЗаполнения", СтруктураДанных);
		
		ФормаДокументаЗаявкаНаДоставку = ПолучитьФорму("Документ._ЗаявкаНаДоставку.ФормаОбъекта", ПараметрыФормы);
		
		Если Элементы.ЗаказыКлиентов.ВыделенныеСтроки.Количество() > 1 Тогда
			ДанныеФормы        = ФормаДокументаЗаявкаНаДоставку.Объект; 	// Получаем объект формы в переменную
			ДокументОснование  = ПустойЗаказ();
			
			ПолучитьЗаказы	   = ВыбранныеЗаказы();
			Если ПолучитьЗаказы = Неопределено Тогда
				Возврат;
			Иначе
				СписокЗаказов  = ПолучитьЗаказы.СписокЗаказов;
			КонецЕсли;
		Иначе			// Элементы.ЗаказыКлиентов.ВыделенныеСтроки.Количество() > 1
			ДанныеФормы        = ФормаДокументаЗаявкаНаДоставку.Объект; 	// Получаем объект формы в переменную
			ДокументОснование  = ПолучитьСсылкуНаДокументЗаказКлиента(); 	// Заказ клиента
			СписокЗаказов 	   = Неопределено;
			
			Если НЕ ПроверитьДокументПроведен(ДокументОснование) Тогда
				Возврат;
			КонецЕсли;
			
			Если НЕ ПроверитьДокументНаЗакрыт(ДокументОснование) Тогда
				Возврат;
			КонецЕсли; 
			
		КонецЕсли;		// Элементы.ЗаказыКлиентов.ВыделенныеСтроки.Количество() > 1 	 
		
		// Заполняем документ на сервере
		ПараметрыЗаполнения    = Новый Структура("ДанныеФормы, ДокументОснование, СписокЗаказов", ДанныеФормы, ДокументОснование, СписокЗаказов);
		ЗаполнитьЗаявкуНаСервере(ПараметрыЗаполнения);
		
		КопироватьДанныеФормы(ПараметрыЗаполнения.ДанныеФормы, ФормаДокументаЗаявкаНаДоставку.Объект); // копируем наш объект в объект формы и далее открываем ее
		
	КонецЕсли; 

	ФормаДокументаЗаявкаНаДоставку.Открыть();

КонецПроцедуры

