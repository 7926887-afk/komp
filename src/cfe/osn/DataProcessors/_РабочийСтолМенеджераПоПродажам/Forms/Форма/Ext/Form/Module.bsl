&НаКлиенте
Процедура Подключаемый_ОбновитьДанныеТаблиц()
	ТекущиеДанные = Элементы.ЗаказыКлиентов.ТекущиеДанные; // Возвращает структуру с данными
	Если ТипЗнч(ТекущиеДанные) = Тип("ДанныеФормыСтруктура") И ТекущиеДанные.Свойство("Ссылка")	Тогда
		СсылкаНаДокумент = ТекущиеДанные.Ссылка;
	Иначе
		СсылкаНаДокумент = ПолучитьПустуюСсылкуНаЗаказКлиента();
	КонецЕсли;

	
	Если НЕ ( Флаг ) Тогда  
		Если НЕ ( СсылкаНаДокумент.Пустая() ) И ( СсылкаНаДокумент <> ЭтаФорма.мТекущийЗаказКлиента ) Тогда
			ОбновитьДанныеТаблицыТоваровЗаказаНаСервереН(СсылкаНаДокумент );
			ЭтаФорма.мТекущийЗаказКлиента = СсылкаНаДокумент;
		КонецЕсли;	
	КонецЕсли;	
	
КонецПроцедуры

&НаКлиенте
Процедура ОткрытьВнешнийОтчет(Команда)
	
	ВнешнийОтчет = ПолучитьСсылкуНаВнешнийОтчетНаСервере(Неопределено);
	
	ИмяОбработкиСлужебное = ДополнительныеОтчетыИОбработкиВызовСервера.ПодключитьВнешнююОбработку(ВнешнийОтчет);
	
	ОткрытьФорму("ВнешнийОтчет." + ИмяОбработкиСлужебное + ".Форма")
	
КонецПроцедуры

&НаСервере
Функция ПолучитьСсылкуНаВнешнийОтчетНаСервере(Отчет)
	Возврат Справочники.ДополнительныеОтчетыИОбработки.НайтиПоНаименованию("АнализПоказателейЗаказов7.9").Ссылка;	
КонецФункции

&НаКлиенте
Процедура СвязанныеДокументы(Команда)
	
	Если ЭтаФорма.ТекущийЭлемент.Имя = "ЗаказыКлиентов" Тогда
		МенюОтчетыУТКлиент.СтруктураПодчиненности(Элементы.ЗаказыКлиентов.ТекущиеДанные.Ссылка,Неопределено);
	ИначеЕсли ЭтаФорма.ТекущийЭлемент.Имя = "ЗаказНаСборкуСписок" Тогда
		МенюОтчетыУТКлиент.СтруктураПодчиненности(Элементы.ЗаказНаСборкуСписок.ТекущаяСтрока,Неопределено);
	ИначеЕсли ЭтаФорма.ТекущийЭлемент.Имя = "РеализацияТоваровУслугСписок" Тогда 	
		МенюОтчетыУТКлиент.СтруктураПодчиненности(Элементы.РеализацияТоваровУслугСписок.ТекущаяСтрока,Неопределено);
	ИначеЕсли ЭтаФорма.ТекущийЭлемент.Имя = "ЗаявкиНаДоставкуСписок" Тогда
		МенюОтчетыУТКлиент.СтруктураПодчиненности(Элементы.ЗаявкиНаДоставкуСписок.ТекущаяСтрока,Неопределено);
	ИначеЕсли ЭтаФорма.ТекущийЭлемент.Имя = "ВнутренниеЗаказы" Тогда    //##
		МенюОтчетыУТКлиент.СтруктураПодчиненности(Элементы.ВнутренниеЗаказы.ТекущаяСтрока,Неопределено);
	КонецЕсли;	
		
КонецПроцедуры

