&НаСервере
Процедура ГруппыДоступаДляЗаявкаНаДоставку(МассивОрганизаций, СписокГруппДоступа)
	
	Если НЕ РольДоступна("АдминистраторСистемы") Тогда
		Если НЕ РольДоступна("Администрирование") Тогда	
			Запрос = Новый Запрос;
			Запрос.Текст = 
			 "ВЫБРАТЬ
			 |	ГруппыДоступа.Ссылка КАК Ссылка,
			 |	ГруппыДоступа.Пользователи.(
			 |		Пользователь КАК Пользователь
			 |	) КАК Пользователи,
			 |	ГруппыДоступа.ЗначенияДоступа.(
			 |		ЗначениеДоступа КАК ЗначениеДоступа
			 |	) КАК ЗначенияДоступа
			 |ИЗ
			 |	Справочник.ГруппыДоступа КАК ГруппыДоступа
			 |ГДЕ
			 |	ГруппыДоступа.Пользователи.Пользователь = &Пользователь";
			
			Запрос.УстановитьПараметр("Пользователь", Пользователи.ТекущийПользователь());
			
			ГруппыДоступа = Запрос.Выполнить().Выгрузить();

			Для Каждого Группа Из ГруппыДоступа Цикл
				Для Каждого Стр Из Группа.ЗначенияДоступа Цикл
					Если ТипЗнч(Стр.ЗначениеДоступа) = Тип("СправочникСсылка.ГруппыДоступаПартнеров") Тогда
			 			СписокГруппДоступа.Добавить(Стр.ЗначениеДоступа);
					КонецЕсли;	
					Если ТипЗнч(Стр.ЗначениеДоступа) = Тип("СправочникСсылка.Организации") Тогда
						МассивОрганизаций.Добавить(Стр.ЗначениеДоступа);
					КонецЕсли;	
				КонецЦикла;
			КонецЦикла;
	
			НовыйЗапрос = Новый Запрос;
			НовыйЗапрос.Текст =
			"ВЫБРАТЬ
