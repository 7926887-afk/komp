    НовыйДокументЗаказКлиента.Статус			 = Перечисления.СтатусыВнутреннихЗаказов.КВыполнению;		// НЕ Согласован
    НовыйДокументЗаказКлиента.Приоритет			 = Справочники.Приоритеты.НайтиПоНаименованию("Средний");
    НовыйДокументЗаказКлиента.Дата				 = ТекущаяДата();
	//**Изменено Максимов В.А. 19.10.20
	НовыйДокументЗаказКлиента.Автор  			    = Пользователи.ТекущийПользователь();	
