&НаСервере
Функция ВыбранныеЗаявкиНаДоставку()
	
	СтрОшибок				= НСтр("ru = ''");
	
	СписокНоменклатуры		= ПолучитьОтборПоТаблицеПотребности();
	
	Если СписокНоменклатуры.Количество() > 0 Тогда
		мСписокНоменклатуры = _ДоработкиСлужебный.ПреобразоватьТаблицуЗначенийВМассив(СписокНоменклатуры);
		Возврат Новый Структура("СписокНоменклатуры", мСписокНоменклатуры);
	Иначе
		Возврат Неопределено;
	КонецЕсли;
	
КонецФункции // ВыбранныеЗаявкиНаДоставку()

&НаКлиенте
Процедура СоздатьЗаказПоставщику(Команда)
	
	ФормаДокумента		  = ПолучитьФорму("Документ.ЗаказПоставщику.ФормаОбъекта");
	ДанныеФормы       	  = ФормаДокумента.Объект; 										// Получаем объект формы в переменную
	
	ДокументОснование	  = ПолучитьПустуюСсылкуНаДокумент("ЗаявкаНаЗакупку");			// ДокументОснование для заказа поставщику
   	ВыбраннаяНоменклатура = ВыбранныеЗаявкиНаДоставку();
	
	Если ВыбраннаяНоменклатура = Неопределено Тогда
		Возврат
	КонецЕсли;
	
	// Заполняем документ на сервере
	ПараметрыЗаполнения  = Новый Структура("ДанныеФормы, ДокументОснование, СписокНоменклатуры, РабочийСтолЗакупок", ДанныеФормы, Неопределено, ВыбраннаяНоменклатура.СписокНоменклатуры, Истина);
	ЗаполнитьДокументНаСервере(ПараметрыЗаполнения, "ЗаказПоставщику");
	
  	КопироватьДанныеФормы(ПараметрыЗаполнения.ДанныеФормы, ФормаДокумента.Объект);	// копируем наш объект в объект формы и далее открываем ее
	Если ЗначениеЗаполнено(ПараметрыЗаполнения.ДанныеФормы.ДокументОснование) Тогда
		ФормаДокумента.Элементы.ГруппаОснование.Видимость = Истина;
	КонецЕсли;		//  		

	ФормаДокумента.Открыть();
	
//  	ОбработатьПотребностьПоЗаказам(ВыбраннаяНоменклатура);
	
	Элементы.ПотребностьПоЗаказам.Обновить();
	
КонецПроцедуры

