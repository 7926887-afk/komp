// Получить заявку на закупку по данным списка документов
&НаКлиенте
Функция ПолучитьСсылкуНаДокументЗаявкаНаЗакупку()

	ТекущиеДанные = Элементы.ПотребностьПоЗаказам.ТекущиеДанные;		// Возвращает структуру с данными
	
	Если ТипЗнч(ТекущиеДанные) = Тип("ДанныеФормыСтруктура")
		И ТекущиеДанные.Свойство("Ссылка")
	Тогда
		СсылкаНаДокумент = ТекущиеДанные.Ссылка;
	Иначе
		СсылкаНаДокумент = ПолучитьПустуюСсылкуНаДокумент("ЗаявкаНаЗакупку");
	КонецЕсли;
	
	ТекущаяЗаявкаНаЗакупку = СсылкаНаДокумент;
	Возврат СсылкаНаДокумент;

КонецФункции // ПолучитьСсылкуНаДокументЗаявкаНаЗакупку()

&НаСервере
Функция ПолучитьТекстЗапросаЗаявки()

	ЗапросТекст = 
	"ВЫБРАТЬ
	|	ЗаявкаНаЗакупкуТовары.КомментарийПродажа КАК КомментарийПродажа,
	|	ЗаявкаНаЗакупкуТовары.КомментарийЗакупка КАК КомментарийЗакупка,
	|	ЗаявкаНаЗакупкуТовары.Ссылка.Номер КАК НомерЗаявки,
	|	ЗаявкаНаЗакупкуТовары.Ссылка.Дата КАК ДатаЗаявки,
	|	ЗаявкаНаЗакупкуТовары.Назначение КАК Назначение,
	|	ЗаявкаНаЗакупкуТовары.Назначение.Заказ КАК ЗаказКлиента,
	|	ЗаявкаНаЗакупкуТовары.Назначение.Заказ.Номер КАК НомерЗаказаКлиента,
	|	ЗаявкаНаЗакупкуТовары.Номенклатура КАК Номенклатура,
	|	ЗаявкаНаЗакупкуТовары.Номенклатура.Артикул КАК Артикул,
	|	ЗаявкаНаЗакупкуТовары.Характеристика КАК Характеристика,
	|	ЗаявкаНаЗакупкуТовары.Упаковка КАК Упаковка,
	|	ЗаявкаНаЗакупкуТовары.КоличествоУпаковок КАК КоличествоУпаковок,
	|	ЗаявкаНаЗакупкуТовары.КоличествоУпаковок - ЗаявкаНаЗакупкуТовары.ЗаказаноКоличествоУпаковок КАК КоличествоУпаковокОстаток,
	|	ЗаявкаНаЗакупкуТовары.Количество - ЗаявкаНаЗакупкуТовары.ЗаказаноКоличество КАК Количество,
	|	ЗаявкаНаЗакупкуТовары.Отменено КАК Отменено,
	|	ЗаявкаНаЗакупкуТовары.Ссылка КАК Ссылка,
	|	ЗаявкаНаЗакупкуТовары.Ссылка.Приоритет КАК Приоритет,
	|	ЗаявкаНаЗакупкуТовары.НомерСтроки КАК СтрокаЗаказа,
	|	ЗаявкаНаЗакупкуТовары.Менеджер КАК Менеджер,
	|	ЗаявкаНаЗакупкуТовары.ЗаказаноКоличество КАК ЗаказаноКоличество,
	|	ЗаявкаНаЗакупкуТовары.ЗаказаноКоличествоУпаковок КАК ЗаказаноКоличествоУпаковок,
	|	ЗаявкаНаЗакупкуТовары.Заказано КАК Заказано,
	|	ЗаявкаНаЗакупкуТовары.ЗаказПоставщику КАК ЗаказПоставщику,
	|	ЗаявкаНаЗакупкуТовары._УИДЗаказ КАК _УИДЗаказ,
	|	ЗаявкаНаЗакупкуТовары._УИДЗакупка КАК _УИДЗакупка,
	|	ЛОЖЬ КАК Отметка,
	|	ЗаявкаНаЗакупкуТовары.Номенклатура КАК НоменклатураТхт,
	|	ЗаявкаНаЗакупкуТовары.Номенклатура.Артикул КАК АртикулТхт,
	|	ЗаявкаНаЗакупкуТовары.Ссылка.Номер КАК НомерЗаявкиТхт,
	|	ЗаявкаНаЗакупкуТовары.Менеджер КАК МенеджерТхт,
	|	ЗаявкаНаЗакупкуТовары.Назначение.Заказ.Номер КАК НомерЗаказаТхт
	|ИЗ
	|	Документ.ЗаявкаНаЗакупку.Товары КАК ЗаявкаНаЗакупкуТовары
	|ГДЕ
	|	ЗаявкаНаЗакупкуТовары.Отменено = ЛОЖЬ
	|	И НЕ ЗаявкаНаЗакупкуТовары.Ссылка.Статус = &Статус
	|	И НЕ ЗаявкаНаЗакупкуТовары.КоличествоУпаковок = 0
	|	И НЕ ЗаявкаНаЗакупкуТовары.Количество = 0
	|	И ЗаявкаНаЗакупкуТовары.Ссылка.Проведен = ИСТИНА
	|	И ЗаявкаНаЗакупкуТовары.Ссылка.ПометкаУдаления = ЛОЖЬ
	|	И &Манагер
	|	И ЗаявкаНаЗакупкуТовары.Заказано = ЛОЖЬ
	|	И &Поиск
	|
	|УПОРЯДОЧИТЬ ПО
	|	Номенклатура,
	|	Ссылка";
	
	Возврат ЗапросТекст;
	
КонецФункции

&НаСервере
Функция ВыбратьДаннынПоНоменклатуре(Знач СтруктураПараметров)

	ОстатокЗаказ = 0;
	ОстатокСклад = 0;
	
	Запрос = Новый Запрос;
	Запрос.Текст = 
	"ВЫБРАТЬ
	|	ЗаказыПоставщикамОстатки.Номенклатура КАК Номенклатура,
	|	ЕСТЬNULL(ЗаказыПоставщикамОстатки.ЗаказаноОстаток, 0) КАК ОстатокЗаказ,
	|	0 КАК ОстатокСклад
	|ПОМЕСТИТЬ ТабОстатки
	|ИЗ
	|	РегистрНакопления.ЗаказыПоставщикам.Остатки(
	|			&ДатаКон,
	|			Номенклатура = &Номенклатура
	|				И Характеристика = &Характеристика) КАК ЗаказыПоставщикамОстатки
	|
	|ОБЪЕДИНИТЬ ВСЕ
	|
	|ВЫБРАТЬ
	|	ТоварыНаСкладахОстатки.Номенклатура,
	|	0,
	|	ЕСТЬNULL(ТоварыНаСкладахОстатки.ВНаличииОстаток, 0)
	|ИЗ
	|	РегистрНакопления.ТоварыНаСкладах.Остатки(
	|			&ДатаКон,
	|			Номенклатура = &Номенклатура
	|				И Характеристика = &Характеристика) КАК ТоварыНаСкладахОстатки
	|;
	|
	|////////////////////////////////////////////////////////////////////////////////
	|ВЫБРАТЬ
	|	ТабОстатки.Номенклатура КАК Номенклатура,
	|	СУММА(ТабОстатки.ОстатокЗаказ) КАК ОстатокЗаказ,
	|	СУММА(ТабОстатки.ОстатокСклад) КАК ОстатокСклад
	|ИЗ
	|	ТабОстатки КАК ТабОстатки
	|
	|СГРУППИРОВАТЬ ПО
	|	ТабОстатки.Номенклатура";
	
	Запрос.УстановитьПараметр("ДатаКон", 		КонецДня(ТекущаяДата()));
	Запрос.УстановитьПараметр("Номенклатура", 	СтруктураПараметров.Номенклатура);
	Запрос.УстановитьПараметр("Характеристика", СтруктураПараметров.Характеристика);
	
	Результат = Запрос.Выполнить();
	Выборка = Результат.Выбрать();
	Пока Выборка.Следующий() Цикл
		ОстатокЗаказ = Выборка.ОстатокЗаказ;
		ОстатокСклад = Выборка.ОстатокСклад;
	КонецЦикла;
	
	Запрос = Новый Запрос;
	Запрос.Текст = 
	"ВЫБРАТЬ
	|	ЗаявкаНаЗакупкуТовары.Номенклатура КАК Номенклатура,
	|	ЗаявкаНаЗакупкуТовары.Характеристика КАК Характеристика,
	|	СУММА(ЗаявкаНаЗакупкуТовары.КоличествоУпаковок) КАК ОстатокЗаявка
	|ИЗ
	|	Документ.ЗаявкаНаЗакупку.Товары КАК ЗаявкаНаЗакупкуТовары
	|ГДЕ
	|	ЗаявкаНаЗакупкуТовары.Ссылка.ПометкаУдаления = ЛОЖЬ
	|	И ЗаявкаНаЗакупкуТовары.Ссылка.Проведен = ИСТИНА
	|	И ЗаявкаНаЗакупкуТовары.Заказано = ЛОЖЬ
	|	И ЗаявкаНаЗакупкуТовары.Отменено = ЛОЖЬ
	|	И ЗаявкаНаЗакупкуТовары.Номенклатура = &Номенклатура
	|	И ЗаявкаНаЗакупкуТовары.Характеристика = &Характеристика
	|	И ЗаявкаНаЗакупкуТовары.Ссылка.Статус В(&Статус)
	|
	|СГРУППИРОВАТЬ ПО
	|	ЗаявкаНаЗакупкуТовары.Номенклатура,
	|	ЗаявкаНаЗакупкуТовары.Характеристика";
	
	Запрос.УстановитьПараметр("Номенклатура", 	СтруктураПараметров.Номенклатура);
	Запрос.УстановитьПараметр("Характеристика", СтруктураПараметров.Характеристика);
	СписокСтатусов = Новый СписокЗначений;
	
	СписокСтатусов.Добавить(Перечисления.СтатусыЗаказовПоставщикам.Согласован);
	СписокСтатусов.Добавить(Перечисления.СтатусыЗаказовПоставщикам.Подтвержден);
	Запрос.УстановитьПараметр("Статус", 		СписокСтатусов);

	Результат = Запрос.Выполнить();
	Выборка = Результат.Выбрать();
	Пока Выборка.Следующий() Цикл
		ОстатокЗаявка = Выборка.ОстатокЗаявка;
	КонецЦикла;
	
	
	
	СтруктураПараметров.Вставить("ОстатокЗаказ",  ОстатокЗаказ);
	СтруктураПараметров.Вставить("ОстатокСклад",  ОстатокСклад);
	СтруктураПараметров.Вставить("ОстатокЗаявка", ОстатокЗаявка);
	
	Возврат СтруктураПараметров;

КонецФункции	// ВыбратьДаннынПоНоменклатуре()

&НаСервере
Функция Получить_ТЗ_Из_ДинамическогоСписка()
 
	Схема               = Элементы.ПотребностьПоЗаказам.ПолучитьИсполняемуюСхемуКомпоновкиДанных();
	Настройки           = Элементы.ПотребностьПоЗаказам.ПолучитьИсполняемыеНастройкиКомпоновкиДанных();
	
	КомпоновщикМакета   = Новый КомпоновщикМакетаКомпоновкиДанных();
	МакетКомпоновки     = КомпоновщикМакета.Выполнить(Схема, Настройки, , , Тип("ГенераторМакетаКомпоновкиДанныхДляКоллекцииЗначений"));
	
	ПроцессорКомпоновки = Новый ПроцессорКомпоновкиДанных;
	ПроцессорКомпоновки.Инициализировать(МакетКомпоновки);
	
	ПроцессорВывода     = Новый ПроцессорВыводаРезультатаКомпоновкиДанныхВКоллекциюЗначений;
	
	ТЗ                  = Новый ТаблицаЗначений;
	ПроцессорВывода.УстановитьОбъект(ТЗ); 
	ПроцессорВывода.Вывести(ПроцессорКомпоновки); 
	
	Возврат ТЗ;
 
КонецФункции

&НаСервере
Функция ПолучитьОтборПоТаблицеПотребности(Номенклатура = Неопределено)
	
	МенеджерВТ = Новый МенеджерВременныхТаблиц;
	
	ТекстЗапроса = 
	"ВЫБРАТЬ
	|	ВыбраннаяНоменклатура.Номенклатура КАК Номенклатура,
	|	&Характеристика КАК Характеристика,
	|	ВыбраннаяНоменклатура.Назначение КАК Назначение,
	|	ВыбраннаяНоменклатура.Артикул КАК Артикул,
	|	ВыбраннаяНоменклатура.КоличествоУпаковок КАК Количество,
	|	ВыбраннаяНоменклатура.Упаковка КАК Упаковка,
	|	ВыбраннаяНоменклатура.Отметка КАК Отметка,
	|	ВыбраннаяНоменклатура.Ссылка КАК Заявка,
	|	ВыбраннаяНоменклатура._УИДЗаказ КАК _УИДЗаказ,
	|	ВыбраннаяНоменклатура._УИДЗакупка КАК _УИДЗакупка,
	|	ВыбраннаяНоменклатура.СтрокаЗаказа КАК СтрокаЗаказа
	|ПОМЕСТИТЬ СписокНоменклатуры
	|ИЗ
	|	&ТаблицаЗначений КАК ВыбраннаяНоменклатура
	|ГДЕ
	|	&Отбор";
	Если Номенклатура = Неопределено Тогда
		ТекстЗапроса = СтрЗаменить(ТекстЗапроса, "&Отбор", "ВыбраннаяНоменклатура.Отметка = ИСТИНА");
	Иначе			// Номенклатура = Неопределено
		ТекстЗапроса = СтрЗаменить(ТекстЗапроса, "&Отбор", "ВыбраннаяНоменклатура.Номенклатура = &Номенклатура");
	КонецЕсли;		// Номенклатура = Неопределено
	
	Запрос = Новый Запрос;
	Запрос.МенеджерВременныхТаблиц = МенеджерВТ;
	
	Запрос.Текст = ТекстЗапроса;
	
	Если Не Номенклатура = Неопределено Тогда
		Запрос.УстановитьПараметр("Номенклатура", Номенклатура);
	КонецЕсли;		// Номенклатура = Неопределено
	
	//ТЗ = Объект.ПотребностьПоЗаказам.Выгрузить();
	ТЗ = Получить_ТЗ_Из_ДинамическогоСписка();
	Запрос.УстановитьПараметр("ТаблицаЗначений", ТЗ);
	
	Если ТЗ.Колонки.Найти("Характеристика") <> Неопределено Тогда
		Запрос.Текст = СтрЗаменить(Запрос.Текст, "&Характеристика КАК Характеристика,", "ВыбраннаяНоменклатура.Характеристика КАК Характеристика,");
	Иначе
		Запрос.Текст = СтрЗаменить(Запрос.Текст, "&Характеристика КАК Характеристика,", "");
	КонецЕсли;
	
	Результат = Запрос.Выполнить();
	
	ЗапросПоНоменклатуре = Новый Запрос;
	ЗапросПоНоменклатуре.МенеджерВременныхТаблиц = МенеджерВТ;
	
	ЗапросПоНоменклатуре.Текст = 
	"ВЫБРАТЬ
	|	СписокНоменклатуры.Номенклатура КАК Номенклатура,
	|	&Характеристика КАК Характеристика,
	|	СписокНоменклатуры.Назначение КАК Назначение,
	|	СписокНоменклатуры.Артикул КАК Артикул,
	|	СписокНоменклатуры.Количество КАК Количество,
	|	СписокНоменклатуры.Упаковка КАК Упаковка,
	|	СписокНоменклатуры.Отметка КАК Отметка,
	|	СписокНоменклатуры.Заявка КАК Заявка,
	|	СписокНоменклатуры.СтрокаЗаказа КАК СтрокаЗаказа,
	|	СписокНоменклатуры._УИДЗаказ КАК _УИДЗаказ,
	|	СписокНоменклатуры._УИДЗакупка КАК _УИДЗакупка
	|ИЗ
	|	СписокНоменклатуры КАК СписокНоменклатуры";
	
	

	Если ТЗ.Колонки.Найти("Характеристика") <> Неопределено Тогда
		ЗапросПоНоменклатуре.Текст = СтрЗаменить(ЗапросПоНоменклатуре.Текст, "&Характеристика КАК Характеристика,", "СписокНоменклатуры.Характеристика,");
	Иначе
		ЗапросПоНоменклатуре.Текст = СтрЗаменить(ЗапросПоНоменклатуре.Текст, "&Характеристика КАК Характеристика,", "");
	КонецЕсли;

	Результат = ЗапросПоНоменклатуре.Выполнить();
	
	Возврат Результат.Выгрузить();
	
КонецФункции // ПолучитьОтборПоТаблицеПотребности()

&НаСервере
Процедура ОбработатьПотребностьПоЗаказам(ВыбраннаяНоменклатура)
	
	СписокНоменклатуры	  = ВыбраннаяНоменклатура.СписокНоменклатуры;
	УдаляемыеСтроки		  = Новый ТаблицаЗначений;
	УдаляемыеСтроки.Колонки.Добавить("Строка");
	
	Для Каждого ТекСтрока Из СписокНоменклатуры Цикл
		СтрокаПотребности = Объект.ПотребностьПоЗаказам.Получить(ТекСтрока.НомерСтроки - 1);
		Если ТекСтрока.Количество < СтрокаПотребности.КоличествоУпаковокОстаток Тогда
			СтрокаПотребности.КоличествоУпаковок = СтрокаПотребности.КоличествоУпаковокОстаток - ТекСтрока.Количество;
			СтрокаПотребности.Отметка = Ложь;
		КонецЕсли 
	КонецЦикла;		// ТекСтрока
	
	СтруктураДляПоиска = Новый Структура("Отметка", Истина);
	МассивУдаляемыхСтрок = Объект.ПотребностьПоЗаказам.НайтиСтроки(СтруктураДляПоиска);
	Для Каждого Строка Из МассивУдаляемыхСтрок Цикл
		Объект.ПотребностьПоЗаказам.Удалить(Строка);
	КонецЦикла;		// Строка Из 
	
КонецПроцедуры	// ОбработатьПотребностьПоЗаказам(ВыбраннаяНоменклатура)()

&НаКлиенте
Процедура РазбитьСтрокуЗаявкиПослеВводаЧислаНаКлинете(Количество, ДополнительныеПараметры) Экспорт
	
	ЧислоВведено = Количество <> Неопределено;

	Если Не ЧислоВведено Тогда
		Возврат;
	ИначеЕсли Количество = 0 Тогда
		ТекстСообщения = НСтр("ru = 'Количество в новой строке не может быть равно нулю.'");
//		Оповещение = Новый ОписаниеОповещения("РазбитьСтрокуЗаявкиЗавершение", ДополнительныеПараметры);
//		ПоказатьПредупреждение(Оповещение,ТекстСообщения);
		ПоказатьПредупреждение(,ТекстСообщения);
		Возврат;
	ИначеЕсли ДополнительныеПараметры.КоличествоПоиск >= 0  И Количество < 0 Тогда
		ТекстСообщения = НСтр("ru = 'Количество в новой строке не может быть отрицательным.'");
//		Оповещение = Новый ОписаниеОповещения("РазбитьСтрокуЗаявкиЗавершение", ДополнительныеПараметры);
//		ПоказатьПредупреждение(Оповещение,ТекстСообщения);
		ПоказатьПредупреждение(,ТекстСообщения);
		Возврат;
	ИначеЕсли ДополнительныеПараметры.КоличествоПоиск >= 0  И Количество >  ДополнительныеПараметры.КоличествоПоиск Тогда
		ТекстСообщения = НСтр("ru = 'Количество в новой строке не может быть больше количества в текущей.'");
//		Оповещение = Новый ОписаниеОповещения("РазбитьСтрокуЗаявкиЗавершение", ДополнительныеПараметры);
//		ПоказатьПредупреждение(Оповещение,ТекстСообщения);
		ПоказатьПредупреждение(,ТекстСообщения);
		Возврат;
	ИначеЕсли Количество =  ДополнительныеПараметры.КоличествоПоиск Тогда
		ТекстСообщения = НСтр("ru = 'Количество в новой строке должно отличаться от количества в текущей.'");
//		Оповещение = Новый ОписаниеОповещения("РазбитьСтрокуЗаявкиЗавершение", ДополнительныеПараметры);
//		ПоказатьПредупреждение(Оповещение,ТекстСообщения);
		ПоказатьПредупреждение(,ТекстСообщения);
		Возврат;
	КонецЕсли;
	
	
	РазбитьСтрокуЗаявкиПослеВводаЧислаНаСервере(Количество, ДополнительныеПараметры);
	
	РазбитьСтрокуЗаявкиЗавершение(ДополнительныеПараметры);
	
КонецПроцедуры	// РазбитьСтрокуЗаявкиПослеВводаЧислаНаКлинете(Количество, ДополнительныеПараметры)
  
&НаСервере
Процедура РазбитьСтрокуЗаявкиПослеВводаЧислаНаСервере(Количество, ДополнительныеПараметры)
	
	
	Остаток	= ДополнительныеПараметры.КоличествоПоиск - Количество; 
	ДополнительныеПараметры.Вставить("Остаток", 		   Остаток);
	ДополнительныеПараметры.Вставить("ЗаказаноКоличество", Количество);
	
	_ОбработкаЗакупкиСервер.РазбитьСтрокиЗаявкиНаЗакупку(ДополнительныеПараметры);
	
	
КонецПроцедуры	// РазбитьСтрокуТЧПослеВводаЧисла(Количество, ДополнительныеПараметры)()

