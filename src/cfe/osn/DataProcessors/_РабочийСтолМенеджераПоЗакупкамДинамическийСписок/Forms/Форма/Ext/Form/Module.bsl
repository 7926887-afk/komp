Процедура ЗадачиПользователяСписокВыбор(Элемент, ВыбраннаяСтрока, Поле, СтандартнаяОбработка)
	
	ТекущаяСтрокаСписка = ВыбраннаяСтрока;
	СтандартнаяОбработка	 = Ложь;
	
	Если Поле = Элементы.ЗадачиПользователяСписокПредмет Тогда
		ПоказатьЗначение(,Элементы.ЗадачиПользователяСписок.ТекущиеДанные.Предмет);
	Иначе
