&НаКлиенте
Процедура СписокОперацийКОплатеОтборОчистка(Элемент, СтандартнаяОбработка)
	
	СписокОперацийОплаты.ЗаполнитьПометки(Ложь);
	
	УстановитьОтборДинамическихСписков();
	
КонецПроцедуры

&НаКлиенте
Процедура СписокОперацийКОплатеОтборОбработкаВыбора(Элемент, ВыбранноеЗначение, СтандартнаяОбработка)
	
	СтандартнаяОбработка = Ложь;
	
	Если ТипЗнч(ВыбранноеЗначение) = Тип("СписокЗначений") Тогда
		
		СписокОперацийОплаты = ВыбранноеЗначение;
	Иначе
		
		Для Каждого ЭлементСписка Из СписокОперацийОплаты Цикл
			ЭлементСписка.Пометка = (ЭлементСписка.Значение = ВыбранноеЗначение);
		КонецЦикла;
	КонецЕсли;
	
	СписокОперацийОплатыПредставление = СписокОперацийПредставление(СписокОперацийОплаты);
	
	УстановитьОтборДинамическихСписков();
	
КонецПроцедуры

&НаКлиентеНаСервереБезКонтекста
Функция СписокОперацийПредставление(СписокОпераций)
	
	СписокОперацийПредставление = "";
	Для Каждого ЭлементСписка Из СписокОпераций Цикл
		Если ЭлементСписка.Пометка Тогда
			СписокОперацийПредставление = СписокОперацийПредставление
				+ ?(ЗначениеЗаполнено(СписокОперацийПредставление), ", ", "")
				+ ?(ЗначениеЗаполнено(ЭлементСписка.Представление), ЭлементСписка.Представление, ЭлементСписка.Значение);
		КонецЕсли;
	КонецЦикла;
	
	Возврат СписокОперацийПредставление;
	
КонецФункции

&НаКлиенте
Процедура УстановитьОтборПоМенеджеру(Команда)
	ПоказатьМанагера = НЕ ПоказатьМанагера;
	УстановкаОтбораПоМенеджеру();
	//СохранитьНастройкиСервер();
КонецПроцедуры

&НаКлиенте
Процедура УстановкаОтбораПоМенеджеру()
	ЭтаФорма.Элементы.ЗаказыКОплатеОтборы.ПодчиненныеЭлементы.УстановитьОтборПоМенеджеру.Заголовок = ?(ПоказатьМанагера,"Показать все заявки", "Только заявки менеджера");

	Если НЕ ПоказатьМанагера Тогда
		Менеджер = ПолучитьПустогоПользователя();
	Иначе	
		Менеджер = ПолучитьТекущегоПользователя();
	КонецЕсли;	
	
	ОбщегоНазначенияКлиентСервер.УстановитьЭлементОтбораДинамическогоСписка(
		ЗаказыКОплате,
		"Менеджер",
		Менеджер,
		ВидСравненияКомпоновкиДанных.Равно,,
		);
	
	Если НЕ ПоказатьМанагера Тогда
		Для Каждого ЭлементНастройки Из ЗаказыКОплате.Отбор.Элементы Цикл
			
			Если Строка(ЭлементНастройки.ЛевоеЗначение) = "Менеджер" Тогда
				ЭлементНастройки.Использование       = Ложь;
			КонецЕсли;
		КонецЦикла;		// ЭлементНастройки Из ПотребностьПоЗаказам.Отбор.Элементы  
		
		ТолькоМоиЗаказы                              = Ложь;
		
	Иначе
		ЭлементДобавлен                              = Ложь;
		
		Для Каждого ЭлементНастройки Из ЗаказыКОплате.Отбор.Элементы Цикл
			Если Строка(ЭлементНастройки.ЛевоеЗначение) = "Менеджер" Тогда
				ЭлементДобавлен                      = Истина;
				ЭлементНастройки.ВидСравнения        = ВидСравненияКомпоновкиДанных.ВСписке;
				СписокМенеджеров                     = Новый СписокЗначений;
				//СписокМенеджеров.Добавить(ПолучитьПустогоПользователя());
				СписокМенеджеров.Добавить(ПолучитьТекущегоПользователя());
				ЭлементНастройки.ПравоеЗначение      = СписокМенеджеров;
				ЭлементНастройки.Использование       = Истина;
			КонецЕсли;
		КонецЦикла;		// ЭлементНастройки Из ПотребностьПоЗаказам.Отбор.Элементы  
		
		Если НЕ ЭлементДобавлен Тогда
			СписокМенеджеров                         = Новый СписокЗначений;
			СписокМенеджеров.Добавить(ПолучитьПустогоПользователя());
			СписокМенеджеров.Добавить(ПолучитьТекущегоПользователя());
			
			НовЭлементОтбора                         = ЗаказыКОплате.Отбор.Элементы.Добавить(Тип("ЭлементОтбораКомпоновкиДанных"));
			НовЭлементОтбора.ЛевоеЗначение           = Новый ПолеКомпоновкиДанных("Менеджер"); 
			НовЭлементОтбора.ВидСравнения			 = ВидСравненияКомпоновкиДанных.ВСписке;
			НовЭлементОтбора.ПравоеЗначение          = СписокМенеджеров;
			НовЭлементОтбора.Использование           = Истина;
		КонецЕсли;
		
	КонецЕсли;
	Элементы.ЗаказыКОплате.Обновить();
	
КонецПроцедуры	// УстановкаОтбораПоменеджеруКлиент()



