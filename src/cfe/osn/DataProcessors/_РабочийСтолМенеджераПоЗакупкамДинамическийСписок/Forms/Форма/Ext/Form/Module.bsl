&НаКлиенте
Процедура ГруппаРазделыРабочегоСтолаПриСменеСтраницы(Элемент, ТекущаяСтраница)
	//**Изменено Максимов	
	Если ТекущаяСтраница.Имя = "ГруппаПотребностьПоЗаказам" Тогда
		//ЗаполнитьПотребностьЗаказов();
		ЭтаФорма.Элементы.ПотребностьПоЗаказам.Обновить();
		ЭтаФорма.Элементы.СоздатьПоручениеЭкспедитору.Видимость = Ложь;
	ИначеЕсли ТекущаяСтраница.Имя = "ГруппаЗаказыПоставщикам" Тогда
		ЭтаФорма.Элементы.ЗаказыПоставщикам.Обновить();
		ЭтаФорма.Элементы.ЗаказыПоставщикам.АвтоОбновление = Истина;
	    ЭтаФорма.Элементы.ЗаказыПоставщикам.ПериодАвтоОбновления = 5;			
		ЭтаФорма.Элементы.СоздатьПоручениеЭкспедитору.Видимость = Истина;	
	ИначеЕсли ТекущаяСтраница.Имя = "ГруппаЗадачиПльзователя" Тогда
		ОбновитьСписокЗадачНаСервере();	
		ЭтаФорма.Элементы.СоздатьПоручениеЭкспедитору.Видимость = Ложь;
	ИначеЕсли ТекущаяСтраница.Имя = "СтраницаЗаказыКОплате" Тогда
		ЭтаФорма.Элементы.ЗаказыКОплате.Обновить();
	КонецЕсли;
	//*******************
КонецПроцедуры

&НаКлиенте
Процедура ЗаказыПоставщикамПриАктивизацииСтроки(Элемент)
	
	ЭтаФорма._СуммаКоличествоЗаказано = ПолучиктьДанныеЗакзаПоставщику(Элемент.ТекущаяСтрока);
	
	ТекущийЗаказПоставщику = Элемент.ТекущаяСтрока;
	//**ДОБАВЛЕНО Максимов В.А.
	Попытка
		ТекДанные = ЭтаФорма.ПодчиненныеЭлементы.ГруппаРазделыРабочегоСтола.ПодчиненныеЭлементы.ГруппаЗаказыПоставщикам.ПодчиненныеЭлементы.ЗаказыПоставщикам.ТекущиеДанные.Товары;
		
		Если НЕ ( ТекДанные = Неопределено ) Тогда
			Для Каждого Стр Из ТекДанные Цикл
				КоличествоЗаказано = ПолучитьКоличествоПоступившегоТовара(Элемент.ТекущаяСтрока, Стр.Номенклатура);
				Если КоличествоЗаказано > Стр.КоличествоУпаковок Тогда 
					Стр._Поступило = Стр.КоличествоУпаковок;
				Иначе	
					Стр._Поступило = КоличествоЗаказано;
				КонецЕсли;	
			КонецЦикла;
		КонецЕсли;	
	Исключение
		
	КонецПопытки;	
	//*************************
	
КонецПроцедуры

