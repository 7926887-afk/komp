&НаСервере		//БезКонтекста
Процедура ЗаполнитьДокументНаСервере(ПараметрыЗаполнения, ТипДокумента)

	Если ТипДокумента = "ЗаявкаНаЗакупку" Тогда
		
		НовыйДокумент = Документы.ЗаявкаНаЗакупку.СоздатьДокумент();
		
	ИначеЕсли ТипДокумента = "ЗаказПоставщику" Тогда
		
		НовыйДокумент = Документы.ЗаказПоставщику.СоздатьДокумент();
		
	КонецЕсли;
	
	Если ТипДокумента = "ПоручениеЭкспедитору" Тогда
		
		НовыйДокумент = Документы.ПоручениеЭкспедитору.СоздатьДокумент();
		
	КонецЕсли;	
	
	Если НЕ ТипЗнч(ПараметрыЗаполнения) = Тип("Структура")
		ИЛИ НЕ ПараметрыЗаполнения.Свойство("ДокументОснование") Тогда
		
		ЗначениеВДанныеФормы(НовыйДокумент, ПараметрыЗаполнения.ДанныеФормы);
		Возврат;
		
	КонецЕсли;
	
	Если ( ПараметрыЗаполнения.СписокНоменклатуры = Неопределено ) И ( НЕ ПараметрыЗаполнения.ДокументОснование = ПолучитьПустуюСсылкуНаДокумент("ЗаявкаНаЗакупку") ) Тогда
		НовыйДокумент.Заполнить(ПараметрыЗаполнения.ДокументОснование);
	Иначе			// ПараметрыЗаполнения.СписокЗаявок = Неопределено
		НовыйДокумент.Заполнить(ПараметрыЗаполнения);
	КонецЕсли;		// ПараметрыЗаполнения.СписокЗаявок = Неопределено 
	
	ЗначениеВДанныеФормы(НовыйДокумент, ПараметрыЗаполнения.ДанныеФормы);

КонецПроцедуры

