&НаКлиенте
Процедура СоздатьЗаявкуНаЗакупку(Команда)

	ФормаДокумента		= ПолучитьФорму("Документ.ЗаявкаНаЗакупку.ФормаОбъекта");
	ДанныеФормы			= ФормаДокумента.Объект; 										// Получаем объект формы в переменную
	
	// Заполняем документ на сервере
	ПараметрыЗаполнения = Новый Структура("ДанныеФормы", ДанныеФормы);
	ТипДокумента		= "ЗаявкаНаЗакупку";
	ЗаполнитьДокументНаСервере(ПараметрыЗаполнения, ТипДокумента);
	
	КопироватьДанныеФормы(ПараметрыЗаполнения.ДанныеФормы, ФормаДокумента.Объект);		// копируем наш объект в объект формы и далее открываем ее
	ФормаДокумента.Открыть();
	
КонецПроцедуры

