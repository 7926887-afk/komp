&НаКлиенте
Процедура ПотребностьПоЗаказамПриАктивизацииСтроки(Элемент)
	
	Если Элемент.ТекущиеДанные = Неопределено Тогда
		ЭтаФорма.СводнаяПотребность.Очистить();
		Возврат
	КонецЕсли;
	
	СтруктураПараметров 		= Новый Структура("Номенклатура, Характеристика", Элемент.ТекущиеДанные.Номенклатура, Элемент.ТекущиеДанные.Характеристика); 
	СтруктураПараметров 		= ВыбратьДаннынПоНоменклатуре(СтруктураПараметров);
	
	ЭтаФорма.СводнаяПотребность.Очистить();
	НоваяСтрока					= ЭтаФорма.СводнаяПотребность.Добавить();
	НоваяСтрока.Номенклатура    = СтруктураПараметров.Номенклатура;
	НоваяСтрока.ТекущийЗаказ	= СтруктураПараметров.ОстатокЗаявка;
	НоваяСтрока.КоличествоСклад	= СтруктураПараметров.ОстатокСклад;
	НоваяСтрока.КоличествоЗаказ = СтруктураПараметров.ОстатокЗаказ;
	
КонецПроцедуры

&НаКлиенте
Процедура ПотребностьПоЗаказамВыбор(Элемент, ВыбраннаяСтрока, Поле, СтандартнаяОбработка)

	ТекущаяСтрокаСписка = ВыбраннаяСтрока;
	СтандартнаяОбработка	 = Ложь;
	Если ( Поле = Элементы.ПотребностьПоЗаказамНомерЗаявки ) ИЛИ ( Поле = Элементы.ПотребностьПоЗаказамДатаЗаявки ) Тогда
		
		ПоказатьЗначение(,Элементы.ПотребностьПоЗаказам.ТекущиеДанные.Ссылка);
		
	ИначеЕсли ( Поле = Элементы.ПотребностьПоЗаказамНоменклатура ) ИЛИ ( Поле = Элементы.ПотребностьПоЗаказамАртикул ) Тогда
		
		ПоказатьЗначение(,Элементы.ПотребностьПоЗаказам.ТекущиеДанные.Номенклатура);
		
	ИначеЕсли Поле = Элементы.ПотребностьПоЗаказамНазначение Тогда
		
		ПоказатьЗначение(,Элементы.ПотребностьПоЗаказам.ТекущиеДанные.Назначение);
		
	ИначеЕсли Поле = Элементы.ПотребностьПоЗаказамХарактеристика Тогда
	 	    
		ПоказатьЗначение(,Элементы.ПотребностьПоЗаказам.ТекущиеДанные.Характеристика);
		
	//ИначеЕсли Поле = Элементы.ПотребностьПоЗаказамНомерЗаказаКлиента Тогда
	// 	    
	//	ПоказатьЗначение(,Элементы.ПотребностьПоЗаказам.ТекущиеДанные.ЗаказКлиента);
		
	ИначеЕсли Поле = Элементы.ПотребностьПоЗаказамКомментарийЗакупка Тогда
	 	    
		ТекЗаявка			 = Элементы.ПотребностьПоЗаказам.ТекущиеДанные.Ссылка;
		СтрокаТовары		 = Элементы.ПотребностьПоЗаказам.ТекущиеДанные.СтрокаЗаказа;
		УИДЗакупка			 = Элементы.ПотребностьПоЗаказам.ТекущиеДанные._УИДЗакупка;
		Текст				 = Элементы.ПотребностьПоЗаказам.ТекущиеДанные.КомментарийЗакупка;
		ПараметрыЗаполнения  = Новый Структура("ТекЗаявка, СтрокаТовары, Текст, УИДЗакупка", ТекЗаявка, СтрокаТовары, Текст, УИДЗакупка);
		
		Оповещение = Новый ОписаниеОповещения("ПослеЗакрытияВопросаОИзмененииКоментария", ЭтотОбъект, ПараметрыЗаполнения);
		ПоказатьВводСтроки(Оповещение, Текст, "Введите коментарий", 150);
		
	ИначеЕсли Поле = Элементы.ПотребностьПоЗаказамМенеджер Тогда
		
		СтрокаТовары		= Элементы.ПотребностьПоЗаказам.ТекущиеДанные.СтрокаЗаказа;
		ТекЗаявка			= Элементы.ПотребностьПоЗаказам.ТекущиеДанные.Ссылка;
		УИДЗакупка			= Элементы.ПотребностьПоЗаказам.ТекущиеДанные._УИДЗакупка;
		Менеджер			= Элементы.ПотребностьПоЗаказам.ТекущиеДанные.Менеджер;
		ПараметрыЗаполнения = Новый Структура("ТекЗаявка, СтрокаТовары, Менеджер, УИДЗакупка", ТекЗаявка, СтрокаТовары, Менеджер, УИДЗакупка);
		
		Оповещение = Новый ОписаниеОповещения("ПослеЗакрытияВопросаОИзмененииКоментария", ЭтотОбъект, ПараметрыЗаполнения);
		ПоказатьВводЗначения(Оповещение, Менеджер, "Выбарите менеджера");
	 	    
	ИначеЕсли Поле = Элементы.ПотребностьПоЗаказамОтметка Тогда
	 	    
		мИндекс = МассивВыбранныхСсылок.Найти(Элементы.ПотребностьПоЗаказам.ТекущиеДанные._УИДЗакупка);
		Если мИндекс = Неопределено Тогда
			МассивВыбранныхСсылок.Добавить(Элементы.ПотребностьПоЗаказам.ТекущиеДанные._УИДЗакупка);       
		Иначе    
			МассивВыбранныхСсылок.Удалить(мИндекс);
		КонецЕсли;
		ркКоличествоВыбранных = МассивВыбранныхСсылок.Количество();
		ПотребностьПоЗаказам.Параметры.УстановитьЗначениеПараметра("МассивВыбранныхСсылок",МассивВыбранныхСсылок);
	
	ИначеЕсли Поле = Элементы.ПотребностьПоЗаказамКоличествоУпаковок Тогда
	 	    
		ПараметрыОбработки = РаботаСТабличнымиЧастямиКлиент.ПараметрыРазбиенияСтроки();
		 
		ДополнительныеПараметры = Новый Структура;
		ДополнительныеПараметры.Вставить("ПараметрыОбработки",	ПараметрыОбработки);
		ДополнительныеПараметры.Вставить("ТекЗаявка",			ЭтаФорма.Элементы.ПотребностьПоЗаказам.ТекущиеДанные.Ссылка);
		ДополнительныеПараметры.Вставить("СтрокаТовары",		ЭтаФорма.Элементы.ПотребностьПоЗаказам.ТекущиеДанные.СтрокаЗаказа);
		ДополнительныеПараметры.Вставить("Номенклатура",		ЭтаФорма.Элементы.ПотребностьПоЗаказам.ТекущиеДанные.Номенклатура);
		ДополнительныеПараметры.Вставить("Характеристика",		ЭтаФорма.Элементы.ПотребностьПоЗаказам.ТекущиеДанные.Характеристика);
		ДополнительныеПараметры.Вставить("Характеристика",		ЭтаФорма.Элементы.ПотребностьПоЗаказам.ТекущиеДанные.Характеристика);
		ДополнительныеПараметры.Вставить("Артикул",				ЭтаФорма.Элементы.ПотребностьПоЗаказам.ТекущиеДанные.Артикул);
		ДополнительныеПараметры.Вставить("КоличествоПоиск",		ЭтаФорма.Элементы.ПотребностьПоЗаказам.ТекущиеДанные.КоличествоУпаковок);
		ДополнительныеПараметры.Вставить("УИДЗаказ",			ЭтаФорма.Элементы.ПотребностьПоЗаказам.ТекущиеДанные._УИДЗаказ);
		ДополнительныеПараметры.Вставить("УИДЗакупка",			ЭтаФорма.Элементы.ПотребностьПоЗаказам.ТекущиеДанные._УИДЗакупка);
		ДополнительныеПараметры.Вставить("НоваяСтрока",			Ложь);
		
		Оповещение = Новый ОписаниеОповещения("РазбитьСтрокуЗаявкиПослеВводаЧислаНаКлинете", ЭтотОбъект, ДополнительныеПараметры);
		Количество = ЭтаФорма.Элементы.ПотребностьПоЗаказам.ТекущиеДанные.КоличествоУпаковок;	
		ПоказатьВводЧисла(Оповещение, Количество, ПараметрыОбработки.Заголовок, 15, 3);
	
	ИначеЕсли Поле = Элементы.ПотребностьПоЗаказамКомментарийЗакупка  ИЛИ
			  Поле = Элементы.ПотребностьПоЗаказамКоличествоУпаковок ИЛИ 
			  Поле = Элементы.ПотребностьПоЗаказамМенеджер Тогда
		СтандартнаяОбработка	 = Истина;
	КонецЕсли;
	
КонецПроцедуры

