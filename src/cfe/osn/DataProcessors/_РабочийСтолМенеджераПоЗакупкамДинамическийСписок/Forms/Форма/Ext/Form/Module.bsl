&НаКлиенте
Процедура УстановкаОтбораПоМенеджеруКлиент()
	ЭтаФорма.Элементы.ПотребностьПоЗаказам.КоманднаяПанель.ПодчиненныеЭлементы.КнопкаПоказатьМенедра.Заголовок = ?(ПоказатьМанагера,"Показать все заявки", "Только заявки менеджера");
	
	Если НЕ ПоказатьМанагера Тогда
		Для Каждого ЭлементНастройки Из ПотребностьПоЗаказам.Отбор.Элементы Цикл
			
			Если Строка(ЭлементНастройки.ЛевоеЗначение) = "Менеджер" Тогда
				ЭлементНастройки.Использование       = Ложь;
			КонецЕсли;
		КонецЦикла;		// ЭлементНастройки Из ПотребностьПоЗаказам.Отбор.Элементы  
		
		ТолькоМоиЗаказы                              = Ложь;
		
	Иначе
		ЭлементДобавлен                              = Ложь;
		
		Для Каждого ЭлементНастройки Из ПотребностьПоЗаказам.Отбор.Элементы Цикл
			Если Строка(ЭлементНастройки.ЛевоеЗначение) = "Менеджер" Тогда
				ЭлементДобавлен                      = Истина;
				ЭлементНастройки.ВидСравнения        = ВидСравненияКомпоновкиДанных.ВСписке;
				СписокМенеджеров                     = Новый СписокЗначений;
				СписокМенеджеров.Добавить(ПолучитьПустогоПользователя());
				СписокМенеджеров.Добавить(ПолучитьТекущегоПользователя());
				ЭлементНастройки.ПравоеЗначение      = СписокМенеджеров;
				ЭлементНастройки.Использование       = Истина;
			КонецЕсли;
		КонецЦикла;		// ЭлементНастройки Из ПотребностьПоЗаказам.Отбор.Элементы  
		
		Если НЕ ЭлементДобавлен Тогда
			СписокМенеджеров                         = Новый СписокЗначений;
			СписокМенеджеров.Добавить(ПолучитьПустогоПользователя());
			СписокМенеджеров.Добавить(ПолучитьТекущегоПользователя());
			
			НовЭлементОтбора                         = ПотребностьПоЗаказам.Отбор.Элементы.Добавить(Тип("ЭлементОтбораКомпоновкиДанных"));
			НовЭлементОтбора.ЛевоеЗначение           = Новый ПолеКомпоновкиДанных("Менеджер"); 
			НовЭлементОтбора.ВидСравнения			 = ВидСравненияКомпоновкиДанных.ВСписке;
			НовЭлементОтбора.ПравоеЗначение          = СписокМенеджеров;
			НовЭлементОтбора.Использование           = Истина;
		КонецЕсли;
		
	КонецЕсли;
	Элементы.ПотребностьПоЗаказам.Обновить();
	
КонецПроцедуры	// УстановкаОтбораПоменеджеруКлиент()
 
&НаКлиенте
Процедура УстановкаОтбораПоДатеКлиент()
	ЭтаФорма.Элементы.ПотребностьПоЗаказам.КоманднаяПанель.ПодчиненныеЭлементы.КнопкаОтборПоДате.Заголовок = ?(ПоказатьДату,"Все заявки после 15.00", "Только заявки до 15.00");
	Если НЕ ПоказатьДату Тогда
		
		
		Для Каждого ЭлементНастройки Из ПотребностьПоЗаказам.Отбор.Элементы Цикл
			Если Строка(ЭлементНастройки.ЛевоеЗначение) = "ДатаЗаявки" Тогда
				ЭлементНастройки.Использование       = Ложь;
			КонецЕсли;
		КонецЦикла;		// ЭлементНастройки Из ПотребностьПоЗаказам.Отбор.Элементы  
		
	Иначе
		
		ЭлементДобавлен                              = Ложь;
		
		Для Каждого ЭлементНастройки Из ПотребностьПоЗаказам.Отбор.Элементы Цикл
			Если Строка(ЭлементНастройки.ЛевоеЗначение) = "ДатаЗаявки" Тогда
				ЭлементДобавлен                      = Истина;
				ЭлементНастройки.ВидСравнения        = ВидСравненияКомпоновкиДанных.Меньше;
				КонтрольнаяДатаЗаявки                = ПолучитьКонтлоьнуюДату();
				ЭлементНастройки.ПравоеЗначение      = КонтрольнаяДатаЗаявки;
				ЭлементНастройки.Использование       = Истина;
			КонецЕсли;
		КонецЦикла;		// ЭлементНастройки Из ПотребностьПоЗаказам.Отбор.Элементы  
		
		Если НЕ ЭлементДобавлен Тогда
			НовЭлементОтбора                         = ПотребностьПоЗаказам.Отбор.Элементы.Добавить(Тип("ЭлементОтбораКомпоновкиДанных"));
			НовЭлементОтбора.ЛевоеЗначение           = Новый ПолеКомпоновкиДанных("ДатаЗаявки"); НовЭлементОтбора.ВидСравнения = ВидСравненияКомпоновкиДанных.Меньше;
			КонтрольнаяДатаЗаявки	                 = ПолучитьКонтлоьнуюДату();
			НовЭлементОтбора.ПравоеЗначение          = КонтрольнаяДатаЗаявки;
			НовЭлементОтбора.Использование           = Истина;
		КонецЕсли;
		
	КонецЕсли;
	Элементы.ПотребностьПоЗаказам.Обновить();
КонецПроцедуры	// УстановкаОтбораПоДатеКлиент()
 
