&НаСервере
Процедура ПриСозданииНаСервере(Отказ, СтандартнаяОбработка)
	
	//**ДОБАВЛЕНО Максимов В.А.
	НомерЗаказа = "";                     
	ДатаЗаказа  = '00010101';
		
	ОбработкаЗадачПользователя();		
	УстановитьУсловноеОформление();
	
	//Новое Максимов
	Если Параметры.Свойство("НомерЗаказа", НомерЗаказа) И Параметры.Свойство("ДатаЗаказа", ДатаЗаказа) Тогда
		ПараметрыЗаказа		  = Новый Структура("НомерЗаказа, ДатаЗаказа", НомерЗаказа, ДатаЗаказа);
		Объект.ПараметрыЗаказа = ПараметрыЗаказа;
	КонецЕсли;	
	
	ТекущаяДатаМинусСемьДней = ТекущаяДата() - (86400 * 7);
	ТекДата = ТекущаяДата(); 
	ТекДатаПлюсОДинДень = ТекДата + 86400;
	ТекДатаПлюсШесть = ТекДата + (86400*7);
	//*************************
	
	НачалоПериода = НачалоГода(ТекущаяДата());
	КонецПериода = КонецДня(ТекущаяДата());	
	
	УстановитьОтборДинамическихСписков();
		
	//**************
	
	Элементы.ЗаказыПоставщикам.УправлениеПоиском.Видимость = Истина;
	Элементы.ЗаказыПоставщикам.УправлениеПоиском.Доступность = Истина;
	Элементы.ЗаказыПоставщикам.ОтображениеСтрокиПоиска.Видимость = Истина;
	Элементы.ЗаказыПоставщикам.ОтображениеСтрокиПоиска.Доступность = Истина;
	Элементы.ЗаказыПоставщикам.КоманднаяПанель.Видимость = Истина;
	Элементы.ЗаказыПоставщикам.КоманднаяПанель.Доступность = Истина;
	
	ИнициализироватьСписокОперацийОплаты();
	//***************************
	
	_РаботаСИнтерфейсомСервер.СистемаНапоминанийПриСозданииНаСервере( "ГруппаРазделыРабочегоСтола" , ЭтаФорма );
	
	// СтандартныеПодсистемы.ПодключаемыеКоманды
	ПараметрыРазмещения = ПодключаемыеКоманды.ПараметрыРазмещения();
	ПараметрыРазмещения.Источники = Новый Массив;
	ПараметрыРазмещения.Источники.Добавить( Метаданные.Документы.ЗаказПоставщику );
	
	ПараметрыРазмещения.КоманднаяПанель = Элементы.ЗаказыПоставщикам.КоманднаяПанель; 
	
	ПодключаемыеКоманды.ПриСозданииНаСервере(ЭтотОбъект, ПараметрыРазмещения);
	//Хз по какой причине но не добавляется команда в подменю кнопок... сделал программно
	ДобавитьКомандуСозданияЗаявкиНаДоставку();
	// Конец СтандартныеПодсистемы.ПодключаемыеКоманды
	
КонецПроцедуры

