&НаКлиенте
Процедура ОбработкаПолейПотреьностейПоЗаказам(Текст)
	
	СохраненнаяСтрока = Элементы.ПотребностьПоЗаказам.ТекущаяСтрока;

	Поле = Элементы.ПотребностьПоЗаказам.ТекущийЭлемент.Имя;
	
	ТекЗаявка			 = Элементы.ПотребностьПоЗаказам.ТекущиеДанные.Ссылка;
	СтрокаТовары		 = Элементы.ПотребностьПоЗаказам.ТекущиеДанные.СтрокаЗаказа;
	УИДЗакупка			 = Элементы.ПотребностьПоЗаказам.ТекущиеДанные._УИДЗакупка;
	Если Поле = "ПотребностьПоЗаказамКомментарийЗакупка" Тогда
		ПараметрыЗаполнения  = Новый Структура("ТекЗаявка, СтрокаТовары, Текст, УИДЗакупка", ТекЗаявка, СтрокаТовары, Текст, УИДЗакупка);
	ИначеЕсли Поле = "ПотребностьПоЗаказамМенеджер" Тогда
		Текст = _ДоработкиСлужебный.ПолучитьСсылкуМенеджера(Текст);
		ПараметрыЗаполнения = Новый Структура("ТекЗаявка, СтрокаТовары, Менеджер, УИДЗакупка", ТекЗаявка, СтрокаТовары, Текст, УИДЗакупка);
	Иначе
		Текст = Неопределено;
		Возврат;
	КонецЕсли;
	
	ПослеЗакрытияВопросаОИзмененииКоментария(Текст, ПараметрыЗаполнения);
	
	Элементы.ПотребностьПоЗаказам.ТекущаяСтрока = СохраненнаяСтрока;
КонецПроцедуры	// ОбработкаПолейПотреьностейПоЗаказам(Текст)

&НаСервере
Процедура ЗаполнитьЗаявкуНаЗакупку(Параметры)
	
	ТекЗаявка				 = Параметры.ТекЗаявка.ПолучитьОбъект();
	СтрокаТовары			 = Параметры.СтрокаТовары;
	
	Если Параметры.Свойство("Текст") Тогда
		ТекЗаявка.Товары[СтрокаТовары-1].КомментарийЗакупка = Параметры.Текст;
	КонецЕсли;  
	
	Если Параметры.Свойство("Менеджер") Тогда
		ТекЗаявка.Товары[СтрокаТовары-1].Менеджер = ?(Параметры.Менеджер = Неопределено, ПолучитьПустогоПользователя(), Параметры.Менеджер) ;
	КонецЕсли;
	
	ТекЗаявка.Записать();
	
	СохраненнаяСтрока = ЭтаФорма.Элементы.ПотребностьПоЗаказам.ТекущаяСтрока;
	ЭтаФорма.Элементы.ПотребностьПоЗаказам.Обновить();
	ЭтаФорма.Элементы.ПотребностьПоЗаказам.ТекущаяСтрока = СохраненнаяСтрока;
КонецПроцедуры	// ЗаполнитьЗаявкуНАЗакупку(Параметры)()
 
// Обработчики, вызываемый после закрытия вопроса пользователю
//
&НаКлиенте
Процедура ПослеЗакрытияВопросаОИзмененииКоментария(Результат, Параметры) Экспорт
	
	Если Результат = Неопределено Тогда
		Возврат;
	КонецЕсли;
	Если Параметры.Свойство("Текст") Тогда
		Параметры.Текст = Результат;
	ИначеЕсли Параметры.Свойство("Менеджер") Тогда
		Параметры.Менеджер = Результат;
	КонецЕсли;
	ЗаполнитьЗаявкуНаЗакупку(Параметры);
	
	ЭтаФорма.Элементы.ПотребностьПоЗаказам.ТекущаяСтрока = ТекущаяСтрокаСписка;
	
КонецПроцедуры

&НаСервере
Процедура ЗаполнитьГруппуЗаявокНаЗакупку(Параметры)
	
	ВыделенныеСтроки = Элементы.ПотребностьПоЗаказам.ВыделенныеСтроки;
	
	Схема       = Элементы.ПотребностьПоЗаказам.ПолучитьИсполняемуюСхемуКомпоновкиДанных();
	Настройки   = Элементы.ПотребностьПоЗаказам.ПолучитьИсполняемыеНастройкиКомпоновкиДанных();
 
	КМ			= Новый КомпоновщикМакетаКомпоновкиДанных;
	Макет	    = КМ.Выполнить(Схема, Настройки, , , Тип("ГенераторМакетаКомпоновкиДанныхДляКоллекцииЗначений"));
 
	ПК			= Новый ПроцессорКомпоновкиДанных;
	ПК.Инициализировать(Макет);
 
	ТЗ			= Новый ТаблицаЗначений;
	
	ПВ			= Новый ПроцессорВыводаРезультатаКомпоновкиДанныхВКоллекциюЗначений;
	ПВ.УстановитьОбъект(ТЗ);
	ПВ.Вывести(ПК);
	
	Для Каждого ТекСтрока Из ВыделенныеСтроки Цикл
		СтрДанных    = ТЗ.Получить(ТекСтрока - 1);
		ТекЗаявка	 = СтрДанных.Ссылка.ПолучитьОбъект();
		СтрокаТовары = СтрДанных.СтрокаЗаказа;
		
		//**ИЗМЕНЕНО Максимов В.А.
		Отбор = Новый Структура;
		Отбор.Вставить("Номенклатура",Параметры.СтрокаТовары);
		Отбор.Вставить("_УИДЗакупка", Параметры.УИДЗакупка);
		НайденнаяСтрока = ТекЗаявка.Товары.НайтиСтроки(Отбор);
		
		Если Параметры.Свойство("Текст") Тогда
			//ТекЗаявка.Товары[НайденнаяСтрока[0].НомерСтроки -1].КомментарийЗакупка = Параметры.Текст;
			ТекЗаявка.Товары[СтрокаТовары-1].КомментарийЗакупка = Параметры.Текст;
		КонецЕсли;  
		
		Если Параметры.Свойство("Менеджер") Тогда
			//ТекЗаявка.Товары[НайденнаяСтрока[0].НомерСтроки -1].Менеджер = ?(Параметры.Менеджер = Неопределено, ПолучитьПустогоПользователя(), Параметры.Менеджер) ;
			ТекЗаявка.Товары[СтрокаТовары-1].Менеджер = ?(Параметры.Менеджер = Неопределено, ПолучитьПустогоПользователя(), Параметры.Менеджер) ;
		КонецЕсли;
		//************************
	
		ТекЗаявка.Записать();
		
	КонецЦикла;		// ТекСтрока Из ВыделенныеСтроки
	
	ЭтаФорма.Элементы.ПотребностьПоЗаказам.Обновить();
	
КонецПроцедуры	// ЗаполнитьГруппуЗаявокНаЗакупку()

&НаКлиенте
Процедура ПослеЗакрытияВопросаОГрупповомИзмененииКоментария(Результат, Параметры) Экспорт
	
	ВыделенныеСтроки = Элементы.ПотребностьПоЗаказам.ВыделенныеСтроки;
	
	Если Результат = Неопределено Тогда
		Возврат;
	КонецЕсли;
	
	Если Параметры.Свойство("Текст") Тогда
		Параметры.Текст = Результат;
	ИначеЕсли Параметры.Свойство("Менеджер") Тогда
		Параметры.Менеджер = Результат;
	КонецЕсли;
	
	ЗаполнитьГруппуЗаявокНаЗакупку(Параметры);
	
	ТекущаяСтрокаСписка = ВыделенныеСтроки[0];
	ЭтаФорма.Элементы.ПотребностьПоЗаказам.ТекущаяСтрока = ТекущаяСтрокаСписка;
	
КонецПроцедуры	// ПослеЗакрытияВопросаОГрупповомИзмененииКоментария()

//**ДОБАВЛЕНО Максимов В.А	

&НаСервере
Функция ПолучитьКоличествоПоступившегоТовара(ЗаказПоставщику, Номенклатура)
	
	Запрос = Новый Запрос;
	Запрос.Текст =
	"ВЫБРАТЬ
	|	ПриобретениеТоваровУслугТовары.Ссылка КАК Ссылка,
	|	ПриобретениеТоваровУслугТовары.Номенклатура КАК Номенклатура,
	|	ПриобретениеТоваровУслугТовары.Количество КАК Количество,
	|	ПриобретениеТоваровУслугТовары.Цена КАК Цена,
	|	ПриобретениеТоваровУслугТовары.Сумма КАК Сумма,
	|	ПриобретениеТоваровУслугТовары.Сделка КАК Сделка
	|ИЗ
	|	Документ.ПриобретениеТоваровУслуг.Товары КАК ПриобретениеТоваровУслугТовары
	|ГДЕ
	|	ПриобретениеТоваровУслугТовары.Ссылка.ЗаказПоставщику = &ЗаказПоставщику
	|	И ПриобретениеТоваровУслугТовары.Номенклатура = &Номенклатура
	|	И ПриобретениеТоваровУслугТовары.Ссылка.Проведен = ИСТИНА
	|	И ПриобретениеТоваровУслугТовары.Ссылка.ПометкаУдаления = ЛОЖЬ";
	
	Запрос.УстановитьПараметр("ЗаказПоставщику", ЗаказПоставщику);
	Запрос.УстановитьПараметр("Номенклатура", Номенклатура);
	
	Результат = Запрос.Выполнить().Выгрузить();
	
	Количество = 0;
	
	Если Результат.Количество() = 1 Тогда
		Для Каждого Стр Из Результат Цикл
			Количество = Стр.Количество;
			Прервать;
		КонецЦикла;
	Иначе
		Для Каждого Строка Из Результат Цикл 
			Количество = Количество + Строка.Количество;			
		КонецЦикла;			
	КонецЕсли;
	
	Возврат Количество;
	
КонецФункции	

