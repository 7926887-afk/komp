Процедура ОбработкаНомераЗаказаКлиент()
	
	Если ТипЗнч(Объект.ПараметрыЗаказа) = Тип("Структура") Тогда
		
		Если  Объект.ПараметрыЗаказа.Свойство("НомерЗаказа") И  Объект.ПараметрыЗаказа.Свойство("ДатаЗаказа") Тогда
			
			ЭлементДобавлен = Ложь;
			Для Каждого ЭлементНастройки Из ЗаказыПоставщикамСписок.Отбор.Элементы Цикл
				Если Строка(ЭлементНастройки.ЛевоеЗначение) = "Номер" Тогда
					ЭлементДобавлен                      = Истина;
					ЭлементНастройки.ВидСравнения        = ВидСравненияКомпоновкиДанных.Равно;
					Номер       			             = Объект.ПараметрыЗаказа.НомерЗаказа;
					ЭлементНастройки.ПравоеЗначение      = Номер;
					ЭлементНастройки.Использование       = Истина;
				КонецЕсли;
			КонецЦикла;		// ЭлементНастройки Из ЗаказыКлиентовСписок.Отбор.Элементы 
						
			Если НЕ ЭлементДобавлен Тогда
				НовЭлементОтбора                         = ЗаказыПоставщикамСписок.Отбор.Элементы.Добавить(Тип("ЭлементОтбораКомпоновкиДанных"));
				НовЭлементОтбора.ЛевоеЗначение           = Новый ПолеКомпоновкиДанных("Номер"); 
				НовЭлементОтбора.ВидСравнения			 = ВидСравненияКомпоновкиДанных.Равно;
				Номер       			         	     = Объект.ПараметрыЗаказа.НомерЗаказа;
				НовЭлементОтбора.ПравоеЗначение 	     = Номер;
				НовЭлементОтбора.Использование           = Истина;
			КонецЕсли;
						
		Иначе
			
			Для Каждого ЭлементНастройки Из ЗаказыПоставщикамСписок.Отбор.Элементы Цикл
				Если Строка(ЭлементНастройки.ЛевоеЗначение) = "Номер" Тогда
					ЭлементДобавлен                      = Истина;
					ЭлементНастройки.ВидСравнения        = ВидСравненияКомпоновкиДанных.Равно;
					Номер       			             = Объект.ПараметрыЗаказа.НомерЗаказа;
					ЭлементНастройки.ПравоеЗначение      = Номер;
					ЭлементНастройки.Использование       = Ложь;
				КонецЕсли;
			КонецЦикла;		// ЭлементНастройки Из ЗаказыКлиентовСписок.Отбор.Элементы 
			
		КонецЕсли;	
		
	Иначе
		
		Для Каждого ЭлементНастройки Из ЗаказыПоставщикамСписок.Отбор.Элементы Цикл
			Если Строка(ЭлементНастройки.ЛевоеЗначение) = "Номер" Тогда
				ЭлементДобавлен                      = Истина;
				ЭлементНастройки.ВидСравнения        = ВидСравненияКомпоновкиДанных.Равно;
				Номер       			             = "";
				ЭлементНастройки.ПравоеЗначение      = Номер;
				ЭлементНастройки.Использование       = Ложь;
			КонецЕсли;
		КонецЦикла;		// ЭлементНастройки Из ЗаказыКлиентовСписок.Отбор.Элементы 
		
	КонецЕсли;
	
КонецПроцедуры	// ОбработкаНомераЗаказаКлиент()

