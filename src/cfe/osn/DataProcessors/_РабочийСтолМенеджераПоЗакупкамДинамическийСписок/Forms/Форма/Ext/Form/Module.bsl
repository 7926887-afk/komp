	Оповещение = Новый ОписаниеОповещения("ПослеЗакрытияВопросаОГрупповомИзмененииКоментария", ЭтотОбъект, ПараметрыЗаполнения);
	ПоказатьВводЗначения(Оповещение, Менеджер, "Выбарите менеджера");
	//************************
	
