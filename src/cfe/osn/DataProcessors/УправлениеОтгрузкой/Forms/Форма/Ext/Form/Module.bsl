&НаСервере
Функция Компит_СоздатьЗаданиеНаПеревозкуНаСервере()
	
	Если ( ЭтотОбъект.ТекущийЭлемент.ТекущаяСтрока.Ссылка.Проведен ) И
		( (ЭтотОбъект.ТекущийЭлемент.ТекущаяСтрока.Ссылка.Статус = Перечисления.СтатусыРасходныхОрдеров.Проверен) ИЛИ
		(ЭтотОбъект.ТекущийЭлемент.ТекущаяСтрока.Ссылка.Статус = Перечисления.СтатусыРасходныхОрдеров.КОтгрузке) ) Тогда
		
		НовоеЗаданиеНаПеревозку = Документы.ЗаданиеНаПеревозку.СоздатьДокумент();
		ЗаданиеНаПеревозку = _ОбработкаДоставкиТоваровСервер.СоздатьЗаданиеНаПеревозкуПоРасходномуОрдеру(ЭтотОбъект.ТекущийЭлемент.ТекущаяСтрока.Ссылка, ДатаОтгрузки);	
		
		Если ЗаданиеНаПеревозку = Документы.ЗаданиеНаПеревозку.ПустаяСсылка() Тогда
			Возврат Неопределено;
		КонецЕсли;
		Возврат ЗаданиеНаПеревозку 
	КонецЕсли;
	
КонецФункции

&НаКлиенте
Процедура Компит_СоздатьЗаланиеНаПеревозку(Команда)
	
	Если НЕ ЭтотОбъект.ТекущийЭлемент.Имя = "ОрдераВРаботе" Тогда
		ТекстСообщения = НСтр("ru='Выбарите расходный ордер'");
		ОбщегоНазначенияКлиентСервер.СообщитьПользователю(ТекстСообщения);
		Возврат;
	КонецЕсли; 
	
	Если НЕ Компит_ПолучитьТипОтгрузки() Тогда
		ТекстСообщения = НСтр("ru='По расходному ордеру " + ЭтотОбъект.ТекущийЭлемент.ТекущиеДанные.Номер + " установлен самовывоз'");
		ОбщегоНазначенияКлиентСервер.СообщитьПользователю(ТекстСообщения);
		Возврат;
	КонецЕсли;
	
	Если НЕ Компит_ЗаданиеНаПеревозкуЗаполнено() Тогда
		ТекстСообщения = НСтр("ru='По расходному ордеру " + ЭтотОбъект.ТекущийЭлемент.ТекущиеДанные.Номер + " установлено Задание на перевозку'");
		ОбщегоНазначенияКлиентСервер.СообщитьПользователю(ТекстСообщения);
		Возврат;
	КонецЕсли;
	
	ФормаЗаданияНаПеревозку = ПолучитьФорму("Документ.ЗаданиеНаПеревозку.ФормаОбъекта");
	ЗаданиеНаПеревозку = Компит_СоздатьЗаданиеНаПеревозкуНаСервере();
	
	Если НЕ ЗаданиеНаПеревозку = Неопределено Тогда
		ОткрытьФорму("Документ.ЗаданиеНаПеревозку.ФормаОбъекта", Новый Структура("Ключ", ЗаданиеНаПеревозку));
		ЗаполнитьРасходныйОрдер(ЗаданиеНаПеревозку);	
	КонецЕсли;
	
КонецПроцедуры

#КонецОбласти

