#Область СозданиеЗаданияНаПеревозку

&НаСервере
Функция Компит_ПолучитьТипОтгрузки()
	
	Если ЭтотОбъект.ТекущийЭлемент.ТекущаяСтрока.Ссылка.ОтгрузкаПоЗаданиюНаПеревозку Тогда
		Возврат Истина;
	Иначе
		Возврат Ложь;
	КонецЕсли;
	
КонецФункции // Компит_ПолучитьТипОтгрузки()

&НаСервере
Функция Компит_ЗаданиеНаПеревозкуЗаполнено()
	
	Если ЭтотОбъект.ТекущийЭлемент.ТекущаяСтрока.Ссылка.ЗаданиеНаПеревозку = Документы.ЗаданиеНаПеревозку.ПустаяСсылка() Тогда
		Возврат Истина;
	Иначе
		Возврат Ложь;
	КонецЕсли;
	
КонецФункции	// Компит_ЗаданиеНаПеревозкуЗаполнено()

&НаСервере
Процедура ЗаполнитьРасходныйОрдер(ЗаданиеНаПеревозку)
	
	ТекОрдер = ЭтотОбъект.ТекущийЭлемент.ТекущаяСтрока.Ссылка.ПолучитьОбъект();
	ТекОрдер.ЗаданиеНаПеревозку = ЗаданиеНаПеревозку;
	ТекОрдер.Записать(РежимЗаписиДокумента.Запись);
	
КонецПроцедуры	// ЗаполнитьРасходныйОрдер(ФормаЗаданияНаПеревозку.Объект.Ссылка)()

#КонецОбласти

//++ Сухарев Б.В. 27.11.2018
&НаСервере
Функция ПолучитьПечатьДокументовОрдера(ТекОрдер)
	
	Отметка = Ложь;
	Если ТекОрдер = Неопределено Тогда
		Возврат Отметка;
	КонецЕсли;
	
	Для Каждого ТекРаспоряжение Из ТекОрдер.ТоварыПоРаспоряжениям Цикл
		Если ТипЗнч(ТекРаспоряжение.Распоряжение) = Тип("ДокументСсылка.ЗаказКлиента") Тогда
			Отметка = ПолучитьОтметкуДокументов(ТекРаспоряжение.Распоряжение);
		Иначе
			Отметка = Ложь;
		КонецЕсли;
		
		Если Отметка = Истина Тогда
			Прервать;
		КонецЕсли;
	КонецЦикла;		// ТекРаспоряжение Из 
	
	Возврат Отметка;
	
КонецФункции // ПолучитьПечатьДокументовОрдера()

&НаКлиенте
Процедура Компит_ОрдераВРаботеПриАктивизацииСтроки(Элемент)
	
	Отметка                                                  = ПолучитьПечатьДокументовОрдера(Элемент.ТекущаяСтрока);
	_НужныДокументыОрдер                                     = Отметка;
	ЭтаФорма.Элементы._Печать.Доступность                    = Отметка;
	ЭтаФорма.Элементы._ПечатьУПД.Доступность                 = Отметка;
	ЭтаФорма.Элементы._ПечатьКомплектаДокументов.Доступность = Отметка;
	ЭтаФорма.Элементы._Реализация.Доступность                = Отметка;
	
КонецПроцедуры

