&НаСервере
Функция Компит_ПечатьУПДНаСервере()
	
	Если ( ЭтотОбъект.ТекущийЭлемент.ТекущаяСтрока.Ссылка.Проведен ) И
		( (ЭтотОбъект.ТекущийЭлемент.ТекущаяСтрока.Ссылка.Статус = Перечисления.СтатусыРасходныхОрдеров.Проверен) ИЛИ
		(ЭтотОбъект.ТекущийЭлемент.ТекущаяСтрока.Ссылка.Статус = Перечисления.СтатусыРасходныхОрдеров.КОтгрузке) ИЛИ
		(ЭтотОбъект.ТекущийЭлемент.ТекущаяСтрока.Ссылка.Статус = Перечисления.СтатусыРасходныхОрдеров.Отгружен ) ) Тогда
		МассивДокументов	= _ОбработкаДоставкиТоваровСервер.ВыборДокументовДляПечатиУПД(ЭтотОбъект.ТекущийЭлемент.ТекущаяСтрока.Ссылка);
		Возврат МассивДокументов;
	КонецЕсли;
	
КонецФункции

&НаКлиенте
Процедура Компит_ПечатьУПД(Команда)
	
	Если НЕ ЭтотОбъект.ТекущийЭлемент.Имя = "ОрдераВРаботе" Тогда
		ТекстСообщения = НСтр("ru='Выбарите расходный ордер'");
		ОбщегоНазначенияКлиентСервер.СообщитьПользователю(ТекстСообщения);
		Возврат
	КонецЕсли; 
	МассивДокументов = "";
	МассивДокументов = Компит_ПечатьУПДНаСервере();
	Если МассивДокументов = Неопределено Тогда
		ТекстСообщения = НСтр("ru='Не созданы документы реализации'");
		ОбщегоНазначенияКлиентСервер.СообщитьПользователю(ТекстСообщения);
		Возврат
	КонецЕсли;
	
	Компит_ПолучитьДокументы(МассивДокументов);
	
КонецПроцедуры

