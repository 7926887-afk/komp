#Область РаботаСБуферомОбмена

Функция ПолучитьТекстБуфераОбмена() Экспорт 
	
	#Если Клиент Тогда 
		Объект = Новый COMОбъект("htmlfile"); 
		Возврат Объект.ParentWindow.ClipboardData.Getdata("Text"); 
	#КонецЕсли 
	
КонецФункции 


Функция УстановитьТекстВБуферОбмена(Текст) Экспорт 
	
	#Если Клиент Тогда 
		Объект = Новый COMОбъект("htmlfile"); 
		Объект.ParentWindow.ClipboardData.Setdata("Text", Текст); 
		Возврат Текст; 
	#КонецЕсли 
	
КонецФункции 

#КонецОбласти


#Область СозданиеРасходныхОрдеровНаТавары

Процедура СоздатьРасходныйОрдерНаТоварыПоДоставке(МассивСсылок, ЗаявкаНаДоставку, НовыйОрдер = Ложь) Экспорт
	
	ОчиститьСообщения();
	
	МассивРаспоряжений = Новый Массив;
	МассивРаспоряжений = МассивСсылок;
	
	ОткрытьФорму("Обработка.УправлениеОтгрузкой.Форма.ФормаНастроекСозданияОрдеров",Новый Структура("МассивРаспоряжений, ЗаявкаНаДоставку, НовыйОрдер",МассивРаспоряжений, ЗаявкаНаДоставку, НовыйОрдер),,,,,);	
	
КонецПроцедуры



#КонецОбласти

