#Область СозданиеРасходныхОрдеровНаТавары

//++ 13.03.2025 Ниронов
Процедура ПерезаполнитьТабличныеЧастиРО(ЗаявкаНаДоставку, РасходныйОрдерОбъект)
	
	Заказы = РасходныйОрдерОбъект.ТоварыПоРаспоряжениям.ВыгрузитьКолонку("Распоряжение");
	
	Запрос = Новый Запрос;
	Запрос.Текст =
	"ВЫБРАТЬ
	|	_ЗаявкаНаДоставку_ТоварыТ.Номенклатура КАК Номенклатура,
	|	_ЗаявкаНаДоставку_ТоварыТ.Характеристика КАК Характеристика,
	|	НазначенияТ.Ссылка КАК Назначение,
	|	_ЗаявкаНаДоставку_ТоварыТ.Серия КАК Серия,
	|	_ЗаявкаНаДоставку_ТоварыТ.Количество КАК Количество,
	|	_ЗаявкаНаДоставку_ТоварыТ.КоличествоУпаковок КАК КоличествоУпаковок,
	|	ЗаказКлиента_ТоварыТ.Ссылка КАК Распоряжение,
	|	ЗНАЧЕНИЕ(Перечисление.ДействияСоСтрокамиОрдеровНаОтгрузку.Отобрать) КАК Действие
	|ИЗ
	|	Документ._ЗаявкаНаДоставку.Товары КАК _ЗаявкаНаДоставку_ТоварыТ
	|	ЛЕВОЕ СОЕДИНЕНИЕ Документ.ЗаказКлиента.Товары КАК ЗаказКлиента_ТоварыТ
	|		ЛЕВОЕ СОЕДИНЕНИЕ Справочник.Назначения КАК НазначенияТ
	|		ПО ЗаказКлиента_ТоварыТ.Ссылка = НазначенияТ.Заказ
	|			И НазначенияТ.ПометкаУдаления = ЛОЖЬ
	|	ПО _ЗаявкаНаДоставку_ТоварыТ._УИДОтгрузка = ЗаказКлиента_ТоварыТ._УИДОтгрузка
	|ГДЕ _ЗаявкаНаДоставку_ТоварыТ.Ссылка = &ЗаявкаНаДоставку
	|	И ЗаказКлиента_ТоварыТ.Ссылка В (&Заказы)
	|";
	Запрос.Параметры.Вставить("ЗаявкаНаДоставку", ЗаявкаНаДоставку);
	Запрос.Параметры.Вставить("Заказы", Заказы);
	
	РезультатЗапроса = Запрос.Выполнить();
	
	РасходныйОрдерОбъект.ТоварыПоРаспоряжениям.Очистить();
	РасходныйОрдерОбъект.ОтгружаемыеТовары.Очистить();
	
	ВыборкаДетальныеЗаписи = РезультатЗапроса.Выбрать();
	Пока ВыборкаДетальныеЗаписи.Следующий() Цикл
		НС = РасходныйОрдерОбъект.ТоварыПоРаспоряжениям.Добавить();
		ЗаполнитьЗначенияСвойств(НС, ВыборкаДетальныеЗаписи);
		НС = РасходныйОрдерОбъект.ОтгружаемыеТовары.Добавить();
		ЗаполнитьЗначенияСвойств(НС, ВыборкаДетальныеЗаписи);
	КонецЦикла;
	
КонецПроцедуры //--

