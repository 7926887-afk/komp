#Область ОбработкаДокументаДоставки

&НаСервере
// Устанавливает страницу доставки в зависимости от способа доставки.
//
// Параметры:
//	ЭлементыФормы - ВсеЭлементыФормы - элементы формы, в которой устанавливается страница доставки;
//	СпособДоставки - ПеречислениеСсылка.СпособыДоставки - способ доставки, в зависимости от которого 
//		выбирается страница доставки;
//
Процедура УстановитьСтраницуДоставки(ЭлементыФормы, Объект ) Экспорт
	
	Если Объект.ДокументОснование = Документы.ЗаказКлиента.ПустаяСсылка() Тогда
		Возврат;
	КонецЕсли;
	
	ВеземДокументы											  = Объект.ВеземДокументы;
	СпособДоставки                                            = Объект.СпособДоставки;
	Если СпособДоставки = ПредопределенноеЗначение("Перечисление.СпособыДоставки.ДоКлиента") ИЛИ СпособДоставки = ПредопределенноеЗначение("Перечисление.СпособыДоставки.ПоручениеЭкспедиторуСоСклада") Тогда
		ЭлементыФормы.ПодГруппаДоставки.Видимость             = Истина;
	ИначеЕсли СпособДоставки                                  = ПредопределенноеЗначение("Перечисление.СпособыДоставки.Самовывоз") Тогда
		ЭлементыФормы.ПодГруппаДоставки.Видимость             = Ложь;
	КонецЕсли;
	
	Если Объект.ОсобыеУсловияПеревозки Тогда
		ЭлементыФормы.ОсобыеУсловияПеревозкиОписание.Доступность = Истина;
	Иначе
		ЭлементыФормы.ОсобыеУсловияПеревозкиОписание.Доступность = Ложь;
	КонецЕсли;
	
КонецПроцедуры	//УстановитьСтраницуДоставки()

&НаСервере
Процедура ЗаполнитьПодчиненныеСвойстваПартнера(Объект) Экспорт
	Если  ЗначениеЗаполнено(Объект.Контрагент) Тогда
		Объект.Менеджер			= Объект.Контрагент.Партнер.ОсновнойМенеджер;
		Объект.Подразделение	= Объект.Контрагент.Партнер.ОсновнойМенеджер.Подразделение;
		
		ТипыКИ = Новый Массив;
		ТипыКИ.Добавить(Перечисления.ТипыКонтактнойИнформации.Телефон);
		
		ИсточникиКИ = Новый Массив;
		ИсточникиКИ.Добавить();
	КонецЕсли; 
	
КонецПроцедуры	//ЗаполнитьПодчиненныеСвойстваКонтрагента(Элементы, Объект)()

&НаСервере
// Очищает списки выбора адресов доставки и реквизиты доставки.
//
// Параметры:
//	ЭлементыФормы - ВсеЭлементыФормы - элементы формы, в которых очищаются списки выбора адресов доставки;
//	ДокОбъект - ДокументОбъект - объект, в котором очищаются реквизиты доставки.
//
Процедура ЗаявкаОчиститьРеквизитыДоставки(Элементы, Объект) Экспорт
	Если Элементы.Найти("АдресДоставки") <> Неопределено Тогда
		Элементы.АдресДоставки.СписокВыбора.Очистить();
	КонецЕсли;
	Если Элементы.Найти("ДополнительнаяИнформация") <> Неопределено Тогда
		Объект.ДополнительнаяИнформацияПоДоставке = "";
	КонецЕсли;
	УстановитьСтраницуДоставки(Элементы, Объект);
	
КонецПроцедуры	//ЗаявкаОчиститьРеквизитыДоставки()

&НаСервере
Процедура _ПриУстановкеНовогоНомераЗаявкиНаДоставку(Источник, СтандартнаяОбработка, Префикс) Экспорт
	// Определим алгоритм формирования номера, согласно типу объекта
	Если ТипЗнч(Источник) = Тип("ДокументОбъект._ЗаявкаНаДоставку") Тогда
		ПрисвоитьНовыйНомерОбъектуЗаявкаНаДоставку(Источник, СтандартнаяОбработка, Префикс);
	КонецЕсли;
КонецПроцедуры

&НаСервере
Процедура ПрисвоитьНовыйНомерОбъектуЗаявкаНаДоставку(Источник, СтандартнаяОбработка, Префикс)
	
	СтандартнаяОбработка = Ложь;
	
	ДатаИсточника = Источник.Дата;
	ДатаИсточника = ?(ЗначениеЗаполнено(ДатаИсточника), ДатаИсточника, ТекущаяДата());
	
	// Префикс документов "Заказ клиента"
	ПрефиксОрганизации = "00";
	Если ЗначениеЗаполнено(Источник.Организация) Тогда
		ПрефиксОрганизации = Источник.Организация.Префикс;
		ПрефиксНовый = ПрефиксОрганизации + Формат(ДатаИсточника, "ДФ=ddMMyy");
	Иначе
		ПрефиксНовый = ПрефиксОрганизации + Формат(ДатаИсточника, "ДФ=ddMMyy");
	КонецЕсли;
	
	НомерИсточника = Источник.Номер;
	
	Если НЕ ЗначениеЗаполнено(НомерИсточника) Тогда
		
		НомерДокументаПоТаблице = ПолучитьНомерДокументаПоТаблице(Новый Структура("ИмяТаблицы, ДатаПолученияДанных, Префикс", "_ЗаявкаНаДоставку", ДатаИсточника, ПрефиксНовый));
		
		Если НомерДокументаПоТаблице = Неопределено Тогда
			Возврат;
		КонецЕсли;
		
		Источник.Номер = НомерДокументаПоТаблице;
		
	Иначе
		
		НомерИсточника   = Формат(0, "ЧЦ=" + СтрДлина(Префикс) +"""; ЧВН=; ЧГ=0") + Прав(НомерИсточника, СтрДлина(НомерИсточника) - СтрДлина(Префикс)); // Нули вместо префикса
		НовыйНомерСтрока = ПрефиксНовый + Прав(НомерИсточника, СтрДлина(НомерИсточника) - СтрДлина(ПрефиксНовый)); // с лева подставляем свой префикс
		
		Источник.Номер = НовыйНомерСтрока;
		
	КонецЕсли;
КонецПроцедуры	//ПрисвоитьНовыйНомерОбъектуЗаявкаНаДоставку()

&НаСервере
Функция ПолучитьНомерДокументаПоТаблице(ПараметрыЗапроса)
	Если НЕ ТипЗнч(ПараметрыЗапроса) = Тип("Структура") Тогда
		Возврат Неопределено;
	КонецЕсли;
	
	ИмяТаблицы = Неопределено;
	ПараметрыЗапроса.Свойство("ИмяТаблицы", ИмяТаблицы);
	
	Если ИмяТаблицы = Неопределено ИЛИ СокрЛП(ИмяТаблицы) = "" Тогда
		Возврат Неопределено;
	КонецЕсли;
	
	ДокументОбъектМетаданных = Метаданные.Документы.Найти(СокрЛП(ИмяТаблицы));
	Если ДокументОбъектМетаданных = Неопределено Тогда
		Возврат Неопределено;
	КонецЕсли;
	
	ДлинаНомера = ДокументОбъектМетаданных.ДлинаНомера;
	
	ДатаПолученияДанных = Неопределено;
	ПараметрыЗапроса.Свойство("ДатаПолученияДанных", ДатаПолученияДанных);
	Если НЕ ТипЗнч(ДатаПолученияДанных) = Тип("Дата") Тогда
		ДатаПолученияДанных = ТекущаяДата();
	КонецЕсли;
	
	Префикс = "00-";
	ПараметрыЗапроса.Свойство("Префикс", Префикс);
	
	Запрос = Новый Запрос;
	Запрос.Текст = "ВЫБРАТЬ ПЕРВЫЕ 1
					|	ТаблицаДокументов.Номер
					|ИЗ
					|	Документ."+ ИмяТаблицы + " КАК ТаблицаДокументов
					|ГДЕ
					|	ТаблицаДокументов.Дата МЕЖДУ НАЧАЛОПЕРИОДА(&ДатаПолученияДанных, ДЕНЬ) И КОНЕЦПЕРИОДА(&ДатаПолученияДанных, ДЕНЬ)
					|	И ТаблицаДокументов.Номер ПОДОБНО """ + Префикс + "%""
					|УПОРЯДОЧИТЬ ПО
					|	ТаблицаДокументов.Номер УБЫВ
					|";
	
	Запрос.УстановитьПараметр("ДатаПолученияДанных", ?(НЕ ЗначениеЗаполнено(ДатаПолученияДанных), ТекущаяДата(), ДатаПолученияДанных));
	
	РезультатЗапроса = Запрос.Выполнить();
	Если РезультатЗапроса.Пустой() Тогда
		
		СтрокаНулей = "";
		Для Итератор = 1 По ДлинаНомера Цикл
			СтрокаНулей = СтрокаНулей + "0";
		КонецЦикла;
		
		ПоследнийНомерПоТаблице = СтрокаНулей;
	Иначе
		
		Выборка = РезультатЗапроса.Выбрать();
		Выборка.Следующий();
		
		ПоследнийНомерПоТаблице = Выборка.Номер;
		
	КонецЕсли;
	
	ДлинаПолученногоНомера = СтрДлина(ПоследнийНомерПоТаблице);
	ОписаниеТиповЧисло = Новый ОписаниеТипов("Число", Новый КвалификаторыЧисла(ДлинаПолученногоНомера, 0));
	
	СтрокаЧислоВНомере = "";
	Для Итератор = 0 По ДлинаПолученногоНомера - 1 Цикл
		
		СимволВНомере = Сред(ПоследнийНомерПоТаблице, ДлинаПолученногоНомера - Итератор, 1);
		СтрокаЧислоВНомере = ?(Найти("0123456789", СимволВНомере) = 0, "0", СимволВНомере) + СтрокаЧислоВНомере;
		
	КонецЦикла;
	
	ЧислоВНомере = ОписаниеТиповЧисло.ПривестиЗначение(СтрокаЧислоВНомере);
	Если НЕ ТипЗнч(ЧислоВНомере) = Тип("Число") Тогда
		ЧислоВНомере = 0;
	КонецЕсли;
	
	НовыйНомерСтрока = Формат(ЧислоВНомере + 1, "ЧЦ=" + ДлинаПолученногоНомера +"""; ЧВН=; ЧГ=0");
	
	НовыйНомерСтрока = Префикс + Прав(НовыйНомерСтрока, ДлинаПолученногоНомера - СтрДлина(Префикс));
	
	Возврат НовыйНомерСтрока;
КонецФункции	//ПолучитьНомерДокументаПоТаблице(ПараметрыЗапроса)

&НаСервере
Процедура ПроверитьВозможностьВводаЗаявкиНаДоставку(ЗаказКлиента) Экспорт
	Запрос = Новый Запрос;
	Запрос.Текст = "ВЫБРАТЬ
					|	_ЗаявкаНаДоставку.Ссылка,
					|	_ЗаявкаНаДоставку.Номер,
					|	_ЗаявкаНаДоставку.Дата,
					|	_ЗаявкаНаДоставку.ДокументОснование,
					|	_ЗаявкаНаДоставку.Заказы.(
					|		Ссылка,
					|		ЗаказКлиента
					|	)
					|ИЗ
					|	Документ._ЗаявкаНаДоставку КАК _ЗаявкаНаДоставку
					|ГДЕ
					|	_ЗаявкаНаДоставку.ДокументОснование = &ЗаказКлиента
					|	И _ЗаявкаНаДоставку.Заказы.ЗаказКлиента = &ЗаказКлиента";
	
	
	Запрос.УстановитьПараметр("ЗаказКлиента", ЗаказКлиента);
	Результат = Запрос.Выполнить().Выгрузить();
	Если НЕ Результат.Количество() = 0 Тогда
		
		ТекстОшибки = НСтр("ru='По документу %Документ% - создана Заявка на отгрузку.'");
		ТекстОшибки = СтрЗаменить(ТекстОшибки, "%Документ%", ЗаказКлиента);
		
		ВызватьИсключение ТекстОшибки;
		
	КонецЕсли;
КонецПроцедуры	//ПроверитьВозможностьВводаЗаявкиНаДоставку()

&НаСервере
Функция ОтборЗаказов(Объект, КлючУникальности)
	
	Запрос = Новый Запрос;
	Запрос.Текст = "ВЫБРАТЬ
					|	_ЗаявкаНаДоставкуЗаказы.НомерСтроки КАК НомерПП,
					|	_ЗаявкаНаДоставкуЗаказы.ЗаказКлиента КАК ЗаказКлиента,
					|	_ЗаявкаНаДоставку.Ссылка КАК ЗаявкаНаДоставку,
					|	&КлючУникальности КАК GUID
					|ИЗ
					|	Документ._ЗаявкаНаДоставку.Заказы КАК _ЗаявкаНаДоставкуЗаказы
					|		ЛЕВОЕ СОЕДИНЕНИЕ Документ._ЗаявкаНаДоставку КАК _ЗаявкаНаДоставку
					|		ПО _ЗаявкаНаДоставкуЗаказы.Ссылка = _ЗаявкаНаДоставку.Ссылка
					|ГДЕ
					|	_ЗаявкаНаДоставку.Ссылка = &Ссылка
					|
					|СГРУППИРОВАТЬ ПО
					|	_ЗаявкаНаДоставкуЗаказы.НомерСтроки,
					|	_ЗаявкаНаДоставкуЗаказы.ЗаказКлиента,
					|	_ЗаявкаНаДоставку.Ссылка";
	
	Запрос.УстановитьПараметр("Ссылка", Объект.Ссылка);
	Запрос.УстановитьПараметр("КлючУникальности", КлючУникальности);
	Результат = Запрос.Выполнить();
	
	Возврат Результат;
	
КонецФункции // ОтборЗаказов()

&НаСервере
Функция ПолучитьТоваыЗаявкиНаОтгрузку(Объект)
	
	Запрос = Новый Запрос;
	Запрос.Текст = "ВЫБРАТЬ
	               |	_ЗаявкаНаДоставкуТовары.Ссылка,
	               |	_ЗаявкаНаДоставкуТовары.НомерСтроки,
	               |	_ЗаявкаНаДоставкуТовары.Номенклатура,
	               |	_ЗаявкаНаДоставкуТовары.Характеристика,
	               |	_ЗаявкаНаДоставкуТовары.Серия,
	               |	_ЗаявкаНаДоставкуТовары.ВариантОбеспечения,
	               |	_ЗаявкаНаДоставкуТовары.Количество,
	               |	_ЗаявкаНаДоставкуТовары.КоличествоУпаковок,
	               |	_ЗаявкаНаДоставкуТовары._УИДОтгрузка
	               |ИЗ
	               |	Документ._ЗаявкаНаДоставку.Товары КАК _ЗаявкаНаДоставкуТовары
	               |ГДЕ
	               |	_ЗаявкаНаДоставкуТовары.Ссылка = &Ссылка";
	
	Запрос.УстановитьПараметр("Ссылка", Объект.Ссылка);
	Результат = Запрос.Выполнить();
	Возврат Результат;
	
КонецФункции	//получитьТоваыЗаявкиНаОтгрузку()

&НаСервере
Процедура СформироватьЗаписиРегистра_ЗаказЗаявка(Объект, КлючУникальности , Удаление = Ложь, Выбран = Ложь, Обработан = Ложь )Экспорт
	
	Если НЕ Выбран Тогда
		НачатьТранзакцию();
		Если НЕ Удаление Тогда
			Результат							= ОтборЗаказов(Объект, КлючУникальности);
			Выборка								= Результат.Выбрать();
			Пока Выборка.Следующий() Цикл
				МенеджерЗаписи					= РегистрыСведений._ЗаказЗаявка.СоздатьМенеджерЗаписи();
				ЗаполнитьЗначенияСвойств(МенеджерЗаписи, Выборка);
				МенеджерЗаписи.Обработан		= Обработан;
				МенеджерЗаписи.Записать(Истина);
			КонецЦикла;
		Иначе			//Удаление
			МенеджерЗаписи						= РегистрыСведений._ЗаказЗаявка.СоздатьМенеджерЗаписи();
			МенеджерЗаписи.ЗаявкаНаДоставку		= Объект.Ссылка;
			МенеджерЗаписи.GUID					= КлючУникальности;
			Для Каждого ТекЗаказ Из Объект.Заказы Цикл
				МенеджерЗаписи.ЗаказКлиента			= ТекЗаказ.ЗаказКлиента;
				МенеджерЗаписи.Прочитать();
				Если МенеджерЗаписи.Выбран() Тогда
					МенеджерЗаписи.Удалить();
				КонецЕсли; 
			КонецЦикла;		// ТекЗаказ Из Объект.Заказы
			Если МенеджерЗаписи.Выбран() Тогда
				МенеджерЗаписи.Удалить();
			КонецЕсли; 
		КонецЕсли;		//Не Удаление
		ЗафиксироватьТранзакцию();
	Иначе			//Выбран
		НачатьТранзакцию();
		МенеджерЗаписи							= РегистрыСведений._ЗаказЗаявка.СоздатьМенеджерЗаписи();
		МенеджерЗаписи.GUID						= КлючУникальности;
		МенеджерЗаписи.ЗаявкаНаДоставку			= Объект.Ссылка;
		Для Каждого ТекЗаказ Из Объект.Заказы Цикл
			МенеджерЗаписи.ЗаказКлиента			= ТекЗаказ.ЗаказКлиента;
			МенеджерЗаписи.Прочитать();
			Если МенеджерЗаписи.Выбран() Тогда
				МенеджерЗаписи.Обработан		= Обработан;
				МенеджерЗаписи.Записать(Истина);
			Иначе
				МенеджерЗаписи					= РегистрыСведений._ЗаказЗаявка.СоздатьМенеджерЗаписи();
				МенеджерЗаписи.GUID				= КлючУникальности;
				МенеджерЗаписи.ЗаявкаНаДоставку = Объект.Ссылка;
				МенеджерЗаписи.ЗаказКлиента		= ТекЗаказ.ЗаказКлиента;
				МенеджерЗаписи.Обработан		= Обработан;
				МенеджерЗаписи.Записать(Истина);
			КонецЕсли; 
		КонецЦикла;		// ТекЗаказ Из Объект.Заказы
		ЗафиксироватьТранзакцию();
	КонецЕсли;		// НЕ Выбран 		 
	
КонецПроцедуры	//СформироватьЗаписиРегистровЗаданий(Объект)

&НаСервере
Функция ОтборЗаказовРегистр(Объект, КлючУникальности)
	
	Запрос = Новый Запрос;
	Запрос.Текст = "ВЫБРАТЬ
					|	_ЗаказЗаявка.ЗаказКлиента,
					|	_ЗаказЗаявка.ЗаявкаНаДоставку,
					|	_ЗаказЗаявка.GUID,
					|	_ЗаказЗаявка.Обработан
					|ИЗ
					|	РегистрСведений._ЗаказЗаявка КАК _ЗаказЗаявка
					|ГДЕ
					|	_ЗаказЗаявка.ЗаявкаНаДоставку = &ЗаявкаНаДоставку
					|	И _ЗаказЗаявка.GUID = &КлючУникальности";
	
	Запрос.УстановитьПараметр("ЗаявкаНаДоставку", Объект.Ссылка);
	Запрос.УстановитьПараметр("КлючУникальности", КлючУникальности);
	Результат = Запрос.Выполнить();
	Возврат Результат;
	
КонецФункции // ОтборЗаказовРегистр()

&НаСервере
Функция ОбработатьДоставкуТовары(Объект, ОбъектЗаказ)
	
	ДатаОтгрузкиЗаявки	= Объект.ЖелаемаяДатаОтгрузки;
	ТоварыЗаявки		= Объект.Товары;
	ТоварыЗаказа		= ОбъектЗаказ.Товары;
	КолСтрокЗаявки		= Объект.Товары.Количество();
	НеОтгружатьЧастями	= Ложь;
	
	Для Каждого СтрокаДоставки Из ТоварыЗаявки Цикл
		СтруктураДляПоиска	= Новый Структура("Номенклатура, Характеристика, ВариантОбеспечения", СтрокаДоставки.Номенклатура, СтрокаДоставки.Характеристика, Перечисления.ВариантыОбеспечения.Отгрузить);
		СтрокиЗаказа		= ТоварыЗаказа.НайтиСтроки(СтруктураДляПоиска);         
		Если НЕ СтрокиЗаказа.Количество() = 0 Тогда
			Для Каждого СтрокаЗаказа Из СтрокиЗаказа Цикл
				СтрокаЗаказа.ДатаОтгрузки = ДатаОтгрузкиЗаявки;
			КонецЦикла;		// СтрокаЗаказа Из СтрокиЗаказа
			КолСтрокЗаявки	= КолСтрокЗаявки - 1;	
		КонецЕсли; 
	КонецЦикла;		// СтрокаДоставки Из ТоварыЗаявки      
	
	Если КолСтрокЗаявки <= 0 Тогда
		НеОтгружатьЧастями = Истина;
	КонецЕсли;
	
	Возврат НеОтгружатьЧастями;
	
КонецФункции // ОбработатьДоставкуТовары(Объект, ОбъектЗаказ)


