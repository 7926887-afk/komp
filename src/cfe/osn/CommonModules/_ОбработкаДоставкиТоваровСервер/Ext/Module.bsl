	|				И ЗаказКлиента.Склад.ВыборГруппы = ЗНАЧЕНИЕ(Перечисление.ВыборГруппыСкладов.РазрешитьВЗаказах)
	|			ТОГДА ЗНАЧЕНИЕ(Справочник.Склады.ПустаяСсылка)
	|		ИНАЧЕ ЗаказКлиента.Склад
	|	КОНЕЦ КАК Склад,
	|	ВЫБОР
	|		КОГДА ЗаказКлиента.Склад.ЭтоГруппа
	|				И ЗаказКлиента.Склад.ВыборГруппы = ЗНАЧЕНИЕ(Перечисление.ВыборГруппыСкладов.РазрешитьВЗаказах)
	|			ТОГДА ИСТИНА
	|		ИНАЧЕ ЛОЖЬ
	|	КОНЕЦ КАК ЗапрещеноВыбиратьГруппуСкладов,
	|	ЗаказКлиента.ЦенаВключаетНДС КАК ЦенаВключаетНДС,
	|	ЗаказКлиента.НалогообложениеНДС КАК НалогообложениеНДС,
	|	ЗаказКлиента.ХозяйственнаяОперация КАК ХозяйственнаяОперация,
	|	ЗаказКлиента.НеОтгружатьЧастями КАК НеОтгружатьЧастями,
	|	ЗаказКлиента.АдресДоставки КАК АдресДоставки,
	|	ЗаказКлиента.Склад.ИспользоватьОрдернуюСхемуПриОтгрузке КАК ОрдернаяСхемаПриОтгрузке,
	|	ЗаказКлиента.ГруппаФинансовогоУчета КАК ГруппаФинансовогоУчета,
	|	ЗаказКлиента.Статус КАК СтатусДокумента,
	|	НЕ ЗаказКлиента.Проведен КАК ЕстьОшибкиПроведен,
	|	ИСТИНА КАК ЕстьОшибкиСтатус,
	|	ЗаказКлиента.БанковскийСчет КАК БанковскийСчетОрганизации,
	|	ЗаказКлиента.БанковскийСчетКонтрагента КАК БанковскийСчетКонтрагента,
	|	ЗаказКлиента.Грузоотправитель КАК Грузоотправитель,
	|	ЗаказКлиента.Грузополучатель КАК Грузополучатель,
	|	ЗаказКлиента.БанковскийСчетГрузоотправителя КАК БанковскийСчетГрузоотправителя,
	|	ЗаказКлиента.БанковскийСчетГрузополучателя КАК БанковскийСчетГрузополучателя,
	|	ЗаказКлиента.ВернутьМногооборотнуюТару КАК ВернутьМногооборотнуюТару,
	|	ЗаказКлиента.СрокВозвратаМногооборотнойТары КАК СрокВозвратаМногооборотнойТары,
	|	ЗаказКлиента.ТребуетсяЗалогЗаТару КАК ТребуетсяЗалогЗаТару,
	|	ВЫБОР
	|		КОГДА &ИспользоватьСоглашенияСКлиентами
	|			ТОГДА ЗаказКлиента.Соглашение.КалендарьВозвратаТары
	|		ИНАЧЕ ЗНАЧЕНИЕ(Справочник.ПроизводственныеКалендари.ПустаяСсылка)
	|	КОНЕЦ КАК КалендарьВозвратаТары,
	|	ВЫБОР
	|		КОГДА &ИспользоватьСоглашенияСКлиентами
	|			ТОГДА ЗаказКлиента.Соглашение.РассчитыватьДатуВозвратаТарыПоКалендарю
	|		ИНАЧЕ ЛОЖЬ
	|	КОНЕЦ КАК РассчитыватьДатуВозвратаТарыПоКалендарю,
	|	ЗаказКлиента.СкидкиНаценки.(
	|		КлючСвязи КАК КлючСвязи,
	|		СкидкаНаценка КАК СкидкаНаценка,
	|		Сумма КАК Сумма
	|	) КАК СкидкиНаценки,
	|	ЗаказКлиента.АдресДоставкиЗначенияПолей КАК АдресДоставкиЗначенияПолей,
	|	ВЫБОР
	|		КОГДА НЕ &ИспользоватьЗаданияНаПеревозкуДляУчетаДоставкиПеревозчиками
	|				И ЗаказКлиента.СпособДоставки = ЗНАЧЕНИЕ(Перечисление.СпособыДоставки.СиламиПеревозчика)
	|			ТОГДА ЗаказКлиента.СпособДоставки
	|	КОНЕЦ КАК СпособДоставки,
	|	ВЫБОР
	|		КОГДА НЕ &ИспользоватьЗаданияНаПеревозкуДляУчетаДоставкиПеревозчиками
	|				И ЗаказКлиента.СпособДоставки = ЗНАЧЕНИЕ(Перечисление.СпособыДоставки.СиламиПеревозчика)
	|			ТОГДА ЗаказКлиента.ПеревозчикПартнер
	|	КОНЕЦ КАК ПеревозчикПартнер,
	|	ВЫБОР
	|		КОГДА НЕ &ИспользоватьЗаданияНаПеревозкуДляУчетаДоставкиПеревозчиками
	|				И ЗаказКлиента.СпособДоставки = ЗНАЧЕНИЕ(Перечисление.СпособыДоставки.СиламиПеревозчика)
	|			ТОГДА ЗаказКлиента.ДополнительнаяИнформацияПоДоставке
	|	КОНЕЦ КАК ДополнительнаяИнформацияПоДоставке,
	|	ЗаказКлиента.ПорядокРасчетов КАК ПорядокРасчетов,
	|	ЗаказКлиента.НаправлениеДеятельности КАК НаправлениеДеятельности
	|ИЗ
	|	Документ.ЗаказКлиента КАК ЗаказКлиента
	|ГДЕ
	|	ЗаказКлиента.Ссылка = &ЗаказКлиента
	|;
	|
	|////////////////////////////////////////////////////////////////////////////////
	|ВЫБРАТЬ РАЗЛИЧНЫЕ
	|	РаспоряженияНаОтгрузку.Склад КАК Склад
	|ИЗ
	|	РегистрНакопления.РаспоряженияНаОтгрузку.Обороты(, , , Распоряжение = &ЗаказКлиента) КАК РаспоряженияНаОтгрузку";
	
		Запрос.УстановитьПараметр("ЗаказКлиента", ДокументОснование);
		Запрос.УстановитьПараметр("ИспользоватьСоглашенияСКлиентами", ИспользоватьСоглашенияСКлиентами);
		Запрос.УстановитьПараметр("ИспользоватьЗаданияНаПеревозкуДляУчетаДоставкиПеревозчиками",
			ПолучитьФункциональнуюОпцию("ИспользоватьЗаданияНаПеревозкуДляУчетаДоставкиПеревозчиками"));
		
		РезультатЗапроса = Запрос.ВыполнитьПакет();
		
		РеквизитыЗаказа = РезультатЗапроса[0].Выбрать();
		РеквизитыЗаказа.Следующий();

		Документы.ЗаказКлиента.ПроверитьВозможностьВводаНаОсновании(
			РеквизитыЗаказа.ЗаказКлиента,
			РеквизитыЗаказа.СтатусДокумента,
			РеквизитыЗаказа.ЕстьОшибкиПроведен);
		
		// Заполнение шапки
		ЗаполнитьЗначенияСвойств(НоваяРеализация, РеквизитыЗаказа);
		Если НЕ ПолучитьФункциональнуюОпцию("ИспользоватьРасширенныеВозможностиЗаказаКлиента") Тогда
			Если НЕ ЗначениеЗаполнено(НоваяРеализация.Дата) Тогда
				НоваяРеализация.Дата = ТекущаяДатаСеанса();
			КонецЕсли;
		КонецЕсли;
		ДатаВозвратаМногооборотнойТары = МногооборотнаяТараСервер.РассчитатьДатуВозвратаМногооборотнойТары(
			НоваяРеализация,
			РеквизитыЗаказа.СрокВозвратаМногооборотнойТары,
			РеквизитыЗаказа.РассчитыватьДатуВозвратаТарыПоКалендарю,
			РеквизитыЗаказа.КалендарьВозвратаТары);
		
		Если РеквизитыЗаказа.ЗапрещеноВыбиратьГруппуСкладов Тогда
			МассивСкладов = РезультатЗапроса[1].Выгрузить().ВыгрузитьКолонку("Склад");
		КонецЕсли;
		
	
	РеализацияПоЗаказам = Истина;
	
	Если НоваяРеализация.ПорядокРасчетов = Перечисления.ПорядокРасчетов.ПоНакладным Тогда
		Если ИспользоватьСоглашенияСКлиентами И ЗначениеЗаполнено(НоваяРеализация.Соглашение) Тогда
			УсловияПродаж = ПродажиСервер.ПолучитьУсловияПродаж(НоваяРеализация.Соглашение);
			ФормаОплаты   = УсловияПродаж.ФормаОплаты;
			
			СтруктураПараметров = ДенежныеСредстваСервер.ПараметрыЗаполненияКассыОрганизацииПоУмолчанию();
			СтруктураПараметров.Организация    			= НоваяРеализация.Организация;
			СтруктураПараметров.НаправлениеДеятельности	= НоваяРеализация.НаправлениеДеятельности;
			СтруктураПараметров.ФормаОплаты				= НоваяРеализация.ФормаОплаты;

			Касса = ЗначениеНастроекПовтИсп.ПолучитьКассуОрганизацииПоУмолчанию(СтруктураПараметров);
			//++ Обновление 
			//ЭтапыОплатыСервер.ЗаполнитьДатуПлатежаПоУмолчанию(НоваяРеализация, УсловияПродаж.ГрафикОплаты);
			//--
		КонецЕсли;
	Иначе
//** 		ЗаполнитьДатуПлатежаПоОснованию(НоваяРеализация, ДокументОснование);
	КонецЕсли;
	
	// Заполнение т.ч. товары.
		ЗаполнятьПоОстаткам = Истина;
		СкладОтгрузки = НоваяРеализация.Склад;
	
	Если ЗаполнятьПоОстаткам Тогда
		
		Если ТипОснования = Тип("Массив") Тогда
			МассивЗаказов = ДокументОснование;
		Иначе
			МассивЗаказов = Новый Массив();
			МассивЗаказов.Добавить(НоваяРеализация.ЗаказКлиента);
		КонецЕсли;
		
		ПараметрыЗаполнения = Новый Структура;
		ПараметрыЗаполнения.Вставить("ВариантОформления", ВариантОформления);
		ПараметрыЗаполнения.Вставить("ПараметрыОформления", ПараметрыОформления);
		
		Документы.РеализацияТоваровУслуг.ЗаполнитьПоОстаткамЗаказов(
			НоваяРеализация,
			НоваяРеализация.Товары,
			НоваяРеализация.СкидкиНаценки,
			?(СкладОтгрузки=Неопределено, Справочники.Склады.ПустаяСсылка(), СкладОтгрузки),
			МассивЗаказов,
			ПараметрыЗаполнения);
		НоваяРеализация.ВариантОформленияПродажи = ?(ЗначениеЗаполнено(ВариантОформления), 
			ВариантОформления,
			Перечисления.ВариантыОформленияПродажи.РеализацияТоваровУслуг);
		ЗаказыСервер.ЗаполнитьЗаказВШапкеПоЗаказамВТабличнойЧасти(НоваяРеализация.ЗаказКлиента, НоваяРеализация.Товары, "ЗаказКлиента");
		
		ПараметрыУказанияСерий = НоменклатураСервер.ПараметрыУказанияСерий(НоваяРеализация, Документы.РеализацияТоваровУслуг);
		НоменклатураСервер.ЗаполнитьСерииПоFEFO(НоваяРеализация,ПараметрыУказанияСерий, Ложь);
		
	КонецЕсли;
	
	Если НЕ ЗначениеЗаполнено(НоваяРеализация.Статус) Тогда
		НоваяРеализация.Статус = Перечисления.СтатусыРеализацийТоваровУслуг.Отгружено;
	КонецЕсли;
	
	СтруктураОснование = Документы.РеализацияТоваровУслуг.СтруктураОснованияДляПечати(НоваяРеализация);
	ЗаполнитьЗначенияСвойств(НоваяРеализация, СтруктураОснование);
	
	СтруктураДействий = Новый Структура;
	_ДоработкиСлужебный.ДобавитьВСтруктуруДействияПриИзмененииКоличестваУпаковок(СтруктураДействий, НоваяРеализация);
	Для Каждого ТекСтрока Из НоваяРеализация.Товары Цикл
		_ДоработкиСлужебный.ПересчитатьСуммуВСтрокеТЧ(ТекСтрока,	СтруктураДействий);
		_ДоработкиСлужебный.ПересчитатьСуммуНДСВСтрокеТЧ(ТекСтрока,	СтруктураДействий);
		_ДоработкиСлужебный.ПересчитатьСуммуСНДСВСтрокеТЧ(ТекСтрока,СтруктураДействий);
	КонецЦикла;		// ТекСтрока Из НоваяРеализация.Товары 
КонецПроцедуры

&НаСервере 
Функция СодатьРеализацию( Организация = Неопределено )
	
	НоваяРеализация			= Документы.РеализацияТоваровУслуг.СоздатьДокумент(); 
	НоваяРеализация.Дата	= ТекущаяДата(); 
	Если ( Организация <> Неопределено ) Тогда
		НоваяРеализация.Организация = Организация;
	КонецЕсли;	
	НоваяРеализация.Записать(РежимЗаписиДокумента.Запись);
	Возврат НоваяРеализация;
	
КонецФункции // СодатьРеализацию(ТекЗаказ)()
 
&НаСервере
Функция ПроверитьНеобходимостьДокументов(ДокументОснование)
	
	ПроверкаЗаказов   = Истина;
	
	Запрос = Новый Запрос;
	Запрос.Текст = "ВЫБРАТЬ РАЗРЕШЕННЫЕ
	               |	_ЗаявкаНаДоставкуЗаказы.ЗаказКлиента
	               |ИЗ
	               |	Документ._ЗаявкаНаДоставку.Заказы КАК _ЗаявкаНаДоставкуЗаказы
	               |ГДЕ
	               |	_ЗаявкаНаДоставкуЗаказы.ЗаказКлиента = &ЗаказКлиента
	               |	И _ЗаявкаНаДоставкуЗаказы.НужныДокументы = ИСТИНА
	               |	И _ЗаявкаНаДоставкуЗаказы.Ссылка.Проведен = ИСТИНА
	               |	И _ЗаявкаНаДоставкуЗаказы.Ссылка.ПометкаУдаления = ЛОЖЬ";
	
	
	Запрос.УстановитьПараметр("ЗаказКлиента", ДокументОснование);
	Результат = Запрос.Выполнить().Выгрузить();
	
	Если НЕ Результат.Количество() = 0 Тогда
		ПроверкаЗаказов =  Истина;
	КонецЕсли;
	
	Возврат ПроверкаЗаказов;
	
КонецФункции // ПроверитьДокументыРеализиции()

&НаСервере
Процедура СоздатьРеализациюПоРасходномуОрдеру(Объект) Экспорт
	
	ТоварыПоРаспоряжениям		= Объект.ТоварыПоРаспоряжениям;
	ОтгружаемыеТовары			= Объект.ОтгружаемыеТовары;
	ДокументОснование			= Документы.ЗаказКлиента.ПустаяСсылка();
	
	Если Объект.ОтгрузкаПоЗаданиюНаПеревозку Тогда
		СпособДоставки = Перечисления.СпособыДоставки.ДоКлиента;
	Иначе
		СпособДоставки = Перечисления.СпособыДоставки.Самовывоз;
	КонецЕсли; 
	
	
	Для Каждого ТекСтрока Из ТоварыПоРаспоряжениям Цикл
		
		Если НЕ ДокументОснование = ТекСтрока.Распоряжение Тогда
			
			СтруктураПоиска		= Новый Структура("Номенклатура, Характеристика, Назначение, Серия, Действие");
			СтруктураПоиска.Вставить("Номенклатура", ТекСтрока.Номенклатура);
			СтруктураПоиска.Вставить("Характеристика", ТекСтрока.Характеристика);
			СтруктураПоиска.Вставить("Назначение", ТекСтрока.Назначение);
			СтруктураПоиска.Вставить("Серия", ТекСтрока.Серия);
			СтруктураПоиска.Вставить("Действие", Перечисления.ДействияСоСтрокамиОрдеровНаОтгрузку.Отгрузить);
			
			НайденныеСтроки		= ОтгружаемыеТовары.НайтиСтроки(СтруктураПоиска);
			
			Если НайденныеСтроки.Количество() = 0 Тогда
				Продолжить;
			КонецЕсли;
			
			ДокументОснование	= ТекСтрока.Распоряжение;
			
			
			Если Не ПроверитьНеобходимостьДокументов(ДокументОснование) Тогда
				ТекстСообщения = НСтр("ru='По документу " + Строка(ДокументОснование) + " - Не  нужны документы'");
				ОбщегоНазначенияКлиентСервер.СообщитьПользователю(ТекстСообщения);
				Возврат
			КонецЕсли;
			
			НоваяРеализация 	= СодатьРеализацию( ДокументОснование.Организация );
			
			СкладОтгрузки		= Неопределено;
			РеквизитыШапки		= Неопределено;
			ПараметрыОформления	= Неопределено;
			ВариантОформления 	= Перечисления.ВариантыОформленияПродажи.РеализацияТоваровУслуг;
			
			ЗаполнитьДокументНаОснованииЗаказаКлиента(ДокументОснование, СкладОтгрузки, ВариантОформления, РеквизитыШапки, ПараметрыОформления, НоваяРеализация);
			НоваяРеализация.РеализацияПоЗаказам = Истина;
			НоваяРеализация.Менеджер			= ДокументОснование.Менеджер;
			НоваяРеализация.СпособДоставки		= СпособДоставки;
			Если НоваяРеализация.Товары.Количество() = 0 Тогда
				ТекстСообщения = НСтр("ru='По документу " + Строка(ДокументОснование) + " - существует документ реализации и счет-фактура'");
				ОбщегоНазначенияКлиентСервер.СообщитьПользователю(ТекстСообщения);
				НоваяРеализация.Записать(РежимЗаписиДокумента.Запись);
				НоваяРеализация.Удалить();
				Возврат
			КонецЕсли;
			
			НоваяРеализация.Записать(РежимЗаписиДокумента.Проведение);
			
			ДанныеСчетаФактуры = Новый Структура;
			ДанныеСчетаФактуры.Вставить("ДокументОснование", НоваяРеализация.Ссылка);
			ДанныеСчетаФактуры.Вставить("Организация",       НоваяРеализация.Организация);

			ВвестиСчетФактуру(ДанныеСчетаФактуры);	
		КонецЕсли;		//НЕ ДокументОснование = ТекСтрока.Распоряжение 
		
		ТекстСообщения = НСтр("ru='По документу " + Строка(ТекСтрока.Распоряжение) + " - создан документ реализации и счет-фактура'");
		ОбщегоНазначенияКлиентСервер.СообщитьПользователю(ТекстСообщения);
		
	КонецЦикла;		// ТекСтрока Из ТоварыПоРаспоряжениям 
	
КонецПроцедуры	// СоздатьРеализациюПоЗаказуКлиента()

&НаСервере
Процедура СоздатьРеализациюПоЗаданиюНаПеревозку(Объект) Экспорт
	
	СпособДоставки  = Перечисления.СпособыДоставки.ДоКлиента;
	
	Распоряжения	= Объект.Распоряжения; 
	ТоварыКДоставке = _ДоработкиСлужебный.ЗаполнитьТоварыКДоставке(Объект);
	ТоварыКДоставке.Сортировать("Распоряжение Возр, Назначение Возр, Номенклатура Возр");  
	ТзЗаказы		= ТоварыКДоставке.Скопировать();
	ТзЗаказы.Свернуть(" Распоряжение, Назначение");
	
	Для Каждого ТекСтрока Из ТзЗаказы Цикл
		ДокументОснование  = ТекСтрока.Распоряжение;
		//ДОВ
		Если ТипЗнч(ДокументОснование) =  Тип("ДокументСсылка.ЗаказПоставщику") Тогда
			Продолжить;
		КонецЕсли;  
		
		Если Не ПроверитьНеобходимостьДокументов(ДокументОснование) Тогда
			ТекстСообщения = НСтр("ru='По документу " + Строка(ДокументОснование) + " - Не  нужны документы'");
			ОбщегоНазначенияКлиентСервер.СообщитьПользователю(ТекстСообщения);
			Продолжить;
		КонецЕсли;
		
		СтруктураПоиска		= Новый Структура("Распоряжение, Назначение");
		СтруктураПоиска.Вставить("Распоряжение", ТекСтрока.Распоряжение);
		СтруктураПоиска.Вставить("Назначение",   ТекСтрока.Назначение);
		
		НайденныеСтроки		= ТоварыКДоставке.НайтиСтроки(СтруктураПоиска);
		
		Если НайденныеСтроки.Количество() = 0 Тогда
			Продолжить;
		КонецЕсли;
		
		НоваяРеализация 	= СодатьРеализацию( ДокументОснование.Организация );
		
		СкладОтгрузки		= Неопределено;
		РеквизитыШапки		= Неопределено;
		ПараметрыОформления	= Неопределено;
		ВариантОформления 	= Перечисления.ВариантыОформленияПродажи.РеализацияТоваровУслуг;
		ЗаполнитьДокументНаОснованииЗаказаКлиента(ДокументОснование, СкладОтгрузки, ВариантОформления, РеквизитыШапки, ПараметрыОформления, НоваяРеализация);
		
		НоваяРеализация.РеализацияПоЗаказам = Истина;
		НоваяРеализация.Менеджер			= ДокументОснование.Менеджер;
		НоваяРеализация.СпособДоставки		= СпособДоставки;
		Если НоваяРеализация.Товары.Количество() = 0 Тогда
			ТекстСообщения = НСтр("ru='По документу " + Строка(ДокументОснование) + " - существует документ реализации и счет-фактура'");
			ОбщегоНазначенияКлиентСервер.СообщитьПользователю(ТекстСообщения);
			НоваяРеализация.Записать(РежимЗаписиДокумента.Запись);
			НоваяРеализация.Удалить();
			Возврат
		КонецЕсли;
		
		НоваяРеализация.Записать(РежимЗаписиДокумента.Проведение);
		
		ДанныеСчетаФактуры = Новый Структура;
		ДанныеСчетаФактуры.Вставить("ДокументОснование", НоваяРеализация.Ссылка);
		ДанныеСчетаФактуры.Вставить("Организация",       НоваяРеализация.Организация);
		ВвестиСчетФактуру(ДанныеСчетаФактуры);	
		
		ТекстСообщения = НСтр("ru='По документу " + Строка(ТекСтрока.Распоряжение) + " - создан документ реализации и счет-фактура'");
		ОбщегоНазначенияКлиентСервер.СообщитьПользователю(ТекстСообщения);
		
	КонецЦикла;		// ТекСтрока Из ТзЗаказы  
	
КонецПроцедуры	// СоздатьРеализациюПоЗаказуКлиента()


#КонецОбласти


#Область ПечатьУПД

&НаСервере
Процедура ДополнитьТекстЗапросаПоРеквизитамОбъекта(ТекстЗапроса, МассивРеквизитов)
	
	ТекстПредставление = "Представление КАК Представление";
	
	Для Инд = 1 По 3 Цикл
		
		ТекстПредставление = ТекстПредставление + ",
			|	" + ?(МассивРеквизитов.Количество() >= Инд,МассивРеквизитов[инд - 1],"NULL") + " Как ДополнительныйРеквизит" + Инд;
		
	КонецЦикла;
	
	ТекстЗапроса = СтрЗаменить(ТекстЗапроса, "#Представление", ТекстПредставление);
	
КонецПроцедуры	//ДополнитьТекстЗапросаПоРеквизитамОбъекта

&НаСервере
Функция ИмяРеквизитаДокумента(ИмяОбъекта, Реквизит) 
	
	ИмяРеквизитаДокумента = СтруктураПодчиненностиПереопределяемый.ИмяРеквизитаДокумента(ИмяОбъекта, Реквизит); 
	
	Если Реквизит = "СуммаДокумента" Тогда
		Возврат ?(ИмяРеквизитаДокумента = Неопределено,"СуммаДокумента",ИмяРеквизитаДокумента);
	ИначеЕсли Реквизит = "Валюта" Тогда
		Возврат ?(ИмяРеквизитаДокумента = Неопределено,"Валюта",ИмяРеквизитаДокумента);
	КонецЕсли;
	
КонецФункции	//ИмяРеквизитаДокумента

&НаСервере
Процедура ДополнитьКэшМетаданных(МетаданныеОбъекта, ИмяОбъекта,КэшРеквизитовОбъекта)

	РеквизитыДокумента = КэшРеквизитовОбъекта[ИмяОбъекта];
	Если РеквизитыДокумента = Неопределено Тогда
		
		РеквизитыДокумента = Новый Соответствие;
		ЯвляетсяДокументом = ОбщегоНазначения.ЭтоДокумент(МетаданныеОбъекта);
		
		ИмяРеквизитаСуммаДокумента = ИмяРеквизитаДокумента(МетаданныеОбъекта.Имя, "СуммаДокумента");
		Если ЯвляетсяДокументом И МетаданныеОбъекта.Реквизиты.Найти(ИмяРеквизитаСуммаДокумента) <> Неопределено Тогда
			РеквизитыДокумента.Вставить("СуммаДокумента", ИмяРеквизитаСуммаДокумента);
		Иначе
			РеквизитыДокумента.Вставить("СуммаДокумента", "NULL");
		КонецЕсли;
		
		ИмяРеквизитаВалюта = ИмяРеквизитаДокумента(МетаданныеОбъекта.Имя, "Валюта");
		Если ЯвляетсяДокументом И МетаданныеОбъекта.Реквизиты.Найти(ИмяРеквизитаВалюта) <> Неопределено Тогда
			РеквизитыДокумента.Вставить("Валюта", ИмяРеквизитаВалюта);
		Иначе
			РеквизитыДокумента.Вставить("Валюта", "NULL");
		КонецЕсли;
		
		Если ЯвляетсяДокументом Тогда
			РеквизитыДокумента.Вставить("Проведен", "Проведен");
		Иначе
			РеквизитыДокумента.Вставить("Проведен", "Ложь");
		КонецЕсли;
		
		Если ЯвляетсяДокументом Тогда
			РеквизитыДокумента.Вставить("Дата", "Дата");
		Иначе
			РеквизитыДокумента.Вставить("Дата", "NULL");
		КонецЕсли;

		КэшРеквизитовОбъекта.Вставить(ИмяОбъекта, РеквизитыДокумента);

	КонецЕсли;
	
КонецПроцедуры	//ДополнитьКэшМетаданных

&НаСервере
Функция ОбъектыПоКритериюОтбора(ЗначениеКритерияОтбора)
	
	Если Метаданные.КритерииОтбора.СвязанныеДокументы.Тип.СодержитТип(ТипЗнч(ЗначениеКритерияОтбора))  Тогда
		
		УстановитьПривилегированныйРежим(Истина);
		
		Запрос = Новый Запрос;
		Запрос.Текст = "ВЫБРАТЬ
		|	СвязанныеДокументы.Ссылка
		|ИЗ
		|	КритерийОтбора.СвязанныеДокументы(&ЗначениеКритерияОтбора) КАК СвязанныеДокументы";
		
		Запрос.УстановитьПараметр("ЗначениеКритерияОтбора",ЗначениеКритерияОтбора);
		Возврат Запрос.Выполнить().Выгрузить();
		
	Иначе
		
		Возврат Неопределено;
		
	КонецЕсли;
	
КонецФункции	//ОбъектыПоКритериюОтбора

&НаСервере
Функция ВывестиСтруктуруПодчиненности(ТекущийОбъект, ТаблицаДокументов) Экспорт
	
	Таблица				= ОбъектыПоКритериюОтбора(ТекущийОбъект);
	Если Таблица = Неопределено Тогда
		Возврат Неопределено;
	КонецЕсли;
	
	КэшПоТипамОбъектов   = Новый Соответствие;
	КэшРеквизитовОбъекта = Новый Соответствие;

	Для Каждого СтрокаТаблицы Из Таблица Цикл

		МетаданныеОбъекта = СтрокаТаблицы.Ссылка.Метаданные();
		Если Не ПравоДоступа("Чтение", МетаданныеОбъекта) Тогда
			Продолжить;
		КонецЕсли;

		ПолноеИмяОбъекта = МетаданныеОбъекта.ПолноеИмя();
		ДополнитьКэшМетаданных(МетаданныеОбъекта, ПолноеИмяОбъекта, КэшРеквизитовОбъекта);

		МассивСсылок = КэшПоТипамОбъектов[ПолноеИмяОбъекта];
		Если МассивСсылок = Неопределено Тогда

			МассивСсылок = Новый Массив;
			КэшПоТипамОбъектов.Вставить(ПолноеИмяОбъекта, МассивСсылок);

		КонецЕсли;

		МассивСсылок.Добавить(СтрокаТаблицы.Ссылка);

	КонецЦикла;		//СтрокаТаблицы
	
	Если КэшПоТипамОбъектов.Количество() = 0 Тогда
		Возврат Неопределено;
	КонецЕсли;

	ТекстЗапросаНачало = "ВЫБРАТЬ РАЗРЕШЕННЫЕ * ИЗ (";
	ТекстЗапросаКонец = ") КАК ПодчиненныеОбъекты УПОРЯДОЧИТЬ ПО ПодчиненныеОбъекты.Дата";

	Запрос = Новый Запрос;
	ТекстЗапроса = "";
	Для Каждого КлючИЗначение Из КэшПоТипамОбъектов Цикл
		
		МассивИмениОбъекта = СтроковыеФункцииКлиентСервер.РазложитьСтрокуВМассивПодстрок(КлючИЗначение.Ключ, ".");
		Если МассивИмениОбъекта.Количество() = 2 Тогда
			ИмяОбъекта = МассивИмениОбъекта[1];
		Иначе
			Продолжить;
		КонецЕсли;

		ТекстПоТипуОбъекта = "
		|" + КэшРеквизитовОбъекта[КлючИЗначение.Ключ]["Дата"] + "           КАК Дата,
		|	Ссылка,
		|" + КэшРеквизитовОбъекта[КлючИЗначение.Ключ]["Проведен"] + "       КАК Проведен,
		|	ПометкаУдаления,
		|" + КэшРеквизитовОбъекта[КлючИЗначение.Ключ]["СуммаДокумента"] + " КАК СуммаДокумента,
		|" + КэшРеквизитовОбъекта[КлючИЗначение.Ключ]["Валюта"] + "         КАК Валюта,
		|	#Представление
		|ИЗ
		|	" + КлючИЗначение.Ключ + "
		|ГДЕ
		|	Ссылка В (&" + ИмяОбъекта + ")";
		
		Запрос.УстановитьПараметр(ИмяОбъекта, КлючИЗначение.Значение);
		
		МассивДопРеквизитов = СтруктураПодчиненностиПереопределяемый.МассивРеквизитовОбъектаДляФормированияПредставления(ИмяОбъекта);
		ДополнитьТекстЗапросаПоРеквизитамОбъекта(ТекстПоТипуОбъекта, МассивДопРеквизитов);
		
		ТекстЗапроса = ТекстЗапроса + ?(ТекстЗапроса = "", " ВЫБРАТЬ ", " ОБЪЕДИНИТЬ ВСЕ ВЫБРАТЬ ") + ТекстПоТипуОбъекта;

	КонецЦикла;		//КлючИЗначение

	Запрос.Текст = ТекстЗапросаНачало + ТекстЗапроса + ТекстЗапросаКонец;
	Выборка = Запрос.Выполнить().Выбрать();

	Пока Выборка.Следующий() Цикл
		
		Если ( ТипЗнч(Выборка.Ссылка) = Тип("ДокументСсылка._ЗаявкаНаДоставку") ) Тогда
			
			СтруктураПоиска = Новый Структура("ЗаказКлиента, НужныДокументы", ТекущийОбъект, Истина);
			МассивНайденныхСтрок  = Выборка.Ссылка.Заказы.НайтиСтроки(СтруктураПоиска);
			 Если МассивНайденныхСтрок.Количество() = 0 Тогда
			 	Продолжить;
			 КонецЕсли; 
			
		КонецЕсли;
		Если ( Выборка.Ссылка.Проведен) И  		//** 
			 ( ТипЗнч(Выборка.Ссылка) = Тип("ДокументСсылка.РеализацияТоваровУслуг") ИЛИ
			   ТипЗнч(Выборка.Ссылка) = Тип("ДокументСсылка.СчетФактураВыданный") ) Тогда
			 
			НоваяСтрока = ТаблицаДокументов.Добавить();
			НоваяСтрока.Документ = Выборка.Ссылка;
			
		КонецЕсли;
		
	КонецЦикла;

	Возврат ТаблицаДокументов;
	
КонецФункции // ВывестиСтруктуруПодчиненности(ТекСтрока.Распоряжение);()

&НаСервере
Функция ВыборДокументовДляПечатиУПД(Объект) Экспорт
	
	ТоварыПоРаспоряжениям		= Объект.ТоварыПоРаспоряжениям;
	ОтгружаемыеТовары			= Объект.ОтгружаемыеТовары;
	
	ТаблицаДокументов			= Новый ТаблицаЗначений;
	ТаблицаДокументов.Колонки.Добавить("Документ");
	
	Для Каждого ТекСтрока Из ТоварыПоРаспоряжениям Цикл
		
		СтруктураПоиска		= Новый Структура("Номенклатура, Характеристика, Назначение, Серия, Действие");
		СтруктураПоиска.Вставить("Номенклатура", ТекСтрока.Номенклатура);
		СтруктураПоиска.Вставить("Характеристика", ТекСтрока.Характеристика);
		СтруктураПоиска.Вставить("Назначение", ТекСтрока.Назначение);
		СтруктураПоиска.Вставить("Серия", ТекСтрока.Серия);
		СтруктураПоиска.Вставить("Действие", Перечисления.ДействияСоСтрокамиОрдеровНаОтгрузку.Отгрузить);
		
		НайденныеСтроки		= ОтгружаемыеТовары.НайтиСтроки(СтруктураПоиска);
		
		Если НайденныеСтроки.Количество() = 0 Тогда
			Продолжить;
		КонецЕсли;
		
		ТаблицаВыборки		= ТаблицаДокументов;
		ТаблицаВыборки.Очистить();
		ВыбранныеДокументы	= ВывестиСтруктуруПодчиненности(ТекСтрока.Распоряжение, ТаблицаВыборки);
		
		//Для Каждого СтрокаДок Из ВыбранныеДокументы Цикл
		//	НовСтрока		= ТаблицаДокументов.Добавить();
		//	ЗаполнитьЗначенияСвойств(НовСтрока, СтрокаДок);
		//КонецЦикла;		// СтрокаДок
		
	КонецЦикла;		// ТекСтрока
	
	Возврат _ДоработкиСлужебный.ПреобразоватьТаблицуЗначенийВМассив(ТаблицаДокументов);	
	
КонецФункции	// ПечатьУПД()

// Функция находит счета-фактуры заданного документа.
//
// Параметры:
//	Основание - ДокументСсылка - Документ, для которого необходимо найти счет-фактуру
//	ПараметрыОтбора - Структура - Отбор счетов-фактуры по реквизитам. Ключ структуры является именем реквизита.
//	РеквизитыСчетаФактуры - Структура - Возвращаемый. Данные счета-фактуры (Ссылка, Номер, Дата, Организация, Валюта и т.д.).
//	Проведен - Булево - Если признак установлен в значение Истина, то будет произведен поиск только проведенных.
//
// Возвращаемое значение:
//	ТаблицаЗначений - Таблица найденных счетов-фактур (Ссылка, Номер, Дата, Организация, Валюта)
//
&НаСервере
Функция СчетаФактурыПоОснованию(Основание, ПараметрыОтбора = Неопределено, РеквизитыСчетаФактуры = Неопределено, Проведен = Ложь) Экспорт
	
	УстановитьПривилегированныйРежим(Истина);
	
	Запрос = Новый Запрос("
	|ВЫБРАТЬ
	|	СчетФактура.Ссылка                    КАК Ссылка,
	|	СчетФактура.Номер                     КАК Номер,
	|	СчетФактура.Дата                      КАК Дата,
	|	СчетФактура.Организация               КАК Организация,
	|	СчетФактура.Контрагент                КАК Контрагент,
	|	СчетФактура.КППКонтрагента            КАК КППКонтрагента,
	|	СчетФактура.Валюта                    КАК Валюта,
	|	СчетФактура.Проведен                  КАК Проведен,
	|	СчетФактура.Корректировочный          КАК Корректировочный,
	|	СчетФактура.ИдентификаторГосКонтракта КАК ИдентификаторГосКонтракта,
	|
	|	СчетФактураДокументыОснования.НомерИсходногоДокумента            КАК НомерИсходногоДокумента,
	|	СчетФактураДокументыОснования.ДатаИсходногоДокумента             КАК ДатаИсходногоДокумента,
	|	СчетФактураДокументыОснования.НомерИсправленияИсходногоДокумента КАК НомерИсправленияИсходногоДокумента,
	|	СчетФактураДокументыОснования.ДатаИсправленияИсходногоДокумента  КАК ДатаИсправленияИсходногоДокумента
	|ИЗ
	|	Документ.СчетФактураВыданный.ДокументыОснования КАК СчетФактураДокументыОснования
	|		ВНУТРЕННЕЕ СОЕДИНЕНИЕ Документ.СчетФактураВыданный КАК СчетФактура
	|		ПО СчетФактураДокументыОснования.Ссылка = СчетФактура.Ссылка
	|ГДЕ
	|	СчетФактураДокументыОснования.ДокументОснование = &Основание
	|	И (НЕ СчетФактура.ПометкаУдаления)
	|	//УсловияОтбора
	|
	|УПОРЯДОЧИТЬ ПО
	|	СчетФактура.НомерИсправления УБЫВ
	|");
	
	Запрос.УстановитьПараметр("Основание",   Основание);
	
	Если ПараметрыОтбора <> Неопределено Тогда
		
		ТекстУсловий = "";
		
		Для Каждого ЭлементОтбора Из ПараметрыОтбора Цикл
			ТекстУсловий = ТекстУсловий + "
			|	И СчетФактура." + ЭлементОтбора.Ключ + " = &" + ЭлементОтбора.Ключ;
			Запрос.УстановитьПараметр(ЭлементОтбора.Ключ, ЭлементОтбора.Значение);
		КонецЦикла;
		
		Запрос.Текст = СтрЗаменить(Запрос.Текст, "//УсловияОтбора", ТекстУсловий);
		
	КонецЕсли;
	
	Если Проведен Тогда
		Запрос.Текст = СтрЗаменить(Запрос.Текст,
			"(НЕ СчетФактура.ПометкаУдаления)",
			"СчетФактура.Проведен");
	КонецЕсли;
	
	РезультатЗапроса = Запрос.Выполнить();
	
	РеквизитыСчетаФактуры = Новый Структура;
	Для Каждого Колонка Из РезультатЗапроса.Колонки Цикл
		РеквизитыСчетаФактуры.Вставить(Колонка.Имя);
	КонецЦикла;
	
	ТаблицаСчетовФактур = Новый ТаблицаЗначений;
	Если НЕ РезультатЗапроса.Пустой() Тогда
		ТаблицаСчетовФактур = РезультатЗапроса.Выгрузить();
		ЗаполнитьЗначенияСвойств(РеквизитыСчетаФактуры, ТаблицаСчетовФактур[0]);
	КонецЕсли;
	
	Возврат ТаблицаСчетовФактур;
	
КонецФункции

&НаСервере
Функция ПолучитьТаблицуСФ(МассивДокументов)
	
	Перем РеквизитыСчетаФактуры;
	
	мТаблицаСчетовФактур = Новый ТаблицаЗначений;
	
	Для Каждого ТекДокумент Из МассивДокументов Цикл
		
		ПараметрыОтбора = Новый Структура("Организация", ТекДокумент.Организация);
		мТаблицаСФ = СчетаФактурыПоОснованию(ТекДокумент, ПараметрыОтбора, РеквизитыСчетаФактуры, Истина);  
		Если мТаблицаСФ.Количество() = 0 Тогда
			Продолжить;
		КонецЕсли;
		Если мТаблицаСчетовФактур.Количество() = 0 Тогда
			мТаблицаСчетовФактур = мТаблицаСФ;
		Иначе
			Для Каждого СтрокаСФ Из мТаблицаСФ Цикл
				НоваяСтрокаСФ = мТаблицаСчетовФактур.Добавить();
				ЗаполнитьЗначенияСвойств(НоваяСтрокаСФ, СтрокаСФ);
			КонецЦикла;		// СтрокаСФ
		КонецЕсли;
	КонецЦикла;		// ТекДокумент 
	
	Возврат мТаблицаСчетовФактур 
	
КонецФункции	// ПолучитьМассивСФ()

&НаСервере
Функция ПечатьУПД(МассивДокументов) Экспорт
	
	ТаблицаСчетовФактур = Новый ТаблицаЗначений;
	
	ТаблицаСФ = ПолучитьТаблицуСФ(МассивДокументов);
	
	Если ТаблицаСчетовФактур.Количество() = 0 Тогда
		ТаблицаСчетовФактур = ТаблицаСФ;
	Иначе
		Для Каждого СтрокаСФ Из ТаблицаСФ Цикл
			НоваяСтрокаСФ = ТаблицаСчетовФактур.Добавить();
			ЗаполнитьЗначенияСвойств(НоваяСтрокаСФ, СтрокаСФ);
		КонецЦикла;		// СтрокаСФ
	КонецЕсли;
	
	Если ТаблицаСчетовФактур.Количество() = 0 Тогда
		ТекстСообщения = НСтр("ru='В Заявке на доставку нет отметок 'Нужны документы' или нет счет-фактур для вывода на печать'");
		ОбщегоНазначенияКлиентСервер.СообщитьПользователю(ТекстСообщения);
	КонецЕсли;
	
	МассивСчетовФактур = _ДоработкиСлужебный.ПреобразоватьТаблицуЗначенийВМассив(ТаблицаСчетовФактур);
	АдресХранилища = ПоместитьВоВременноеХранилище(МассивСчетовФактур);
	
	Возврат АдресХранилища;
	
КонецФункции // ОткрытьВыборДокументовНаСервере()

#КонецОбласти
 

#Область ЗаданиеНаПеревозку

&НаСервере
Функция СоздатьЗаданиеНаПеревозкуПоРасходномуОрдеру(Объект, ДатаОтгрузки) Экспорт
	
	ТоварыПоРаспоряжениям		= Объект.ТоварыПоРаспоряжениям;
	ОтгружаемыеТовары			= Объект.ОтгружаемыеТовары;
	ДокументОснование			= Документы.ЗаказКлиента.ПустаяСсылка();
	
	ТоварыПоРаспоряжениям		= Объект.ТоварыПоРаспоряжениям;
	ОтгружаемыеТовары			= Объект.ОтгружаемыеТовары;
	ДокументОснование			= Документы.ЗаказКлиента.ПустаяСсылка();
	

	Если ТоварыПоРаспоряжениям.Количество() = 0 Тогда
		ТекстСообщения = НСтр("ru='Задание на перевозку не создано, в расходном ордере на товары отсутствуют распоряжения'");
		ОбщегоНазначенияКлиентСервер.СообщитьПользователю(ТекстСообщения);
		Возврат (Документы.ЗаданиеНаПеревозку.СоздатьДокумент());
	КонецЕсли;  
	
	ЗаданиеНаПеревозку = СоздатьНовоеЗаданиеНаПеревозку(ДатаОтгрузки);
	//ЗаданиеНаПеревозку.Дата					= ТекущаяДата();
	//ЗаданиеНаПеревозку.ДатаВремяРейсаПланС	= ДатаОтгрузки;
	//ЗаданиеНаПеревозку.ДатаВремяРейсаПланПо	= ДатаОтгрузки;
	
	Для Каждого ТекСтрока Из ТоварыПоРаспоряжениям Цикл
		
		Если НЕ ДокументОснование = ТекСтрока.Распоряжение Тогда
			
			СтруктураПоиска		 = Новый Структура("Номенклатура, Характеристика, Назначение, Серия, Действие");
			СтруктураПоиска.Вставить("Номенклатура", ТекСтрока.Номенклатура);
			СтруктураПоиска.Вставить("Характеристика", ТекСтрока.Характеристика);
			СтруктураПоиска.Вставить("Назначение", ТекСтрока.Назначение);
			СтруктураПоиска.Вставить("Серия", ТекСтрока.Серия);
			СтруктураПоиска.Вставить("Действие", Перечисления.ДействияСоСтрокамиОрдеровНаОтгрузку.Отгрузить);
			
			НайденныеСтроки		 = ОтгружаемыеТовары.НайтиСтроки(СтруктураПоиска);
			
			Если НайденныеСтроки.Количество() = 0 Тогда
				Продолжить;
			КонецЕсли;
			
			ДокументОснование = ТекСтрока.Распоряжение;
			
			ЗаполнитьЗаданиеНаПеревозку(Объект, ЗаданиеНаПеревозку, ДокументОснование, ДатаОтгрузки);
			
		КонецЕсли;		//НЕ ДокументОснование = ТекСтрока.Распоряжение 
	КонецЦикла;		// ТекСтрока Из ТоварыПоРаспоряжениям
	
	Если НЕ ЗаданиеНаПеревозку.Маршрут.Количество() = 0 Тогда
		ЗаданиеНаПеревозку.Записать(РежимЗаписиДокумента.Проведение);
		Возврат ЗаданиеНаПеревозку.Ссылка;
	Иначе
		
		Возврат Документы.ЗаданиеНаПеревозку.ПустаяСсылка();
	КонецЕсли; 
	
КонецФункции	// СоздатьЗаданиеНаПеревозкуПоРасходномуОрдеру(ЭтотОбъект.ТекущийЭлемент.ТекущаяСтрока.Ссылка)()


&НаСервере
Функция СоздатьНовоеЗаданиеНаПеревозку(ДатаОтгрузки)
	
	НовоеЗаданиеНаПеревозку							= Документы.ЗаданиеНаПеревозку.СоздатьДокумент(); 
	НовоеЗаданиеНаПеревозку.Дата					= ТекущаяДата();
	НовоеЗаданиеНаПеревозку.ДатаВремяРейсаПланС		= ДатаОтгрузки;
	НовоеЗаданиеНаПеревозку.ДатаВремяРейсаПланПо	= ДатаОтгрузки;
//	НовоеЗаданиеНаПеревозку.Записать(РежимЗаписиДокумента.Запись);
	
	Возврат НовоеЗаданиеНаПеревозку;
	
КонецФункции // СоздатьНовоеЗаданиеНаПеревозку()

&НаСервере
Процедура ЗаполнитьЗаданиеНаПеревозку(Ордер, ЗаданиеНаПеревозку, ДокРаспоряжение, ДатаОтгрузки)
	
	 ВремяОтгрузки	  = ДатаОтгрузки - НачалоДня(ДатаОтгрузки);
	 ВремяДоставкиС	  = ДокРаспоряжение.ВремяДоставкиС - НачалоДня(ДокРаспоряжение.ВремяДоставкиС);
	 ВремяДоставкиПо  = ДокРаспоряжение.ВремяДоставкиПо - НачалоДня(ДокРаспоряжение.ВремяДоставкиПо);
	 ВремяРейсаПланС  = ЗаданиеНаПеревозку.ДатаВремяРейсаПланС - НачалоДня(ЗаданиеНаПеревозку.ДатаВремяРейсаПланС);
	 ВремяРейсаПланПо = ЗаданиеНаПеревозку.ДатаВремяРейсаПланС - НачалоДня(ЗаданиеНаПеревозку.ДатаВремяРейсаПланС);
	 
	 Если ВремяРейсаПланС = 0 Тогда
	 	ЗаданиеНаПеревозку.ДатаВремяРейсаПланС = НачалоДня(ЗаданиеНаПеревозку.ДатаВремяРейсаПланС) + ВремяДоставкиС;
	 ИначеЕсли ВремяРейсаПланС > ВремяДоставкиС Тогда
	 	ЗаданиеНаПеревозку.ДатаВремяРейсаПланС = НачалоДня(ЗаданиеНаПеревозку.ДатаВремяРейсаПланС) + ВремяДоставкиС;
	 КонецЕсли;
	 
	 Если ВремяРейсаПланПо = 0 Тогда
	 	ЗаданиеНаПеревозку.ДатаВремяРейсаПланПо = НачалоДня(ЗаданиеНаПеревозку.ДатаВремяРейсаПланПо) + ВремяДоставкиПо;
	 ИначеЕсли ВремяРейсаПланС < ВремяДоставкиПо Тогда
	 	ЗаданиеНаПеревозку.ДатаВремяРейсаПланПо = НачалоДня(ЗаданиеНаПеревозку.ДатаВремяРейсаПланПо) + ВремяДоставкиПо;
	 КонецЕсли;
	 
	 ЗаданиеНаПеревозку.ЗаданиеВыполняет		= Перечисления.ТипыИсполнителейЗаданийНаПеревозку.НашаТранспортнаяСлужба;
	 ЗаданиеНаПеревозку.ЛицензионнаяКарточкаВид	= "Стандартная";
	 ЗаданиеНаПеревозку.Операция				= Перечисления.ВидыДоставки.СоСклада;
	 ЗаданиеНаПеревозку.Ответственный			= Ордер.Ответственный;
	 ЗаданиеНаПеревозку.Приоритет				= Справочники.Приоритеты.ПолучитьПриоритетПоУмолчанию(ЗаданиеНаПеревозку.Приоритет);
	 ЗаданиеНаПеревозку.Склад					= Ордер.Склад;
	 ЗаданиеНаПеревозку.Статус					= Перечисления.СтатусыЗаданийНаПеревозку.Формируется;
	 ЗаданиеНаПеревозку.ТранспортноеСредство	= Ордер._СпособДоставки;
	 
	 Распоряжения								= ЗаданиеНаПеревозку.Распоряжения;
	 Маршрут									= ЗаданиеНаПеревозку.Маршрут;
	 
	 
	 
	 
	 СтрокаРаспоряжения = Распоряжения.Найти(ДокРаспоряжение.Ссылка, "Распоряжение");
	 Если СтрокаРаспоряжения = Неопределено Тогда
		КлючСвязи								= Новый УникальныйИдентификатор();
	Иначе
		КлючСвязи								= СтрокаРаспоряжения.КлючСвязи;
	КонецЕсли;
	
	НовоеРаспоряжение							= Распоряжения.Добавить();
	НовоеРаспоряжение.Распоряжение				= ДокРаспоряжение.Ссылка;
	НовоеРаспоряжение.КлючСвязи					= КлючСвязи;
	НовоеРаспоряжение.ВремяС					= ВремяДоставкиС;
	НовоеРаспоряжение.ВремяПо					= ВремяДоставкиПо;
	НовоеРаспоряжение.Склад						= ДокРаспоряжение.Склад;
	НовоеРаспоряжение.ДоставляетсяПолностью 	= ДокРаспоряжение.НеОтгружатьЧастями;
	НовоеРаспоряжение.Перевозчик				= Справочники.Партнеры.ПустаяСсылка();
	НовоеРаспоряжение.ПолучательОтправитель		= ДокРаспоряжение.Партнер;
	
	
	СтрокаМаршрута								= Маршрут.Найти(КлючСвязи, "КлючСвязи");
	 Если СтрокаМаршрута = Неопределено Тогда
	 	НовыйМаршрут							= Маршрут.Добавить();
		НовыйМаршрут.КлючСвязи					= КлючСвязи;
		НовыйМаршрут.ВремяС                     = НачалоДня(ЗаданиеНаПеревозку.ДатаВремяРейсаПланС) + ВремяДоставкиС;
		НовыйМаршрут.ВремяПо                    = НачалоДня(ЗаданиеНаПеревозку.ДатаВремяРейсаПланПо) + ВремяДоставкиПо;
		НовыйМаршрут.Адрес						= ДокРаспоряжение.АдресДоставки;
		НовыйМаршрут.Зона						= ДокРаспоряжение.ЗонаДоставки;
	 КонецЕсли;
	 
	 //ЗаданиеНаПеревозку.Записать(РежимЗаписиДокумента.Запись);
КонецПроцедуры	// ЗаполнитьЗаданиеНаПеревозку(ЗаданиеНаПеревозку, ТекДокументОснование, ДатаОтгрузки)()


