Функция ПолучитьСостояниеЗаказаКлиента(ЗаказКлиента) Экспорт
	
	Запрос = Новый Запрос;
	Запрос.Текст = "ВЫБРАТЬ
	|	СостоянияЗаказовКлиентов.Заказ КАК Заказ,
	|	СостоянияЗаказовКлиентов.Состояние КАК Состояние
	|ИЗ
	|	РегистрСведений.СостоянияЗаказовКлиентов КАК СостоянияЗаказовКлиентов
	|ГДЕ
	|	СостоянияЗаказовКлиентов.Заказ = &ЗаказКлиента";
	
	Запрос.УстановитьПараметр("ЗаказКлиента", ЗаказКлиента);
	
	Результат = Запрос.Выполнить();
	Если Результат.Пустой() Тогда
		Возврат Перечисления.СостоянияЗаказовКлиентов.ПустаяСсылка();
	КонецЕсли;
	
	Возврат Результат.Выгрузить()[0].Состояние
	
КонецФункции // ПолучитьСостояниеЗаказаКлиента()

Функция ПроверитьПоступлениеПоЗаказуПоставщику(Источник, Заказ) Экспорт
	
	Если Заказ = Неопределено Тогда
		Возврат "";
	КонецЕсли;
	
	мТекст = СокрЛП(Сред(Строка(ТипЗнч(Источник)), 18)) + " № " + Источник.Номер + " от " + Формат(Источник.Дата,"ДФ=""дд.ММ.гг 'г.'""");
	Запрос = Новый Запрос;
	Запрос.Текст = "ВЫБРАТЬ
	               |	ПриобретениеТоваровУслугТовары.Ссылка КАК Ссылка,
	               |	ПриобретениеТоваровУслугТовары.Назначение КАК Назначение,
	               |	ПриобретениеТоваровУслугТовары.Номенклатура КАК Номенклатура,
	               |	ПриобретениеТоваровУслугТовары.Характеристика КАК Характеристика,
	               |	ПриобретениеТоваровУслугТовары.Серия КАК Серия,
	               |	ПриобретениеТоваровУслугТовары.КоличествоУпаковок КАК КоличествоУпаковок,
	               |	ПриобретениеТоваровУслугТовары.Количество КАК Количество
	               |ИЗ
	               |	Документ.ПриобретениеТоваровУслуг.Товары КАК ПриобретениеТоваровУслугТовары
	               |ГДЕ
	               |	ПриобретениеТоваровУслугТовары.ЗаказПоставщику = &Заказ";
	
	
	Запрос.УстановитьПараметр("Заказ", Заказ);
	
	ТЗТваровПоЗаказу = Запрос.Выполнить().Выгрузить();
	ТЗТваровПоЗаказу.Свернуть("Номенклатура, Характеристика", "КоличествоУпаковок, Количество");
	
	ТзЗаказы		 = Заказ.Товары.Выгрузить();
	ТзЗаказы.Свернуть("Номенклатура, Характеристика", "КоличествоУпаковок, Количество");
	
	Если ТЗТваровПоЗаказу.Количество() > 0 Тогда
		Для Каждого ТекСтрока Из ТзЗаказы Цикл
			ПараметрыПоиска   = Новый Структура("Номенклатура, Характеристика", ТекСтрока.Номенклатура, ТекСтрока.Характеристика);
			Строки 			  = ТЗТваровПоЗаказу.НайтиСтроки(ПараметрыПоиска);
			
			Если Строки.Количество() > 0 Тогда
				Для Каждого СтрокаЗаказа Из Строки Цикл
					ТекСтрока.КоличествоУпаковок = ТекСтрока.КоличествоУпаковок - СтрокаЗаказа.КоличествоУпаковок ;
					ТекСтрока.Количество		 = ТекСтрока.Количество			- СтрокаЗаказа.Количество ;
				КонецЦикла;		// СтрокаЗаказа Из Строки
			КонецЕсли; 
		КонецЦикла;		// ТекСтрока Из ТЗТваровПоЗаказу 
		
		Если ТзЗаказы.Итог("КоличествоУпаковок") = 0 Тогда
			мТекст = "Весь товар по заказу: Поступил";
		КонецЕсли;	
	КонецЕсли;
	
	Возврат мТекст;	
	
КонецФункции // ПостулениеТовара()



