#Область ОбработкиПроведенияДокументов
Процедура ДополнительноПриПроведенииДокументов(Источник, Отказ, РежимПроведения) Экспорт
	
	Если Источник.Статус = Перечисления.СтатусыЗаданийНаПеревозку.КПогрузке ИЛИ Источник.Статус = Перечисления.СтатусыЗаданийНаПеревозку.Формируется Тогда	
		ТоварыКДоставке = ЗаполнитьТоварыКДоставке(Источник);
		ТзРаспоряжения = Источник.Распоряжения.Выгрузить();
		
		//++ 25.02.2025 КОМПИТ 
		// При проведении и смене статуса Задания на перевозку будем менять только статус ордера. Статус отгрузки и задание не трогаем
		// Ниже по коду закомментировано
		//Если Источник.Статус = Перечисления.СтатусыЗаданийНаПеревозку.КПогрузке Тогда
		//	СтатусОрдера	   = Перечисления.СтатусыРасходныхОрдеров.КОтгрузке;
		//	СтатусОтгрузки	   = Истина;
		//	ЗаданиеНаПеревозку = Источник.Ссылка;
		//Иначе
		//	СтатусОрдера	   = Перечисления.СтатусыРасходныхОрдеров.Проверен;
		//	СтатусОтгрузки	   = Ложь;
		//	ЗаданиеНаПеревозку = Документы.ЗаданиеНаПеревозку.ПустаяСсылка();
		//КонецЕсли; 
		СтатусОтгрузки     = Истина;
		ЗаданиеНаПеревозку = Источник.Ссылка;
		СтатусОрдера = ?(
			Источник.Статус = Перечисления.СтатусыЗаданийНаПеревозку.КПогрузке, 
			Перечисления.СтатусыРасходныхОрдеров.КОтгрузке, 
			Перечисления.СтатусыРасходныхОрдеров.Проверен);
		//-- 25.02.2025 КОМПИТ
		
		Для Каждого тСтрока Из ТоварыКДоставке Цикл
			Если ТипЗнч(тСтрока.Распоряжение) = Тип("ДокументСсылка.ПоручениеЭкспедитору") Тогда
				Продолжить;
			КонецЕсли;
			ТзОрдера = ПолучитьИнформациюПоРасходномуОрдеру(тСтрока.Распоряжение, тСтрока.Назначение, тСтрока.Номенклатура, тСтрока.Характеристика, тСтрока.ВсеТовары);
			Если НЕ ТзОрдера = Неопределено Тогда
				Для Каждого СтрОрдер Из ТзОрдера Цикл
					СтруктураПоиска = Новый Структура("Распоряжение, _ЗаявкаНаДоставку", СтрОрдер.Распоряжение, СтрОрдер.ЗаявкаНаДоставку);
					НыйденныеСтроки = ТзРаспоряжения.НайтиСтроки(СтруктураПоиска);
					Если НыйденныеСтроки.Количество() = 0 Тогда
						Продолжить;
					КонецЕсли;
					ТекОрдер = СтрОрдер.Ссылка;
					Если НЕ ТекОрдер = Документы.РасходныйОрдерНаТовары.ПустаяСсылка() И ТекОрдер.Проведен И (ТекОрдер.Статус = Перечисления.СтатусыРасходныхОрдеров.Проверен ИЛИ ТекОрдер.Статус = Перечисления.СтатусыРасходныхОрдеров.КОтгрузке) Тогда
						Если ТекОрдер.ЗаданиеНаПеревозку = ЗаданиеНаПеревозку И ТекОрдер.ОтгрузкаПоЗаданиюНаПеревозку = СтатусОтгрузки И ТекОрдер.Статус = СтатусОрдера Тогда
							продолжить;
						КонецЕсли; 
						ДокОрдер							  = ТекОрдер.ПолучитьОбъект();
						ДокОрдер.ЗаданиеНаПеревозку			  = ЗаданиеНаПеревозку;
						ДокОрдер.ОтгрузкаПоЗаданиюНаПеревозку = СтатусОтгрузки;
						ДокОрдер.Статус						  = СтатусОрдера;
						Если НЕ ДокОрдер._СпособДоставки = Источник.ТранспортноеСредство Тогда
							ДокОрдер._СпособДоставки		  = Источник.ТранспортноеСредство;
						КонецЕсли;
						ДокОрдер.Записать();
					КонецЕсли;
				КонецЦикла;		// ТекОрдер Из ТзОрдера 
			КонецЕсли; 
		КонецЦикла;		// тСтрока Из ТоварыКДоставке
	ИначеЕсли Источник.Статус = Перечисления.СтатусыЗаданийНаПеревозку.Формируется Тогда
		ДополнительноОтменеПроведенияДокументаОбработкаУдаленияПроведения(Источник, Отказ)
	КонецЕсли;
	
КонецПроцедуры	// ДополнительноПриПроведенииДокументов()

