	Запрос.Текст = 
	"ВЫБРАТЬ
	|	_ЗаявкаНаДоставку.Ссылка КАК Ссылка,
	|	_ЗаявкаНаДоставку.ДокументОснование КАК ДокументОснование,
	|	_ЗаявкаНаДоставку.Номер КАК Номер
	|ИЗ
	|	Документ._ЗаявкаНаДоставку КАК _ЗаявкаНаДоставку
	|ГДЕ
	|	_ЗаявкаНаДоставку.ДокументОснование = &ДокументОснование
	|	И НЕ _ЗаявкаНаДоставку.ПометкаУдаления";
	
	Запрос.УстановитьПараметр("ДокументОснование", Распоряжение);
	Запрос.УстановитьПараметр("СпособДоставки", СпособДоставки);
	
	РезультатЗапроса = Запрос.Выполнить();
	
	ВыборкаДетальныеЗаписи = РезультатЗапроса.Выбрать(); 	
	
	Пока ВыборкаДетальныеЗаписи.Следующий() Цикл
		
		Возврат ВыборкаДетальныеЗаписи.Ссылка;
		
	КонецЦикла;
	
КонецФункции // ВернутьЗаявкаНаДоставкуНомер()
