Функция ПроверитьДату(ДатаПроверки, ГодПроверки ) Экспорт 
	Запрос = Новый Запрос;
	Запрос.Текст = "ВЫБРАТЬ
	               |	ДанныеПроизводственногоКалендаря.Дата КАК Дата,
	               |	ДанныеПроизводственногоКалендаря.ВидДня КАК ВидДня
	               |ИЗ
	               |	РегистрСведений.ДанныеПроизводственногоКалендаря КАК ДанныеПроизводственногоКалендаря
	               |ГДЕ
	               |	ДанныеПроизводственногоКалендаря.Дата = &ДатаПроверки
	               |	И ДанныеПроизводственногоКалендаря.Год = &ГодПроверки
				   |";
	
	Запрос.УстановитьПараметр("ДатаПроверки",НачалоДня(ДатаПроверки));
	Запрос.УстановитьПараметр("ГодПроверки" ,ГодПроверки);
	
	Результат = Запрос.Выполнить();
	Выборка = Результат.Выбрать();
	Выборка.Следующий();
	//Если Выборка.ВидДня = Перечисления.ВидыДнейПроизводственногоКалендаря.Рабочий Тогда
		Возврат Истина;
	//Иначе
	//	Возврат Ложь;
	//КонецЕсли;
		 	
КонецФункции // ПроверитьДату()

&НаСервере
Функция ПолучитьСледующийДень(ДатаПроверки, БольшеСемнадцати = Истина) Экспорт
	
	Сутки = 60 * 60 * 24; 
	Если БольшеСемнадцати Тогда
		Если ДатаПроверки >= Дата(Год(ТекущаяДата()), Месяц(ТекущаяДата()), День(ТекущаяДата()),  17, 0, 0) Тогда
			НоваяДата = ТекущаяДата() + Сутки * 2;
		Иначе
			НоваяДата = ТекущаяДата() + Сутки;
		КонецЕсли;
	Иначе
		НоваяДата = ТекущаяДата() + Сутки;
	КонецЕсли;
	
	Пока НЕ ПроверитьДату(НоваяДата, Год(НоваяДата)) Цикл
		НоваяДата = НоваяДата + Сутки
	КонецЦикла;		// 
	
	Возврат НоваяДата;
	
КонецФункции // ПолучитьСледующийДень()

Процедура _ПриПроведенииДокументаПоступлениеДСОбработкаПроведения(Источник, Отказ, РежимПроведения) Экспорт

	Для Каждого Стр Из Источник.РасшифровкаПлатежа Цикл
		Если ТипЗнч(Стр.ОснованиеПлатежа) = Тип("ДокументСсылка.ЗаказКлиента") Тогда
			Если НЕ ЗначениеЗаполнено(Стр.ОснованиеПлатежа) Тогда
				Продолжить;
			КонецЕсли;	
			Док = Стр.ОснованиеПлатежа.ПолучитьОбъект();
			Док.Статус = Перечисления.СтатусыЗаказовКлиентов.КОбеспечению;
			Попытка
				Если Док.ПометкаУдаления = Истина Тогда
					Если Док.Дата > Дата("20220101") Тогда
						Док.ПометкаУдаления = Ложь;
						Док.Записать(РежимЗаписиДокумента.Проведение);
						Док.ПометкаУдаления = Истина;					
					Иначе
						
					КонецЕсли;	
				Иначе	
					Если Док.Дата > Дата("20220101") Тогда
						Док.Записать(РежимЗаписиДокумента.Проведение);
					КонецЕсли;	
				КонецЕсли;	
			Исключение
				Сообщить(""+ОписаниеОшибки());
			КонецПопытки;					
		КонецЕсли;	
	КонецЦикла;	
	
КонецПроцедуры



