// Нумерация заказов клиента
Процедура НомерВЗаказеКлиентаПередЗаписью(Источник, Отказ, РежимЗаписи, РежимПроведения) Экспорт

	Если Источник.ЭтоНовый() Тогда
		
		//ТекНомер = ПрефиксацияОбъектовКлиентСервер.НомерНаПечать(Источник.Номер, Истина, Истина);
		
		Префикс = Источник.Организация.Префикс;
		
		Запрос = Новый Запрос;
		Запрос.Текст = "
		|ВЫБРАТЬ
		|	ЗаказКлиента.Номер				КАК Номер
		|ИЗ
		|	Документ.ЗаказКлиента КАК ЗаказКлиента
		|ГДЕ
		|	ЗаказКлиента.Организация = &Организация
		|	И ЗаказКлиента.Дата МЕЖДУ &ДатаН И &ДатаК
		|
		|УПОРЯДОЧИТЬ ПО
		|	Номер
		|";
		Запрос.УстановитьПараметр("Организация", Источник.Организация);
		Запрос.УстановитьПараметр("ДатаН",       НачалоДня(Источник.Дата));
		Запрос.УстановитьПараметр("ДатаК",       КонецДня(Источник.Дата));
		
		РезультатЗапроса = Запрос.Выполнить().Выгрузить();
		РезультатЗапроса.Колонки.Добавить("НомерДляСортировки", Новый ОписаниеТипов( , , , , Новый КвалификаторыСтроки(11, ДопустимаяДлина.Переменная), , ), "Номер для сортировки", );
		Для Каждого СтрокаРезультата Из РезультатЗапроса Цикл
			СтрокаРезультата.НомерДляСортировки = Прав(СокрЛП(СтрокаРезультата.Номер), 3);
		КонецЦикла;
		
		РезультатЗапроса.Сортировать("НомерДляСортировки Убыв");
		Если РезультатЗапроса.Количество() > 0 Тогда
			
			ПерваяСтрока = РезультатЗапроса[0];
			Попытка
				НомерЧислом = ПерваяСтрока.НомерДляСортировки;
			Исключение
				НомерЧислом = 0;
			КонецПопытки;
			
			Если СтрДлина(СокрЛП(НомерЧислом + 1)) > 1 Тогда
				ТекНомер = "0"  + СокрЛП(НомерЧислом + 1);
			Иначе
				ТекНомер = "00" + СокрЛП(НомерЧислом + 1);
			КонецЕсли;
			
		Иначе
			ТекНомер = "001";
			
		КонецЕсли;
		
		Источник.Номер = Источник.Организация.Префикс + Формат(Источник.Дата, "ДФ=ddMMyy") + ТекНомер;
		
		а = 1;
		
	КонецЕсли;

КонецПроцедуры

// Нумерация реализаций товаров
Процедура НомерВРеализацииПередЗаписью(Источник, Отказ, РежимЗаписи, РежимПроведения) Экспорт
	
	Если Источник.ЭтоНовый() ИЛИ НЕ ЗначениеЗаполнено(Источник.Номер) Тогда
		
		ТекДата = Формат(Источник.Дата, "ДФ=dd.MM.yy");
		Стр   = СтрЗаменить(ТекДата, ".", Символы.ПС);
		День  = СтрПолучитьСтроку(Стр, 1);
		Месяц = СтрПолучитьСтроку(Стр, 2);
		Год   = СтрПолучитьСтроку(Стр, 3);
		
		//ТекНомер = ПрефиксацияОбъектовКлиентСервер.НомерНаПечать(Источник.Номер, Истина, Истина);
		
		Префикс = Источник.Организация.Префикс;
		
		Запрос = Новый Запрос;
		Запрос.Текст = "
		|ВЫБРАТЬ
		|	РеализацияТоваровУслуг.Номер КАК Номер
		|ИЗ
		|	Документ.РеализацияТоваровУслуг КАК РеализацияТоваровУслуг
		|ГДЕ
		|	РеализацияТоваровУслуг.Организация = &Организация
		|	И РеализацияТоваровУслуг.Дата МЕЖДУ &ДатаН И &ДатаК
		|
		|УПОРЯДОЧИТЬ ПО
		|	Номер";
		Запрос.УстановитьПараметр("Организация", Источник.Организация);
		Запрос.УстановитьПараметр("ДатаН",       НачалоДня(Источник.Дата));
		Запрос.УстановитьПараметр("ДатаК",       КонецДня(Источник.Дата));
		Результат = Запрос.Выполнить();
		Выборка = Результат.Выбрать();
		
		ТЗ1 = Новый ТаблицаЗначений;
		ТЗ1.Колонки.Добавить("Номер");
		
		Пока Выборка.Следующий() Цикл
			СтрТЗ1 = ТЗ1.Добавить();
			СтрТЗ1.Номер = Прав(СокрЛП(Выборка.Номер), 3);
		КонецЦикла;
		
		ТЗ1.Сортировать("Номер Убыв");
		Если ТЗ1.Количество() > 0 Тогда
			Если СтрДлина(СокрЛП(Число(ТЗ1[0].Номер) + 1)) > 1 Тогда
				ТекНомер = "0" + СокрЛП(Число(ТЗ1[0].Номер) + 1);
			Иначе
				ТекНомер = "00" + СокрЛП(Число(ТЗ1[0].Номер) + 1);
			КонецЕсли;
		Иначе
			ТекНомер = "001";
		КонецЕсли;
		
		Источник.Номер = Источник.Организация.Префикс + День + Месяц + Год + ТекНомер;
		
		а = 1;
		
	КонецЕсли;

КонецПроцедуры

// Нумерация счетов факутр
Процедура НомерВСФПередЗаписью(Источник, Отказ, РежимЗаписи, РежимПроведения) Экспорт

	Если Источник.ЭтоНовый() ИЛИ НЕ ЗначениеЗаполнено(Источник.Номер) Тогда
		Если Источник.ДокументыОснования.Количество() > 0 Тогда
			Если ЗначениеЗаполнено(Источник.ДокументыОснования[0].ДокументОснование) Тогда
				Источник.Номер = Источник.ДокументыОснования[0].ДокументОснование.Номер;
				
				Если ( ОбщегоНазначения.ЕстьРеквизитОбъекта("ПредставлениеНомера", Источник.Метаданные()) ) Тогда
					Источник.ПредставлениеНомера = Кт_ИсправитьНомер( Источник.Номер );
				КонецЕсли;	
				
			КонецЕсли;
		КонецЕсли;
	КонецЕсли;

КонецПроцедуры

