
#Область СистемаНапоминанийПользователя

Процедура СистемаНапоминанийПриСозданииНаСервере( ИмяОсновнойГруппыСтраниц , Форма ) Экспорт
	
	ИспользоватьНапоминания = ПолучитьФункциональнуюОпцию("ИспользоватьНапоминанияПользователя");
	
	Если НЕ ( ИспользоватьНапоминания ) Тогда
		Возврат;
	КонецЕсли;
	
	ИмяСпискаНапоминаний = "СписокНапоминаний";
	ТаблицаСписка        = "РегистрСведений.НапоминанияПользователя";
	
	
	СтраницаСписокНапоминаний = Форма.Элементы.Добавить( "СтраницаСписокНапоминаний", Тип("ГруппаФормы"), Форма.Элементы[ ИмяОсновнойГруппыСтраниц ]);
	СтраницаСписокНапоминаний.Вид = ВидГруппыФормы.Страница;
	СтраницаСписокНапоминаний.Заголовок = "Мои напоминания";
	
	ГруппаШапка = Форма.Элементы.Добавить(	"ГруппаШапка",Тип("ГруппаФормы"),СтраницаСписокНапоминаний);
	ГруппаШапка.Вид = ВидГруппыФормы.ОбычнаяГруппа;
	ГруппаШапка.Отображение 				= ОтображениеОбычнойГруппы.Нет;
	ГруппаШапка.ОтображатьЗаголовок 		= Ложь; 
	ГруппаШапка.Группировка 				= ГруппировкаПодчиненныхЭлементовФормы.ГоризонтальнаяВсегда;
	ГруппаШапка.РастягиватьПоГоризонтали 	= Истина;
	
	//КоманднаяПанельСписка  = Форма.Элементы.Добавить(ИмяСпискаНапоминаний + "КоманднаяПанель2",Тип("ГруппаФормы"),ГруппаШапка);
	//КоманднаяПанельСписка.Вид = ВидГруппыФормы.КоманднаяПанель;
	
	
	ГруппаПодвал = Форма.Элементы.Добавить(	"ГруппаПодвал",Тип("ГруппаФормы"),СтраницаСписокНапоминаний);
	ГруппаПодвал.Вид = ВидГруппыФормы.ОбычнаяГруппа;
	ГруппаПодвал.Отображение 				= ОтображениеОбычнойГруппы.Нет;
	ГруппаПодвал.ОтображатьЗаголовок 		= Ложь; 
	ГруппаПодвал.Группировка 				= ГруппировкаПодчиненныхЭлементовФормы.Вертикальная;
	ГруппаПодвал.РастягиватьПоГоризонтали 	= Истина;

	
	//Динамический список
	
	ТипыРеквизита = Новый Массив;                             
	ТипыРеквизита.Добавить(Тип("ДинамическийСписок"));
	
	ОписаниеТиповДляРеквизита = Новый ОписаниеТипов(ТипыРеквизита); 
	ДинамическийСписок = Новый РеквизитФормы(ИмяСпискаНапоминаний, ОписаниеТиповДляРеквизита,,"",ЛОЖЬ); 
	ДобавляемыеРеквизиты = Новый Массив;
	ДобавляемыеРеквизиты.Добавить(ДинамическийСписок);
	
	Форма.ИзменитьРеквизиты(ДобавляемыеРеквизиты);        
	РеквизитДинамическийСписок = Форма[ИмяСпискаНапоминаний]; 
	
	РеквизитДинамическийСписок.ПроизвольныйЗапрос = ИСТИНА;
	РеквизитДинамическийСписок.ТекстЗапроса = "ВЫБРАТЬ
												|	РегистрСведенийНапоминанияПользователя.Пользователь КАК Пользователь,
												|	РегистрСведенийНапоминанияПользователя.ВремяСобытия КАК ВремяСобытия,
												|	РегистрСведенийНапоминанияПользователя.Источник КАК Источник,
												|	РегистрСведенийНапоминанияПользователя.СрокНапоминания КАК СрокНапоминания,
												|	РегистрСведенийНапоминанияПользователя.Описание КАК Описание,
												|	РегистрСведенийНапоминанияПользователя.СпособУстановкиВремениНапоминания КАК СпособУстановкиВремениНапоминания,
												|	РегистрСведенийНапоминанияПользователя.ИнтервалВремениНапоминания КАК ИнтервалВремениНапоминания,
												|	РегистрСведенийНапоминанияПользователя.ИмяРеквизитаИсточника КАК ИмяРеквизитаИсточника,
												|	РегистрСведенийНапоминанияПользователя.Расписание КАК Расписание,
												|	РегистрСведенийНапоминанияПользователя.ПредставлениеИсточника КАК ПредставлениеИсточника
												|ИЗ
												|	РегистрСведений.НапоминанияПользователя КАК РегистрСведенийНапоминанияПользователя
												|ГДЕ
												|	РегистрСведенийНапоминанияПользователя.Пользователь = &Пользователь";
	Если НЕ ПустаяСтрока(ТаблицаСписка) Тогда 
		РеквизитДинамическийСписок.ОсновнаяТаблица = ТаблицаСписка; 
	КонецЕсли;
	
	ТаблицаФормы = Форма.Элементы.Добавить(ИмяСпискаНапоминаний,Тип("ТаблицаФормы"), ГруппаПодвал );
	ТаблицаФормы.ПутьКДанным = ИмяСпискаНапоминаний;
	Форма.Элементы[ИмяСпискаНапоминаний].ПоложениеКоманднойПанели = ПоложениеКоманднойПанелиЭлементаФормы.Нет;
	
	СтКолонки = "СрокНапоминания,Описание,ВремяСобытия,Источник,Пользователь";
	МассивКолонок = СтроковыеФункцииКлиентСервер.РазложитьСтрокуВМассивПодстрок(СтКолонки,",");
	
	Для Каждого Элемент Из МассивКолонок Цикл
		НоваяКолонкаТаблицы = Форма.Элементы.Добавить(ИмяСпискаНапоминаний + Элемент, Тип("ПолеФормы"), ТаблицаФормы);
		НоваяКолонкаТаблицы.Заголовок = Элемент; 
		НоваяКолонкаТаблицы.ПутьКДанным = ИмяСпискаНапоминаний + "." + Элемент; 	
		Если ( Элемент = "Пользователь" ) Тогда
			НоваяКолонкаТаблицы.Видимость = Ложь;
		КонецЕсли;	
	КонецЦикла;
	
	РеквизитДинамическийСписок.Параметры.УстановитьЗначениеПараметра("Пользователь", Пользователи.ТекущийПользователь());
	
	
	//Кнопки-Команды
	
	ДобавитьКнопкуНаФорму( Форма, "СоздатьНапоминание", "Создать", "ПодключаемыйСоздатьНапоминание", ГруппаШапка );
	ДобавитьКнопкуНаФорму( Форма, "ИзменитьНапоминание", "Изменить", "ПодключаемыйИзменитьНапоминание", ГруппаШапка );
	ДобавитьКнопкуНаФорму( Форма, "УдалитьНапоминание", "Удалить", "ПодключаемыйУдалитьНапоминание", ГруппаШапка );
	
	
	
КонецПроцедуры	

Процедура ДобавитьКнопкуНаФорму( Форма, ИмяКоманды, Заголовок, ИмяДействия, Группа )
	
	//Добавление команды формы
	Команда = Форма.Команды.Добавить(ИмяКоманды );
	Команда.Заголовок = Заголовок;
	Команда.Действие  = ИмяДействия; //Имя связанной процедуры
	
	
	//Добавление кнопки формы
	КнопкаФормы = Форма.Элементы.Добавить( "Кнопка" + ИмяКоманды, Тип("КнопкаФормы"), Группа); 
	КнопкаФормы.ИмяКоманды = ИмяКоманды; 
	КнопкаФормы.Вид = ВидКнопкиФормы.ОбычнаяКнопка; 
	
КонецПроцедуры	

#КонецОбласти

#Область СистемаОповещенийПользователя


Функция ПроверитьОбъект( Источник ,ИмяОбъекта )
	Если ТипЗнч(Источник) = Тип("ДокументОбъект." + ИмяОбъекта) ИЛИ 
		ТипЗнч(Источник) = Тип("ДокументСсылка." + ИмяОбъекта) Тогда
		Возврат Истина;
	Иначе
		Возврат Ложь;
	КонецЕсли;	
КонецФункции	

Процедура СоздатьСообщениеПоСобытию(Источник, Отказ, РежимПроведения) Экспорт
	
	Если НЕ ИспользоватьСообщенияПользователям() Тогда
		Возврат;
	КонецЕсли;
	
	Если ПроверитьОбъект( Источник ,"ПоступлениеБезналичныхДенежныхСредств" ) Тогда
		мТекст = СформироватьНаименованиеНовости(СокрЛП(Сред(Строка(ТипЗнч(Источник)), 18)),
		                                         Источник.Номер,
												 Источник.Дата);
		
		
		//мТекст = СтроковыеФункцииКлиентСервер.ПодставитьПараметрыВСтроку("%1 № %2 от %3",СокрЛП(Сред(Строка(ТипЗнч(Источник)), 18)),
		//																Источник.Номер,
		//																Формат(Источник.Дата,"ДФ=""дд.ММ.гг 'г.'"""));
		Если ТипЗнч(Источник.ДокументОснование) = Тип("ДокументСсылка.ЗаказКлиента") Тогда
			НаименованиеОповещения = СформироватьНаименованиеНовости(Строка(ТипЗнч(Источник.ДокументОснование)),Источник.ДокументОснование.Номер, мТекст);
			ОповещениеПользователя =  РегистрыСведений._СостоянияОповещенияПользователей.ПолучитьОповещение( НаименованиеОповещения , Источник.ДокументОснование.Автор); 
														
			ТекстНовости = СтроковыеФункцииКлиентСервер.ПодставитьПараметрыВСтроку("Поступление безналичных денежных средств по Заказу клиента № %1 от %2 %3 Контрагент : %4", 
								   Источник.ДокументОснование.Номер, Формат(Источник.ДокументОснование.Дата,"ДФ=""дд.ММ.гг 'г.'"""),
								   Символы.ПС, СокрЛП(Источник.ОснованиеПлатежа.Контрагент.Наименование));
								   
			СостояниеЗаказа = _ДоработкиСлужебный.ПолучитьСостояниеЗаказаКлиента(Источник.ДокументОснование);
			Если НЕ СостояниеЗаказа = Перечисления.СостоянияЗаказовКлиентов.Закрыт Тогда
				СоздатьСообщениеПользователю(ОповещениеПользователя,НаименованиеОповещения, ТекстНовости, Источник.ДокументОснование.Автор, Источник.ДокументОснование);
			КонецЕсли; 
								   
		ИначеЕсли Источник.ДокументОснование = Неопределено Тогда
			
			Для Каждого ТекСтрока Из Источник.РасшифровкаПлатежа Цикл
				Если ТипЗнч(ТекСтрока.ОснованиеПлатежа) = Тип("ДокументСсылка.ЗаказКлиента") Тогда
					НаименованиеОповещения = СформироватьНаименованиеНовости(Строка(ТипЗнч(ТекСтрока.ОснованиеПлатежа)),
		                                         ТекСтрока.ОснованиеПлатежа.Номер,мТекст);
					ОповещениеПользователя = РегистрыСведений._СостоянияОповещенияПользователей.ПолучитьОповещение( НаименованиеОповещения ,ТекСтрока.ОснованиеПлатежа.Автор); 
					ТекстНовости = СтроковыеФункцииКлиентСервер.ПодставитьПараметрыВСтроку("Поступление безналичных денежных средств по Заказу клиента № %1 от %2 %3 Контрагент : %4", 
								   ТекСтрока.ОснованиеПлатежа.Номер, Формат(ТекСтрока.ОснованиеПлатежа.Дата,"ДФ=""дд.ММ.гг 'г.'"""),
								   Символы.ПС, СокрЛП(ТекСтрока.ОснованиеПлатежа.Контрагент.Наименование));
										   
					СостояниеЗаказа = _ДоработкиСлужебный.ПолучитьСостояниеЗаказаКлиента(ТекСтрока.ОснованиеПлатежа);
					Если НЕ СостояниеЗаказа = Перечисления.СостоянияЗаказовКлиентов.Закрыт Тогда
						СоздатьСообщениеПользователю(ОповещениеПользователя,НаименованиеОповещения, ТекстНовости, ТекСтрока.ОснованиеПлатежа.Автор, ТекСтрока.ОснованиеПлатежа);
					КонецЕсли; 
				КонецЕсли;
			КонецЦикла;		// ТекСтрока Из Источник.РасшифровкаПлатежа
			
		КонецЕсли; 
		
	ИначеЕсли ПроверитьОбъект( Источник ,"ПриобретениеТоваровУслуг" ) Тогда
		
		Если ТипЗнч(Источник.ЗаказПоставщику.ДокументОснование) = Тип("ДокументСсылка.ЗаказКлиента")  И НЕ Источник.ЗаказПоставщику.ДокументОснование = Документы.ЗаказКлиента.ПустаяСсылка() Тогда
			Заказ					= Источник.ЗаказПоставщику.ДокументОснование;
			ПостулениеТовара	 	= ПроверитьПоступление(Источник, Заказ); 
			
			НаименованиеОповещения = СформироватьНаименованиеНовости(Строка(ТипЗнч(Заказ)),Строка(ТипЗнч(Заказ)), ПостулениеТовара);
			ОповещениеПользователя = РегистрыСведений._СостоянияОповещенияПользователей.ПолучитьОповещение( НаименованиеОповещения ,Заказ.Автор); 
														
														
														
			ТекстНовости = СтроковыеФункцииКлиентСервер.ПодставитьПараметрыВСтроку("Поступление товаров по Заказу клиента № %1 от %2 %3 %4 %5 Контрагент : %6", 
								   Заказ.Номер, Формат(Заказ.Дата,"ДФ=""дд.ММ.гг 'г.'"""),
								   Символы.ПС,ПостулениеТовара,Символы.ПС, СокрЛП(Заказ.Контрагент.Наименование));						   
									   
									   
			СостояниеЗаказа = _ДоработкиСлужебный.ПолучитьСостояниеЗаказаКлиента(Заказ);
			Если НЕ СостояниеЗаказа = Перечисления.СостоянияЗаказовКлиентов.Закрыт Тогда
				СоздатьСообщениеПользователю(ОповещениеПользователя,НаименованиеОповещения, ТекстНовости, Заказ.Автор, Заказ);
				СозданиеЗадач(Источник, Заказ);
			КонецЕсли; 
			
			//**ДОБАВЛЕНО Максимов В.А.
			
			//**Поступления по заказу начало
			
			ЗаказПоставщику 		= Источник.ЗаказПоставщику;
			ПоступлениеПоЗаказу 	= _ДоработкиСлужебный.ПроверитьПоступлениеПоЗаказуПоставщику(Источник, ЗаказПоставщику);
			
			НаименованиеОповещения = СформироватьНаименованиеНовости(Строка(ТипЗнч(ЗаказПоставщику)), ЗаказПоставщику.Номер,ПоступлениеПоЗаказу);
			ОповещениеПользователя = РегистрыСведений._СостоянияОповещенияПользователей.ПолучитьОповещение( НаименованиеОповещения , ЗаказПоставщику.Автор); 
			
			ТекстНовости		 	= "Поступление товаров по Заказу поставщику № " + 
									   ЗаказПоставщику.Номер + " от " + 
									   Формат(ЗаказПоставщику.Дата,"ДФ=""дд.ММ.гг 'г.'""") +
									   Символы.ПС + ПостулениеТовара + Символы.ПС + 
									   "Контрагент : " + СокрЛП(ЗаказПоставщику.Контрагент.Наименование);
												   
			СоздатьСообщениеПользователю(ОповещениеПользователя,НаименованиеОповещения, ТекстНовости, ЗаказПоставщику.Автор, ЗаказПоставщику);
			СозданиеЗадачЗакупщика(Источник, ЗаказПоставщику);
			
			//**Поступления по заказу конец
			
		ИначеЕсли ТипЗнч(Источник.ЗаказПоставщику.ДокументОснование) = Тип("ДокументСсылка.ЗаказКлиента")  И Источник.ЗаказПоставщику.ДокументОснование = Документы.ЗаказКлиента.ПустаяСсылка() Тогда
			ТзЗакупки = Источник.Товары.Выгрузить(,"Назначение");
			ТзЗакупки.Колонки.Добавить("Заказ");
			Для Каждого ТекСтрока Из ТзЗакупки Цикл
				ТекСтрока.Заказ = ТекСтрока.Назначение.Заказ;
			КонецЦикла;		// ТекСтрока Из ТзЗакупки
			ТзЗакупки.Свернуть("Заказ");
			Заказ					= Документы.ЗаказКлиента.ПустаяСсылка(); 
			Для Каждого ТекСтрока Из ТзЗакупки Цикл
				Если Заказ = ТекСтрока.Заказ Тогда
					Продолжить;
				КонецЕсли;
				Заказ				= ТекСтрока.Заказ;
				ПостулениеТовара	= ПроверитьПоступление(Источник, Заказ); 
				
				Если ПостулениеТовара = "" Тогда
					Продолжить;
				КонецЕсли;
				
				НаименованиеОповещения = СформироватьНаименованиеНовости(Строка(ТипЗнч(Заказ)),	Заказ.Номер,ПостулениеТовара);
				
				Если ОбщегоНазначения.ЕстьРеквизитОбъекта("Автор", Заказ.Метаданные() ) Тогда
					ОповещениеПользователя = РегистрыСведений._СостоянияОповещенияПользователей.ПолучитьОповещение( НаименованиеОповещения , Заказ.Автор);	
				ИначеЕсли ОбщегоНазначения.ЕстьРеквизитОбъекта("Ответственный", Заказ.Метаданные() ) Тогда	
					ОповещениеПользователя = РегистрыСведений._СостоянияОповещенияПользователей.ПолучитьОповещение( НаименованиеОповещения , Заказ.Ответственный);
				Иначе	
					Продолжить;
				КонецЕсли;
				
				
				Если ( Заказ.ДокументОснование = Неопределено ) Тогда
					ТекстНовости	 	= "Поступление товаров по Заказу клиента № " + 
										   Заказ.Номер + " от " + 
										   Формат(Заказ.Дата,"ДФ=""дд.ММ.гг 'г.'""") +
										   Символы.ПС + ПостулениеТовара + Символы.ПС + 
										   "Контрагент : " + СокрЛП(Заказ.Контрагент.Наименование);
			    Иначе
					ТекстНовости	 	= "Поступление товаров по Заказу клиента № " + 
										   Заказ.Номер + " от " + 
										   Формат(Заказ.Дата,"ДФ=""дд.ММ.гг 'г.'""") +
										   Символы.ПС + ПостулениеТовара + Символы.ПС + 
										   "Контрагент : " + СокрЛП(Заказ.ДокументОснование.Контрагент.Наименование);										   
				КонецЕсли;										   
										   
										   
				СостояниеЗаказа = _ДоработкиСлужебный.ПолучитьСостояниеЗаказаКлиента(Заказ);
				Если НЕ СостояниеЗаказа = Перечисления.СостоянияЗаказовКлиентов.Закрыт Тогда
					Если ОбщегоНазначения.ЕстьРеквизитОбъекта("Автор", Заказ.Метаданные() ) Тогда
						СоздатьСообщениеПользователю(ОповещениеПользователя ,НаименованиеОповещения, ТекстНовости, Заказ.Автор, Заказ);
					ИначеЕсли ОбщегоНазначения.ЕстьРеквизитОбъекта("Ответственный", Заказ.Метаданные() ) Тогда
						СоздатьСообщениеПользователю(ОповещениеПользователя ,НаименованиеОповещения, ТекстНовости, Заказ.Ответственный, Заказ.ДокументОснование);						
					КонецЕсли;	
					СозданиеЗадач(Источник, Заказ);
				КонецЕсли; 
				
			КонецЦикла;		// ТекЗаказ Из ТзЗакупки
		КонецЕсли;
		
	ИначеЕсли ПроверитьОбъект( Источник ,"СборкаТоваров" ) Тогда
		
		
		Если Источник.Статус = Перечисления.СтатусыСборокТоваров.СобраноРазобрано Тогда
			
			Заказ				= Источник.ЗаказНаСборку.ДокументОснование;
			//мТекст				= СокрЛП(Сред(Строка(ТипЗнч(Источник)), 18)) + " № " + Источник.Номер + " от " + Формат(Источник.Дата,"ДФ=""дд.ММ.гг 'г.'""");
			
			
			мТекст = СформироватьНаименованиеНовости(СокрЛП(Сред(Строка(ТипЗнч(Источник)), 18)),
		                                         Источник.Номер,Источник.Дата);
			НаименованиеОповещения = СформироватьНаименованиеНовости(Строка(ТипЗнч(Заказ)),
		                                         	Заказ.Номер,мТекст);									 
												 
			ОповещениеПользователя =  РегистрыСведений._СостоянияОповещенияПользователей.ПолучитьОповещение( НаименованиеОповещения , Заказ.Автор);
			ТекстНовости	 	= "Сборка товаров по Заказу клиента № " + 
								   Заказ.Номер + " от " + 
								   Формат(Заказ.Дата,"ДФ=""дд.ММ.гг 'г.'""") +
								   Символы.ПС + "Собрано " + СокрЛП(Источник.Номенклатура.Наименование) + " - " +Источник.КоличествоУпаковок + " " + СокрЛП(Источник.Номенклатура.ЕдиницаИзмерения.Наименование) +
								   Символы.ПС + "Контрагент : " + СокрЛП(Заказ.Контрагент.Наименование);
			СостояниеЗаказа = _ДоработкиСлужебный.ПолучитьСостояниеЗаказаКлиента(Заказ);
			Если НЕ СостояниеЗаказа = Перечисления.СостоянияЗаказовКлиентов.Закрыт Тогда
				СоздатьСообщениеПользователю(ОповещениеПользователя,НаименованиеОповещения, ТекстНовости, Заказ.Автор, Заказ);
				СозданиеЗадач(Источник, Заказ);
			КонецЕсли; 
				
		КонецЕсли;		
		
	КонецЕсли;
	
КонецПроцедуры

