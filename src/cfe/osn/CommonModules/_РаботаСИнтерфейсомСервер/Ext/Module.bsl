Процедура СозданиеЗадачЗакупщикаЗаказПросрочен(Заказ) Экспорт
	
	ПараметрыЗадачи = ПолучитьПараметрыЗадачи();
	ПараметрыЗадачи.Исполнитель		= Заказ.Автор;
	ПараметрыЗадачи.ДатаИсполнения	= ТекущаяДата();
