		ПараметрыЗадачи.Наименование	= "Приход по Заказу поставщику № " + 
										   Заказ.Номер + " от " + Формат(Заказ.Дата,"ДФ=""дд.ММ.гг 'г.'""");
		ПараметрыЗадачи.Описание		= "По Заказу поставщику № " + 
										   Заказ.Номер + " от " + Формат(Заказ.Дата,"ДФ=""дд.ММ.гг 'г.'""") + 
										   "  - поступил весь товар.";
		ПараметрыЗадачи.ПредметСтрокой	= Строка(Заказ);
