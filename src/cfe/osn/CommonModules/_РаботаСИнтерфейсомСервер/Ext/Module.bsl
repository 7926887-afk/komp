#Область ЗадачиПользователю

Процедура СозданиеЗадач(Источник, Заказ)
	
		Если ПроверитьПоступление(Источник, Заказ) = "Весь товар по заказу: Поступил" Тогда
			ПараметрыЗадачи = ПолучитьПараметрыЗадачи();
			ПараметрыЗадачи.Исполнитель		= Заказ.Автор;
			ПараметрыЗадачи.ДатаИсполнения	= ТекущаяДата();
			ПараметрыЗадачи.Предмет			= Заказ.Ссылка;
			ПараметрыЗадачи.Наименование	= "Отгрузка по Заказу клиента № " + 
											   Заказ.Номер + " от " + Формат(Заказ.Дата,"ДФ=""дд.ММ.гг 'г.'""");
			ПараметрыЗадачи.Описание		= "По Заказу клиента № " + 
											   Заказ.Номер + " от " + Формат(Заказ.Дата,"ДФ=""дд.ММ.гг 'г.'""") + 
											   "  - поступил весь товар. Необходимо провести отгрузку товара клиенту";
			ПараметрыЗадачи.ПредметСтрокой	= Строка(Заказ);
			ПараметрыЗадачи.Автор			= Константы._АвторСистемныхЗдач.Получить();
			ПараметрыЗадачи.АвторСтрокой	= Строка(Константы._АвторСистемныхЗдач.Получить());
			СоздатьЗадачуИсполнителю(ПараметрыЗадачи);
		КонецЕсли;
	
КонецПроцедуры	// СозданиеЗадач()

//**ДОБАВЛЕНО Максимов В.А.

Процедура СозданиеЗадачЗакупщика(Источник, Заказ)
	
	Если _ДоработкиСлужебный.ПроверитьПоступлениеПоЗаказуПоставщику(Источник, Заказ) = "Весь товар по заказу: Поступил" Тогда
