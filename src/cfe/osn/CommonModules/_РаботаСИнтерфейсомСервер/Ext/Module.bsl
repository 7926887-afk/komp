КонецФункции // ПолучитьСсылкуОповещения(ТекущееОповещение)

Процедура СоздатьСообщениеПользователю(ОповещениеПользователя, НаименованиеОповещения , ТекстНовости, Автор, СсылкаДокумента, ДатаНачалаОповещения = Неопределено) Экспорт
	
	Если ( ОповещениеПользователя.ИдентификаторНовости = Новый УникальныйИдентификатор("00000000-0000-0000-0000-000000000000")) Тогда
		
		ИдентификаторНовости = Новый УникальныйИдентификатор();
		
		
		НаборЗаписей = РегистрыСведений._СостоянияОповещенияПользователей.СоздатьНаборЗаписей();
		НаборЗаписей.Отбор.Пользователь.Установить(Автор);
		НаборЗаписей.Отбор.ИдентификаторНовости.Установить(ИдентификаторНовости);
		НоваяЗапись = НаборЗаписей.Добавить();
		
		НоваяЗапись.Пользователь         	= Автор;
		НоваяЗапись.ИдентификаторНовости	= ИдентификаторНовости;
		
		НоваяЗапись.Наименование			= НаименованиеОповещения;
		НоваяЗапись.ТекстНовости			= ТекстНовости;
		
		Если ( ДатаНачалаОповещения = Неопределено ) Тогда
			НоваяЗапись.ДатаНачалаОповещения 	= ТекущаяДата();
		Иначе
			НоваяЗапись.ДатаНачалаОповещения 	= ДатаНачалаОповещения;
		КонецЕсли;
		
		НоваяЗапись.Прочтена             	= Ложь;
		НоваяЗапись.Пометка              	= 0;
		НоваяЗапись.ОповещениеВключено   	= Истина;
		НоваяЗапись.УдаленаИзСпискаНовостей = Ложь;
		
		
		Если ЗначениеЗаполнено( СсылкаДокумента ) Тогда
			Если НЕ ( СсылкаДокумента.Пустая() ) Тогда
				ДопСтруктура = РегистрыСведений._СостоянияОповещенияПользователей.ПолучитьСтруктуруДополнительныхЗначенийСообщения();
				ДопСтруктура.ИмяДокумента				= СсылкаДокумента.МетаДанные().Имя;
				ДопСтруктура.НомерДокумента				= СсылкаДокумента.Номер;
				ДопСтруктура.ДатаДокумента				= СсылкаДокумента.Дата;
		        ДопСтруктура.УникальныйИдентификатор 	= XMLСтрока( СсылкаДокумента.УникальныйИдентификатор() );
				
				НоваяЗапись.ДополнительныеЗначения = ОбщегоНазначения.ЗначениеВСтрокуXML( ДопСтруктура );
			КонецЕсли;	
		КонецЕсли;
		
		НаборЗаписей.Записать(Истина);
	КонецЕсли;
	
КонецПроцедуры	// СоздатьСообщениеПользователю()

Процедура ЗаписатьИзменениеСостоянияНовостиСервер(ИдентификаторНовости, лкПрочтена, лкПометка, лкОповещениеВключено, лкДатаНачалаОповещения = '00010101', лкТекущийПользователь) Экспорт
