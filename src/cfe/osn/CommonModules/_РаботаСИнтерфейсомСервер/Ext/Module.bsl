Функция ДобавитьДнейКДате(ТекДата, КолДней) Экспорт
	
	ОдинДень   = 60 * 60 * 24;
	ДатаНаДень = ТекДата + (ОдинДень * КолДней);
	
	СдвигДаты  = 0;
	Если ДеньНедели(ДатаНаДень) = 6 Тогда
		СдвигДаты  = 2;
	ИначеЕсли ДеньНедели(ДатаНаДень) = 7 Тогда
		СдвигДаты  = 1;
	ИначеЕсли ДеньНедели(ДатаНаДень) = 1 Тогда
		СдвигДаты  = 2;
	КонецЕсли;
	
	Возврат ТекДата + (ОдинДень * (КолДней + СдвигДаты));
	
КонецФункции

Функция СозданаЗадачаИсполнителю(ПараметрыЗадачи)
	
	Запрос = Новый Запрос;
	Запрос.Текст = "ВЫБРАТЬ
	               |	ДанныеБизнесПроцессов.БизнесПроцесс КАК БизнесПроцесс,
	               |	ДанныеБизнесПроцессов.Номер КАК Номер,
	               |	ДанныеБизнесПроцессов.Дата КАК Дата,
	               |	ДанныеБизнесПроцессов.Завершен КАК Завершен,
	               |	ДанныеБизнесПроцессов.Стартован КАК Стартован,
	               |	ДанныеБизнесПроцессов.Автор КАК Автор,
	               |	ДанныеБизнесПроцессов.ДатаЗавершения КАК ДатаЗавершения,
	               |	ДанныеБизнесПроцессов.Наименование КАК Наименование,
	               |	ДанныеБизнесПроцессов.ПометкаУдаления КАК ПометкаУдаления
	               |ИЗ
	               |	РегистрСведений.ДанныеБизнесПроцессов КАК ДанныеБизнесПроцессов
	               |ГДЕ
	               |	ДанныеБизнесПроцессов.Наименование = &Наименование
	               |	И ДанныеБизнесПроцессов.БизнесПроцесс.Исполнитель = &Исполнитель";
	
	Запрос.УстановитьПараметр("Наименование", ПараметрыЗадачи.Наименование);
	Запрос.УстановитьПараметр("Исполнитель",  ПараметрыЗадачи.Исполнитель);
	
	Результат = Запрос.Выполнить().Выгрузить();
	Если Результат.Количество() > 0 Тогда
		Возврат Истина;
	Иначе
		Возврат Ложь;
	КонецЕсли;
	
КонецФункции // ПолучитьЗадачу()

