Функция ПолучитьИнформациюПоРасходномуОрдеру(Распоряжение, Назначение, Номенклатура, Характеристика, ВсеТовары = Ложь, ПоРабСтолу = Ложь) Экспорт
	
	Запрос = Новый Запрос;
	Если ВсеТовары Тогда
		Запрос.Текст ="ВЫБРАТЬ
		              |	РасходныйОрдерНаТоварыТоварыПоРаспоряжениям.Ссылка КАК Ссылка,
		              |	РасходныйОрдерНаТоварыТоварыПоРаспоряжениям.Ссылка._ЗаявкаНаДоставку КАК ЗаявкаНаДоставку,
		              |	РасходныйОрдерНаТоварыТоварыПоРаспоряжениям.Ссылка.Склад КАК Склад,
		              |	РасходныйОрдерНаТоварыТоварыПоРаспоряжениям.Распоряжение КАК Распоряжение,
		              |	РасходныйОрдерНаТоварыТоварыПоРаспоряжениям.Назначение КАК Назначение,
		              |	РасходныйОрдерНаТоварыТоварыПоРаспоряжениям.Номенклатура КАК Номенклатура,
		              |	РасходныйОрдерНаТоварыТоварыПоРаспоряжениям.Характеристика КАК Характеристика,
		              |	РасходныйОрдерНаТоварыТоварыПоРаспоряжениям.Ссылка._СпособДоставки КАК СпособДоставки
		              |ИЗ
		              |	Документ.РасходныйОрдерНаТовары.ТоварыПоРаспоряжениям КАК РасходныйОрдерНаТоварыТоварыПоРаспоряжениям
		              |ГДЕ
		              |	РасходныйОрдерНаТоварыТоварыПоРаспоряжениям.Распоряжение = &Распоряжение
					  |";
	Иначе
		Запрос.Текст ="ВЫБРАТЬ
		              |	РасходныйОрдерНаТоварыТоварыПоРаспоряжениям.Ссылка КАК Ссылка,
		              |	РасходныйОрдерНаТоварыТоварыПоРаспоряжениям.Ссылка._ЗаявкаНаДоставку КАК ЗаявкаНаДоставку,
		              |	РасходныйОрдерНаТоварыТоварыПоРаспоряжениям.Ссылка.Склад КАК Склад,
		              |	РасходныйОрдерНаТоварыТоварыПоРаспоряжениям.Распоряжение КАК Распоряжение,
		              |	РасходныйОрдерНаТоварыТоварыПоРаспоряжениям.Назначение КАК Назначение,
		              |	РасходныйОрдерНаТоварыТоварыПоРаспоряжениям.Номенклатура КАК Номенклатура,
		              |	РасходныйОрдерНаТоварыТоварыПоРаспоряжениям.Характеристика КАК Характеристика,
		              |	РасходныйОрдерНаТоварыТоварыПоРаспоряжениям.Ссылка._СпособДоставки КАК СпособДоставки
		              |ИЗ
		              |	Документ.РасходныйОрдерНаТовары.ТоварыПоРаспоряжениям КАК РасходныйОрдерНаТоварыТоварыПоРаспоряжениям
		              |ГДЕ
		              |	РасходныйОрдерНаТоварыТоварыПоРаспоряжениям.Распоряжение = &Распоряжение
		              |	И РасходныйОрдерНаТоварыТоварыПоРаспоряжениям.Назначение = &Назначение
		              |	И РасходныйОрдерНаТоварыТоварыПоРаспоряжениям.Номенклатура = &Номенклатура
		              |	И РасходныйОрдерНаТоварыТоварыПоРаспоряжениям.Характеристика = &Характеристика";
		
		Запрос.УстановитьПараметр("Назначение",     Назначение);
		Запрос.УстановитьПараметр("Номенклатура",   Номенклатура);
		Запрос.УстановитьПараметр("Характеристика", Характеристика);
	КонецЕсли;
	
	Запрос.УстановитьПараметр("Распоряжение",   Распоряжение);
	
	Результат = Запрос.Выполнить();
	Если  НЕ Результат.Пустой() Тогда
		Если ПоРабСтолу Тогда
			Выборка	  = Результат.Выгрузить()[0];
		Иначе
			Выборка	  = Результат.Выгрузить();
		КонецЕсли;
		
		Возврат Выборка
	Иначе
		Возврат Неопределено;
	КонецЕсли;

КонецФункции // ПолучитьТипТранспортногоСредства()

Функция ЗаполнитьТоварыКДоставке(ТекОбъект) Экспорт
	
	ТоварыКДоставке = Новый ТаблицаЗначений;
	
	НаборЗаписей = РегистрыСведений.ТоварыКДоставке.СоздатьНаборЗаписей();
	НаборЗаписей.Отбор.ЗаданиеНаПеревозку.Установить(ТекОбъект.Ссылка);
	НаборЗаписей.Прочитать();
	ТоварыКДоставке = НаборЗаписей.Выгрузить();
	
	Возврат ТоварыКДоставке;
	
